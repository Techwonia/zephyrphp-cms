{
    "name": "Feedback Survey",
    "slug": "feedback-survey",
    "description": "A customer feedback survey to collect ratings, comments, and satisfaction data.",
    "is_multi_step": false,
    "fields": [
        {
            "slug": "rating",
            "label": "Rating",
            "type": "radio",
            "is_required": true,
            "validation": "required",
            "options": {
                "choices": [
                    {"label": "1 Star", "value": "1"},
                    {"label": "2 Stars", "value": "2"},
                    {"label": "3 Stars", "value": "3"},
                    {"label": "4 Stars", "value": "4"},
                    {"label": "5 Stars", "value": "5"}
                ]
            }
        },
        {
            "slug": "category",
            "label": "Category",
            "type": "select",
            "is_required": true,
            "validation": "required",
            "options": {
                "choices": [
                    {"label": "Product", "value": "product"},
                    {"label": "Service", "value": "service"},
                    {"label": "Support", "value": "support"},
                    {"label": "Website", "value": "website"},
                    {"label": "Other", "value": "other"}
                ]
            }
        },
        {
            "slug": "comments",
            "label": "Comments",
            "type": "textarea",
            "placeholder": "Tell us more about your experience...",
            "is_required": true,
            "validation": "required|min:10|max:5000"
        },
        {
            "slug": "would_recommend",
            "label": "Would you recommend us?",
            "type": "radio",
            "is_required": true,
            "validation": "required",
            "options": {
                "choices": [
                    {"label": "Yes", "value": "yes"},
                    {"label": "No", "value": "no"}
                ]
            }
        },
        {
            "slug": "email",
            "label": "Email for follow-up",
            "type": "email",
            "placeholder": "your@email.com (optional)",
            "is_required": false,
            "validation": "email"
        }
    ],
    "settings": {
        "success_message": "Thank you for your feedback! Your response helps us improve.",
        "submit_button_text": "Submit Feedback",
        "honeypot_enabled": true,
        "email_notify": true
    }
}
