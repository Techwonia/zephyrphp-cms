{
    "name": "Newsletter Signup",
    "slug": "newsletter",
    "description": "A newsletter subscription form to collect email addresses and subscriber preferences.",
    "is_multi_step": false,
    "fields": [
        {
            "slug": "email",
            "label": "Email",
            "type": "email",
            "placeholder": "your@email.com",
            "is_required": true,
            "validation": "required|email"
        },
        {
            "slug": "first_name",
            "label": "First Name",
            "type": "text",
            "placeholder": "Your first name",
            "is_required": false,
            "validation": "max:100"
        },
        {
            "slug": "interests",
            "label": "Interests",
            "type": "checkbox",
            "is_required": false,
            "options": {
                "choices": [
                    {"label": "Technology", "value": "technology"},
                    {"label": "Business", "value": "business"},
                    {"label": "Design", "value": "design"},
                    {"label": "Marketing", "value": "marketing"}
                ]
            }
        }
    ],
    "settings": {
        "success_message": "You have been subscribed! Check your inbox to confirm.",
        "submit_button_text": "Subscribe",
        "honeypot_enabled": true,
        "email_notify": true
    }
}
