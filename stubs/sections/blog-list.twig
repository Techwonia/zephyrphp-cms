<section class="section-blog-list" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container" style="max-width:{{ section.settings.max_width|default(1200) }}px; margin:0 auto; padding:0 24px;">

        {# ── Blocks: Heading / Subheading / CTA above the listing ── #}
        {% for block in section.blocks %}
            {% if block.type == 'heading' %}
                <h2 data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ block.settings.color|default(section.settings.heading_color|default('#303030')) }}; font-size:{{ block.settings.size|default(32) }}px; font-weight:{{ block.settings.weight|default(700) }}; margin:0 0 8px;">
                    {{ block.settings.text }}
                </h2>
            {% elseif block.type == 'subheading' %}
                <p data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ block.settings.color|default(section.settings.text_color|default('#616161')) }}; font-size:{{ block.settings.size|default(16) }}px; max-width:600px; {% if section.settings.text_align|default('center') == 'center' %}margin:0 auto 24px;{% else %}margin:0 0 24px;{% endif %} line-height:1.6;">
                    {{ block.settings.text }}
                </p>
            {% elseif block.type == 'cta_button' %}
                <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="text-align:{{ section.settings.text_align|default('center') }}; margin-bottom:24px;">
                    <a href="{{ block.settings.url|default('#') }}" style="
                        display:inline-block; padding:10px 28px; border-radius:8px; text-decoration:none; font-weight:600; font-size:14px;
                        {% if block.settings.style|default('filled') == 'outline' %}
                            background:transparent; color:{{ block.settings.color|default('#008060') }}; border:2px solid {{ block.settings.color|default('#008060') }};
                        {% else %}
                            background:{{ block.settings.color|default('#008060') }}; color:#fff; border:2px solid {{ block.settings.color|default('#008060') }};
                        {% endif %}
                    ">{{ block.settings.text|default('View All') }}</a>
                </div>
            {% endif %}
        {% endfor %}

        {% if section.blocks|length == 0 and section.settings.heading %}
            <h2 style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.heading_color|default('#303030') }}; font-size:28px; margin:0 0 8px;">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.blocks|length == 0 and section.settings.subheading %}
            <p style="text-align:{{ section.settings.text_align|default('center') }}; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 32px; font-size:16px;">{{ section.settings.subheading }}</p>
        {% endif %}

        {# ── Dynamic Collection Data ── #}
        {% if section.settings.collection %}
            {% set tf = section.settings.title_field|default('title') %}
            {% set ef = section.settings.excerpt_field|default('') %}
            {% set imgf = section.settings.image_field|default('') %}
            {% set df = section.settings.date_field|default('') %}
            {% set cf = section.settings.category_field|default('') %}
            {% set lf = section.settings.link_field|default('slug') %}
            {% set lp = section.settings.link_prefix|default('') %}
            {% set items = collection(section.settings.collection, {per_page: section.settings.items_count|default(6), sort_dir: section.settings.sort_dir|default('DESC')}) %}

            {% if items.data|length > 0 %}

                {% if section.settings.layout == 'featured' %}
                {# ── FEATURED LAYOUT: First item large, rest in grid ── #}
                {% set first = items.data|first %}
                <div style="margin-bottom:{{ section.settings.gap|default(24) }}px;">
                    <div style="display:flex; flex-wrap:wrap; gap:24px; background:{{ section.settings.card_bg|default('#fafafa') }}; border-radius:{{ section.settings.card_radius|default(8) }}px; overflow:hidden; border:1px solid {{ section.settings.card_border|default('#eeeeee') }};">
                        {% if section.settings.show_image and imgf and attribute(first, imgf) is defined and attribute(first, imgf) %}
                            <div style="flex:1; min-width:300px; height:360px; overflow:hidden;">
                                <img src="/{{ attribute(first, imgf) }}" alt="" style="width:100%; height:100%; object-fit:cover;">
                            </div>
                        {% endif %}
                        <div style="flex:1; min-width:300px; padding:{{ section.settings.card_padding|default(32) }}px; display:flex; flex-direction:column; justify-content:center;">
                            {% if section.settings.show_category and cf and attribute(first, cf) is defined and attribute(first, cf) %}
                                <span style="display:inline-block; width:fit-content; padding:3px 10px; border-radius:4px; font-size:11px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; background:{{ section.settings.category_bg|default('#e8f5e9') }}; color:{{ section.settings.category_color|default('#2e7d32') }}; margin-bottom:12px;">{{ attribute(first, cf) }}</span>
                            {% endif %}
                            {% if section.settings.show_date and df and attribute(first, df) is defined and attribute(first, df) %}
                                <time style="font-size:12px; color:{{ section.settings.date_color|default('#999999') }}; margin-bottom:8px;">{{ attribute(first, df) }}</time>
                            {% endif %}
                            {% if tf and attribute(first, tf) is defined %}
                                <h3 style="margin:0 0 12px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:{{ (section.settings.title_size|default(18) + 6) }}px; line-height:1.3;">{{ attribute(first, tf) }}</h3>
                            {% endif %}
                            {% if section.settings.show_excerpt and ef and attribute(first, ef) is defined and attribute(first, ef) %}
                                <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:{{ section.settings.excerpt_size|default(14) }}px; line-height:1.6; margin:0 0 16px;">{{ attribute(first, ef)|striptags|slice(0, section.settings.excerpt_length|default(200)) }}{% if attribute(first, ef)|length > section.settings.excerpt_length|default(200) %}...{% endif %}</p>
                            {% endif %}
                            {% if section.settings.show_link and lf and attribute(first, lf) is defined %}
                                <a href="{% if lp %}{{ lp }}/{{ attribute(first, lf) }}{% else %}{{ attribute(first, lf) }}{% endif %}" style="color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:600; font-size:{{ section.settings.link_size|default(14) }}px;">{{ section.settings.link_text|default('Read More') }} &rarr;</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
                {% if items.data|length > 1 %}
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax({{ section.settings.card_min_width|default(280) }}px, 1fr)); gap:{{ section.settings.gap|default(24) }}px;">
                    {% for item in items.data|slice(1) %}
                        {% include "_blog_card" ignore missing %}
                    {% endfor %}
                </div>
                {% endif %}

                {% elseif section.settings.layout == 'list' %}
                {# ── LIST LAYOUT ── #}
                <div style="display:flex; flex-direction:column; gap:{{ section.settings.gap|default(0) }}px;">
                    {% for item in items.data %}
                        <div style="display:flex; gap:20px; align-items:center; padding:{{ section.settings.card_padding|default(16) }}px;{% if section.settings.card_radius > 0 %} border-radius:{{ section.settings.card_radius }}px; border:1px solid {{ section.settings.card_border|default('#eeeeee') }}; margin-bottom:{{ section.settings.gap|default(8) }}px;{% else %} border-bottom:1px solid {{ section.settings.card_border|default('#eeeeee') }};{% endif %}{% if section.settings.card_bg and section.settings.card_bg != '#ffffff' %} background:{{ section.settings.card_bg }};{% endif %}">
                            {% if section.settings.show_image and imgf and attribute(item, imgf) is defined and attribute(item, imgf) %}
                                <img src="/{{ attribute(item, imgf) }}" alt="" style="width:{{ section.settings.image_height|default(120) }}px; height:{{ section.settings.image_height|default(120) }}px; object-fit:cover; border-radius:{{ section.settings.card_radius|default(6) }}px; flex-shrink:0;">
                            {% endif %}
                            <div style="flex:1; min-width:0;">
                                {% if section.settings.show_category and cf and attribute(item, cf) is defined and attribute(item, cf) %}
                                    <span style="display:inline-block; padding:2px 8px; border-radius:4px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; background:{{ section.settings.category_bg|default('#e8f5e9') }}; color:{{ section.settings.category_color|default('#2e7d32') }}; margin-bottom:6px;">{{ attribute(item, cf) }}</span>
                                {% endif %}
                                {% if tf and attribute(item, tf) is defined and attribute(item, tf) %}
                                    <h3 style="margin:0 0 4px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:{{ section.settings.title_size|default(18) }}px;">{{ attribute(item, tf) }}</h3>
                                {% endif %}
                                <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
                                    {% if section.settings.show_date and df and attribute(item, df) is defined and attribute(item, df) %}
                                        <time style="font-size:12px; color:{{ section.settings.date_color|default('#999999') }};">{{ attribute(item, df) }}</time>
                                    {% endif %}
                                </div>
                                {% if section.settings.show_excerpt and ef and attribute(item, ef) is defined and attribute(item, ef) %}
                                    <p style="margin:0; color:{{ section.settings.text_color|default('#616161') }}; font-size:{{ section.settings.excerpt_size|default(14) }}px; line-height:1.5;">{{ attribute(item, ef)|striptags|slice(0, section.settings.excerpt_length|default(120)) }}{% if attribute(item, ef)|length > section.settings.excerpt_length|default(120) %}...{% endif %}</p>
                                {% endif %}
                            </div>
                            {% if section.settings.show_link and lf and attribute(item, lf) is defined %}
                                <a href="{% if lp %}{{ lp }}/{{ attribute(item, lf) }}{% else %}{{ attribute(item, lf) }}{% endif %}" style="color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:500; white-space:nowrap; font-size:{{ section.settings.link_size|default(14) }}px;">{{ section.settings.link_text|default('Read More') }} &rarr;</a>
                            {% endif %}
                        </div>
                    {% endfor %}
                </div>

                {% else %}
                {# ── GRID LAYOUT (default) ── #}
                <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax({{ section.settings.card_min_width|default(280) }}px, 1fr)); gap:{{ section.settings.gap|default(24) }}px;">
                    {% for item in items.data %}
                        <div style="background:{{ section.settings.card_bg|default('#fafafa') }}; border-radius:{{ section.settings.card_radius|default(8) }}px; overflow:hidden; border:1px solid {{ section.settings.card_border|default('#eeeeee') }}; transition:box-shadow 0.2s;">
                            {% if section.settings.show_image and imgf and attribute(item, imgf) is defined and attribute(item, imgf) %}
                                <div style="height:{{ section.settings.image_height|default(200) }}px; overflow:hidden;">
                                    <img src="/{{ attribute(item, imgf) }}" alt="" style="width:100%; height:100%; object-fit:cover;">
                                </div>
                            {% endif %}
                            <div style="padding:{{ section.settings.card_padding|default(20) }}px;">
                                {% if section.settings.show_category and cf and attribute(item, cf) is defined and attribute(item, cf) %}
                                    <span style="display:inline-block; padding:2px 8px; border-radius:4px; font-size:10px; font-weight:600; text-transform:uppercase; letter-spacing:0.5px; background:{{ section.settings.category_bg|default('#e8f5e9') }}; color:{{ section.settings.category_color|default('#2e7d32') }}; margin-bottom:8px;">{{ attribute(item, cf) }}</span>
                                {% endif %}
                                {% if section.settings.show_date and df and attribute(item, df) is defined and attribute(item, df) %}
                                    <time style="display:block; font-size:12px; color:{{ section.settings.date_color|default('#999999') }}; margin-bottom:6px;">{{ attribute(item, df) }}</time>
                                {% endif %}
                                {% if tf and attribute(item, tf) is defined and attribute(item, tf) %}
                                    <h3 style="margin:0 0 8px; color:{{ section.settings.heading_color|default('#303030') }}; font-size:{{ section.settings.title_size|default(18) }}px; line-height:1.3;">{{ attribute(item, tf) }}</h3>
                                {% endif %}
                                {% if section.settings.show_excerpt and ef and attribute(item, ef) is defined and attribute(item, ef) %}
                                    <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:{{ section.settings.excerpt_size|default(14) }}px; margin:0 0 12px; line-height:1.5;">{{ attribute(item, ef)|striptags|slice(0, section.settings.excerpt_length|default(120)) }}{% if attribute(item, ef)|length > section.settings.excerpt_length|default(120) %}...{% endif %}</p>
                                {% endif %}
                                {% if section.settings.show_link and lf and attribute(item, lf) is defined %}
                                    <a href="{% if lp %}{{ lp }}/{{ attribute(item, lf) }}{% else %}{{ attribute(item, lf) }}{% endif %}" style="display:inline-block; color:{{ section.settings.link_color|default('#008060') }}; text-decoration:none; font-weight:500; font-size:{{ section.settings.link_size|default(14) }}px;">{{ section.settings.link_text|default('Read More') }} &rarr;</a>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
                {% endif %}

            {% else %}
                <p style="text-align:center; color:#999; padding:40px 0;">{{ section.settings.empty_message|default('No posts found.') }}</p>
            {% endif %}
        {% else %}
            <p style="text-align:center; color:#999; padding:40px 0;">Select a collection to display.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Blog List",
    "description": "Display blog posts from a collection with grid, list, or featured layout",
    "icon": "blog",
    "settings": [
        {"type": "collection", "id": "collection", "label": "Collection", "group": "Data Source"},
        {"type": "range", "id": "items_count", "label": "Posts to Show", "min": 1, "max": 24, "step": 1, "default": 6, "group": "Data Source"},
        {"type": "select", "id": "sort_dir", "label": "Sort Order", "default": "DESC", "group": "Data Source",
         "options": [{"value": "DESC", "label": "Newest First"}, {"value": "ASC", "label": "Oldest First"}]},
        {"type": "text", "id": "link_prefix", "label": "Link Prefix", "default": "", "group": "Data Source",
         "info": "URL prefix for links, e.g. /blog. Leave empty to use the field value directly."},

        {"type": "field_select", "id": "title_field", "label": "Title Field", "collection_setting": "collection", "default": "title", "group": "Field Mapping"},
        {"type": "field_select", "id": "excerpt_field", "label": "Excerpt / Description", "collection_setting": "collection", "default": "", "group": "Field Mapping"},
        {"type": "field_select", "id": "image_field", "label": "Image Field", "collection_setting": "collection", "default": "", "group": "Field Mapping"},
        {"type": "field_select", "id": "date_field", "label": "Date Field", "collection_setting": "collection", "default": "", "group": "Field Mapping"},
        {"type": "field_select", "id": "category_field", "label": "Category Field", "collection_setting": "collection", "default": "", "group": "Field Mapping"},
        {"type": "field_select", "id": "link_field", "label": "Link / Slug Field", "collection_setting": "collection", "default": "slug", "group": "Field Mapping"},

        {"type": "layout_select", "id": "layout", "label": "Layout", "default": "grid", "group": "Layout",
         "options": [{"value": "grid", "label": "Grid"}, {"value": "list", "label": "List"}, {"value": "featured", "label": "Featured"}]},
        {"type": "range", "id": "card_min_width", "label": "Card Min Width (px)", "min": 200, "max": 400, "step": 10, "default": 280, "group": "Layout"},
        {"type": "range", "id": "max_width", "label": "Max Width (px)", "min": 600, "max": 1400, "step": 50, "default": 1200, "group": "Layout"},
        {"type": "select", "id": "text_align", "label": "Header Alignment", "default": "center", "group": "Layout",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}]},

        {"type": "checkbox", "id": "show_image", "label": "Show Image", "default": true, "group": "Content"},
        {"type": "checkbox", "id": "show_excerpt", "label": "Show Excerpt", "default": true, "group": "Content"},
        {"type": "checkbox", "id": "show_date", "label": "Show Date", "default": true, "group": "Content"},
        {"type": "checkbox", "id": "show_category", "label": "Show Category", "default": true, "group": "Content"},
        {"type": "checkbox", "id": "show_link", "label": "Show Link", "default": true, "group": "Content"},
        {"type": "text", "id": "link_text", "label": "Link Text", "default": "Read More", "group": "Content"},
        {"type": "text", "id": "empty_message", "label": "Empty Message", "default": "No posts found.", "group": "Content"},
        {"type": "text", "id": "heading", "label": "Fallback Heading", "default": "", "group": "Content"},
        {"type": "text", "id": "subheading", "label": "Fallback Subheading", "default": "", "group": "Content"},

        {"type": "range", "id": "title_size", "label": "Title Size (px)", "min": 14, "max": 32, "step": 1, "default": 18, "group": "Typography"},
        {"type": "range", "id": "excerpt_size", "label": "Excerpt Size (px)", "min": 12, "max": 18, "step": 1, "default": 14, "group": "Typography"},
        {"type": "range", "id": "excerpt_length", "label": "Excerpt Length (chars)", "min": 50, "max": 300, "step": 10, "default": 120, "group": "Typography"},
        {"type": "range", "id": "link_size", "label": "Link Size (px)", "min": 12, "max": 18, "step": 1, "default": 14, "group": "Typography"},

        {"type": "range", "id": "image_height", "label": "Image Height (px)", "min": 60, "max": 400, "step": 10, "default": 200, "group": "Card Style"},
        {"type": "range", "id": "card_padding", "label": "Card Padding (px)", "min": 8, "max": 40, "step": 4, "default": 20, "group": "Card Style"},
        {"type": "range", "id": "card_radius", "label": "Card Radius (px)", "min": 0, "max": 24, "step": 2, "default": 8, "group": "Card Style"},
        {"type": "range", "id": "gap", "label": "Spacing (px)", "min": 0, "max": 48, "step": 4, "default": 24, "group": "Card Style"},

        {"type": "color", "id": "bg_color", "label": "Background", "default": "#ffffff", "group": "Colors"},
        {"type": "color", "id": "card_bg", "label": "Card Background", "default": "#fafafa", "group": "Colors"},
        {"type": "color", "id": "card_border", "label": "Card Border", "default": "#eeeeee", "group": "Colors"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030", "group": "Colors"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161", "group": "Colors"},
        {"type": "color", "id": "link_color", "label": "Link Color", "default": "#008060", "group": "Colors"},
        {"type": "color", "id": "date_color", "label": "Date Color", "default": "#999999", "group": "Colors"},
        {"type": "color", "id": "category_color", "label": "Category Text", "default": "#2e7d32", "group": "Colors"},
        {"type": "color", "id": "category_bg", "label": "Category Background", "default": "#e8f5e9", "group": "Colors"},

        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60, "group": "Spacing"}
    ],
    "blocks": [
        {
            "type": "heading",
            "name": "Heading",
            "settings": [
                {"type": "text", "id": "text", "label": "Text", "default": "Latest Posts"},
                {"type": "range", "id": "size", "label": "Font Size (px)", "min": 18, "max": 48, "step": 1, "default": 32},
                {"type": "select", "id": "weight", "label": "Font Weight", "default": "700",
                 "options": [{"value": "400", "label": "Normal"}, {"value": "600", "label": "Semi-bold"}, {"value": "700", "label": "Bold"}]},
                {"type": "color", "id": "color", "label": "Color", "default": "#303030"}
            ]
        },
        {
            "type": "subheading",
            "name": "Subheading",
            "settings": [
                {"type": "textarea", "id": "text", "label": "Text", "default": "Stay up to date with our latest articles and news."},
                {"type": "range", "id": "size", "label": "Font Size (px)", "min": 12, "max": 24, "step": 1, "default": 16},
                {"type": "color", "id": "color", "label": "Color", "default": "#616161"}
            ]
        },
        {
            "type": "cta_button",
            "name": "CTA Button",
            "settings": [
                {"type": "text", "id": "text", "label": "Label", "default": "View All Posts"},
                {"type": "url", "id": "url", "label": "URL", "default": "#"},
                {"type": "color", "id": "color", "label": "Color", "default": "#008060"},
                {"type": "select", "id": "style", "label": "Style", "default": "filled",
                 "options": [{"value": "filled", "label": "Filled"}, {"value": "outline", "label": "Outline"}]}
            ]
        }
    ],
    "presets": [
        {
            "name": "Blog List",
            "settings": {"heading": "", "layout": "grid", "items_count": 6, "show_image": true, "show_excerpt": true, "show_date": true, "show_category": true},
            "blocks": [
                {"type": "heading", "settings": {"text": "Latest Posts", "size": 32}},
                {"type": "subheading", "settings": {"text": "Stay up to date with our latest articles and news."}}
            ]
        }
    ]
}
{% endschema %}
