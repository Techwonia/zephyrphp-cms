<section class="section-stats" style="background:{{ section.settings.bg_color|default('#1e293b') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:center; color:{{ section.settings.heading_color|default('#ffffff') }}; margin-bottom:40px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(4) }}, 1fr); gap:32px; text-align:center;">
                {% for block in section.blocks %}
                    {% if block.type == 'stat' %}
                        <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="padding:16px;">
                            <div style="font-size:42px; font-weight:700; color:{{ section.settings.heading_color|default('#ffffff') }}; margin-bottom:8px; line-height:1.2;">
                                {{ block.settings.prefix }}{{ block.settings.value|default('0') }}{{ block.settings.suffix }}
                            </div>
                            {% if block.settings.label %}
                                <div style="font-size:15px; color:{{ section.settings.text_color|default('#94a3b8') }}; font-weight:500; text-transform:uppercase; letter-spacing:1px;">
                                    {{ block.settings.label }}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add stat blocks to populate this section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Stats",
    "description": "Display key statistics and numbers",
    "icon": "stats",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "4",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#1e293b"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#94a3b8"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#ffffff"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "stat",
            "name": "Stat",
            "settings": [
                {"type": "text", "id": "value", "label": "Value", "default": "99%"},
                {"type": "text", "id": "label", "label": "Label", "default": "Uptime"},
                {"type": "text", "id": "prefix", "label": "Prefix (e.g. $)"},
                {"type": "text", "id": "suffix", "label": "Suffix (e.g. +)"}
            ]
        }
    ],
    "presets": [
        {
            "name": "Stats",
            "settings": {"columns": "4"},
            "blocks": [
                {"type": "stat", "settings": {"value": "10K", "label": "Users", "suffix": "+"}},
                {"type": "stat", "settings": {"value": "99.9", "label": "Uptime", "suffix": "%"}},
                {"type": "stat", "settings": {"value": "24/7", "label": "Support"}},
                {"type": "stat", "settings": {"value": "50", "label": "Integrations", "suffix": "+"}}
            ]
        }
    ]
}
{% endschema %}
