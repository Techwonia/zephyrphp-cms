{% set scheme = section.settings.color_scheme|default('custom') %}
{% if scheme == 'light' %}
    {% set _bg = '#ffffff' %}
    {% set _text = theme_settings.text_color|default('#1a1a1a') %}
    {% set _heading = theme_settings.text_color|default('#1a1a1a') %}
{% elseif scheme == 'dark' %}
    {% set _bg = '#1a1a1a' %}
    {% set _text = '#e0e0e0' %}
    {% set _heading = '#ffffff' %}
{% elseif scheme == 'brand' %}
    {% set _bg = theme_settings.primary_color|default('#005bd3') %}
    {% set _text = '#ffffff' %}
    {% set _heading = '#ffffff' %}
{% else %}
    {% set _bg = section.settings.bg_color|default('#0a0e27') %}
    {% set _text = '#8892b0' %}
    {% set _heading = '#ffffff' %}
{% endif %}
<section class="section-hero" style="background:{{ _bg }}; padding:{{ section.settings.padding|default(80) }}px 0; text-align:{{ section.settings.text_align|default('center') }};">
    <div class="container" style="max-width:{{ section.settings.max_width|default(800) }}px; margin:0 auto;">
        {% for block in section.blocks %}
            {% if block.type == 'heading' %}
                <h1 data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="font-size:{{ block.settings.size|default(48) }}px; color:{{ block.settings.color|default('#ffffff') }}; margin-bottom:16px; font-weight:{{ block.settings.weight|default(700) }}; line-height:1.15;">
                    {{ block.settings.text }}
                </h1>
            {% elseif block.type == 'subheading' %}
                <p data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="font-size:{{ block.settings.size|default(18) }}px; color:{{ block.settings.color|default('#8892b0') }}; max-width:640px; {% if section.settings.text_align == 'center' %}margin:0 auto 24px;{% else %}margin:0 0 24px;{% endif %} line-height:1.6;">
                    {{ block.settings.text }}
                </p>
            {% elseif block.type == 'button' %}
                <a data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" href="{{ block.settings.url|default('#') }}" style="
                    padding:{{ block.settings.padding_y|default(12) }}px {{ block.settings.padding_x|default(32) }}px;
                    font-size:{{ block.settings.font_size|default(16) }}px;
                    border-radius:{{ block.settings.border_radius|default(8) }}px;
                    text-decoration:none;
                    display:inline-block;
                    font-weight:500;
                    margin:4px;
                    {% if block.settings.style == 'outline' %}
                        background:transparent;
                        color:{{ block.settings.color|default('#ffffff') }};
                        border:1px solid {{ block.settings.color|default('#ffffff') }};
                    {% else %}
                        background:{{ block.settings.color|default('#008060') }};
                        color:#fff;
                        border:1px solid {{ block.settings.color|default('#008060') }};
                    {% endif %}
                ">
                    {{ block.settings.text }}
                </a>
            {% elseif block.type == 'image' %}
                <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="margin:24px {% if section.settings.text_align == 'center' %}auto{% else %}0{% endif %}; max-width:{{ block.settings.max_width|default(600) }}px;">
                    {% if block.settings.image %}
                        <img src="/{{ block.settings.image }}" alt="{{ block.settings.alt|default('') }}" style="width:100%; height:auto; border-radius:{{ block.settings.border_radius|default(8) }}px;">
                    {% else %}
                        <div style="width:100%; height:200px; background:rgba(255,255,255,0.1); border-radius:{{ block.settings.border_radius|default(8) }}px; display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,0.4);">No Image</div>
                    {% endif %}
                </div>
            {% elseif block.type == 'spacer' %}
                <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="height:{{ block.settings.height|default(24) }}px;"></div>
            {% endif %}
        {% endfor %}

        {% if section.blocks|length == 0 %}
            <p style="color:rgba(255,255,255,0.4);">Add blocks to build your hero section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Hero Banner",
    "description": "A full-width hero section built from blocks — heading, text, buttons, images",
    "icon": "hero",
    "settings": [
        {"type": "select", "id": "color_scheme", "label": "Color Scheme", "default": "custom",
         "options": [
            {"value": "light", "label": "Light"},
            {"value": "dark", "label": "Dark"},
            {"value": "brand", "label": "Brand"},
            {"value": "custom", "label": "Custom"}
         ]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#0a0e27"},
        {"type": "select", "id": "text_align", "label": "Text Alignment", "default": "center",
         "options": [{"value": "left", "label": "Left"}, {"value": "center", "label": "Center"}, {"value": "right", "label": "Right"}]},
        {"type": "range", "id": "max_width", "label": "Content Max Width (px)", "min": 600, "max": 1200, "step": 50, "default": 800},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 20, "max": 200, "step": 4, "default": 80}
    ],
    "blocks": [
        {
            "type": "heading",
            "name": "Heading",
            "settings": [
                {"type": "text", "id": "text", "label": "Text", "default": "Welcome to Our Site"},
                {"type": "range", "id": "size", "label": "Font Size (px)", "min": 24, "max": 72, "step": 2, "default": 48},
                {"type": "select", "id": "weight", "label": "Font Weight", "default": "700",
                 "options": [{"value": "400", "label": "Normal"}, {"value": "600", "label": "Semi-bold"}, {"value": "700", "label": "Bold"}, {"value": "800", "label": "Extra Bold"}]},
                {"type": "color", "id": "color", "label": "Color", "default": "#ffffff"}
            ]
        },
        {
            "type": "subheading",
            "name": "Text",
            "settings": [
                {"type": "textarea", "id": "text", "label": "Text", "default": "Build something amazing with our platform."},
                {"type": "range", "id": "size", "label": "Font Size (px)", "min": 14, "max": 24, "step": 1, "default": 18},
                {"type": "color", "id": "color", "label": "Color", "default": "#8892b0"}
            ]
        },
        {
            "type": "button",
            "name": "Button",
            "settings": [
                {"type": "text", "id": "text", "label": "Label", "default": "Get Started"},
                {"type": "url", "id": "url", "label": "URL", "default": "#"},
                {"type": "color", "id": "color", "label": "Color", "default": "#008060"},
                {"type": "select", "id": "style", "label": "Style", "default": "filled",
                 "options": [{"value": "filled", "label": "Filled"}, {"value": "outline", "label": "Outline"}]},
                {"type": "range", "id": "font_size", "label": "Font Size (px)", "min": 12, "max": 20, "step": 1, "default": 16},
                {"type": "range", "id": "padding_y", "label": "Vertical Padding (px)", "min": 6, "max": 20, "step": 2, "default": 12},
                {"type": "range", "id": "padding_x", "label": "Horizontal Padding (px)", "min": 16, "max": 48, "step": 4, "default": 32},
                {"type": "range", "id": "border_radius", "label": "Border Radius (px)", "min": 0, "max": 24, "step": 2, "default": 8}
            ]
        },
        {
            "type": "image",
            "name": "Image",
            "settings": [
                {"type": "image", "id": "image", "label": "Image"},
                {"type": "text", "id": "alt", "label": "Alt Text"},
                {"type": "range", "id": "max_width", "label": "Max Width (px)", "min": 200, "max": 1000, "step": 50, "default": 600},
                {"type": "range", "id": "border_radius", "label": "Border Radius (px)", "min": 0, "max": 24, "step": 2, "default": 8}
            ]
        },
        {
            "type": "spacer",
            "name": "Spacer",
            "settings": [
                {"type": "range", "id": "height", "label": "Height (px)", "min": 4, "max": 80, "step": 4, "default": 24}
            ]
        }
    ],
    "presets": [
        {
            "name": "Hero Banner",
            "settings": {"bg_color": "#0a0e27", "text_align": "center", "padding": 80},
            "blocks": [
                {"type": "heading", "settings": {"text": "Welcome to Our Site", "size": 48, "color": "#ffffff"}},
                {"type": "subheading", "settings": {"text": "Build something amazing with our platform.", "size": 18, "color": "#8892b0"}},
                {"type": "button", "settings": {"text": "Get Started", "url": "#", "color": "#008060", "style": "filled"}},
                {"type": "button", "settings": {"text": "Learn More", "url": "#", "color": "#ffffff", "style": "outline"}}
            ]
        }
    ]
}
{% endschema %}
