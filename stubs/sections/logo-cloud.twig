<section class="section-logos" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:center; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:32px; font-size:18px; font-weight:600; text-transform:uppercase; letter-spacing:1px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(5) }}, 1fr); gap:{{ section.settings.gap|default(32) }}px; align-items:center; justify-items:center;">
                {% for block in section.blocks %}
                    {% if block.type == 'logo' %}
                        <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="display:flex; align-items:center; justify-content:center;">
                            {% if block.settings.image %}
                                {% if block.settings.url %}
                                    <a href="{{ block.settings.url }}" target="_blank" rel="noopener noreferrer" style="display:inline-block;">
                                {% endif %}
                                <img src="{{ block.settings.image }}" alt="{{ block.settings.alt|default('Logo') }}" style="max-width:100%; max-height:60px; object-fit:contain;{{ section.settings.grayscale ? ' filter:grayscale(100%); opacity:0.6; transition:filter 0.3s, opacity 0.3s;' : '' }}">
                                {% if block.settings.url %}
                                    </a>
                                {% endif %}
                            {% else %}
                                <div style="width:120px; height:48px; background:#f3f4f6; border-radius:8px; display:flex; align-items:center; justify-content:center; color:#9ca3af; font-size:12px;{{ section.settings.grayscale ? ' filter:grayscale(100%); opacity:0.6;' : '' }}">
                                    Logo
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add logo blocks to populate this section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Logo Cloud",
    "description": "Display a grid of partner or client logos",
    "icon": "logos",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Trusted by"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "5",
         "options": [{"value": "4", "label": "4 Columns"}, {"value": "5", "label": "5 Columns"}, {"value": "6", "label": "6 Columns"}]},
        {"type": "range", "id": "gap", "label": "Gap (px)", "min": 8, "max": 64, "step": 4, "default": 32},
        {"type": "checkbox", "id": "grayscale", "label": "Grayscale Filter", "default": false},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "logo",
            "name": "Logo",
            "settings": [
                {"type": "image", "id": "image", "label": "Logo Image"},
                {"type": "text", "id": "alt", "label": "Alt Text"},
                {"type": "url", "id": "url", "label": "Link URL"}
            ]
        }
    ],
    "presets": [
        {
            "name": "Logo Cloud",
            "settings": {"heading": "Trusted by", "columns": "5"},
            "blocks": [
                {"type": "logo", "settings": {"alt": "Partner 1"}},
                {"type": "logo", "settings": {"alt": "Partner 2"}},
                {"type": "logo", "settings": {"alt": "Partner 3"}},
                {"type": "logo", "settings": {"alt": "Partner 4"}},
                {"type": "logo", "settings": {"alt": "Partner 5"}}
            ]
        }
    ]
}
{% endschema %}
