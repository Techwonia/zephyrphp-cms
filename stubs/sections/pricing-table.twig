<section class="section-pricing" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:center; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:12px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="text-align:center; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 40px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(3) }}, 1fr); gap:32px; align-items:start;">
                {% for block in section.blocks %}
                    {% if block.type == 'plan' %}
                        <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="background:#fff; border-radius:12px; padding:32px 24px; text-align:center; border:2px solid {{ block.settings.is_featured ? '#3b82f6' : '#e5e7eb' }}; position:relative; box-shadow:{{ block.settings.is_featured ? '0 4px 24px rgba(59,130,246,0.15)' : '0 1px 4px rgba(0,0,0,0.06)' }};">
                            {% if block.settings.is_featured %}
                                <div style="position:absolute; top:-14px; left:50%; transform:translateX(-50%); background:#3b82f6; color:#fff; font-size:12px; font-weight:600; padding:4px 16px; border-radius:20px; text-transform:uppercase; letter-spacing:0.5px;">
                                    Popular
                                </div>
                            {% endif %}
                            {% if block.settings.name %}
                                <h3 style="color:{{ section.settings.heading_color|default('#303030') }}; margin:0 0 8px; font-size:20px; font-weight:600;">
                                    {{ block.settings.name }}
                                </h3>
                            {% endif %}
                            <div style="margin-bottom:16px;">
                                <span style="font-size:42px; font-weight:700; color:{{ section.settings.heading_color|default('#303030') }};">{{ block.settings.price|default('$0') }}</span>
                                {% if block.settings.period %}
                                    <span style="font-size:16px; color:{{ section.settings.text_color|default('#616161') }};">{{ block.settings.period }}</span>
                                {% endif %}
                            </div>
                            {% if block.settings.description %}
                                <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:14px; line-height:1.5; margin-bottom:20px;">
                                    {{ block.settings.description }}
                                </p>
                            {% endif %}
                            {% if block.settings.features %}
                                <ul style="list-style:none; padding:0; margin:0 0 24px; text-align:left;">
                                    {% for feature in block.settings.features|split("\n") %}
                                        {% if feature|trim %}
                                            <li style="padding:8px 0; border-bottom:1px solid #f3f4f6; color:{{ section.settings.text_color|default('#616161') }}; font-size:14px;">
                                                &#10003; {{ feature|trim }}
                                            </li>
                                        {% endif %}
                                    {% endfor %}
                                </ul>
                            {% endif %}
                            {% if block.settings.button_text %}
                                <a href="{{ block.settings.button_url|default('#') }}" style="display:inline-block; padding:12px 28px; background:{{ block.settings.is_featured ? '#3b82f6' : '#303030' }}; color:#fff; text-decoration:none; border-radius:8px; font-weight:600; font-size:15px;">
                                    {{ block.settings.button_text }}
                                </a>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add plan blocks to populate this section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Pricing Table",
    "description": "Display pricing plans in a comparison grid",
    "icon": "pricing",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Pricing Plans"},
        {"type": "text", "id": "subheading", "label": "Subheading", "default": "Choose the plan that fits your needs"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "3",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "plan",
            "name": "Plan",
            "settings": [
                {"type": "text", "id": "name", "label": "Plan Name", "default": "Basic"},
                {"type": "text", "id": "price", "label": "Price", "default": "$9"},
                {"type": "text", "id": "period", "label": "Period", "default": "/month"},
                {"type": "textarea", "id": "description", "label": "Description"},
                {"type": "text", "id": "button_text", "label": "Button Text", "default": "Get Started"},
                {"type": "url", "id": "button_url", "label": "Button URL", "default": "#"},
                {"type": "checkbox", "id": "is_featured", "label": "Featured (highlighted)", "default": false},
                {"type": "textarea", "id": "features", "label": "Features (one per line)"}
            ]
        }
    ],
    "presets": [
        {
            "name": "Pricing Table",
            "settings": {"heading": "Pricing Plans", "subheading": "Choose the plan that fits your needs", "columns": "3"},
            "blocks": [
                {"type": "plan", "settings": {"name": "Basic", "price": "$9", "period": "/month", "description": "Perfect for getting started", "button_text": "Get Started", "button_url": "#", "is_featured": false, "features": "5 Projects\n1 GB Storage\nEmail Support"}},
                {"type": "plan", "settings": {"name": "Pro", "price": "$29", "period": "/month", "description": "Best for growing teams", "button_text": "Get Started", "button_url": "#", "is_featured": true, "features": "Unlimited Projects\n50 GB Storage\nPriority Support\nAdvanced Analytics"}},
                {"type": "plan", "settings": {"name": "Enterprise", "price": "$99", "period": "/month", "description": "For large organizations", "button_text": "Contact Sales", "button_url": "#", "is_featured": false, "features": "Unlimited Everything\n500 GB Storage\n24/7 Phone Support\nCustom Integrations\nDedicated Manager"}}
            ]
        }
    ]
}
{% endschema %}
