<section class="section-team" style="background:{{ section.settings.bg_color|default('#ffffff') }}; padding:{{ section.settings.padding|default(60) }}px 0;">
    <div class="container">
        {% if section.settings.heading %}
            <h2 style="text-align:center; color:{{ section.settings.heading_color|default('#303030') }}; margin-bottom:12px;">
                {{ section.settings.heading }}
            </h2>
        {% endif %}
        {% if section.settings.subheading %}
            <p style="text-align:center; color:{{ section.settings.text_color|default('#616161') }}; max-width:600px; margin:0 auto 40px;">
                {{ section.settings.subheading }}
            </p>
        {% endif %}

        {% if section.blocks|length > 0 %}
            <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns|default(3) }}, 1fr); gap:32px;">
                {% for block in section.blocks %}
                    {% if block.type == 'member' %}
                        <div data-block-id="{{ block.id }}" data-block-type="{{ block.type }}" style="background:{{ section.settings.card_bg|default('#f9fafb') }}; border-radius:12px; padding:32px 24px; text-align:center;">
                            {% if block.settings.image %}
                                <img src="{{ block.settings.image }}" alt="{{ block.settings.name|default('Team member') }}" style="width:96px; height:96px; border-radius:50%; object-fit:cover; margin-bottom:16px;">
                            {% else %}
                                <div style="width:96px; height:96px; border-radius:50%; background:#e5e7eb; margin:0 auto 16px; display:flex; align-items:center; justify-content:center; color:#9ca3af; font-size:32px;">
                                    &#128100;
                                </div>
                            {% endif %}
                            {% if block.settings.name %}
                                <h3 style="color:{{ section.settings.heading_color|default('#303030') }}; margin:0 0 4px; font-size:18px; font-weight:600;">
                                    {{ block.settings.name }}
                                </h3>
                            {% endif %}
                            {% if block.settings.role %}
                                <p style="color:#3b82f6; font-size:14px; font-weight:500; margin:0 0 12px;">
                                    {{ block.settings.role }}
                                </p>
                            {% endif %}
                            {% if block.settings.bio %}
                                <p style="color:{{ section.settings.text_color|default('#616161') }}; font-size:14px; line-height:1.6; margin:0 0 16px;">
                                    {{ block.settings.bio }}
                                </p>
                            {% endif %}
                            {% if block.settings.linkedin or block.settings.twitter %}
                                <div style="display:flex; gap:12px; justify-content:center;">
                                    {% if block.settings.linkedin %}
                                        <a href="{{ block.settings.linkedin }}" target="_blank" rel="noopener noreferrer" style="color:#0077b5; text-decoration:none; font-size:18px;" title="LinkedIn">in</a>
                                    {% endif %}
                                    {% if block.settings.twitter %}
                                        <a href="{{ block.settings.twitter }}" target="_blank" rel="noopener noreferrer" style="color:#1da1f2; text-decoration:none; font-size:18px;" title="Twitter">&#120143;</a>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}
            </div>
        {% else %}
            <p style="text-align:center; color:#999;">Add member blocks to populate this section.</p>
        {% endif %}
    </div>
</section>

{% schema %}
{
    "name": "Team",
    "description": "Showcase team members with photos and bios",
    "icon": "team",
    "settings": [
        {"type": "text", "id": "heading", "label": "Heading", "default": "Our Team"},
        {"type": "text", "id": "subheading", "label": "Subheading", "default": "Meet the people behind the product"},
        {"type": "select", "id": "columns", "label": "Columns", "default": "3",
         "options": [{"value": "2", "label": "2 Columns"}, {"value": "3", "label": "3 Columns"}, {"value": "4", "label": "4 Columns"}]},
        {"type": "color", "id": "bg_color", "label": "Background Color", "default": "#ffffff"},
        {"type": "color", "id": "heading_color", "label": "Heading Color", "default": "#303030"},
        {"type": "color", "id": "text_color", "label": "Text Color", "default": "#616161"},
        {"type": "color", "id": "card_bg", "label": "Card Background", "default": "#f9fafb"},
        {"type": "range", "id": "padding", "label": "Section Padding (px)", "min": 0, "max": 120, "step": 4, "default": 60}
    ],
    "blocks": [
        {
            "type": "member",
            "name": "Member",
            "settings": [
                {"type": "image", "id": "image", "label": "Photo"},
                {"type": "text", "id": "name", "label": "Name", "default": "Jane Doe"},
                {"type": "text", "id": "role", "label": "Role", "default": "CEO"},
                {"type": "textarea", "id": "bio", "label": "Bio"},
                {"type": "url", "id": "linkedin", "label": "LinkedIn URL"},
                {"type": "url", "id": "twitter", "label": "Twitter URL"}
            ]
        }
    ],
    "presets": [
        {
            "name": "Team",
            "settings": {"heading": "Our Team", "subheading": "Meet the people behind the product", "columns": "3"},
            "blocks": [
                {"type": "member", "settings": {"name": "Jane Doe", "role": "CEO", "bio": "Visionary leader with 15 years of experience."}},
                {"type": "member", "settings": {"name": "John Smith", "role": "CTO", "bio": "Full-stack engineer and architecture expert."}},
                {"type": "member", "settings": {"name": "Sarah Lee", "role": "Head of Design", "bio": "Award-winning designer focused on user experience."}}
            ]
        }
    ]
}
{% endschema %}
