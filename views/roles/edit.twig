{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Role{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/roles">Roles</a> / Edit
</div>

<div class="page-header">
    <h1>Edit Role</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="/cms/roles/{{ editRole.getId() }}">
            {{ csrf_field() | raw }}

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-400);">
                <div class="form-group">
                    <label for="name">Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ flash('_old_input').name ?? editRole.getName() }}"
                           placeholder="e.g. Editor" required>
                    {% if flash('errors').name is defined %}
                        <div class="invalid-feedback">{{ flash('errors').name }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label for="slug">Slug *</label>
                    <input type="text" id="slug" name="slug" class="form-control"
                           value="{{ flash('_old_input').slug ?? editRole.getSlug() }}"
                           {% if editRole.getSlug() == 'admin' %}readonly{% endif %}>
                    {% if editRole.getSlug() == 'admin' %}
                        <small style="color: var(--text-secondary);">The admin slug cannot be changed.</small>
                    {% endif %}
                    {% if flash('errors').slug is defined %}
                        <div class="invalid-feedback">{{ flash('errors').slug }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="form-control" rows="3"
                          placeholder="Optional description of this role">{{ flash('_old_input').description ?? editRole.getDescription() ?? '' }}</textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a href="/cms/roles" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
