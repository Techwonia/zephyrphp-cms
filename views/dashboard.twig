{% extends "@cms/layouts/cms.twig" %}

{% block title %}CMS Dashboard{% endblock %}

{% block content %}
<div class="page-header">
    <h1>CMS Dashboard</h1>
    <div class="page-actions">
        <a href="/cms/collections/create" class="btn btn-primary">+ New Collection</a>
    </div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon">&#128203;</div>
        <div class="stat-info">
            <div class="stat-value">{{ totalCollections }}</div>
            <div class="stat-label">Collections</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">&#128196;</div>
        <div class="stat-info">
            <div class="stat-value">{{ totalEntries }}</div>
            <div class="stat-label">Total Entries</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon">&#128247;</div>
        <div class="stat-info">
            <div class="stat-value">{{ totalMedia }}</div>
            <div class="stat-label">Media Files</div>
        </div>
    </div>
</div>

{% if collections|length > 0 %}
<div class="card">
    <div class="card-header">
        <h3>Collections</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Fields</th>
                        <th>Entries</th>
                        <th>API</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for collection in collections %}
                    <tr>
                        <td><strong>{{ collection.getName() }}</strong></td>
                        <td><code>{{ collection.getSlug() }}</code></td>
                        <td>{{ collection.getFields()|length }}</td>
                        <td>{{ stats[collection.getSlug()] ?? 0 }}</td>
                        <td>
                            {% if collection.isApiEnabled() %}
                                <span class="badge">API</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endif %}
                        </td>
                        <td class="actions-cell">
                            <a href="/cms/collections/{{ collection.getSlug() }}/entries" class="btn btn-sm btn-outline">Entries</a>
                            <a href="/cms/collections/{{ collection.getSlug() }}" class="btn btn-sm btn-outline">Edit</a>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="empty-state">
    <h3>No collections yet</h3>
    <p>Create your first collection to start building your content.</p>
    <a href="/cms/collections/create" class="btn btn-primary">+ Create Collection</a>
</div>
{% endif %}
{% endblock %}
