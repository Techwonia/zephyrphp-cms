{% extends "@cms/layouts/cms.twig" %}

{% block title %}Notifications{% endblock %}

{% block content %}
<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--sp-6);">
    <div>
        <h1 style="margin: 0;">Notifications</h1>
        {% if unreadCount > 0 %}
        <p style="color: var(--text-secondary); margin: var(--sp-1) 0 0;">{{ unreadCount }} unread</p>
        {% endif %}
    </div>
    <div style="display: flex; gap: var(--sp-2);">
        {% if unreadCount > 0 %}
        <form method="POST" action="{{ admin_url('notifications/read-all') }}" style="margin: 0;">
            <input type="hidden" name="_token" value="{{ csrf_token() }}">
            <button type="submit" class="btn btn-outline btn-sm">Mark all as read</button>
        </form>
        {% endif %}
        <a href="{{ admin_url('notifications/preferences') }}" class="btn btn-outline btn-sm">Preferences</a>
    </div>
</div>

{% if notifications|length > 0 %}
<div class="card">
    <div style="divide-y: 1px solid var(--border);">
        {% for notification in notifications %}
        <div style="display: flex; align-items: flex-start; gap: var(--sp-4); padding: var(--sp-4) var(--sp-5); border-bottom: 1px solid var(--border); {% if not notification.isRead() %}background: var(--zui-info-50);{% endif %}">
            <div style="flex-shrink: 0; margin-top: 2px;">
                {% if notification.getType() == 'entry_published' %}
                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--zui-success-600);"></span>
                {% elseif notification.getType() == 'form_submitted' %}
                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--zui-info-600);"></span>
                {% elseif notification.getType() == 'user_registered' %}
                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--zui-warning-600);"></span>
                {% else %}
                    <span style="display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--text-secondary);"></span>
                {% endif %}
            </div>
            <div style="flex: 1; min-width: 0;">
                <div style="font-weight: {% if not notification.isRead() %}600{% else %}400{% endif %};">
                    {% if notification.getLink() %}
                        <a href="{{ notification.getLink() }}" style="color: inherit; text-decoration: none;">{{ notification.getTitle() }}</a>
                    {% else %}
                        {{ notification.getTitle() }}
                    {% endif %}
                </div>
                {% if notification.getBody() %}
                <div style="color: var(--text-secondary); font-size: var(--text-sm); margin-top: var(--sp-1);">
                    {{ notification.getBody()|length > 120 ? notification.getBody()|slice(0, 120) ~ '...' : notification.getBody() }}
                </div>
                {% endif %}
                <div style="color: var(--text-disabled); font-size: var(--text-xs); margin-top: var(--sp-1);">
                    {{ notification.getCreatedAt()|date('M j, Y g:i A') }}
                </div>
            </div>
            {% if not notification.isRead() %}
            <form method="POST" action="{{ admin_url('notifications/' ~ notification.getId() ~ '/read') }}" style="margin: 0; flex-shrink: 0;">
                <input type="hidden" name="_token" value="{{ csrf_token() }}">
                <button type="submit" class="btn btn-outline btn-sm" title="Mark as read" style="padding: 4px 8px; font-size: var(--text-xs);">
                    Mark read
                </button>
            </form>
            {% endif %}
        </div>
        {% endfor %}
    </div>
</div>

{% if notifications|length >= 20 %}
<div style="text-align: center; margin-top: var(--sp-6);">
    <a href="{{ admin_url('notifications?page=' ~ page + 1) }}" class="btn btn-outline btn-sm">Load more</a>
</div>
{% endif %}

{% else %}
<div class="card" style="padding: var(--sp-8); text-align: center;">
    <p style="color: var(--text-secondary); margin: 0;">No notifications yet.</p>
</div>
{% endif %}
{% endblock %}
