{% extends "@cms/layouts/cms.twig" %}

{% block title %}Automation Rules{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> / Automation Rules
</div>

<div class="page-header">
    <h1>Automation Rules</h1>
    <div class="page-actions">
        <a href="{{ admin_url('automations/create') }}" class="btn btn-primary">+ New Rule</a>
    </div>
</div>

{% if rules|length > 0 %}
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Collection</th>
                        <th>Trigger</th>
                        <th>Schedule</th>
                        <th>Last Run</th>
                        <th style="text-align: center;">Status</th>
                        <th style="text-align: right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for rule in rules %}
                    <tr>
                        <td><strong>{{ rule.getName() }}</strong></td>
                        <td>{{ collectionMap[rule.getCollectionSlug()] ?? rule.getCollectionSlug() }}</td>
                        <td>
                            <span class="badge">{{ triggers[rule.getTriggerType()] ?? rule.getTriggerType() }}</span>
                        </td>
                        <td>
                            {% if rule.getTriggerType() == 'schedule' and rule.getSchedule() %}
                                {{ schedules[rule.getSchedule()] ?? rule.getSchedule() }}
                            {% else %}
                                <span class="text-muted">--</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if rule.getLastRunAt() %}
                                {{ rule.getLastRunAt()|date('M d, Y H:i') }}
                            {% else %}
                                <span class="text-muted">Never</span>
                            {% endif %}
                        </td>
                        <td style="text-align: center;">
                            {% if rule.isActive() %}
                                <span class="badge badge-success">Active</span>
                            {% else %}
                                <span class="badge badge-default">Inactive</span>
                            {% endif %}
                        </td>
                        <td style="text-align: right; white-space: nowrap;">
                            <form method="POST" action="{{ admin_url('automations/' ~ rule.getId() ~ '/run') }}"
                                  style="display: inline;">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn btn-sm btn-outline" title="Run now"
                                        onclick="return confirm('Run this automation rule now?');">Run</button>
                            </form>
                            <a href="{{ admin_url('automations/' ~ rule.getId()) }}" class="btn btn-sm btn-outline">Edit</a>
                            <form method="POST" action="{{ admin_url('automations/' ~ rule.getId() ~ '/delete') }}"
                                  style="display: inline;" class="confirm-delete" data-message="Delete this automation rule?">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% if totalPages > 1 %}
<div class="pagination" style="margin-top: var(--space-400); display: flex; gap: var(--space-200); justify-content: center;">
    {% if page > 1 %}
        <a href="{{ admin_url('automations?page=' ~ (page - 1)) }}" class="btn btn-outline btn-sm">Previous</a>
    {% endif %}
    <span style="line-height: 32px; color: var(--text-secondary);">Page {{ page }} of {{ totalPages }}</span>
    {% if page < totalPages %}
        <a href="{{ admin_url('automations?page=' ~ (page + 1)) }}" class="btn btn-outline btn-sm">Next</a>
    {% endif %}
</div>
{% endif %}

{% else %}
<div class="empty-state">
    <h3>No automation rules yet</h3>
    <p>Create rules to automatically manage your content -- unpublish old entries, send notifications on status changes, and more.</p>
    <a href="{{ admin_url('automations/create') }}" class="btn btn-primary">+ Create Rule</a>
</div>
{% endif %}
{% endblock %}
