{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create Automation Rule{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> /
    <a href="{{ admin_url('automations') }}">Automation Rules</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> New
</div>

<div class="page-header">
    <h1>Create Automation Rule</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="{{ admin_url('automations') }}" id="automationForm">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" class="form-control" required
                       placeholder="e.g. Unpublish old entries" value="{{ flash('_old_input').name ?? '' }}">
            </div>

            <div class="form-group">
                <label for="collection_slug">Collection *</label>
                <select id="collection_slug" name="collection_slug" class="form-control" required>
                    <option value="">-- Select Collection --</option>
                    {% for c in collections %}
                        <option value="{{ c.getSlug() }}" {{ (flash('_old_input').collection_slug ?? '') == c.getSlug() ? 'selected' : '' }}>
                            {{ c.getName() }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group">
                <label for="trigger_type">Trigger *</label>
                <select id="trigger_type" name="trigger_type" class="form-control" required>
                    {% for key, label in triggers %}
                        <option value="{{ key }}" {{ (flash('_old_input').trigger_type ?? 'schedule') == key ? 'selected' : '' }}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group" id="scheduleGroup">
                <label for="schedule">Schedule Interval</label>
                <select id="schedule" name="schedule" class="form-control">
                    <option value="">-- Select Interval --</option>
                    {% for key, label in schedules %}
                        <option value="{{ key }}" {{ (flash('_old_input').schedule ?? '') == key ? 'selected' : '' }}>
                            {{ label }}
                        </option>
                    {% endfor %}
                </select>
                <p class="text-secondary text-sm">How often this rule should run. Only applies to scheduled triggers.</p>
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: var(--sp-2); cursor: pointer;">
                    <input type="hidden" name="is_active" value="0">
                    <input type="checkbox" name="is_active" value="1" checked>
                    <span>Active</span>
                </label>
            </div>

            <hr style="margin: var(--sp-4) 0;">

            {# --- Conditions --- #}
            <h3 style="margin-bottom: var(--sp-3);">Conditions</h3>
            <p class="text-secondary text-sm" style="margin-bottom: var(--sp-3);">
                All conditions must match for the rule to apply (AND logic). Leave empty to match all entries.
            </p>

            <div id="conditionsContainer"></div>
            <button type="button" class="btn btn-outline btn-sm" onclick="addCondition()" style="margin-bottom: var(--sp-4);">
                + Add Condition
            </button>

            <hr style="margin: var(--sp-4) 0;">

            {# --- Actions --- #}
            <h3 style="margin-bottom: var(--sp-3);">Actions</h3>
            <p class="text-secondary text-sm" style="margin-bottom: var(--sp-3);">
                Actions to perform on matching entries.
            </p>

            <div id="actionsContainer"></div>
            <button type="button" class="btn btn-outline btn-sm" onclick="addAction()" style="margin-bottom: var(--sp-4);">
                + Add Action
            </button>

            <hr style="margin: var(--sp-4) 0;">

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Rule</button>
                <a href="{{ admin_url('automations') }}" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script nonce="{{ csp_nonce() }}">
var operators = {{ operators|json_encode|raw }};
var actionTypes = {{ actionTypes|json_encode|raw }};

// Toggle schedule field visibility
var triggerSelect = document.getElementById('trigger_type');
var scheduleGroup = document.getElementById('scheduleGroup');

function toggleSchedule() {
    scheduleGroup.style.display = triggerSelect.value === 'schedule' ? '' : 'none';
}
triggerSelect.addEventListener('change', toggleSchedule);
toggleSchedule();

// --- Conditions ---
var conditionsContainer = document.getElementById('conditionsContainer');
var conditionIndex = 0;

function addCondition(field, operator, value) {
    field = field || '';
    operator = operator || 'equals';
    value = value || '';

    var row = document.createElement('div');
    row.className = 'condition-row';
    row.style.cssText = 'display: flex; gap: var(--sp-2); margin-bottom: var(--sp-2); align-items: center;';

    var fieldInput = '<input type="text" name="condition_field[]" class="form-control" placeholder="Field name (e.g. created_at, status)" value="' + escapeAttr(field) + '" style="flex: 1;">';

    var opSelect = '<select name="condition_operator[]" class="form-control" style="flex: 0 0 150px;">';
    for (var key in operators) {
        var selected = key === operator ? ' selected' : '';
        opSelect += '<option value="' + key + '"' + selected + '>' + operators[key] + '</option>';
    }
    opSelect += '</select>';

    var valueInput = '<input type="text" name="condition_value[]" class="form-control" placeholder="Value (e.g. 365 days, published)" value="' + escapeAttr(value) + '" style="flex: 1;">';

    var removeBtn = '<button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.remove();" style="flex: 0 0 auto;">X</button>';

    row.innerHTML = fieldInput + opSelect + valueInput + removeBtn;
    conditionsContainer.appendChild(row);
    conditionIndex++;
}

// --- Actions ---
var actionsContainer = document.getElementById('actionsContainer');
var actionIndex = 0;

function addAction(type, field, value, message) {
    type = type || 'unpublish';
    field = field || '';
    value = value || '';
    message = message || '';

    var row = document.createElement('div');
    row.className = 'action-row';
    row.style.cssText = 'display: flex; gap: var(--sp-2); margin-bottom: var(--sp-2); align-items: center; flex-wrap: wrap;';

    var typeSelect = '<select name="action_type[]" class="form-control action-type-select" style="flex: 0 0 180px;" onchange="toggleActionFields(this)">';
    for (var key in actionTypes) {
        var selected = key === type ? ' selected' : '';
        typeSelect += '<option value="' + key + '"' + selected + '>' + actionTypes[key] + '</option>';
    }
    typeSelect += '</select>';

    var fieldInput = '<input type="text" name="action_field[]" class="form-control action-field" placeholder="Field name" value="' + escapeAttr(field) + '" style="flex: 1; display: ' + (type === 'update_field' ? '' : 'none') + ';">';

    var valueInput = '<input type="text" name="action_value[]" class="form-control action-value" placeholder="New value" value="' + escapeAttr(value) + '" style="flex: 1; display: ' + (type === 'update_field' ? '' : 'none') + ';">';

    var messageInput = '<input type="text" name="action_message[]" class="form-control action-message" placeholder="Notification message" value="' + escapeAttr(message) + '" style="flex: 1; display: ' + (type === 'notify' ? '' : 'none') + ';">';

    var removeBtn = '<button type="button" class="btn btn-sm btn-danger" onclick="this.parentElement.remove();" style="flex: 0 0 auto;">X</button>';

    row.innerHTML = typeSelect + fieldInput + valueInput + messageInput + removeBtn;
    actionsContainer.appendChild(row);
    actionIndex++;
}

function toggleActionFields(select) {
    var row = select.closest('.action-row');
    var type = select.value;
    var fieldEl = row.querySelector('.action-field');
    var valueEl = row.querySelector('.action-value');
    var messageEl = row.querySelector('.action-message');

    fieldEl.style.display = type === 'update_field' ? '' : 'none';
    valueEl.style.display = type === 'update_field' ? '' : 'none';
    messageEl.style.display = type === 'notify' ? '' : 'none';
}

function escapeAttr(str) {
    var div = document.createElement('div');
    div.appendChild(document.createTextNode(str));
    return div.innerHTML.replace(/"/g, '&quot;');
}

// Start with one empty action row
addAction();
</script>
{% endblock %}
