{% extends "@cms/layouts/cms.twig" %}

{% block title %}Site Analytics{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/analytics-dashboard.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Analytics
</div>

<div class="page-header" style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: var(--sp-3);">
    <h1>Site Analytics</h1>
    <div class="flex items-center gap-2">
        {% if liveVisitors is defined %}
        <div style="display: flex; align-items: center; gap: var(--sp-2); padding: var(--sp-2) var(--sp-4); background: var(--zui-success-50); border-radius: var(--radius-full); font-size: var(--text-sm);">
            <span style="width: 8px; height: 8px; background: var(--zui-success-600); border-radius: 50%; display: inline-block; animation: livePulse 2s infinite;"></span>
            <strong style="color: var(--zui-success-600);">{{ liveVisitors }}</strong>
            <span class="text-secondary">live now</span>
        </div>
        {% endif %}
        <div class="analytics-range-picker" style="display: flex; border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden;">
            <a href="?range=today" class="range-btn{% if range == 'today' %} active{% endif %}" style="padding: var(--sp-2) var(--sp-4); font-size: var(--text-sm); text-decoration: none; color: var(--text); border-right: 1px solid var(--border); {% if range == 'today' %}background: var(--zui-primary-500); color: #FFF;{% else %}background: var(--bg-surface);{% endif %}">Today</a>
            <a href="?range=7d" class="range-btn{% if range == '7d' %} active{% endif %}" style="padding: var(--sp-2) var(--sp-4); font-size: var(--text-sm); text-decoration: none; color: var(--text); border-right: 1px solid var(--border); {% if range == '7d' %}background: var(--zui-primary-500); color: #FFF;{% else %}background: var(--bg-surface);{% endif %}">7 Days</a>
            <a href="?range=30d" class="range-btn{% if range == '30d' %} active{% endif %}" style="padding: var(--sp-2) var(--sp-4); font-size: var(--text-sm); text-decoration: none; color: var(--text); border-right: 1px solid var(--border); {% if range == '30d' %}background: var(--zui-primary-500); color: #FFF;{% else %}background: var(--bg-surface);{% endif %}">30 Days</a>
            <a href="?range=90d" class="range-btn{% if range == '90d' %} active{% endif %}" style="padding: var(--sp-2) var(--sp-4); font-size: var(--text-sm); text-decoration: none; color: var(--text); {% if range == '90d' %}background: var(--zui-primary-500); color: #FFF;{% else %}background: var(--bg-surface);{% endif %}">90 Days</a>
        </div>
    </div>
</div>

{% if error is defined and error %}
<div class="card" class="mb-5">
    <div class="card-body" style="color: var(--zui-error-600);">
        <strong>Error:</strong> {{ error }}
    </div>
</div>
{% else %}

{# ── Stats Cards ── #}
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-primary-500);">{{ totalRange|number_format }}</div>
            <div style="color: var(--text-secondary); font-size: var(--text-sm);">Page Views</div>
            <div style="color: var(--text-secondary); font-size: var(--text-xs); margin-top: var(--sp-1);">
                Today: {{ totalToday|number_format }} &middot; 7d: {{ total7d|number_format }} &middot; 30d: {{ total30d|number_format }}
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-info-600);">{{ uniqueRange|number_format }}</div>
            <div style="color: var(--text-secondary); font-size: var(--text-sm);">Unique Visitors</div>
            <div style="color: var(--text-secondary); font-size: var(--text-xs); margin-top: var(--sp-1);">
                Today: {{ uniqueToday|number_format }} &middot; 7d: {{ unique7d|number_format }} &middot; 30d: {{ unique30d|number_format }}
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: {% if bounceRate > 70 %}var(--zui-warning-600){% elseif bounceRate > 50 %}var(--text){% else %}var(--zui-success-600){% endif %};">{{ bounceRate }}%</div>
            <div style="color: var(--text-secondary); font-size: var(--text-sm);">Bounce Rate</div>
            <div style="color: var(--text-secondary); font-size: var(--text-xs); margin-top: var(--sp-1);">
                Single-page visits
            </div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-primary-500);">{{ avgPagesPerSession }}</div>
            <div style="color: var(--text-secondary); font-size: var(--text-sm);">Pages / Session</div>
            <div style="color: var(--text-secondary); font-size: var(--text-xs); margin-top: var(--sp-1);">
                Average depth
            </div>
        </div>
    </div>
</div>

{# ── Traffic Chart (SVG Polyline) ── #}
<div class="card" class="mb-5">
    <div class="card-header" class="flex items-center justify-between">
        <h3 style="margin:0; font-size:1rem;">Traffic Overview</h3>
        <div style="display: flex; align-items: center; gap: var(--sp-4); font-size: var(--text-xs); color: var(--text-secondary);">
            <span style="display: flex; align-items: center; gap: var(--sp-1);"><span style="width: 12px; height: 3px; background: var(--zui-primary-500); border-radius: 2px; display: inline-block;"></span> Page Views</span>
            <span style="display: flex; align-items: center; gap: var(--sp-1);"><span style="width: 12px; height: 3px; background: var(--zui-success-600); border-radius: 2px; display: inline-block;"></span> Visitors</span>
        </div>
    </div>
    <div class="card-body" style="padding: var(--sp-4);">
        {% if trafficChart|length > 0 %}
            {% set max_views = 1 %}
            {% for day in trafficChart %}
                {% if day.views > max_views %}{% set max_views = day.views %}{% endif %}
            {% endfor %}

            {% set chart_w = 900 %}
            {% set chart_h = 220 %}
            {% set pad_x = 50 %}
            {% set pad_y = 20 %}
            {% set inner_w = chart_w - pad_x - 10 %}
            {% set inner_h = chart_h - pad_y - 30 %}
            {% set step_x = trafficChart|length > 1 ? inner_w / (trafficChart|length - 1) : inner_w %}

            <div style="overflow-x: auto;">
            <svg viewBox="0 0 {{ chart_w }} {{ chart_h }}" style="width: 100%; height: auto; min-height: 200px; max-height: 300px;" xmlns="http://www.w3.org/2000/svg">
                {# Grid lines #}
                {% for i in 0..4 %}
                    {% set y_pos = pad_y + (inner_h * i / 4) %}
                    {% set label_val = ((max_views * (4 - i) / 4))|round %}
                    <line x1="{{ pad_x }}" y1="{{ y_pos }}" x2="{{ chart_w - 10 }}" y2="{{ y_pos }}" stroke="#E3E3E3" stroke-width="1" stroke-dasharray="4,4"/>
                    <text x="{{ pad_x - 8 }}" y="{{ y_pos + 4 }}" fill="#616161" font-size="10" text-anchor="end" font-family="Inter, sans-serif">{{ label_val }}</text>
                {% endfor %}

                {# Views area fill #}
                {% set views_points = '' %}
                {% set area_points = '' %}
                {% for day in trafficChart %}
                    {% set x = pad_x + (loop.index0 * step_x) %}
                    {% set y = pad_y + inner_h - (day.views / max_views * inner_h) %}
                    {% set views_points = views_points ~ x ~ ',' ~ y ~ ' ' %}
                    {% if loop.first %}
                        {% set area_points = x ~ ',' ~ (pad_y + inner_h) ~ ' ' %}
                    {% endif %}
                    {% set area_points = area_points ~ x ~ ',' ~ y ~ ' ' %}
                    {% if loop.last %}
                        {% set area_points = area_points ~ x ~ ',' ~ (pad_y + inner_h) %}
                    {% endif %}
                {% endfor %}
                <polygon points="{{ area_points }}" fill="var(--zui-primary-500)" opacity="0.08"/>
                <polyline points="{{ views_points }}" fill="none" stroke="var(--zui-primary-500)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>

                {# Visitors line #}
                {% set visitor_points = '' %}
                {% for day in trafficChart %}
                    {% set x = pad_x + (loop.index0 * step_x) %}
                    {% set y = pad_y + inner_h - (day.visitors / max_views * inner_h) %}
                    {% set visitor_points = visitor_points ~ x ~ ',' ~ y ~ ' ' %}
                {% endfor %}
                <polyline points="{{ visitor_points }}" fill="none" stroke="var(--zui-success-600)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" stroke-dasharray="6,3"/>

                {# Data point dots for views #}
                {% for day in trafficChart %}
                    {% set x = pad_x + (loop.index0 * step_x) %}
                    {% set y = pad_y + inner_h - (day.views / max_views * inner_h) %}
                    <circle cx="{{ x }}" cy="{{ y }}" r="3" fill="var(--zui-primary-500)" stroke="white" stroke-width="1.5">
                        <title>{{ day.date }}: {{ day.views }} views, {{ day.visitors }} visitors</title>
                    </circle>
                {% endfor %}

                {# X-axis labels #}
                {% for day in trafficChart %}
                    {% if trafficChart|length <= 14 or loop.index0 % (trafficChart|length / 7)|round(0, 'ceil') == 0 or loop.last %}
                        {% set x = pad_x + (loop.index0 * step_x) %}
                        <text x="{{ x }}" y="{{ chart_h - 5 }}" fill="#616161" font-size="10" text-anchor="middle" font-family="Inter, sans-serif">{{ day.date|slice(5) }}</text>
                    {% endif %}
                {% endfor %}
            </svg>
            </div>
        {% else %}
            <div style="text-align: center; padding: var(--sp-8); color: var(--text-secondary);">
                No traffic data available for this period. Analytics data is collected by the tracking middleware.
            </div>
        {% endif %}
    </div>
</div>

{# ── Top Pages & Referrer Sources ── #}
<div style="display: grid; grid-template-columns: 3fr 2fr; gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Top Pages</h3></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Page</th>
                            <th class="text-right">Views</th>
                            <th style="width: 120px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set max_page_views = topPages[0].views|default(1) %}
                        {% for page in topPages %}
                        <tr>
                            <td><code style="font-size: var(--text-sm);">{{ page.path|length > 60 ? page.path[:60] ~ '...' : page.path }}</code></td>
                            <td style="text-align: right; font-weight: 600; white-space: nowrap;">{{ page.views|number_format }}</td>
                            <td>
                                <div style="background: var(--bg-subdued); border-radius: var(--radius-sm); height: 6px; overflow: hidden;">
                                    <div style="background: var(--zui-primary-500); height: 100%; width: {{ (page.views / max_page_views * 100)|round }}%; border-radius: var(--radius-sm);"></div>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="3" style="text-align: center; color: var(--text-secondary);">No page data</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Referrer Sources</h3></div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Source</th>
                            <th class="text-right">Visits</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set max_ref = topReferrers[0].count|default(1) %}
                        {% for ref in topReferrers %}
                        <tr>
                            <td>
                                {% if ref.source == 'Direct / None' %}
                                    <span class="text-secondary">{{ ref.source }}</span>
                                {% else %}
                                    {{ ref.source }}
                                {% endif %}
                            </td>
                            <td class="text-right">
                                <div style="display: flex; align-items: center; justify-content: flex-end; gap: var(--sp-2);">
                                    <div style="width: 60px; background: var(--bg-subdued); border-radius: var(--radius-sm); height: 6px; overflow: hidden;">
                                        <div style="background: var(--zui-info-600); height: 100%; width: {{ (ref.count / max_ref * 100)|round }}%; border-radius: var(--radius-sm);"></div>
                                    </div>
                                    <span style="font-weight: 600; min-width: 30px;">{{ ref.count|number_format }}</span>
                                </div>
                            </td>
                        </tr>
                        {% else %}
                        <tr><td colspan="2" style="text-align: center; color: var(--text-secondary);">No referrer data</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

{# ── Browser & Device Breakdown + Content Sections ── #}
<div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: var(--sp-4); margin-bottom: var(--sp-5);">
    {# Browser Breakdown #}
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Browsers</h3></div>
        <div class="card-body" style="padding: var(--sp-4);">
            {% set max_browser = browserBreakdown[0].count|default(1) %}
            {% set browser_colors = ['#1A7BA8', '#047B5D', '#B98900', '#D72C0D', '#2C6ECB', '#6D28D9', '#DB2777', '#EA580C'] %}
            {% for browser in browserBreakdown %}
            <div class="mb-3">
                <div style="display: flex; justify-content: space-between; font-size: var(--text-sm); margin-bottom: var(--sp-1);">
                    <span>{{ browser.name }}</span>
                    <span class="font-semibold">{{ browser.count|number_format }}{% if totalRange > 0 %} <span style="color: var(--text-secondary); font-weight: 400;">({{ ((browser.count / totalRange) * 100)|round(1) }}%)</span>{% endif %}</span>
                </div>
                <div style="background: var(--bg-subdued); border-radius: var(--radius-sm); height: 8px; overflow: hidden;">
                    <div style="background: {{ browser_colors[loop.index0] ?? '#1A7BA8' }}; height: 100%; width: {{ (browser.count / max_browser * 100)|round }}%; border-radius: var(--radius-sm); transition: width 0.3s ease;"></div>
                </div>
            </div>
            {% else %}
            <div style="text-align: center; color: var(--text-secondary); padding: var(--sp-4);">No browser data</div>
            {% endfor %}
        </div>
    </div>

    {# Device Breakdown #}
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Devices</h3></div>
        <div class="card-body" style="padding: var(--sp-4);">
            {% set device_icons = {'Desktop': 'M4 6h16v10H4zm2 12h12', 'Mobile': 'M7 2h10v20H7z', 'Tablet': 'M6 2h12v20H6z'} %}
            {% set device_colors = {'Desktop': '#1A7BA8', 'Mobile': '#047B5D', 'Tablet': '#B98900'} %}
            {% set max_device = deviceBreakdown[0].count|default(1) %}

            {# SVG Donut Chart #}
            {% if deviceBreakdown|length > 0 %}
            <div style="display: flex; justify-content: center; margin-bottom: var(--sp-4);">
                <svg viewBox="0 0 120 120" style="width: 120px; height: 120px;">
                    {% set offset = 0 %}
                    {% set total = 0 %}
                    {% for device in deviceBreakdown %}
                        {% set total = total + device.count %}
                    {% endfor %}
                    {% for device in deviceBreakdown %}
                        {% set pct = total > 0 ? (device.count / total * 100) : 0 %}
                        {% set dashLen = pct * 2.827 %}
                        {% set dashGap = 282.7 - dashLen %}
                        <circle cx="60" cy="60" r="45" fill="none" stroke="{{ device_colors[device.name] ?? '#999' }}" stroke-width="16" stroke-dasharray="{{ dashLen }} {{ dashGap }}" stroke-dashoffset="{{ -offset * 2.827 }}" transform="rotate(-90 60 60)" opacity="0.85"/>
                        {% set offset = offset + pct %}
                    {% endfor %}
                    <text x="60" y="56" text-anchor="middle" font-size="14" font-weight="700" fill="var(--text)" font-family="Inter, sans-serif">{{ totalRange|number_format }}</text>
                    <text x="60" y="70" text-anchor="middle" font-size="9" fill="var(--text-secondary)" font-family="Inter, sans-serif">total</text>
                </svg>
            </div>
            {% endif %}

            {% for device in deviceBreakdown %}
            <div style="display: flex; align-items: center; justify-content: space-between; padding: var(--sp-2) 0; {% if not loop.last %}border-bottom: 1px solid var(--border);{% endif %}">
                <div class="flex items-center gap-2">
                    <span style="width: 10px; height: 10px; background: {{ device_colors[device.name] ?? '#999' }}; border-radius: 50%; display: inline-block;"></span>
                    <span style="font-size: var(--text-sm);">{{ device.name }}</span>
                </div>
                <div style="font-size: var(--text-sm);">
                    <strong>{{ device.count|number_format }}</strong>
                    {% if totalRange > 0 %}
                    <span class="text-secondary">({{ ((device.count / totalRange) * 100)|round(1) }}%)</span>
                    {% endif %}
                </div>
            </div>
            {% else %}
            <div style="text-align: center; color: var(--text-secondary); padding: var(--sp-4);">No device data</div>
            {% endfor %}
        </div>
    </div>

    {# Content Sections #}
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Content Sections</h3></div>
        <div class="card-body" style="padding: var(--sp-4);">
            {% set max_section = topSections[0].views|default(1) %}
            {% set section_colors = ['#1A7BA8', '#2C6ECB', '#047B5D', '#6D28D9', '#B98900', '#DB2777', '#EA580C', '#0D9488', '#7C3AED', '#DC2626'] %}
            {% for section in topSections %}
            <div class="mb-3">
                <div style="display: flex; justify-content: space-between; font-size: var(--text-sm); margin-bottom: var(--sp-1);">
                    <span style="text-transform: capitalize;">/{{ section.section }}</span>
                    <span class="font-semibold">{{ section.views|number_format }}</span>
                </div>
                <div style="background: var(--bg-subdued); border-radius: var(--radius-sm); height: 8px; overflow: hidden;">
                    <div style="background: {{ section_colors[loop.index0] ?? '#1A7BA8' }}; height: 100%; width: {{ (section.views / max_section * 100)|round }}%; border-radius: var(--radius-sm);"></div>
                </div>
            </div>
            {% else %}
            <div style="text-align: center; color: var(--text-secondary); padding: var(--sp-4);">No section data</div>
            {% endfor %}
        </div>
    </div>
</div>

{% endif %}

{% endblock %}
