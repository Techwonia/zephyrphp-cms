{% extends "@cms/layouts/cms.twig" %}

{% block title %}System Health{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> System / Health
</div>

<div class="page-header">
    <h1>System Health</h1>
</div>

{# Status Overview #}
<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-primary-500);">{{ php.version }}</div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">PHP Version</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: {% if database.connected %}var(--zui-success-600){% else %}var(--zui-error-600){% endif %};">
                {% if database.connected %}Connected{% else %}Error{% endif %}
            </div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Database</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: {% if disk.used_percent > 90 %}var(--zui-error-600){% elseif disk.used_percent > 70 %}var(--zui-warning-600){% else %}var(--zui-success-600){% endif %};">{{ disk.used_percent }}%</div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Disk Usage</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-4);">
            <div style="font-size: 2rem; font-weight: 700; color: {% if maintenance.active %}var(--zui-warning-600){% else %}var(--zui-success-600){% endif %};">
                {% if maintenance.active %}Down{% else %}Live{% endif %}
            </div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">App Status</div>
        </div>
    </div>
</div>

{# Environment #}
<div class="card" class="mb-5">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Environment</h3></div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <tbody>
                    {% for key, value in environment %}
                    <tr>
                        <td style="width:200px; font-weight:600;">{{ key|capitalize }}</td>
                        <td>{{ value }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# PHP Info #}
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">PHP Configuration</h3></div>
        <div class="card-body">
            <table class="data-table">
                <tbody>
                    {% for key, value in php %}
                    <tr>
                        <td style="width:180px; font-weight:600;">{{ key|replace({'_': ' '})|title }}</td>
                        <td>{{ value }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Memory & Disk</h3></div>
        <div class="card-body">
            <table class="data-table">
                <tbody>
                    <tr><td class="font-semibold">Current Memory</td><td>{{ memory.current }}</td></tr>
                    <tr><td class="font-semibold">Peak Memory</td><td>{{ memory.peak }}</td></tr>
                    <tr><td class="font-semibold">Memory Limit</td><td>{{ memory.limit }}</td></tr>
                    <tr><td class="font-semibold">Disk Total</td><td>{{ disk.total }}</td></tr>
                    <tr><td class="font-semibold">Disk Free</td><td>{{ disk.free }}</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

{# Storage Sizes #}
<div class="card" class="mb-5">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Storage Usage</h3></div>
    <div class="card-body">
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: var(--sp-4);">
            {% for name, size in storage %}
            <div style="text-align: center; padding: var(--sp-3); background: var(--bg-subdued); border-radius: var(--radius);">
                <div style="font-size: 1.25rem; font-weight: 600;">{{ size }}</div>
                <div style="color: var(--text-secondary); font-size: 0.85rem;">{{ name|replace({'_': ' '})|title }}</div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

{# Database Info #}
{% if database.connected %}
<div class="card" class="mb-5">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Database</h3></div>
    <div class="card-body">
        <table class="data-table">
            <tbody>
                <tr><td style="width:180px; font-weight:600;">Driver</td><td>{{ database.driver }}</td></tr>
                <tr><td class="font-semibold">Host</td><td>{{ database.host }}</td></tr>
                <tr><td class="font-semibold">Database</td><td>{{ database.database }}</td></tr>
                <tr><td class="font-semibold">Tables</td><td>{{ database.table_count }}</td></tr>
                <tr><td class="font-semibold">Size</td><td>{{ database.size }}</td></tr>
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# Directory Permissions #}
<div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Directory Permissions</h3></div>
        <div class="card-body">
            <table class="data-table">
                <tbody>
                    {% for dir, writable in writableDirs %}
                    <tr>
                        <td>{{ dir }}</td>
                        <td>
                            {% if writable %}
                                <span class="badge" style="background: var(--zui-success-600); color: #fff;">Writable</span>
                            {% else %}
                                <span class="badge" style="background: var(--zui-error-600); color: #fff;">Not Writable</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card">
        <div class="card-header"><h3 style="margin:0; font-size:1rem;">Required Extensions</h3></div>
        <div class="card-body">
            <table class="data-table">
                <tbody>
                    {% for ext, loaded in extensionStatus %}
                    <tr>
                        <td>{{ ext }}</td>
                        <td>
                            {% if loaded %}
                                <span class="badge" style="background: var(--zui-success-600); color: #fff;">Loaded</span>
                            {% else %}
                                <span class="badge" style="background: var(--zui-error-600); color: #fff;">Missing</span>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}
