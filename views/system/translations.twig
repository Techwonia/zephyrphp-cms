{% extends "@cms/layouts/cms.twig" %}

{% block title %}Translation Manager{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> System / Translations
</div>

<div class="page-header" class="flex items-center justify-between">
    <h1>Translation Manager</h1>
    <div class="flex gap-2">
        <a href="{{ admin_url('system/translations/progress') }}" class="btn btn-outline btn-sm">Translation Progress</a>
    </div>
</div>

{# Locale & Group Selector #}
<div class="card" class="mb-5">
    <div class="card-body">
        <form method="GET" action="{{ admin_url('system/translations') }}" style="display: flex; gap: var(--sp-3); align-items: flex-end; flex-wrap: wrap;">
            <div>
                <label class="form-label">Locale</label>
                <select name="locale" class="form-control" style="min-width: 120px;" onchange="this.form.submit()">
                    {% for locale in locales %}
                    <option value="{{ locale }}" {{ selectedLocale == locale ? 'selected' : '' }}>{{ locale }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label">Group</label>
                <select name="group" class="form-control" style="min-width: 150px;" onchange="this.form.submit()">
                    <option value="">-- Select Group --</option>
                    {% for group in groups %}
                    <option value="{{ group }}" {{ selectedGroup == group ? 'selected' : '' }}>{{ group }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label">Compare With</label>
                <select name="compare" class="form-control" style="min-width: 120px;" onchange="this.form.submit()">
                    <option value="">-- None --</option>
                    {% for locale in locales %}
                        {% if locale != selectedLocale %}
                        <option value="{{ locale }}" {{ compareLocale == locale ? 'selected' : '' }}>{{ locale }}</option>
                        {% endif %}
                    {% endfor %}
                </select>
            </div>
            <div>
                <label class="form-label">Search</label>
                <div class="flex gap-2">
                    <input type="text" name="search" class="form-control" value="{{ search }}" placeholder="Search keys or values...">
                    <button type="submit" class="btn btn-outline btn-sm">Filter</button>
                </div>
            </div>
        </form>
    </div>
</div>

{# Actions Row: Create Group, Create Locale, Export, Import #}
<div style="display: flex; gap: var(--sp-4); margin-bottom: var(--sp-5); flex-wrap: wrap; align-items: flex-end;">
    {# Create Group #}
    <form method="POST" action="{{ admin_url('system/translations/create-group') }}" style="display: flex; gap: var(--sp-2); align-items: flex-end;">
        {{ csrf_field() | raw }}
        <input type="hidden" name="locale" value="{{ selectedLocale }}">
        <div>
            <label class="form-label">New Group</label>
            <input type="text" name="new_group" class="form-control" placeholder="e.g. messages" pattern="[a-z0-9_-]+" required>
        </div>
        <button type="submit" class="btn btn-outline btn-sm">Create Group</button>
    </form>

    {# Create Locale #}
    <form method="POST" action="{{ admin_url('system/translations/create-locale') }}" style="display: flex; gap: var(--sp-2); align-items: flex-end;">
        {{ csrf_field() | raw }}
        <div>
            <label class="form-label">New Locale</label>
            <input type="text" name="new_locale" class="form-control" placeholder="e.g. fr, pt-BR" pattern="[a-z]{2}(-[A-Z]{2})?" required style="width: 120px;">
        </div>
        <button type="submit" class="btn btn-outline btn-sm">Create Locale</button>
    </form>

    {# Export #}
    {% if selectedLocale %}
    <div style="display: flex; gap: var(--sp-2); align-items: flex-end;">
        <div>
            <label class="form-label">Export ({{ selectedLocale }})</label>
            <div style="display: flex; gap: var(--sp-1);">
                <a href="{{ admin_url('system/translations/export?locale=' ~ selectedLocale ~ '&format=json') }}" class="btn btn-outline btn-sm">JSON</a>
                <a href="{{ admin_url('system/translations/export?locale=' ~ selectedLocale ~ '&format=csv') }}" class="btn btn-outline btn-sm">CSV</a>
            </div>
        </div>
    </div>

    {# Import #}
    <div>
        <label class="form-label">Import to {{ selectedLocale }}</label>
        <button type="button" class="btn btn-outline btn-sm" onclick="document.getElementById('importModal').style.display='flex'">Import File</button>
    </div>
    {% endif %}
</div>

{# Translation Editor #}
{% if selectedGroup %}
<form method="POST" action="{{ admin_url('system/translations/update') }}">
    {{ csrf_field() | raw }}
    <input type="hidden" name="locale" value="{{ selectedLocale }}">
    <input type="hidden" name="group" value="{{ selectedGroup }}">

    <div class="card" class="mb-4">
        <div class="card-header">
            <h3 style="margin:0; font-size:1rem;">{{ selectedGroup }} ({{ selectedLocale }}) — {{ translations|length }} keys</h3>
        </div>
        <div class="card-body" class="p-0">
            {% if translations|length > 0 %}
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th style="width: 30%;">Key</th>
                            <th>Value ({{ selectedLocale }})</th>
                            {% if compareLocale %}
                            <th>Value ({{ compareLocale }})</th>
                            {% endif %}
                            <th style="width: 50px;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for key, value in translations %}
                        <tr>
                            <td style="font-family: monospace; font-size: 0.85rem;">
                                <input type="hidden" name="keys[]" value="{{ key }}">
                                {{ key }}
                            </td>
                            <td>
                                <input type="text" name="values[]" class="form-control" value="{{ value }}" style="font-size: 0.85rem;">
                            </td>
                            {% if compareLocale %}
                            <td style="font-size: 0.85rem; color: var(--text-secondary);">
                                {% if compareTranslations[key] is defined %}
                                    {{ compareTranslations[key] }}
                                {% else %}
                                    <span style="color: var(--zui-error-600); font-size: 0.75rem;">Missing</span>
                                {% endif %}
                            </td>
                            {% endif %}
                            <td>
                                <form method="POST" action="{{ admin_url('system/translations/delete-key') }}" style="margin:0;">
                                    {{ csrf_field() | raw }}
                                    <input type="hidden" name="locale" value="{{ selectedLocale }}">
                                    <input type="hidden" name="group" value="{{ selectedGroup }}">
                                    <input type="hidden" name="key" value="{{ key }}">
                                    <button type="submit" class="btn btn-outline btn-sm" style="color: var(--zui-error-600); padding: 2px 6px;" title="Delete key" onclick="return confirm('Delete key {{ key }}?')">&times;</button>
                                </form>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% else %}
            <div style="padding: var(--sp-4); color: var(--text-secondary);">No translation keys in this group yet.</div>
            {% endif %}
        </div>
    </div>

    {% if translations|length > 0 %}
    <div class="mb-5">
        <button type="submit" class="btn btn-primary">Save Translations</button>
    </div>
    {% endif %}
</form>

{# Add New Key #}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Add New Key</h3></div>
    <div class="card-body">
        <form method="POST" action="{{ admin_url('system/translations/add-key') }}" style="display: flex; gap: var(--sp-3); align-items: flex-end;">
            {{ csrf_field() | raw }}
            <input type="hidden" name="locale" value="{{ selectedLocale }}">
            <input type="hidden" name="group" value="{{ selectedGroup }}">
            <div class="flex-1">
                <label class="form-label">Key</label>
                <input type="text" name="new_key" class="form-control" placeholder="e.g. welcome_message" required>
            </div>
            <div class="flex-1">
                <label class="form-label">Value</label>
                <input type="text" name="new_value" class="form-control" placeholder="Translation value...">
            </div>
            <button type="submit" class="btn btn-outline">Add Key</button>
        </form>
    </div>
</div>

{% elseif locales|length == 0 %}
<div class="empty-state">
    <h3>No locales found</h3>
    <p>Create a locale above or add a <code>lang/</code> directory with locale subdirectories (e.g. <code>lang/en/</code>) to get started.</p>
</div>
{% else %}
<div class="empty-state">
    <h3>Select a group</h3>
    <p>Choose a locale and translation group above to begin editing.</p>
</div>
{% endif %}

{# Import Modal #}
<div id="importModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 450px; width: 100%;">
        <div class="card-header" class="flex items-center justify-between">
            <h3 style="margin: 0; font-size: 1rem;">Import Translations</h3>
            <button type="button" onclick="document.getElementById('importModal').style.display='none'" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-secondary);">&times;</button>
        </div>
        <div class="card-body">
            <form method="POST" action="{{ admin_url('system/translations/import') }}" enctype="multipart/form-data">
                {{ csrf_field() | raw }}
                <input type="hidden" name="locale" value="{{ selectedLocale }}">

                <div class="mb-4">
                    <label class="form-label">File (JSON or CSV)</label>
                    <input type="file" name="file" class="form-control" accept=".json,.csv" required>
                    <span style="font-size: 0.75rem; color: var(--text-secondary);">
                        JSON format: <code>{"group": {"key": "value"}}</code><br>
                        CSV format: <code>group,key,value</code> (with header row)
                    </span>
                </div>

                <div class="mb-4">
                    <label class="form-label">Import Mode</label>
                    <select name="mode" class="form-control">
                        <option value="merge">Merge (keep existing, add/update new)</option>
                        <option value="overwrite">Overwrite (replace group contents)</option>
                    </select>
                </div>

                <div style="display: flex; gap: var(--sp-2); justify-content: flex-end;">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('importModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-primary">Import</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
// Close modal on backdrop click
var importModal = document.getElementById('importModal');
if (importModal) {
    importModal.addEventListener('click', function(e) {
        if (e.target === this) this.style.display = 'none';
    });
}
</script>
{% endblock %}
