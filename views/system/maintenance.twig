{% extends "@cms/layouts/cms.twig" %}

{% block title %}Maintenance Mode{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / System / Maintenance
</div>

<div class="page-header">
    <h1>Maintenance Mode</h1>
</div>

{# Current Status #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-body" style="display: flex; align-items: center; justify-content: space-between;">
        <div>
            <div style="font-size: 1.25rem; font-weight: 700;">
                {% if isDown %}
                    <span style="color: var(--warning);">Application is in Maintenance Mode</span>
                {% else %}
                    <span style="color: var(--success);">Application is Live</span>
                {% endif %}
            </div>
            {% if isDown and data.time is defined %}
                <div style="color: var(--text-secondary); font-size: 0.85rem; margin-top: 4px;">
                    Since: {{ data.time }}
                </div>
            {% endif %}
        </div>
        {% if isDown %}
            <form method="POST" action="/cms/system/maintenance/deactivate">
                {{ csrf_field() | raw }}
                <button type="submit" class="btn btn-primary">Bring Application Live</button>
            </form>
        {% endif %}
    </div>
</div>

{% if isDown and data %}
{# Current settings when down #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Current Maintenance Settings</h3></div>
    <div class="card-body">
        <table class="data-table">
            <tbody>
                <tr><td style="width:180px; font-weight:600;">Message</td><td>{{ data.message|default('Default message') }}</td></tr>
                {% if data.retry is defined %}<tr><td style="font-weight:600;">Retry After</td><td>{{ data.retry }} seconds</td></tr>{% endif %}
                {% if data.allowed is defined %}<tr><td style="font-weight:600;">Allowed IPs</td><td>{{ data.allowed|join(', ') }}</td></tr>{% endif %}
                {% if data.secret is defined %}<tr><td style="font-weight:600;">Bypass Secret</td><td>{{ data.secret }}</td></tr>{% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}

{# Activate Form #}
{% if not isDown %}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Enable Maintenance Mode</h3></div>
    <div class="card-body">
        <form method="POST" action="/cms/system/maintenance/activate">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="message">Maintenance Message</label>
                <textarea id="message" name="message" class="form-control" rows="3" placeholder="We are currently performing maintenance. Please check back soon."></textarea>
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-400);">
                <div class="form-group">
                    <label for="retry">Retry After (seconds)</label>
                    <input type="number" id="retry" name="retry" class="form-control" placeholder="60" min="0">
                    <small style="color: var(--text-secondary);">Sets the Retry-After HTTP header</small>
                </div>

                <div class="form-group">
                    <label for="secret">Bypass Secret</label>
                    <input type="text" id="secret" name="secret" class="form-control" placeholder="my-secret-token">
                    <small style="color: var(--text-secondary);">Access via ?bypass=secret in URL</small>
                </div>
            </div>

            <div class="form-group">
                <label for="allowed">Allowed IP Addresses</label>
                <textarea id="allowed" name="allowed" class="form-control" rows="3" placeholder="One IP per line&#10;127.0.0.1&#10;192.168.1.100"></textarea>
                <small style="color: var(--text-secondary);">These IPs can access the site during maintenance</small>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-warning" onclick="return confirm('Put the application into maintenance mode?')">Activate Maintenance Mode</button>
            </div>
        </form>
    </div>
</div>
{% endif %}

{% endblock %}
