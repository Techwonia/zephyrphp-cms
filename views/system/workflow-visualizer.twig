{% extends "@cms/layouts/cms.twig" %}

{% block title %}Workflow Builder{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> System / Workflow Builder
</div>

<div class="page-header" style="display: flex; align-items: center; justify-content: space-between;">
    <div>
        <h1>Workflow Builder</h1>
        <p style="color: var(--text-secondary); margin-top: var(--sp-1);">Configure workflow stages, transitions, and reviewers per collection.</p>
    </div>
    <button class="btn btn-primary" onclick="document.getElementById('enableModal').style.display='flex'">+ Enable Workflow</button>
</div>

{% if collections is empty %}
    <div class="card">
        <div class="card-body" style="text-align: center; padding: var(--sp-6); color: var(--text-secondary);">
            No workflow-enabled collections found. Click "Enable Workflow" above to get started.
        </div>
    </div>
{% else %}
    {% for collection in collections %}
    <div class="card" style="margin-bottom: var(--sp-5);">
        <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
            <h3 style="margin: 0; font-size: 1rem;">
                {% if collection.icon %}
                    <i class="{{ collection.icon }}" style="margin-right: var(--sp-1);"></i>
                {% endif %}
                {{ collection.name }}
            </h3>
            <div style="display: flex; align-items: center; gap: var(--sp-2);">
                <span class="badge" style="background: var(--bg-subdued); color: var(--text-secondary); font-size: 0.8rem;">
                    {{ collection.total }} {{ collection.total == 1 ? 'entry' : 'entries' }}
                </span>
                <button class="btn btn-outline btn-sm" onclick="toggleEditPanel('{{ collection.slug }}')">Edit Stages</button>
                <button class="btn btn-outline btn-sm" onclick="toggleReviewerPanel('{{ collection.slug }}')">Reviewers</button>
                <form method="POST" action="{{ admin_url('system/workflow/disable') }}" style="margin:0;" onsubmit="return confirm('Disable workflow for {{ collection.name }}?')">
                    {{ csrf_field() | raw }}
                    <input type="hidden" name="slug" value="{{ collection.slug }}">
                    <button type="submit" class="btn btn-outline btn-sm" style="color: var(--zui-error-600); border-color: var(--zui-error-600);">Disable</button>
                </form>
            </div>
        </div>
        <div class="card-body">
            {# Pipeline visualization #}
            <div style="display: flex; align-items: center; gap: 0; overflow-x: auto; padding: var(--sp-4) 0;">
                {% for stage in collection.stages %}
                    {% set bgColor = 'var(--bg-subdued)' %}
                    {% set textColor = 'var(--text)' %}
                    {% set borderColor = 'var(--border)' %}
                    {% set countColor = 'var(--text-secondary)' %}

                    {% if stage.name == 'draft' %}
                        {% set bgColor = 'var(--bg-subdued)' %}
                        {% set countColor = 'var(--text-secondary)' %}
                        {% set borderColor = 'var(--text-secondary)' %}
                    {% elseif stage.name == 'review' %}
                        {% set bgColor = 'rgba(234, 179, 8, 0.1)' %}
                        {% set countColor = 'var(--zui-warning-600)' %}
                        {% set borderColor = 'var(--zui-warning-600)' %}
                    {% elseif stage.name == 'approved' %}
                        {% set bgColor = 'rgba(59, 130, 246, 0.1)' %}
                        {% set countColor = 'var(--zui-info-600)' %}
                        {% set borderColor = 'var(--zui-info-600)' %}
                    {% elseif stage.name == 'published' %}
                        {% set bgColor = 'rgba(34, 197, 94, 0.1)' %}
                        {% set countColor = 'var(--zui-success-600)' %}
                        {% set borderColor = 'var(--zui-success-600)' %}
                    {% elseif stage.name == 'rejected' %}
                        {% set bgColor = 'rgba(215, 44, 13, 0.1)' %}
                        {% set countColor = 'var(--zui-error-600)' %}
                        {% set borderColor = 'var(--zui-error-600)' %}
                    {% endif %}

                    <div style="
                        display: inline-flex;
                        flex-direction: column;
                        align-items: center;
                        justify-content: center;
                        min-width: 120px;
                        padding: var(--sp-3) var(--sp-4);
                        background: {{ bgColor }};
                        border: 2px solid {{ borderColor }};
                        border-radius: var(--radius);
                        text-align: center;
                        position: relative;
                        {% if collection.bottleneck == stage.name and stage.count > 0 %}
                            box-shadow: 0 0 0 3px rgba(234, 179, 8, 0.3);
                        {% endif %}
                    ">
                        <div style="font-size: 1.75rem; font-weight: 700; color: {{ countColor }}; line-height: 1;">
                            {{ stage.count }}
                        </div>
                        <div style="font-size: 0.8rem; color: var(--text-secondary); margin-top: var(--sp-1); text-transform: capitalize;">
                            {{ stage.name }}
                        </div>
                        {% if collection.bottleneck == stage.name and stage.count > 0 %}
                            <span style="
                                position: absolute;
                                top: -10px;
                                right: -10px;
                                background: var(--zui-warning-600);
                                color: #fff;
                                font-size: 0.65rem;
                                font-weight: 600;
                                padding: 2px 6px;
                                border-radius: 10px;
                                white-space: nowrap;
                            ">Bottleneck</span>
                        {% endif %}
                    </div>

                    {% if not loop.last %}
                        <div style="
                            display: inline-flex;
                            align-items: center;
                            padding: 0 var(--sp-1);
                            color: var(--text-secondary);
                            font-size: 1.25rem;
                            flex-shrink: 0;
                        ">&rarr;</div>
                    {% endif %}
                {% endfor %}
            </div>

            {# Stats row #}
            <div style="
                display: flex;
                gap: var(--sp-4);
                padding-top: var(--sp-3);
                border-top: 1px solid var(--border);
                font-size: 0.85rem;
                color: var(--text-secondary);
            ">
                <span><strong>{{ collection.total }}</strong> total entries</span>
                <span><strong>{{ collection.stages|length }}</strong> stages</span>
                {% if collection.bottleneck %}
                    <span>Bottleneck: <strong style="text-transform: capitalize;">{{ collection.bottleneck }}</strong></span>
                {% endif %}
            </div>
        </div>

        {# Edit Stages Panel (hidden by default) #}
        <div class="card-body" id="editPanel_{{ collection.slug }}" style="display: none; border-top: 1px solid var(--border); background: var(--bg-subdued);">
            <h4 style="font-size: 0.9rem; margin-bottom: var(--sp-3);">Edit Workflow Stages</h4>
            <form method="POST" action="{{ admin_url('system/workflow/save-stages') }}">
                {{ csrf_field() | raw }}
                <input type="hidden" name="slug" value="{{ collection.slug }}">

                <div id="stageList_{{ collection.slug }}" style="display: flex; flex-direction: column; gap: var(--sp-2); margin-bottom: var(--sp-4);">
                    {% for stage in collection.stages %}
                    <div class="wf-stage-row" style="display: flex; align-items: center; gap: var(--sp-2);">
                        <span style="color: var(--text-secondary); font-size: 0.8rem; min-width: 20px;">{{ loop.index }}.</span>
                        <input type="text" name="stages[]" value="{{ stage.name }}" class="form-control" style="flex: 1; max-width: 250px;" pattern="[a-z0-9_-]+" required placeholder="stage_name">
                        <button type="button" class="btn btn-outline btn-sm" onclick="removeStageRow(this)" style="color: var(--zui-error-600);" title="Remove">&times;</button>
                    </div>
                    {% endfor %}
                </div>

                <div style="display: flex; gap: var(--sp-2); align-items: center;">
                    <button type="button" class="btn btn-outline btn-sm" onclick="addStageRow('{{ collection.slug }}')">+ Add Stage</button>
                    <button type="submit" class="btn btn-primary btn-sm">Save Stages</button>
                    <span style="font-size: 0.75rem; color: var(--text-secondary);">Use lowercase letters, numbers, underscores, hyphens only. Min 2 stages.</span>
                </div>
            </form>
        </div>

        {# Reviewer Assignment Panel (hidden by default) #}
        <div class="card-body" id="reviewerPanel_{{ collection.slug }}" style="display: none; border-top: 1px solid var(--border); background: var(--bg-subdued);">
            <h4 style="font-size: 0.9rem; margin-bottom: var(--sp-3);">Reviewer Assignments</h4>
            <p style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: var(--sp-3);">
                Assign users who can advance entries from each stage. Leave empty to allow any authenticated user.
            </p>
            <form method="POST" action="{{ admin_url('system/workflow/save-reviewers') }}">
                {{ csrf_field() | raw }}
                <input type="hidden" name="slug" value="{{ collection.slug }}">

                <div style="display: flex; flex-direction: column; gap: var(--sp-3);">
                    {% for stage in collection.stages %}
                        {% if not loop.last %}
                        <div style="display: flex; align-items: flex-start; gap: var(--sp-3); padding: var(--sp-2) 0; border-bottom: 1px solid var(--border);">
                            <div style="min-width: 120px; padding-top: 6px;">
                                <strong style="text-transform: capitalize; font-size: 0.85rem;">{{ stage.name }}</strong>
                                <div style="font-size: 0.75rem; color: var(--text-secondary);">Who can advance?</div>
                            </div>
                            <div style="flex: 1;">
                                <select name="reviewers[{{ stage.name }}][]" multiple class="form-control" style="min-height: 60px; font-size: 0.85rem;">
                                    {% for u in users %}
                                    <option value="{{ u.id }}" {{ u.id in (collection.reviewers[stage.name] ?? []) ? 'selected' : '' }}>
                                        {{ u.name }}
                                    </option>
                                    {% endfor %}
                                </select>
                                <span style="font-size: 0.7rem; color: var(--text-secondary);">Hold Ctrl/Cmd to select multiple. Empty = anyone can review.</span>
                            </div>
                        </div>
                        {% endif %}
                    {% endfor %}
                </div>

                <div style="margin-top: var(--sp-3);">
                    <button type="submit" class="btn btn-primary btn-sm">Save Reviewers</button>
                </div>
            </form>
        </div>
    </div>
    {% endfor %}
{% endif %}

{# Recent Transitions #}
<div class="card" style="margin-top: var(--sp-5);">
    <div class="card-header">
        <h3 style="margin: 0; font-size: 1rem;">Recent Transitions</h3>
    </div>
    <div class="card-body">
        {% if transitions is empty %}
            <p style="text-align: center; color: var(--text-secondary); padding: var(--sp-4);">
                No workflow transitions recorded yet.
            </p>
        {% else %}
            <div class="table-responsive">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Collection</th>
                            <th>Entry</th>
                            <th>Transition</th>
                            <th>User</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for t in transitions %}
                        <tr>
                            <td style="white-space: nowrap;">{{ t.date }}</td>
                            <td>{{ t.collection }}</td>
                            <td>#{{ t.entry_id }}</td>
                            <td>
                                <span style="text-transform: capitalize;">{{ t.from }}</span>
                                &rarr;
                                <span style="text-transform: capitalize;">{{ t.to }}</span>
                            </td>
                            <td>{{ t.user }}</td>
                            <td>
                                {% if t.action == 'advance' %}
                                    <span class="badge" style="background: var(--zui-success-600); color: #fff;">Advance</span>
                                {% elseif t.action == 'reject' %}
                                    <span class="badge" style="background: var(--zui-error-600); color: #fff;">Reject</span>
                                {% else %}
                                    <span class="badge" style="background: var(--bg-subdued); color: var(--text-secondary);">{{ t.action|capitalize }}</span>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>

{# Enable Workflow Modal #}
<div id="enableModal" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.5); z-index: 999; align-items: center; justify-content: center;">
    <div class="card" style="max-width: 400px; width: 100%;">
        <div class="card-header" style="display: flex; align-items: center; justify-content: space-between;">
            <h3 style="margin: 0; font-size: 1rem;">Enable Workflow</h3>
            <button type="button" onclick="document.getElementById('enableModal').style.display='none'" style="background: none; border: none; font-size: 1.2rem; cursor: pointer; color: var(--text-secondary);">&times;</button>
        </div>
        <div class="card-body">
            <form method="POST" action="{{ admin_url('system/workflow/enable') }}">
                {{ csrf_field() | raw }}
                <div style="margin-bottom: var(--sp-4);">
                    <label class="form-label">Select Collection</label>
                    <select name="slug" class="form-control" required>
                        <option value="">-- Choose --</option>
                        {% for c in allCollections %}
                            {% if not c.isWorkflowEnabled() %}
                            <option value="{{ c.getSlug() }}">{{ c.getName() }}</option>
                            {% endif %}
                        {% endfor %}
                    </select>
                </div>
                <p style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: var(--sp-4);">
                    Default stages: Draft &rarr; Review &rarr; Approved &rarr; Published. You can customize stages after enabling.
                </p>
                <div style="display: flex; gap: var(--sp-2); justify-content: flex-end;">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('enableModal').style.display='none'">Cancel</button>
                    <button type="submit" class="btn btn-primary">Enable</button>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
function toggleEditPanel(slug) {
    var el = document.getElementById('editPanel_' + slug);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
    // Close reviewer panel if open
    var rev = document.getElementById('reviewerPanel_' + slug);
    if (rev) rev.style.display = 'none';
}

function toggleReviewerPanel(slug) {
    var el = document.getElementById('reviewerPanel_' + slug);
    el.style.display = el.style.display === 'none' ? 'block' : 'none';
    // Close edit panel if open
    var edit = document.getElementById('editPanel_' + slug);
    if (edit) edit.style.display = 'none';
}

function addStageRow(slug) {
    var list = document.getElementById('stageList_' + slug);
    var count = list.querySelectorAll('.wf-stage-row').length + 1;
    var row = document.createElement('div');
    row.className = 'wf-stage-row';
    row.style.cssText = 'display: flex; align-items: center; gap: var(--sp-2);';
    row.innerHTML = '<span style="color: var(--text-secondary); font-size: 0.8rem; min-width: 20px;">' + count + '.</span>' +
        '<input type="text" name="stages[]" value="" class="form-control" style="flex: 1; max-width: 250px;" pattern="[a-z0-9_-]+" required placeholder="new_stage">' +
        '<button type="button" class="btn btn-outline btn-sm" onclick="removeStageRow(this)" style="color: var(--zui-error-600);" title="Remove">&times;</button>';
    list.appendChild(row);
    row.querySelector('input').focus();
}

function removeStageRow(btn) {
    var row = btn.closest('.wf-stage-row');
    var list = row.parentElement;
    if (list.querySelectorAll('.wf-stage-row').length <= 2) {
        alert('At least 2 stages are required.');
        return;
    }
    row.remove();
    // Renumber
    list.querySelectorAll('.wf-stage-row').forEach(function(r, i) {
        r.querySelector('span').textContent = (i + 1) + '.';
    });
}

// Close modal on backdrop click
document.getElementById('enableModal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
});
</script>
{% endblock %}
