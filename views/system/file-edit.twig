{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit: {{ filename }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> <a href="{{ admin_url('system/files?root=' ~ root) }}">Files</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> {{ filename }}
</div>

<div class="page-header" class="flex items-center justify-between">
    <h1>{{ filename }}</h1>
    <div style="display: flex; gap: var(--sp-2); align-items: center;">
        <span class="badge">{{ extension }}</span>
        <span style="font-size: 0.85rem; color: var(--text-secondary);">{{ size }}</span>
        {% if not writable %}
            <span class="badge" style="background: var(--zui-error-600); color: white;">Read Only</span>
        {% endif %}
    </div>
</div>

{% if writable %}
<form method="POST" action="{{ admin_url('system/files/save') }}">
    {{ csrf_field() | raw }}
    <input type="hidden" name="root" value="{{ root }}">
    <input type="hidden" name="file" value="{{ file }}">

    <div class="card" class="mb-4">
        <div class="card-body" class="p-0">
            <textarea name="content" class="form-control" style="font-family: monospace; font-size: 0.85rem; min-height: 500px; border: none; border-radius: 0; resize: vertical; tab-size: 4; white-space: pre; overflow-wrap: normal; overflow-x: auto;">{{ content }}</textarea>
        </div>
    </div>

    <div class="flex items-center justify-between">
        <div style="font-size: 0.85rem; color: var(--text-secondary);">
            Last modified: {{ modified }}
        </div>
        <div class="flex gap-2">
            <a href="{{ admin_url('system/files?root=' ~ root) }}" class="btn btn-outline">Cancel</a>
            <button type="submit" class="btn btn-primary">Save File</button>
        </div>
    </div>
</form>
{% else %}
<div class="card" class="mb-4">
    <div class="card-body" class="p-0">
        <pre style="margin: 0; padding: var(--sp-4); font-size: 0.85rem; overflow-x: auto; white-space: pre;">{{ content }}</pre>
    </div>
</div>

<div class="flex items-center justify-between">
    <div style="font-size: 0.85rem; color: var(--text-secondary);">
        Last modified: {{ modified }}
    </div>
    <a href="{{ admin_url('system/files?root=' ~ root) }}" class="btn btn-outline">Back</a>
</div>
{% endif %}

{% endblock %}
