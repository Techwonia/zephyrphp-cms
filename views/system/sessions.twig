{% extends "@cms/layouts/cms.twig" %}

{% block title %}Session Manager{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> System / Sessions
</div>

<div class="page-header" class="flex items-center justify-between">
    <h1>Session Manager</h1>
    <form method="POST" action="{{ admin_url('system/sessions/terminate-all') }}" onsubmit="return confirm('Terminate ALL other sessions? All users except you will be logged out.')">
        {{ csrf_field() | raw }}
        <button type="submit" class="btn btn-danger btn-sm">Terminate All Others</button>
    </form>
</div>

{# Stats #}
<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--sp-4); margin-bottom: var(--sp-5);">
    <div class="card">
        <div class="card-body" class="text-center">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-primary-500);">{{ stats.active_sessions }}</div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Active Sessions</div>
        </div>
    </div>
    <div class="card">
        <div class="card-body" class="text-center">
            <div style="font-size: 2rem; font-weight: 700; color: var(--zui-primary-500);">{{ stats.unique_users }}</div>
            <div style="color: var(--text-secondary); font-size: 0.85rem;">Unique Users</div>
        </div>
    </div>
</div>

{# Active Sessions #}
<div class="card" class="mb-5">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Active Sessions</h3></div>
    <div class="card-body" class="p-0">
        {% if sessions|length > 0 %}
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>IP Address</th>
                        <th>Browser</th>
                        <th>Last Activity</th>
                        <th>Started</th>
                        <th style="width: 120px;">Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for session in sessions %}
                    <tr>
                        <td>
                            {% if session.user_name %}
                                <strong>{{ session.user_name }}</strong>
                                <br><small class="text-secondary">{{ session.user_email }}</small>
                            {% else %}
                                <em class="text-secondary">Guest</em>
                            {% endif %}
                        </td>
                        <td style="font-family: monospace; font-size: 0.85rem;">{{ session.ip_address }}</td>
                        <td style="font-size: 0.85rem;">{{ session.browser }}</td>
                        <td style="font-size: 0.85rem;">{{ session.last_activity }}</td>
                        <td style="font-size: 0.85rem;">{{ session.created_at }}</td>
                        <td>
                            {% if session.is_current %}
                                <span class="badge" style="background: var(--zui-success-600); color: white;">Current</span>
                            {% else %}
                                <form method="POST" action="{{ admin_url('system/sessions/' ~ session.id ~ '/terminate') }}" style="display: inline;" onsubmit="return confirm('Terminate this session?')">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="btn btn-danger btn-sm">Terminate</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        {% else %}
        <div style="padding: var(--sp-4); color: var(--text-secondary);">No active sessions found.</div>
        {% endif %}
    </div>
</div>

{# Login History #}
{% if history|length > 0 %}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Recent Login History</h3></div>
    <div class="card-body" class="p-0">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Action</th>
                        <th>Status</th>
                        <th>IP Address</th>
                        <th>Time</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in history %}
                    <tr>
                        <td>
                            {{ entry.user_name ?: entry.user_email ?: 'Unknown' }}
                        </td>
                        <td>{{ entry.action|replace({'_': ' '})|title }}</td>
                        <td>
                            {% if entry.status == 'success' %}
                                <span class="badge" style="background: var(--zui-success-600); color: white;">{{ entry.status }}</span>
                            {% else %}
                                <span class="badge" style="background: var(--zui-error-600); color: white;">{{ entry.status }}</span>
                            {% endif %}
                        </td>
                        <td style="font-family: monospace; font-size: 0.85rem;">{{ entry.ip_address }}</td>
                        <td style="font-size: 0.85rem;">{{ entry.created_at }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endif %}

{% endblock %}
