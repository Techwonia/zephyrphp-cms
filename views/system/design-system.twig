{% extends "@cms/layouts/cms.twig" %}

{% block title %}Design System{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/design-system.css">{% endblock %}

{% block content %}

{# Hero #}
<div class="ds-hero">
    <div class="ds-version">ZephyrUI v2.0</div>
    <h1>Design System</h1>
    <p>The visual language behind ZephyrPHP CMS. Every component, token, and pattern in one place.</p>
</div>

{# ── COLORS ── #}
<section class="ds-section">
    <div class="ds-section-header">
        <h2>Colors</h2>
        <p>Click any swatch to copy its CSS variable</p>
    </div>

    <div class="ds-block">
        <div class="ds-block-header">
            <span class="ds-block-title">Primary</span>
            <span class="ds-block-label">Teal-Blue</span>
        </div>
        <div class="ds-preview" style="padding:var(--sp-4) var(--sp-5)">
            <div class="ds-swatch-row" style="flex:1">
                <div class="ds-swatch light" style="background:var(--zui-primary-50)" data-copy="--zui-primary-50"><span class="ds-swatch-name">50</span><span class="ds-swatch-hex">#F0F9FF</span></div>
                <div class="ds-swatch light" style="background:var(--zui-primary-100)" data-copy="--zui-primary-100"><span class="ds-swatch-name">100</span><span class="ds-swatch-hex">#E0F2FE</span></div>
                <div class="ds-swatch light" style="background:var(--zui-primary-200)" data-copy="--zui-primary-200"><span class="ds-swatch-name">200</span><span class="ds-swatch-hex">#BAE6FD</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-primary-300)" data-copy="--zui-primary-300"><span class="ds-swatch-name">300</span><span class="ds-swatch-hex">#7DD3FC</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-primary-400)" data-copy="--zui-primary-400"><span class="ds-swatch-name">400</span><span class="ds-swatch-hex">#38BDF8</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-primary-500)" data-copy="--zui-primary-500"><span class="ds-swatch-name">500</span><span class="ds-swatch-hex">#0EA5E9</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-primary-600)" data-copy="--zui-primary-600"><span class="ds-swatch-name">600</span><span class="ds-swatch-hex">#0284C7</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-primary-700)" data-copy="--zui-primary-700"><span class="ds-swatch-name">700</span><span class="ds-swatch-hex">#0369A1</span></div>
            </div>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header">
            <span class="ds-block-title">Neutral</span>
            <span class="ds-block-label">Slate</span>
        </div>
        <div class="ds-preview" style="padding:var(--sp-4) var(--sp-5)">
            <div class="ds-swatch-row" style="flex:1">
                <div class="ds-swatch light" style="background:var(--zui-gray-50);border:1px solid var(--border)" data-copy="--zui-gray-50"><span class="ds-swatch-name">50</span></div>
                <div class="ds-swatch light" style="background:var(--zui-gray-100)" data-copy="--zui-gray-100"><span class="ds-swatch-name">100</span></div>
                <div class="ds-swatch light" style="background:var(--zui-gray-200)" data-copy="--zui-gray-200"><span class="ds-swatch-name">200</span></div>
                <div class="ds-swatch light" style="background:var(--zui-gray-300)" data-copy="--zui-gray-300"><span class="ds-swatch-name">300</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-400)" data-copy="--zui-gray-400"><span class="ds-swatch-name">400</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-500)" data-copy="--zui-gray-500"><span class="ds-swatch-name">500</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-600)" data-copy="--zui-gray-600"><span class="ds-swatch-name">600</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-700)" data-copy="--zui-gray-700"><span class="ds-swatch-name">700</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-800)" data-copy="--zui-gray-800"><span class="ds-swatch-name">800</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-900)" data-copy="--zui-gray-900"><span class="ds-swatch-name">900</span></div>
                <div class="ds-swatch dark" style="background:var(--zui-gray-950)" data-copy="--zui-gray-950"><span class="ds-swatch-name">950</span></div>
            </div>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header">
            <span class="ds-block-title">Status</span>
            <span class="ds-block-label">Semantic</span>
        </div>
        <div class="ds-preview grid-2" style="padding:var(--sp-4) var(--sp-5);gap:var(--sp-3)">
            {% for color, hex in {success: {50:'#F0FDF4',500:'#22C55E',700:'#15803D'}, warning: {50:'#FFFBEB',500:'#F59E0B',700:'#B45309'}, error: {50:'#FEF2F2',500:'#EF4444',700:'#B91C1C'}, info: {50:'#EFF6FF',500:'#3B82F6',700:'#2563EB'}} %}
            <div>
                <div class="text-xs font-medium mb-2" style="text-transform:capitalize">{{ color }}</div>
                <div class="ds-swatch-row">
                    {% for shade, h in hex %}
                    <div class="ds-swatch {% if shade == '50' %}light{% else %}dark{% endif %}" style="background:var(--zui-{{ color }}-{{ shade }}){% if shade == '50' %};border:1px solid var(--border){% endif %}" data-copy="--zui-{{ color }}-{{ shade }}">
                        <span class="ds-swatch-name">{{ shade }}</span><span class="ds-swatch-hex">{{ h }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── TYPOGRAPHY ── #}
<section class="ds-section">
    <div class="ds-section-header">
        <h2>Typography</h2>
        <p>Inter font family, 4px baseline grid</p>
    </div>
    <div class="ds-block">
        <div class="ds-preview col" style="gap:0;padding:var(--sp-5) var(--sp-6)">
            <div class="ds-type-row"><span class="ds-type-sample text-3xl font-bold">The quick brown fox</span><span class="ds-type-meta">30px / bold</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-2xl font-bold">The quick brown fox</span><span class="ds-type-meta">24px / bold</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-xl font-semibold">The quick brown fox</span><span class="ds-type-meta">20px / semi</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-lg font-semibold">The quick brown fox</span><span class="ds-type-meta">18px / semi</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-md font-medium">The quick brown fox</span><span class="ds-type-meta">16px / medium</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-base">The quick brown fox</span><span class="ds-type-meta">14px / regular</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-sm">The quick brown fox</span><span class="ds-type-meta">13px / regular</span></div>
            <div class="ds-type-row"><span class="ds-type-sample text-xs">The quick brown fox</span><span class="ds-type-meta">12px / regular</span></div>
            <div class="ds-type-row"><span class="ds-type-sample mono text-sm" style="color:var(--zui-primary-600)">const x = await fetch()</span><span class="ds-type-meta">mono / code</span></div>
        </div>
    </div>
</section>

{# ── BUTTONS ── #}
<section class="ds-section">
    <div class="ds-section-header">
        <h2>Buttons</h2>
        <p>5 variants, 3 sizes, icon support</p>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Variants</span><span class="ds-block-label">.btn .btn-*</span></div>
        <div class="ds-preview">
            <button class="btn btn-primary">Primary</button>
            <button class="btn btn-outline">Outline</button>
            <button class="btn btn-ghost">Ghost</button>
            <button class="btn btn-danger">Danger</button>
            <button class="btn btn-soft">Soft</button>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">With Icons</span><span class="ds-block-label">svg + text</span></div>
        <div class="ds-preview">
            <button class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Create</button>
            <button class="btn btn-outline">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Export</button>
            <button class="btn btn-danger">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %} Delete</button>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Sizes</span><span class="ds-block-label">.btn-sm / .btn-lg</span></div>
        <div class="ds-preview" style="align-items:center">
            <button class="btn btn-primary btn-sm">Small (28px)</button>
            <button class="btn btn-primary">Default (32px)</button>
            <button class="btn btn-primary btn-lg">Large (40px)</button>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Icon Only & Disabled</span><span class="ds-block-label">.btn-icon</span></div>
        <div class="ds-preview" style="align-items:center">
            <button class="btn btn-outline btn-icon btn-sm">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %}</button>
            <button class="btn btn-outline btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}</button>
            <button class="btn btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}</button>
            <div style="width:1px;height:24px;background:var(--border);margin:0 var(--sp-2)"></div>
            <button class="btn btn-primary" disabled>Disabled</button>
            <button class="btn btn-outline" disabled>Disabled</button>
        </div>
    </div>
</section>

{# ── BADGES ── #}
<section class="ds-section">
    <div class="ds-section-header">
        <h2>Badges & Status</h2>
        <p>6 color variants with optional dot indicator</p>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Solid Badges</span><span class="ds-block-label">.badge .badge-*</span></div>
        <div class="ds-preview">
            <span class="badge badge-default">Default</span>
            <span class="badge badge-primary">Primary</span>
            <span class="badge badge-success">Success</span>
            <span class="badge badge-warning">Warning</span>
            <span class="badge badge-error">Error</span>
            <span class="badge badge-info">Info</span>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Status Badges (with dot)</span><span class="ds-block-label">.badge-dot</span></div>
        <div class="ds-preview">
            <span class="badge badge-success"><span class="badge-dot"></span> Published</span>
            <span class="badge badge-warning"><span class="badge-dot"></span> Draft</span>
            <span class="badge badge-error"><span class="badge-dot"></span> Rejected</span>
            <span class="badge badge-info"><span class="badge-dot"></span> Scheduled</span>
            <span class="badge badge-default"><span class="badge-dot"></span> Archived</span>
            <span class="badge badge-primary"><span class="badge-dot"></span> In Review</span>
        </div>
    </div>
</section>

{# ── FORMS ── #}
<section class="ds-section">
    <div class="ds-section-header">
        <h2>Form Controls</h2>
        <p>Inputs, selects, textareas, toggles, checkboxes</p>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Inputs</span><span class="ds-block-label">.form-control</span></div>
        <div class="ds-preview grid-2">
            <div class="form-group">
                <label class="form-label">Default</label>
                <input type="text" class="form-control" placeholder="Enter text...">
                <div class="form-hint">Helpful description</div>
            </div>
            <div class="form-group">
                <label class="form-label">Error State</label>
                <input type="text" class="form-control error" value="Invalid">
                <div class="form-error-text">This field is required</div>
            </div>
            <div class="form-group">
                <label class="form-label">Select</label>
                <select class="form-control"><option>Choose option...</option><option>Option A</option><option>Option B</option></select>
            </div>
            <div class="form-group">
                <label class="form-label">File</label>
                <input type="file" class="form-control">
            </div>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Textarea</span></div>
        <div class="ds-preview">
            <div class="form-group" style="width:100%">
                <label class="form-label">Message</label>
                <textarea class="form-control" rows="3" placeholder="Write something..."></textarea>
            </div>
        </div>
    </div>

    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Toggles & Checks</span></div>
        <div class="ds-preview" style="gap:var(--sp-6)">
            <div class="form-check-row"><input type="checkbox" id="ds-c1" checked><label for="ds-c1" class="text-sm">Checked</label></div>
            <div class="form-check-row"><input type="checkbox" id="ds-c2"><label for="ds-c2" class="text-sm">Unchecked</label></div>
            <div class="form-check-row"><input type="radio" name="ds-r" id="ds-r1" checked><label for="ds-r1" class="text-sm">Radio A</label></div>
            <div class="form-check-row"><input type="radio" name="ds-r" id="ds-r2"><label for="ds-r2" class="text-sm">Radio B</label></div>
            <div style="width:1px;height:20px;background:var(--border)"></div>
            <div class="flex items-center gap-2"><label class="zui-toggle"><input type="checkbox" checked><div class="zui-toggle-track"></div></label><span class="text-sm">On</span></div>
            <div class="flex items-center gap-2"><label class="zui-toggle"><input type="checkbox"><div class="zui-toggle-track"></div></label><span class="text-sm">Off</span></div>
        </div>
    </div>
</section>

{# ── CARDS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Cards</h2><p>Surface containers and stat cards</p></div>
    <div class="ds-preview grid-3" style="padding:0;background:transparent;border:none">
        <div class="card card-hover">
            <div class="card-header"><h3>Card Title</h3></div>
            <div class="card-body"><p class="text-sm text-secondary">Body content with text, forms, or any component.</p></div>
            <div class="card-footer"><a href="#" class="btn btn-sm btn-soft">Action</a></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'layers'} only %}</div>
            <div><div class="stat-value">1,284</div><div class="stat-label">Total Entries</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon success">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'activity'} only %}</div>
            <div><div class="stat-value">42</div><div class="stat-label">Published Today</div></div>
        </div>
    </div>
</section>

{# ── TABLE ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Data Table</h2><p>Sortable, actionable rows</p></div>
    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Standard Table</span><span class="ds-block-label">.data-table</span></div>
        <div style="padding:0">
            <table class="data-table">
                <thead><tr><th>Name</th><th>Status</th><th>Collection</th><th>Updated</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr><td><a href="#" class="row-link">Getting Started Guide</a></td><td><span class="badge badge-success"><span class="badge-dot"></span> Published</span></td><td class="text-secondary text-sm">Blog</td><td class="text-secondary text-sm">2h ago</td><td><div class="actions-cell"><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</button><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}</button></div></td></tr>
                    <tr><td><a href="#" class="row-link">About Us</a></td><td><span class="badge badge-warning"><span class="badge-dot"></span> Draft</span></td><td class="text-secondary text-sm">Pages</td><td class="text-secondary text-sm">5d ago</td><td><div class="actions-cell"><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</button><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}</button></div></td></tr>
                    <tr><td><a href="#" class="row-link">Contact Form Handler</a></td><td><span class="badge badge-error"><span class="badge-dot"></span> Rejected</span></td><td class="text-secondary text-sm">Forms</td><td class="text-secondary text-sm">1w ago</td><td><div class="actions-cell"><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</button><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}</button></div></td></tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

{# ── ALERTS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Alerts</h2><p>Contextual feedback messages</p></div>
    <div class="alert alert-success">Settings saved successfully.</div>
    <div class="alert alert-warning">Your session will expire in 5 minutes.</div>
    <div class="alert alert-error">Failed to save. Please check the form for errors.</div>
    <div class="alert alert-info">A new version of ZephyrPHP is available.</div>
</section>

{# ── TABS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Tabs</h2></div>
    <div class="ds-block">
        <div class="ds-block-header"><span class="ds-block-title">Navigation Tabs</span><span class="ds-block-label">.tab-nav .tab-btn</span></div>
        <div class="ds-preview col">
            <div class="tab-nav" style="width:100%"><button class="tab-btn active">General</button><button class="tab-btn">Fields</button><button class="tab-btn">API & Routing</button><button class="tab-btn">Access Control</button><button class="tab-btn">Workflow</button></div>
            <p class="text-sm text-secondary">Active tab content renders here.</p>
        </div>
    </div>
</section>

{# ── PAGINATION ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Pagination</h2></div>
    <div class="ds-block">
        <div class="ds-preview" style="justify-content:space-between">
            <span class="pagination-info">Showing 1-10 of 128</span>
            <div class="pagination-controls">
                <button class="pagination-btn" disabled>&laquo;</button>
                <button class="pagination-btn active">1</button>
                <button class="pagination-btn">2</button>
                <button class="pagination-btn">3</button>
                <button class="pagination-btn">...</button>
                <button class="pagination-btn">13</button>
                <button class="pagination-btn">&raquo;</button>
            </div>
        </div>
    </div>
</section>

{# ── EMPTY STATE ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Empty State</h2></div>
    <div class="ds-block">
        <div class="ds-preview center pad-lg">
            <div class="empty-state" style="padding:var(--sp-6) 0">
                <div class="empty-state-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %}</div>
                <h2>No entries yet</h2>
                <p>Create your first entry to get started with content management.</p>
                <button class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Create Entry</button>
            </div>
        </div>
    </div>
</section>

{# ── SKELETONS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Skeleton Loaders</h2><p>Content placeholders during loading</p></div>
    <div class="ds-preview grid-3" style="padding:0;background:transparent;border:none">
        <div class="card"><div class="card-body"><div class="skeleton skeleton-heading"></div><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text"></div><div class="skeleton skeleton-text-sm"></div></div></div>
        <div class="skeleton skeleton-card"></div>
        <div class="card"><div class="card-body"><div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div><div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div><div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div></div></div>
    </div>
</section>

{# ── ICONS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Icons</h2><p>44 icons from Lucide v1.7 (ISC license). Click to copy name.</p></div>
    <div class="ds-block">
        <div class="ds-preview" style="gap:0;padding:var(--sp-4)">
            {% set icons = ['home','database','layers','image','palette','users','user','shield','settings','terminal','globe','folder','folder-plus','file','file-text','code','search','mail','bell','link','lock','key','clock','zap','tag','grid','activity','heart','archive','monitor','git-branch','bar-chart','puzzle','package','store','sparkles','plus','tool','map','corner-down-right','alert-triangle','share-2','layout','arrow-left'] %}
            {% for name in icons %}
            <div class="ds-icon-item" data-copy="{{ name }}" title="{{ name }}">
                <div class="ds-icon-box">{% include '@cms/partials/sidebar-icon.twig' with {icon: name} only %}</div>
                <span>{{ name }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── SPACING ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Spacing</h2><p>4px base unit grid</p></div>
    <div class="ds-block">
        <div class="ds-preview col" style="gap:var(--sp-1);padding:var(--sp-5) var(--sp-6)">
            {% set spaces = {'sp-1':'4','sp-2':'8','sp-3':'12','sp-4':'16','sp-5':'20','sp-6':'24','sp-8':'32','sp-10':'40','sp-12':'48','sp-16':'64'} %}
            {% for name, px in spaces %}
            <div class="ds-space-bar">
                <div class="ds-space-visual" style="width:{{ px }}px"></div>
                <span class="ds-space-label">--{{ name }}</span>
                <span class="ds-space-value">{{ px }}px</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── RADIUS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Border Radius</h2><p>Fluent 2 inspired: 4px default</p></div>
    <div class="ds-block">
        <div class="ds-preview" style="gap:var(--sp-6)">
            {% set radii = {'sm':'4px','':'6px','lg':'8px','xl':'12px','full':'pill'} %}
            {% for suffix, val in radii %}
            <div class="ds-radius-item">
                <div class="ds-radius-box" style="border-radius:var(--radius{{ suffix ? '-' ~ suffix : '' }})"></div>
                <span class="text-xs font-medium">{{ suffix|default('md') }}</span>
                <span class="text-xs text-secondary">{{ val }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# ── SHADOWS ── #}
<section class="ds-section">
    <div class="ds-section-header"><h2>Elevation</h2><p>Key + ambient shadow system</p></div>
    <div class="ds-block">
        <div class="ds-preview" style="gap:var(--sp-6);background:var(--zui-gray-50)">
            {% set shadows = {'shadow-xs':'XS','shadow-sm':'SM','shadow':'Default','shadow-md':'MD','shadow-lg':'LG'} %}
            {% for v, label in shadows %}
            <div class="ds-shadow-item">
                <div class="ds-shadow-box" style="box-shadow:var(--{{ v }})"></div>
                <span class="text-xs font-medium">{{ label }}</span>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{# Copied toast #}
<div class="ds-copied" id="dsCopied">Copied!</div>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var toast = document.getElementById('dsCopied');
    var timer;

    document.addEventListener('click', function(e) {
        var el = e.target.closest('[data-copy]');
        if (!el) return;

        var text = el.getAttribute('data-copy');
        if (navigator.clipboard) {
            navigator.clipboard.writeText(text);
        }

        toast.textContent = 'Copied: ' + text;
        toast.classList.add('show');
        clearTimeout(timer);
        timer = setTimeout(function() { toast.classList.remove('show'); }, 1500);
    });
})();
</script>
{% endblock %}

{% endblock %}
