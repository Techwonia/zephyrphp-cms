{% extends "@cms/layouts/cms.twig" %}

{% block title %}Design System{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a>
    <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    <span class="breadcrumb-current">Design System</span>
</div>

<div class="page-header">
    <div>
        <h1>ZephyrUI Design System</h1>
        <p class="page-header-sub">Components, tokens, and patterns</p>
    </div>
</div>

{# COLORS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Colors</h2>
    <div class="card">
        <div class="card-body">
            <h3 class="font-semibold mb-3">Primary</h3>
            <div class="flex gap-2 flex-wrap mb-5">
                {% for n in ['50','100','200','300','400','500','600','700'] %}
                <div style="width:60px;height:44px;border-radius:var(--radius);background:var(--zui-primary-{{ n }}){% if n == '50' %};border:1px solid var(--border){% endif %}" title="primary-{{ n }}"></div>
                {% endfor %}
            </div>
            <h3 class="font-semibold mb-3">Neutral</h3>
            <div class="flex gap-2 flex-wrap mb-5">
                {% for n in ['50','100','200','300','400','500','600','700','800','900','950'] %}
                <div style="width:48px;height:44px;border-radius:var(--radius);background:var(--zui-gray-{{ n }}){% if n == '50' %};border:1px solid var(--border){% endif %}" title="gray-{{ n }}"></div>
                {% endfor %}
            </div>
            <h3 class="font-semibold mb-3">Status</h3>
            <div class="flex gap-4 flex-wrap">
                {% for color in ['success','warning','error','info'] %}
                <div class="flex gap-1">
                    <div style="width:44px;height:44px;border-radius:var(--radius);background:var(--zui-{{ color }}-50);border:1px solid var(--border)" title="{{ color }}-50"></div>
                    <div style="width:44px;height:44px;border-radius:var(--radius);background:var(--zui-{{ color }}-500)" title="{{ color }}-500"></div>
                    <div style="width:44px;height:44px;border-radius:var(--radius);background:var(--zui-{{ color }}-700)" title="{{ color }}-700"></div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

{# TYPOGRAPHY #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Typography</h2>
    <div class="card">
        <div class="card-body">
            <div class="mb-2"><span class="text-3xl font-bold">Heading 3XL</span> <span class="text-xs text-secondary ml-2">30px</span></div>
            <div class="mb-2"><span class="text-2xl font-bold">Heading 2XL</span> <span class="text-xs text-secondary ml-2">24px</span></div>
            <div class="mb-2"><span class="text-xl font-semibold">Heading XL</span> <span class="text-xs text-secondary ml-2">20px</span></div>
            <div class="mb-2"><span class="text-lg font-semibold">Heading LG</span> <span class="text-xs text-secondary ml-2">18px</span></div>
            <div class="mb-2"><span class="text-md font-medium">Body MD</span> <span class="text-xs text-secondary ml-2">16px</span></div>
            <div class="mb-2"><span class="text-base">Body Base</span> <span class="text-xs text-secondary ml-2">14px</span></div>
            <div class="mb-2"><span class="text-sm">Body SM</span> <span class="text-xs text-secondary ml-2">13px</span></div>
            <div class="mb-2"><span class="text-xs">Caption XS</span> <span class="text-xs text-secondary ml-2">12px</span></div>
            <div><span class="mono text-sm">Monospace</span> <span class="text-xs text-secondary ml-2">SF Mono, Consolas</span></div>
        </div>
    </div>
</section>

{# BUTTONS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Buttons</h2>
    <div class="card">
        <div class="card-body">
            <h3 class="font-semibold mb-3">Variants</h3>
            <div class="flex gap-3 flex-wrap mb-5">
                <button class="btn btn-primary">Primary</button>
                <button class="btn btn-outline">Outline</button>
                <button class="btn btn-ghost">Ghost</button>
                <button class="btn btn-danger">Danger</button>
                <button class="btn btn-soft">Soft</button>
            </div>
            <h3 class="font-semibold mb-3">With Icons</h3>
            <div class="flex gap-3 flex-wrap mb-5">
                <button class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Create</button>
                <button class="btn btn-outline"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg> Export</button>
                <button class="btn btn-danger"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg> Delete</button>
            </div>
            <h3 class="font-semibold mb-3">Sizes</h3>
            <div class="flex gap-3 items-center flex-wrap mb-5">
                <button class="btn btn-primary btn-sm">Small</button>
                <button class="btn btn-primary">Default</button>
                <button class="btn btn-primary btn-lg">Large</button>
            </div>
            <h3 class="font-semibold mb-3">Icon Only</h3>
            <div class="flex gap-2 items-center mb-5">
                <button class="btn btn-outline btn-icon btn-sm"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></button>
                <button class="btn btn-outline btn-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg></button>
                <button class="btn btn-ghost btn-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg></button>
            </div>
            <h3 class="font-semibold mb-3">Disabled</h3>
            <div class="flex gap-3 flex-wrap">
                <button class="btn btn-primary" disabled>Disabled</button>
                <button class="btn btn-outline" disabled>Disabled</button>
            </div>
        </div>
    </div>
</section>

{# BADGES #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Badges & Status</h2>
    <div class="card">
        <div class="card-body">
            <h3 class="font-semibold mb-3">Variants</h3>
            <div class="flex gap-2 flex-wrap mb-5">
                <span class="badge badge-default">Default</span>
                <span class="badge badge-primary">Primary</span>
                <span class="badge badge-success">Success</span>
                <span class="badge badge-warning">Warning</span>
                <span class="badge badge-error">Error</span>
                <span class="badge badge-info">Info</span>
            </div>
            <h3 class="font-semibold mb-3">With Dot</h3>
            <div class="flex gap-2 flex-wrap">
                <span class="badge badge-success"><span class="badge-dot"></span> Published</span>
                <span class="badge badge-warning"><span class="badge-dot"></span> Draft</span>
                <span class="badge badge-error"><span class="badge-dot"></span> Rejected</span>
                <span class="badge badge-info"><span class="badge-dot"></span> Scheduled</span>
                <span class="badge badge-default"><span class="badge-dot"></span> Archived</span>
            </div>
        </div>
    </div>
</section>

{# FORMS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Form Controls</h2>
    <div class="card">
        <div class="card-body">
            <div class="form-row mb-5">
                <div class="form-group">
                    <label class="form-label">Text Input</label>
                    <input type="text" class="form-control" placeholder="Enter text...">
                    <div class="form-hint">Helpful hint text</div>
                </div>
                <div class="form-group">
                    <label class="form-label">Error State</label>
                    <input type="text" class="form-control error" value="Bad value">
                    <div class="form-error-text">This field is required</div>
                </div>
            </div>
            <div class="form-row mb-5">
                <div class="form-group">
                    <label class="form-label">Select</label>
                    <select class="form-control"><option>Option 1</option><option>Option 2</option></select>
                </div>
                <div class="form-group">
                    <label class="form-label">File</label>
                    <input type="file" class="form-control">
                </div>
            </div>
            <div class="form-group mb-5">
                <label class="form-label">Textarea</label>
                <textarea class="form-control" rows="3" placeholder="Write..."></textarea>
            </div>
            <div class="flex gap-5 items-center mb-5">
                <div class="form-check-row"><input type="checkbox" id="c1" checked><label for="c1" class="text-sm">Checked</label></div>
                <div class="form-check-row"><input type="checkbox" id="c2"><label for="c2" class="text-sm">Unchecked</label></div>
                <div class="form-check-row"><input type="radio" name="r" id="r1" checked><label for="r1" class="text-sm">Radio A</label></div>
                <div class="form-check-row"><input type="radio" name="r" id="r2"><label for="r2" class="text-sm">Radio B</label></div>
            </div>
            <div class="flex gap-5 items-center">
                <label class="zui-toggle"><input type="checkbox" checked><div class="zui-toggle-track"></div></label>
                <span class="text-sm">Toggle On</span>
                <label class="zui-toggle"><input type="checkbox"><div class="zui-toggle-track"></div></label>
                <span class="text-sm">Toggle Off</span>
            </div>
        </div>
    </div>
</section>

{# CARDS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Cards</h2>
    <div class="grid grid-3 gap-4">
        <div class="card card-hover">
            <div class="card-header"><h3>Card Title</h3></div>
            <div class="card-body"><p class="text-sm text-secondary">Card body with content.</p></div>
            <div class="card-footer"><a href="#" class="btn btn-sm btn-soft">Action</a></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</div>
            <div><div class="stat-value">128</div><div class="stat-label">Total Entries</div></div>
        </div>
        <div class="stat-card">
            <div class="stat-icon success">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'activity'} only %}</div>
            <div><div class="stat-value">42</div><div class="stat-label">Published</div></div>
        </div>
    </div>
</section>

{# TABLE #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Data Table</h2>
    <div class="card">
        <div class="card-body-flush">
            <table class="data-table">
                <thead><tr><th>Name</th><th>Status</th><th>Type</th><th>Updated</th><th>Actions</th></tr></thead>
                <tbody>
                    <tr>
                        <td><a href="#" class="row-link">Getting Started</a></td>
                        <td><span class="badge badge-success"><span class="badge-dot"></span> Published</span></td>
                        <td class="text-secondary">Blog</td>
                        <td class="text-sm text-secondary">2h ago</td>
                        <td><div class="actions-cell"><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</button></div></td>
                    </tr>
                    <tr>
                        <td><a href="#" class="row-link">About Us</a></td>
                        <td><span class="badge badge-warning"><span class="badge-dot"></span> Draft</span></td>
                        <td class="text-secondary">Page</td>
                        <td class="text-sm text-secondary">5d ago</td>
                        <td><div class="actions-cell"><button class="btn btn-sm btn-ghost btn-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</button></div></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

{# ALERTS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Alerts</h2>
    <div class="alert alert-success">Success alert message.</div>
    <div class="alert alert-warning">Warning alert message.</div>
    <div class="alert alert-error">Error alert message.</div>
    <div class="alert alert-info">Info alert message.</div>
</section>

{# TABS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Tabs</h2>
    <div class="card">
        <div class="card-body">
            <div class="tab-nav">
                <button class="tab-btn active">General</button>
                <button class="tab-btn">Fields</button>
                <button class="tab-btn">API</button>
                <button class="tab-btn">Access</button>
            </div>
            <p class="text-sm text-secondary">Tab content area.</p>
        </div>
    </div>
</section>

{# PAGINATION #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Pagination</h2>
    <div class="card">
        <div class="card-body">
            <div class="pagination">
                <span class="pagination-info">Showing 1-10 of 128</span>
                <div class="pagination-controls">
                    <button class="pagination-btn" disabled>&laquo;</button>
                    <button class="pagination-btn active">1</button>
                    <button class="pagination-btn">2</button>
                    <button class="pagination-btn">3</button>
                    <button class="pagination-btn">...</button>
                    <button class="pagination-btn">13</button>
                    <button class="pagination-btn">&raquo;</button>
                </div>
            </div>
        </div>
    </div>
</section>

{# EMPTY STATE #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Empty State</h2>
    <div class="card">
        <div class="card-body">
            <div class="empty-state">
                <div class="empty-state-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %}</div>
                <h2>No entries yet</h2>
                <p>Create your first entry to get started.</p>
                <button class="btn btn-primary"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg> Create Entry</button>
            </div>
        </div>
    </div>
</section>

{# SKELETONS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Skeleton Loaders</h2>
    <div class="grid grid-3 gap-4">
        <div class="card"><div class="card-body">
            <div class="skeleton skeleton-heading"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text"></div>
            <div class="skeleton skeleton-text-sm"></div>
        </div></div>
        <div class="skeleton skeleton-card"></div>
        <div class="card"><div class="card-body">
            <div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div>
            <div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div>
            <div class="skeleton-table-row"><div class="skeleton"></div><div class="skeleton"></div><div class="skeleton"></div></div>
        </div></div>
    </div>
</section>

{# ICONS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Icons (Lucide v1.7)</h2>
    <div class="card">
        <div class="card-body">
            <div class="flex gap-4 flex-wrap">
                {% set icons = ['home','database','image','palette','users','user','shield','settings','terminal','globe','folder','folder-plus','file','file-text','code','search','mail','bell','link','lock','key','clock','zap','tag','layers','grid','activity','heart','archive','monitor','git-branch','bar-chart','puzzle','package','store','sparkles','plus','tool','map','corner-down-right','alert-triangle','share-2','layout','arrow-left'] %}
                {% for name in icons %}
                <div class="text-center" style="width:52px">
                    <div class="flex items-center justify-center" style="width:36px;height:36px;margin:0 auto 4px;background:var(--zui-gray-50);border-radius:var(--radius);color:var(--text-secondary)">
                        {% include '@cms/partials/sidebar-icon.twig' with {icon: name} only %}
                    </div>
                    <span class="text-xs text-secondary">{{ name }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

{# SPACING & RADIUS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Spacing & Radius</h2>
    <div class="grid grid-2 gap-4">
        <div class="card">
            <div class="card-header"><h3>Spacing (4px base)</h3></div>
            <div class="card-body">
                {% set spaces = {'sp-1':'4px','sp-2':'8px','sp-3':'12px','sp-4':'16px','sp-5':'20px','sp-6':'24px','sp-8':'32px','sp-10':'40px'} %}
                {% for name, val in spaces %}
                <div class="flex items-center gap-3 mb-2">
                    <div style="width:{{ val }};height:10px;background:var(--zui-primary-200);border-radius:2px;flex-shrink:0"></div>
                    <span class="text-xs mono">--{{ name }}</span>
                    <span class="text-xs text-secondary">{{ val }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
        <div class="card">
            <div class="card-header"><h3>Border Radius</h3></div>
            <div class="card-body">
                <div class="flex gap-4 flex-wrap">
                    {% set radii = {'sm':'4px','':'6px','lg':'8px','xl':'12px','full':'pill'} %}
                    {% for suffix, val in radii %}
                    <div class="text-center">
                        <div style="width:44px;height:44px;background:var(--zui-primary-100);border:2px solid var(--zui-primary-300);border-radius:var(--radius{{ suffix ? '-' ~ suffix : '' }})"></div>
                        <span class="text-xs text-secondary mt-1 block">{{ val }}</span>
                    </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</section>

{# SHADOWS #}
<section class="mb-8">
    <h2 class="text-lg font-semibold mb-4">Shadows</h2>
    <div class="flex gap-5 flex-wrap">
        {% set shadows = {'shadow-xs':'XS','shadow-sm':'SM','shadow':'Default','shadow-md':'MD','shadow-lg':'LG'} %}
        {% for v, label in shadows %}
        <div class="text-center">
            <div style="width:96px;height:72px;background:var(--bg-surface);border-radius:var(--radius-lg);box-shadow:var(--{{ v }})"></div>
            <span class="text-xs text-secondary mt-2 block">{{ label }}</span>
        </div>
        {% endfor %}
    </div>
</section>

{% endblock %}
