{% extends "@cms/layouts/cms.twig" %}

{% block title %}Translation Progress{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> System / <a href="{{ admin_url('system/translations') }}">Translations</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Progress
</div>

<div class="page-header">
    <h1>Translation Progress</h1>
</div>

{% if locales|length > 0 %}

{# Progress Overview #}
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: var(--sp-4); margin-bottom: var(--sp-5);">
    {% for locale in locales %}
    {% set p = progress[locale] %}
    <div class="card">
        <div class="card-body">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--sp-2);">
                <strong style="font-size: 1.1rem;">{{ locale }}</strong>
                <span style="font-size: 1.1rem; font-weight: 700; color: {{ p.percentage >= 90 ? 'var(--zui-success-600)' : (p.percentage >= 50 ? 'var(--zui-warning-600)' : 'var(--zui-error-600)') }};">{{ p.percentage }}%</span>
            </div>
            <div style="background: var(--bg-subdued); border-radius: 4px; height: 8px; overflow: hidden; margin-bottom: var(--sp-2);">
                <div style="background: {{ p.percentage >= 90 ? 'var(--zui-success-600)' : (p.percentage >= 50 ? 'var(--zui-warning-600)' : 'var(--zui-error-600)') }}; height: 100%; width: {{ p.percentage }}%; transition: width 0.3s;"></div>
            </div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">
                {{ p.translated }}/{{ p.total }} keys
                {% if p.missing > 0 %}
                    &mdash; <span style="color: var(--zui-error-600);">{{ p.missing }} missing</span>
                {% endif %}
            </div>
            {% if locale == defaultLocale %}
                <div style="margin-top: var(--sp-2);"><span class="badge">Reference Locale</span></div>
            {% endif %}
        </div>
    </div>
    {% endfor %}
</div>

{# Missing Keys Detail #}
{% set hasMissing = false %}
{% for locale, groups in missing %}
    {% if groups|length > 0 %}{% set hasMissing = true %}{% endif %}
{% endfor %}

{% if hasMissing %}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Missing Translations</h3></div>
    <div class="card-body" style="padding: 0;">
        {% for locale, groups in missing %}
            {% if groups|length > 0 %}
            <details style="border-bottom: 1px solid var(--border);">
                <summary style="padding: var(--sp-3) var(--sp-4); cursor: pointer; font-weight: 600;">
                    {{ locale }}
                    <span class="badge" style="background: var(--zui-error-600); color: white; margin-left: var(--sp-2);">
                        {% set totalMissing = 0 %}
                        {% for group, keys in groups %}{% set totalMissing = totalMissing + keys|length %}{% endfor %}
                        {{ totalMissing }} missing
                    </span>
                </summary>
                <div style="padding: 0 var(--sp-4) var(--sp-4);">
                    {% for group, keys in groups %}
                    <div style="margin-bottom: var(--sp-3);">
                        <strong>{{ group }}</strong> ({{ keys|length }} missing)
                        <div style="margin-top: var(--sp-1);">
                            {% for key in keys %}
                            <code style="display: inline-block; margin: 2px 4px 2px 0; padding: 2px 6px; font-size: 0.8rem; background: var(--bg-subdued); border-radius: 3px;">{{ key }}</code>
                            {% endfor %}
                        </div>
                        <div style="margin-top: var(--sp-2);">
                            <a href="{{ admin_url('system/translations?locale=' ~ locale ~ '&group=' ~ group) }}" class="btn btn-outline btn-sm">Edit</a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </details>
            {% endif %}
        {% endfor %}
    </div>
</div>
{% endif %}

{% else %}
<div class="empty-state">
    <h3>No locales found</h3>
    <p>Create locale directories in <code>lang/</code> to track translation progress.</p>
</div>
{% endif %}

{% endblock %}
