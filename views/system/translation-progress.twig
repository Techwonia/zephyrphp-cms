{% extends "@cms/layouts/cms.twig" %}

{% block title %}Translation Progress{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / System / <a href="/cms/system/translations">Translations</a> / Progress
</div>

<div class="page-header">
    <h1>Translation Progress</h1>
</div>

{% if locales|length > 0 %}

{# Progress Overview #}
<div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: var(--space-400); margin-bottom: var(--space-500);">
    {% for locale in locales %}
    {% set p = progress[locale] %}
    <div class="card">
        <div class="card-body">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-200);">
                <strong style="font-size: 1.1rem;">{{ locale }}</strong>
                <span style="font-size: 1.1rem; font-weight: 700; color: {{ p.percentage >= 90 ? 'var(--success)' : (p.percentage >= 50 ? 'var(--warning)' : 'var(--danger)') }};">{{ p.percentage }}%</span>
            </div>
            <div style="background: var(--bg-secondary); border-radius: 4px; height: 8px; overflow: hidden; margin-bottom: var(--space-200);">
                <div style="background: {{ p.percentage >= 90 ? 'var(--success)' : (p.percentage >= 50 ? 'var(--warning)' : 'var(--danger)') }}; height: 100%; width: {{ p.percentage }}%; transition: width 0.3s;"></div>
            </div>
            <div style="font-size: 0.8rem; color: var(--text-secondary);">
                {{ p.translated }}/{{ p.total }} keys
                {% if p.missing > 0 %}
                    &mdash; <span style="color: var(--danger);">{{ p.missing }} missing</span>
                {% endif %}
            </div>
            {% if locale == defaultLocale %}
                <div style="margin-top: var(--space-200);"><span class="badge">Reference Locale</span></div>
            {% endif %}
        </div>
    </div>
    {% endfor %}
</div>

{# Missing Keys Detail #}
{% set hasMissing = false %}
{% for locale, groups in missing %}
    {% if groups|length > 0 %}{% set hasMissing = true %}{% endif %}
{% endfor %}

{% if hasMissing %}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Missing Translations</h3></div>
    <div class="card-body" style="padding: 0;">
        {% for locale, groups in missing %}
            {% if groups|length > 0 %}
            <details style="border-bottom: 1px solid var(--border-color);">
                <summary style="padding: var(--space-300) var(--space-400); cursor: pointer; font-weight: 600;">
                    {{ locale }}
                    <span class="badge" style="background: var(--danger); color: white; margin-left: var(--space-200);">
                        {% set totalMissing = 0 %}
                        {% for group, keys in groups %}{% set totalMissing = totalMissing + keys|length %}{% endfor %}
                        {{ totalMissing }} missing
                    </span>
                </summary>
                <div style="padding: 0 var(--space-400) var(--space-400);">
                    {% for group, keys in groups %}
                    <div style="margin-bottom: var(--space-300);">
                        <strong>{{ group }}</strong> ({{ keys|length }} missing)
                        <div style="margin-top: var(--space-100);">
                            {% for key in keys %}
                            <code style="display: inline-block; margin: 2px 4px 2px 0; padding: 2px 6px; font-size: 0.8rem; background: var(--bg-secondary); border-radius: 3px;">{{ key }}</code>
                            {% endfor %}
                        </div>
                        <div style="margin-top: var(--space-200);">
                            <a href="/cms/system/translations?locale={{ locale }}&group={{ group }}" class="btn btn-outline btn-sm">Edit</a>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </details>
            {% endif %}
        {% endfor %}
    </div>
</div>
{% endif %}

{% else %}
<div class="empty-state">
    <h3>No locales found</h3>
    <p>Create locale directories in <code>lang/</code> to track translation progress.</p>
</div>
{% endif %}

{% endblock %}
