{% extends "@cms/layouts/cms.twig" %}

{% block title %}Scheduled Tasks{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / System / Scheduled Tasks
</div>

<div class="page-header">
    <h1>Scheduled Tasks</h1>
</div>

{# Create Task #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Add New Task</h3></div>
    <div class="card-body">
        <form method="POST" action="/cms/system/scheduled-tasks">
            {{ csrf_field() | raw }}
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-300); margin-bottom: var(--space-300);">
                <div>
                    <label class="form-label">Task Name</label>
                    <input type="text" name="name" class="form-control" placeholder="e.g. Publish Scheduled Posts" required>
                </div>
                <div>
                    <label class="form-label">Schedule (Cron)</label>
                    <input type="text" name="schedule" class="form-control" placeholder="e.g. */5 * * * *" required>
                </div>
            </div>
            <div style="margin-bottom: var(--space-300);">
                <label class="form-label">Command</label>
                <input type="text" name="command" class="form-control" placeholder="e.g. php craftsman schedule:run" required>
                <small style="color: var(--text-secondary);">Only <code>php craftsman</code> commands are allowed for security.</small>
            </div>
            <div style="margin-bottom: var(--space-300);">
                <label class="form-label">Description (optional)</label>
                <input type="text" name="description" class="form-control" placeholder="Brief description of what this task does">
            </div>
            <button type="submit" class="btn btn-primary">Create Task</button>
        </form>
    </div>
</div>

{# Common Schedules Reference #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Common Schedules</h3></div>
    <div class="card-body" style="padding: 0;">
        <table class="data-table">
            <tbody>
                <tr><td style="font-family: monospace; width: 180px;">* * * * *</td><td>Every minute</td></tr>
                <tr><td style="font-family: monospace;">*/5 * * * *</td><td>Every 5 minutes</td></tr>
                <tr><td style="font-family: monospace;">*/15 * * * *</td><td>Every 15 minutes</td></tr>
                <tr><td style="font-family: monospace;">0 * * * *</td><td>Every hour</td></tr>
                <tr><td style="font-family: monospace;">0 0 * * *</td><td>Daily at midnight</td></tr>
                <tr><td style="font-family: monospace;">0 0 * * 0</td><td>Weekly on Sunday</td></tr>
                <tr><td style="font-family: monospace;">0 0 1 * *</td><td>Monthly on the 1st</td></tr>
            </tbody>
        </table>
    </div>
</div>

{# Task List #}
{% if tasks|length > 0 %}
<div class="card">
    <div class="card-header"><h3 style="margin:0; font-size:1rem;">Registered Tasks</h3></div>
    <div class="card-body" style="padding: 0;">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Command</th>
                        <th>Schedule</th>
                        <th>Status</th>
                        <th>Last Run</th>
                        <th>Next Run</th>
                        <th style="width: 200px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for task in tasks %}
                    <tr>
                        <td>
                            <strong>{{ task.name }}</strong>
                            {% if task.description %}
                                <br><small style="color: var(--text-secondary);">{{ task.description }}</small>
                            {% endif %}
                        </td>
                        <td style="font-family: monospace; font-size: 0.85rem;">{{ task.command }}</td>
                        <td style="font-family: monospace; font-size: 0.85rem;">{{ task.schedule }}</td>
                        <td>
                            {% if not task.is_active %}
                                <span class="badge" style="background: var(--text-secondary); color: white;">Disabled</span>
                            {% elseif task.last_run_status == 'success' %}
                                <span class="badge" style="background: var(--success); color: white;">OK</span>
                            {% elseif task.last_run_status == 'failed' %}
                                <span class="badge" style="background: var(--danger); color: white;">Failed</span>
                            {% else %}
                                <span class="badge">Pending</span>
                            {% endif %}
                        </td>
                        <td style="font-size: 0.85rem; color: var(--text-secondary);">
                            {% if task.last_run_at %}
                                {{ task.last_run_at }}
                                {% if task.last_run_duration_ms %}
                                    <br><small>{{ task.last_run_duration_ms }}ms</small>
                                {% endif %}
                            {% else %}
                                Never
                            {% endif %}
                        </td>
                        <td style="font-size: 0.85rem; color: var(--text-secondary);">
                            {% if task.is_active %}
                                {{ task.next_run }}
                                {% if task.is_due %}
                                    <br><span class="badge" style="font-size: 0.65rem;">Due</span>
                                {% endif %}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            <div style="display: flex; gap: var(--space-200); flex-wrap: wrap;">
                                <form method="POST" action="/cms/system/scheduled-tasks/{{ task.id }}/run" style="display: inline;">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="btn btn-outline btn-sm">Run</button>
                                </form>
                                <form method="POST" action="/cms/system/scheduled-tasks/{{ task.id }}/toggle" style="display: inline;">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="btn btn-outline btn-sm">{{ task.is_active ? 'Disable' : 'Enable' }}</button>
                                </form>
                                <form method="POST" action="/cms/system/scheduled-tasks/{{ task.id }}/delete" style="display: inline;" onsubmit="return confirm('Delete this task?')">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {% if task.last_run_output %}
                    <tr>
                        <td colspan="7" style="background: var(--bg-secondary); padding: var(--space-300);">
                            <details>
                                <summary style="cursor: pointer; font-size: 0.85rem; color: var(--text-secondary);">Last Output</summary>
                                <pre style="margin-top: var(--space-200); font-size: 0.8rem; white-space: pre-wrap; max-height: 200px; overflow-y: auto;">{{ task.last_run_output }}</pre>
                            </details>
                        </td>
                    </tr>
                    {% endif %}
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<div style="margin-top: var(--space-400); padding: var(--space-400); background: var(--bg-secondary); border-radius: var(--radius-200);">
    <h4 style="margin: 0 0 var(--space-200);">Setup Cron</h4>
    <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: var(--space-200);">
        Add this entry to your server's crontab to run scheduled tasks automatically:
    </p>
    <code style="display: block; padding: var(--space-300); background: var(--bg-primary); border-radius: var(--radius-100); font-size: 0.85rem;">* * * * * cd /path/to/project && php craftsman schedule:run >> /dev/null 2>&1</code>
</div>

{% else %}
<div class="empty-state">
    <h3>No scheduled tasks</h3>
    <p>Create a task above to get started.</p>
</div>
{% endif %}

{% endblock %}
