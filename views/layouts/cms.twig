    <script nonce="{{ csp_nonce() }}">
    document.addEventListener('DOMContentLoaded', function() {
        var activityBar = document.getElementById('activityBar');
        var sidebarPanel = document.getElementById('sidebarPanel');
        var panelTitle = document.getElementById('panelTitle');
        var panelClose = document.getElementById('panelClose');
        var cmsMain = document.getElementById('cmsMain');
        var overlay = document.getElementById('cmsOverlay');
        var mobileToggle = document.getElementById('mobileToggle');
        var activePanel = null;

        // Section labels for panel title
        var sectionLabels = {};
        {% for section in sidebar_sections %}
            {% if section.items|length > 1 and section.id != 'footer' %}
            sectionLabels['{{ section.id }}'] = '{{ section.label }}';
            {% endif %}
        {% endfor %}

        // Activity bar panel toggle buttons
        activityBar.querySelectorAll('[data-panel]').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var panelId = btn.dataset.panel;

                if (activePanel === panelId) {
                    closePanel();
                    return;
                }

                // Hide all panel lists
                sidebarPanel.querySelectorAll('.sidebar-panel-nav ul').forEach(function(ul) {
                    ul.style.display = 'none';
                });

                // Show target panel list
                var targetList = document.getElementById('panel-' + panelId);
                if (targetList) {
                    targetList.style.display = 'block';
                }

                // Update title
                panelTitle.textContent = sectionLabels[panelId] || '';

                // Highlight active button
                activityBar.querySelectorAll('[data-panel]').forEach(function(b) {
                    b.classList.remove('active');
                });
                btn.classList.add('active');

                // Re-add active class to single-item links that match current path
                activityBar.querySelectorAll('a.ab-item[data-tooltip]').forEach(function(a) {
                    // Handled by server-side active class, no JS needed
                });

                // Open panel
                sidebarPanel.classList.add('open');
                cmsMain.classList.add('panel-open');
                activePanel = panelId;
            });
        });

        function closePanel() {
            sidebarPanel.classList.remove('open');
            cmsMain.classList.remove('panel-open');

            // Remove active from panel buttons, but keep for current section
            activityBar.querySelectorAll('[data-panel]').forEach(function(b) {
                // Check if any item in this section is active (on current page)
                var panelId = b.dataset.panel;
                var panelList = document.getElementById('panel-' + panelId);
                if (panelList && panelList.querySelector('a.active')) {
                    b.classList.add('active');
                } else {
                    b.classList.remove('active');
                }
            });

            activePanel = null;
        }

        // Close button
        panelClose.addEventListener('click', closePanel);

        // Mobile toggle
        if (mobileToggle) {
            mobileToggle.addEventListener('click', function() {
                activityBar.classList.toggle('open');
                overlay.classList.toggle('active');
            });
        }

        // Overlay click closes everything
        if (overlay) {
            overlay.addEventListener('click', function() {
                activityBar.classList.remove('open');
                sidebarPanel.classList.remove('open');
                cmsMain.classList.remove('panel-open');
                overlay.classList.remove('active');
                activePanel = null;
            });
        }

        // Profile dropdown
        var profileDropdown = document.getElementById('profileDropdown');
        var profileTrigger = document.getElementById('profileTrigger');
        if (profileTrigger) {
            profileTrigger.addEventListener('click', function(e) {
                e.stopPropagation();
                profileDropdown.classList.toggle('open');
            });
        }
        document.addEventListener('click', function(e) {
            if (profileDropdown && !profileDropdown.contains(e.target)) {
                profileDropdown.classList.remove('open');
            }
        });

        // Auto-open panel for current section on page load (without animation)
        var currentSectionBtn = activityBar.querySelector('[data-panel].active');
        if (currentSectionBtn) {
            sidebarPanel.style.transition = 'none';
            cmsMain.style.transition = 'none';
            currentSectionBtn.click();
            // Re-enable transitions after paint
            requestAnimationFrame(function() {
                requestAnimationFrame(function() {
                    sidebarPanel.style.transition = '';
                    cmsMain.style.transition = '';
                });
            });
        }

        // Tab switching
        document.querySelectorAll('.tab-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var target = btn.dataset.tab;
                document.querySelectorAll('.tab-btn').forEach(function(b) { b.classList.remove('active'); });
                document.querySelectorAll('.tab-panel').forEach(function(p) { p.classList.remove('active'); });
                btn.classList.add('active');
                document.getElementById(target).classList.add('active');
            });
        });

        // Hash-based tab activation
        if (window.location.hash) {
            var hashTab = document.querySelector('[data-tab="tab-' + window.location.hash.slice(1) + '"]');
            if (hashTab) hashTab.click();
        }

        // Confirm delete forms
        document.querySelectorAll('.confirm-delete').forEach(function(form) {
            form.addEventListener('submit', function(e) {
                if (!confirm(form.dataset.message || 'Are you sure?')) {
                    e.preventDefault();
                }
            });
        });

        // ── Global Search ──
        (function() {
            var input = document.getElementById('globalSearchInput');
            var resultsBox = document.getElementById('globalSearchResults');
            if (!input || !resultsBox) return;

            var debounceTimer = null;
            var currentQuery = '';

            input.addEventListener('input', function() {
                var q = input.value.trim();
                currentQuery = q;
                clearTimeout(debounceTimer);

                if (q.length < 2) {
                    resultsBox.style.display = 'none';
                    resultsBox.innerHTML = '';
                    return;
                }

                debounceTimer = setTimeout(function() {
                    fetch('/admin/search?q=' + encodeURIComponent(q), {
                        headers: { 'Accept': 'application/json' }
                    })
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (input.value.trim() !== currentQuery) return;
                        renderSearchResults(data.results || []);
                    })
                    .catch(function() {
                        resultsBox.style.display = 'none';
                    });
                }, 250);
            });

            input.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    resultsBox.style.display = 'none';
                    input.blur();
                }
                // Arrow navigation
                if (e.key === 'ArrowDown' || e.key === 'ArrowUp') {
                    e.preventDefault();
                    var items = resultsBox.querySelectorAll('.gs-item');
                    if (!items.length) return;
                    var active = resultsBox.querySelector('.gs-item.active');
                    var idx = active ? Array.from(items).indexOf(active) : -1;
                    if (active) active.classList.remove('active');
                    if (e.key === 'ArrowDown') idx = (idx + 1) % items.length;
                    else idx = idx <= 0 ? items.length - 1 : idx - 1;
                    items[idx].classList.add('active');
                    items[idx].scrollIntoView({ block: 'nearest' });
                }
                if (e.key === 'Enter') {
                    var active = resultsBox.querySelector('.gs-item.active');
                    if (active) {
                        e.preventDefault();
                        window.location.href = active.getAttribute('href');
                    }
                }
            });

            // Ctrl+K / Cmd+K shortcut
            document.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
                    e.preventDefault();
                    input.focus();
                    input.select();
                }
            });

            // Close on click outside
            document.addEventListener('click', function(e) {
                if (!input.contains(e.target) && !resultsBox.contains(e.target)) {
                    resultsBox.style.display = 'none';
                }
            });

            function renderSearchResults(results) {
                if (!results.length) {
                    resultsBox.innerHTML = '<div style="padding: 12px 16px; color: var(--text-secondary); font-size: var(--font-sm);">No results found.</div>';
                    resultsBox.style.display = 'block';
                    return;
                }

                var typeLabels = { entry: 'Entries', media: 'Media', collection: 'Collections' };
                var grouped = {};
                results.forEach(function(r) {
                    if (!grouped[r.type]) grouped[r.type] = [];
                    grouped[r.type].push(r);
                });

                var html = '';
                for (var type in grouped) {
                    html += '<div style="padding: 6px 16px; font-size: 0.7rem; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em; background: var(--bg-subdued);">' + (typeLabels[type] || type) + '</div>';
                    grouped[type].forEach(function(r) {
                        html += '<a href="' + escHtml(r.url) + '" class="gs-item" style="display: flex; align-items: center; gap: 10px; padding: 8px 16px; text-decoration: none; color: var(--text); font-size: var(--font-sm); cursor: pointer; transition: background 0.1s;">' +
                            '<span style="font-weight: 500;">' + escHtml(r.title) + '</span>' +
                            '<span style="color: var(--text-secondary); font-size: 0.75rem; margin-left: auto;">' + escHtml(r.meta) + '</span>' +
                            '</a>';
                    });
                }

                resultsBox.innerHTML = html;
                resultsBox.style.display = 'block';

                // Hover effect
                resultsBox.querySelectorAll('.gs-item').forEach(function(item) {
                    item.addEventListener('mouseenter', function() {
                        resultsBox.querySelectorAll('.gs-item.active').forEach(function(a) { a.classList.remove('active'); });
                        item.classList.add('active');
                    });
                });
            }

            function escHtml(str) {
                var d = document.createElement('div');
                d.textContent = str || '';
                return d.innerHTML;
            }
        })();
    });
    </script>
