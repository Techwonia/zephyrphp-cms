    <script nonce="{{ csp_nonce() }}">
    (function() {
        var quickNavOverlay = document.getElementById('kbQuickNav');
        var quickNavInput = document.getElementById('kbQuickNavInput');
        var quickNavList = document.getElementById('kbQuickNavList');
        var helpOverlay = document.getElementById('kbShortcutsHelp');
        var helpCloseBtn = document.getElementById('kbHelpClose');

        // Set correct hrefs on quick nav items based on adminUrl
        quickNavList.querySelectorAll('.kb-quicknav-item').forEach(function(item) {
            item.href = adminUrl + (item.dataset.path || '');
        });

        // ── Overlay helpers ──
        function openOverlay(overlay) {
            overlay.classList.add('active');
            // Trap focus
            var focusable = overlay.querySelector('input, button, a');
            if (focusable) focusable.focus();
        }

        function closeOverlay(overlay) {
            overlay.classList.remove('active');
        }

        function closeAllOverlays() {
            closeOverlay(quickNavOverlay);
            closeOverlay(helpOverlay);
        }

        function isAnyOverlayOpen() {
            return quickNavOverlay.classList.contains('active') || helpOverlay.classList.contains('active');
        }

        // ── Quick Nav ──
        function toggleQuickNav() {
            if (quickNavOverlay.classList.contains('active')) {
                closeOverlay(quickNavOverlay);
            } else {
                closeAllOverlays();
                quickNavInput.value = '';
                filterQuickNav('');
                openOverlay(quickNavOverlay);
                quickNavInput.focus();
            }
        }

        function filterQuickNav(query) {
            var items = quickNavList.querySelectorAll('li');
            var q = query.toLowerCase().trim();
            var firstVisible = null;
            items.forEach(function(li) {
                var link = li.querySelector('.kb-quicknav-item');
                var label = link.querySelector('.kb-nav-label').textContent.toLowerCase();
                var show = !q || label.indexOf(q) !== -1;
                li.style.display = show ? '' : 'none';
                link.classList.remove('active');
                if (show && !firstVisible) {
                    firstVisible = link;
                }
            });
            if (firstVisible) firstVisible.classList.add('active');
        }

        quickNavInput.addEventListener('input', function() {
            filterQuickNav(this.value);
        });

        quickNavInput.addEventListener('keydown', function(e) {
            var items = Array.from(quickNavList.querySelectorAll('li')).filter(function(li) {
                return li.style.display !== 'none';
            });
            var links = items.map(function(li) { return li.querySelector('.kb-quicknav-item'); });
            var activeIdx = -1;
            links.forEach(function(link, i) {
                if (link.classList.contains('active')) activeIdx = i;
            });

            if (e.key === 'ArrowDown') {
                e.preventDefault();
                links.forEach(function(l) { l.classList.remove('active'); });
                activeIdx = (activeIdx + 1) % links.length;
                links[activeIdx].classList.add('active');
                links[activeIdx].scrollIntoView({ block: 'nearest' });
            } else if (e.key === 'ArrowUp') {
                e.preventDefault();
                links.forEach(function(l) { l.classList.remove('active'); });
                activeIdx = activeIdx <= 0 ? links.length - 1 : activeIdx - 1;
                links[activeIdx].classList.add('active');
                links[activeIdx].scrollIntoView({ block: 'nearest' });
            } else if (e.key === 'Enter') {
                e.preventDefault();
                var active = quickNavList.querySelector('.kb-quicknav-item.active');
                if (active) window.location.href = active.href;
            }
        });

        // Close on click outside modal
        quickNavOverlay.addEventListener('click', function(e) {
            if (e.target === quickNavOverlay) closeOverlay(quickNavOverlay);
        });

        // ── Shortcuts Help ──
        function toggleShortcutsHelp() {
            if (helpOverlay.classList.contains('active')) {
                closeOverlay(helpOverlay);
            } else {
                closeAllOverlays();
                openOverlay(helpOverlay);
            }
        }

        helpCloseBtn.addEventListener('click', function() {
            closeOverlay(helpOverlay);
        });

        helpOverlay.addEventListener('click', function(e) {
            if (e.target === helpOverlay) closeOverlay(helpOverlay);
        });

        // ── Key Sequence System ──
        var keySequence = '';
        var sequenceTimer = null;
        var SEQUENCE_TIMEOUT = 1000;

        document.addEventListener('keydown', function(e) {
            var tag = e.target.tagName;
            var inInput = (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT');
            var ctrl = e.ctrlKey || e.metaKey;
            var shift = e.shiftKey;
            var key = e.key.toLowerCase();

            // Esc — always works, close overlays first
            if (key === 'escape') {
                if (isAnyOverlayOpen()) {
                    closeAllOverlays();
                    e.preventDefault();
                    return;
                }
                // Let Esc propagate for other uses (close search results, etc.)
                return;
            }

            // Ctrl+K — Quick nav (override existing handler when overlay should open)
            if (ctrl && key === 'k') {
                e.preventDefault();
                // If the global search input exists and no overlay is open, focus it
                // But also provide the quick nav as a toggle
                var globalSearch = document.getElementById('globalSearchInput');
                if (globalSearch && !isAnyOverlayOpen()) {
                    globalSearch.focus();
                    globalSearch.select();
                } else {
                    toggleQuickNav();
                }
                return;
            }

            // Ctrl+/ — Shortcuts help
            if (ctrl && key === '/') {
                e.preventDefault();
                toggleShortcutsHelp();
                return;
            }

            // Don't process modifier shortcuts or sequences while typing in form fields
            if (inInput && !ctrl) {
                keySequence = '';
                return;
            }

            // Ctrl+S — Save (form submit)
            if (ctrl && !shift && key === 's') {
                e.preventDefault();
                var form = document.querySelector('form[method="post"], form[method="POST"]');
                if (form) {
                    // Skip delete/duplicate forms, find the main edit form
                    var forms = document.querySelectorAll('form[method="post"], form[method="POST"]');
                    for (var i = 0; i < forms.length; i++) {
                        if (!forms[i].classList.contains('confirm-delete') &&
                            !forms[i].action.match(/\/(delete|duplicate|logout|workflow)\b/)) {
                            forms[i].submit();
                            break;
                        }
                    }
                }
                return;
            }

            // Ctrl+Shift+P — Publish
            if (ctrl && shift && key === 'p') {
                e.preventDefault();
                var statusSelect = document.querySelector('select[name="status"]');
                if (statusSelect) {
                    statusSelect.value = 'published';
                    var form = statusSelect.closest('form');
                    if (form) form.submit();
                }
                return;
            }

            // Ctrl+Shift+D — Save as Draft
            if (ctrl && shift && key === 'd') {
                e.preventDefault();
                var statusSelect = document.querySelector('select[name="status"]');
                if (statusSelect) {
                    statusSelect.value = 'draft';
                    var form = statusSelect.closest('form');
                    if (form) form.submit();
                }
                return;
            }

            // Don't process G-sequences when overlays are open or in inputs
            if (isAnyOverlayOpen() || inInput) return;

            // G-key sequences for navigation
            clearTimeout(sequenceTimer);
            keySequence += key;
            sequenceTimer = setTimeout(function() { keySequence = ''; }, SEQUENCE_TIMEOUT);

            var navMap = {
                'gd': '',
                'gc': '/collections',
                'gm': '/media',
                'gu': '/users',
                'gs': '/settings/system'
            };

            if (navMap.hasOwnProperty(keySequence)) {
                window.location.href = adminUrl + navMap[keySequence];
                keySequence = '';
            }

            // Reset if sequence is too long (no match possible)
            if (keySequence.length > 2) {
                keySequence = key;
            }
        });
    })();
    </script>

    {# Quill Rich Text Editor — standalone UMD build #}
    <script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
    <script nonce="{{ csp_nonce() }}">
    (function() {
        if (typeof Quill === 'undefined') return;

        var textareas = document.querySelectorAll('textarea.richtext-editor');
        if (!textareas.length) return;

        var toolbarOptions = [
            [{ 'header': [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'list': 'ordered'}, { 'list': 'bullet' }],
            ['blockquote', 'code-block'],
            ['link', 'image', 'video'],
            [{ 'align': [] }],
            ['clean']
        ];

        var mediaUrl = '{{ admin_url("media/browse") }}';
        var uploadUrl = '{{ admin_url("media/upload") }}';
        var csrfInput = document.querySelector('input[name="csrf_token"], input[name="_token"]');
        var csrfVal = csrfInput ? csrfInput.value : '';

        // Media browser for richtext image/video insertion
        function openRichtextMediaBrowser(filter, onSelect) {
            var modal = document.createElement('div');
            modal.className = 'media-modal-overlay';
            modal.innerHTML = '<div class="media-modal">'
                + '<div class="media-modal-header"><h3>Select from Media Library</h3><button type="button" class="media-modal-close">&times;</button></div>'
                + '<div class="media-modal-toolbar">'
                + '<div class="media-modal-search"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input type="text" class="media-search-input" placeholder="Search files..."></div>'
                + '<div class="media-modal-filters">'
                + '<button type="button" class="media-filter-btn' + (filter === 'all' ? ' active' : '') + '" data-filter="all">All</button>'
                + '<button type="button" class="media-filter-btn' + (filter === 'images' ? ' active' : '') + '" data-filter="images">Images</button>'
                + '<button type="button" class="media-filter-btn' + (filter === 'video' ? ' active' : '') + '" data-filter="video">Video</button>'
                + '</div></div>'
                + '<div class="media-modal-body"><p style="text-align:center;padding:40px;color:#616161">Loading...</p></div>'
                + '<div class="media-modal-upload-bar">'
                + '<label class="media-upload-label"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload<input type="file" class="media-upload-input" multiple style="display:none"'
                + (filter === 'images' ? ' accept="image/*"' : filter === 'video' ? ' accept="video/*"' : '')
                + '></label><span class="media-upload-status"></span></div></div>';
            document.body.appendChild(modal);

            var currentFilter = filter || 'all';
            var currentSearch = '';

            modal.querySelector('.media-modal-close').addEventListener('click', function() { modal.remove(); });
            modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
            document.addEventListener('keydown', function onEsc(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onEsc); } });

            function loadItems() {
                var body = modal.querySelector('.media-modal-body');
                body.innerHTML = '<p style="text-align:center;padding:40px;color:#616161">Loading...</p>';
                fetch(mediaUrl + '?filter=' + currentFilter + '&per_page=36' + (currentSearch ? '&search=' + encodeURIComponent(currentSearch) : ''))
                    .then(function(r) { return r.json(); })
                    .then(function(data) {
                        if (!data.data || !data.data.length) {
                            body.innerHTML = '<div style="text-align:center;padding:60px"><p style="font-weight:600">No files found</p><p style="color:#616161;font-size:13px">Upload using the button below</p></div>';
                            return;
                        }
                        var html = '<div class="media-modal-grid">';
                        data.data.forEach(function(item) {
                            var thumb = item.is_image ? '<img src="' + (item.thumbnail || item.url) + '" loading="lazy">' : '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#666"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>';
                            html += '<div class="media-modal-item" data-url="' + item.url + '"><div class="media-modal-thumb">' + thumb + '</div><div class="media-modal-name">' + item.name + '</div></div>';
                        });
                        body.innerHTML = html + '</div>';
                        body.querySelectorAll('.media-modal-item').forEach(function(el) {
                            el.addEventListener('click', function() {
                                onSelect(el.dataset.url);
                                modal.remove();
                            });
                        });
                    });
            }

            var searchTimer;
            modal.querySelector('.media-search-input').addEventListener('input', function() {
                clearTimeout(searchTimer); var v = this.value;
                searchTimer = setTimeout(function() { currentSearch = v; loadItems(); }, 300);
            });
            modal.querySelectorAll('.media-filter-btn').forEach(function(btn) {
                btn.addEventListener('click', function() {
                    modal.querySelectorAll('.media-filter-btn').forEach(function(b) { b.classList.remove('active'); });
                    btn.classList.add('active');
                    currentFilter = btn.dataset.filter;
                    loadItems();
                });
            });
            // Upload
            modal.querySelector('.media-upload-input').addEventListener('change', function() {
                var files = this.files; if (!files.length) return;
                var status = modal.querySelector('.media-upload-status');
                status.textContent = 'Uploading...';
                var lastUrl = '';
                var done = 0;
                Array.from(files).forEach(function(f) {
                    var fd = new FormData(); fd.append('file', f); fd.append('csrf_token', csrfVal);
                    var xhr = new XMLHttpRequest();
                    xhr.open('POST', uploadUrl, true);
                    xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                    xhr.onload = function() {
                        done++;
                        try { var r = JSON.parse(xhr.responseText); if (r.path) lastUrl = '/' + r.path; } catch(e) {}
                        if (done >= files.length) {
                            if (lastUrl && files.length === 1) {
                                onSelect(lastUrl);
                                modal.remove();
                            } else {
                                status.textContent = 'Uploaded!';
                                loadItems();
                            }
                        }
                    };
                    xhr.onerror = function() { done++; status.textContent = 'Error'; };
                    xhr.send(fd);
                });
            });

            loadItems();
        }

        textareas.forEach(function(textarea) {
            textarea.style.display = 'none';

            // Create wrapper
            var wrap = document.createElement('div');
            wrap.className = 'ql-wrap';

            // Create toolbar container
            var toolbarDiv = document.createElement('div');
            toolbarDiv.className = 'ql-toolbar-container';

            // Create editor container
            var editorDiv = document.createElement('div');
            editorDiv.innerHTML = textarea.value || '';

            // Create source textarea
            var sourceArea = document.createElement('textarea');
            sourceArea.className = 'ql-source-area';

            // Create footer
            var footer = document.createElement('div');
            footer.className = 'ql-footer';
            footer.innerHTML = '<span class="ql-word-count">0 words</span><button type="button" class="ql-source-btn">&lt;/&gt; HTML</button>';

            wrap.appendChild(toolbarDiv);
            wrap.appendChild(editorDiv);
            wrap.appendChild(sourceArea);
            wrap.appendChild(footer);
            textarea.parentNode.insertBefore(wrap, textarea.nextSibling);

            // Initialize Quill
            var quill = new Quill(editorDiv, {
                theme: 'snow',
                modules: {
                    toolbar: {
                        container: toolbarOptions,
                        handlers: {
                            image: function() {
                                var q = this.quill;
                                openRichtextMediaBrowser('images', function(url) {
                                    var range = q.getSelection(true);
                                    q.insertEmbed(range.index, 'image', url);
                                    q.setSelection(range.index + 1);
                                });
                            },
                            video: function() {
                                var q = this.quill;
                                openRichtextMediaBrowser('video', function(url) {
                                    var range = q.getSelection(true);
                                    q.insertEmbed(range.index, 'video', url);
                                    q.setSelection(range.index + 1);
                                });
                            }
                        }
                    }
                },
                placeholder: textarea.placeholder || 'Write your content...',
            });

            // Move Quill's generated toolbar into our toolbar container
            var generatedToolbar = wrap.querySelector('.ql-toolbar');
            if (generatedToolbar && generatedToolbar !== toolbarDiv) {
                toolbarDiv.appendChild(generatedToolbar);
            }

            // Sync content to hidden textarea on change
            quill.on('text-change', function() {
                var html = quill.getSemanticHTML();
                textarea.value = html;
                // Update word count
                var text = quill.getText().trim();
                var words = text ? text.split(/\s+/).length : 0;
                footer.querySelector('.ql-word-count').textContent = words + ' word' + (words !== 1 ? 's' : '');
            });

            // Initial word count
            var initText = quill.getText().trim();
            var initWords = initText ? initText.split(/\s+/).length : 0;
            footer.querySelector('.ql-word-count').textContent = initWords + ' word' + (initWords !== 1 ? 's' : '');

            // Source toggle
            var isSource = false;
            var sourceBtn = footer.querySelector('.ql-source-btn');
            var qlContainer = wrap.querySelector('.ql-container');
            sourceBtn.addEventListener('click', function() {
                isSource = !isSource;
                if (isSource) {
                    sourceArea.value = quill.getSemanticHTML();
                    sourceArea.classList.add('active');
                    if (qlContainer) qlContainer.classList.add('ql-container-hidden');
                    sourceBtn.classList.add('active');
                } else {
                    quill.clipboard.dangerouslyPasteHTML(sourceArea.value);
                    textarea.value = sourceArea.value;
                    sourceArea.classList.remove('active');
                    if (qlContainer) qlContainer.classList.remove('ql-container-hidden');
                    sourceBtn.classList.remove('active');
                }
            });
        });
    })();
    </script>

