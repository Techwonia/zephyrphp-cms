{% extends "@cms/layouts/cms.twig" %}

{% block title %}Languages{% endblock %}

{% block content %}
<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--sp-6);">
    <h1 class="p-0">Languages</h1>
</div>

{# Add Language Form #}
<div class="card" class="mb-6">
    <div style="padding: var(--sp-4) var(--sp-5); border-bottom: 1px solid var(--border); font-weight: 600;">Add Language</div>
    <div style="padding: var(--sp-5);">
        <form method="POST" action="{{ admin_url('languages') }}" style="display: flex; gap: var(--sp-3); flex-wrap: wrap; align-items: flex-end;">
            <input type="hidden" name="_token" value="{{ csrf_token() }}">
            <div class="form-group" style="flex: 0 0 100px;">
                <label class="form-label">Code</label>
                <input type="text" name="code" class="form-control" placeholder="en" maxlength="10" required
                       value="{{ flash('_old_input')['code'] ?? '' }}"
                       pattern="[a-z]{2}(-[a-z]{2})?" title="e.g., en, fr, pt-br">
            </div>
            <div class="form-group" style="flex: 1; min-width: 150px;">
                <label class="form-label">Name</label>
                <input type="text" name="name" class="form-control" placeholder="English" required
                       value="{{ flash('_old_input')['name'] ?? '' }}">
            </div>
            <div class="form-group" style="flex: 1; min-width: 150px;">
                <label class="form-label">Native Name</label>
                <input type="text" name="native_name" class="form-control" placeholder="English"
                       value="{{ flash('_old_input')['native_name'] ?? '' }}">
            </div>
            <div class="form-group" style="display: flex; align-items: center; gap: var(--sp-2); padding-bottom: 2px;">
                <label style="display: flex; align-items: center; gap: var(--sp-1); cursor: pointer;">
                    <input type="checkbox" name="is_default" value="1"> Default
                </label>
            </div>
            <div class="form-group">
                <button type="submit" class="btn btn-primary">Add</button>
            </div>
        </form>
    </div>
</div>

{# Language List #}
{% if languages|length > 0 %}
<div class="card">
    <table class="table" style="width: 100%;">
        <thead>
            <tr>
                <th>Code</th>
                <th>Name</th>
                <th>Native Name</th>
                <th class="text-center">Default</th>
                <th class="text-center">Active</th>
                <th class="text-right">Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for lang in languages %}
            <tr>
                <td><code style="background: var(--bg-subdued); padding: 2px 6px; border-radius: var(--radius-sm); font-size: var(--text-xs);">{{ lang.getCode() }}</code></td>
                <td class="font-medium">{{ lang.getName() }}</td>
                <td>{{ lang.getNativeName() }}</td>
                <td class="text-center">
                    {% if lang.isDefault() %}
                        <span class="badge badge-success">Default</span>
                    {% endif %}
                </td>
                <td class="text-center">
                    {% if lang.isActive() %}
                        <span class="badge badge-success">Active</span>
                    {% else %}
                        <span class="badge badge-default">Inactive</span>
                    {% endif %}
                </td>
                <td class="text-right">
                    <button onclick="editLanguage({{ lang.getId() }}, '{{ lang.getName()|e('js') }}', '{{ lang.getNativeName()|e('js') }}', {{ lang.isActive() ? 'true' : 'false' }}, {{ lang.isDefault() ? 'true' : 'false' }})" class="btn btn-outline btn-sm">Edit</button>
                    {% if not lang.isDefault() %}
                    <form method="POST" action="{{ admin_url('languages/' ~ lang.getId() ~ '/delete') }}" style="display: inline;" class="confirm-delete" data-message="Delete this language and all its translations?">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                    </form>
                    {% endif %}
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<div class="card" style="padding: var(--sp-8); text-align: center;">
    <p style="color: var(--text-secondary); margin: 0;">No languages configured. Add your first language above.</p>
</div>
{% endif %}

{# Edit Modal #}
<div id="edit-modal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:1000; display:none; align-items:center; justify-content:center;">
    <div style="background:var(--bg-surface); border-radius:var(--radius-lg); padding:var(--sp-6); width:100%; max-width:420px; box-shadow:var(--shadow-md);">
        <h3 style="margin:0 0 var(--sp-4);">Edit Language</h3>
        <form id="edit-form" method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token() }}">
            <div class="form-group" class="mb-3">
                <label class="form-label">Name</label>
                <input type="text" name="name" id="edit-name" class="form-control" required>
            </div>
            <div class="form-group" class="mb-3">
                <label class="form-label">Native Name</label>
                <input type="text" name="native_name" id="edit-native" class="form-control">
            </div>
            <div style="display:flex; gap:var(--sp-4); margin-bottom:var(--sp-4);">
                <label style="display:flex; align-items:center; gap:var(--sp-1); cursor:pointer;">
                    <input type="checkbox" name="is_active" id="edit-active" value="1"> Active
                </label>
                <label style="display:flex; align-items:center; gap:var(--sp-1); cursor:pointer;">
                    <input type="checkbox" name="is_default" id="edit-default" value="1"> Default
                </label>
            </div>
            <div style="display:flex; gap:var(--sp-2); justify-content:flex-end;">
                <button type="button" onclick="closeEditModal()" class="btn btn-outline">Cancel</button>
                <button type="submit" class="btn btn-primary">Save</button>
            </div>
        </form>
    </div>
</div>

<script nonce="{{ csp_nonce() }}">
function editLanguage(id, name, native, active, isDefault) {
    document.getElementById('edit-form').action = '/admin/languages/' + id;
    document.getElementById('edit-name').value = name;
    document.getElementById('edit-native').value = native;
    document.getElementById('edit-active').checked = active;
    document.getElementById('edit-default').checked = isDefault;
    var modal = document.getElementById('edit-modal');
    modal.style.display = 'flex';
}
function closeEditModal() {
    document.getElementById('edit-modal').style.display = 'none';
}
document.getElementById('edit-modal').addEventListener('click', function(e) {
    if (e.target === this) closeEditModal();
});
</script>
{% endblock %}
