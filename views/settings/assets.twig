{% extends "@cms/layouts/cms.twig" %}

{% block title %}Asset Settings{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / Settings / <a href="/cms/settings/system">System</a> / Assets
</div>

<div class="page-header" style="display:flex; justify-content:space-between; align-items:center;">
    <h1>Asset Settings</h1>
    <button class="btn btn-primary" id="saveBtn">Save Changes</button>
</div>

{# Asset Files (public/assets/) #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
        <h3 style="margin:0; font-size:1rem;">Asset Files</h3>
    </div>
    <div class="card-body">
        <p style="color:var(--text-secondary); font-size:0.8125rem; margin:0 0 16px;">
            Upload CSS, JavaScript, and font files to <code>/public/assets/</code>. Use directly with <code>{{ '{{ css(\'css/file.css\') }}' }}</code>.
        </p>

        {# Upload Form #}
        <div style="background: var(--bg-subdued, #fafafa); border: 2px dashed var(--border-default, #e3e3e3); border-radius: 8px; padding: 24px; margin-bottom: 20px; text-align: center;" id="assetDropZone">
            <form id="assetUploadForm" enctype="multipart/form-data" style="display: inline-flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center;">
                <select id="assetCategory" name="category" class="form-control" style="width: auto;">
                    <option value="css" selected>CSS</option>
                    <option value="js">JavaScript</option>
                    <option value="fonts">Fonts</option>
                </select>
                <label class="btn btn-primary btn-sm" style="cursor: pointer; margin: 0;">
                    Choose File
                    <input type="file" id="assetFileInput" name="asset_file" style="display: none;"
                           accept=".css,.js,.woff,.woff2,.ttf,.otf,.eot,.map">
                </label>
                <span id="assetFileName" style="color: var(--text-secondary); font-size: 0.8125rem;">or drag &amp; drop files here</span>
                <button type="button" class="btn btn-sm btn-outline" id="assetUploadBtn" style="display: none;">Upload</button>
            </form>
            <div id="assetUploadProgress" style="display: none; margin-top: 12px;">
                <div style="background: var(--border-default); border-radius: 4px; height: 4px; overflow: hidden;">
                    <div id="assetProgressBar" style="background: var(--color-primary, #008060); height: 100%; width: 0%; transition: width 0.3s;"></div>
                </div>
            </div>
        </div>

        {# Existing Files #}
        <div id="assetFilesList">
            {% set hasAssets = publicAssets.css|length > 0 or publicAssets.js|length > 0 or publicAssets.fonts|length > 0 %}
            {% if hasAssets %}
            <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:16px;">
                {% for cat, files in publicAssets %}
                    {% if files|length > 0 %}
                    <div>
                        <h4 style="font-size:0.8125rem; margin:0 0 6px; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.05em;">{{ cat }} ({{ files|length }})</h4>
                        {% for f in files %}
                        <div style="display:flex; align-items:center; gap:6px; padding:6px 8px; font-size:0.8125rem; font-family:monospace; background:var(--bg-subdued); border-radius:4px; margin-bottom:3px;">
                            <span style="overflow:hidden; text-overflow:ellipsis; white-space:nowrap; flex:1;">{{ f.name }}</span>
                            <code style="color:var(--text-secondary); font-size:0.6875rem; flex-shrink:0;">{{ f.size }}</code>
                            <button class="btn btn-xs btn-danger delete-file-btn" data-path="{{ f.path }}" data-name="{{ f.name }}" title="Delete">&times;</button>
                        </div>
                        {% endfor %}
                    </div>
                    {% endif %}
                {% endfor %}
            </div>
            {% else %}
            <p style="color:var(--text-secondary); font-size:0.8125rem; margin:0; text-align:center; padding:20px;">No asset files yet. Upload CSS, JS, or font files above.</p>
            {% endif %}
        </div>
    </div>
</div>

{# General Asset Settings #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header">
        <h3 style="margin:0; font-size:1rem;">Versioning &amp; Performance</h3>
    </div>
    <div class="card-body">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--space-400);">
            <div class="form-group">
                <label for="versionStrategy">Versioning Strategy</label>
                <select id="versionStrategy" class="form-control">
                    <option value="timestamp" {% if versionStrategy == 'timestamp' %}selected{% endif %}>Timestamp (dev-friendly)</option>
                    <option value="hash" {% if versionStrategy == 'hash' %}selected{% endif %}>Content Hash (production)</option>
                    <option value="manifest" {% if versionStrategy == 'manifest' %}selected{% endif %}>Manifest (Vite/Webpack)</option>
                    <option value="global" {% if versionStrategy == 'global' %}selected{% endif %}>Global Version</option>
                    <option value="none" {% if versionStrategy == 'none' %}selected{% endif %}>None</option>
                </select>
                <small style="color:var(--text-secondary);">How <code>?v=</code> is appended to asset URLs for cache busting.</small>
            </div>
            <div class="form-group">
                <label for="globalVersion">Global Version</label>
                <input type="text" id="globalVersion" class="form-control" value="{{ globalVersion }}" placeholder="1.0.0">
                <small style="color:var(--text-secondary);">Used when strategy is "Global Version". Increment on deploy.</small>
            </div>
            <div class="form-group">
                <label for="cdnUrl">CDN URL</label>
                <input type="text" id="cdnUrl" class="form-control" value="{{ cdnUrl }}" placeholder="https://cdn.example.com">
                <small style="color:var(--text-secondary);">Prefix all asset URLs with this CDN domain.</small>
            </div>
            <div class="form-group">
                <label for="manifest">Build Manifest Path</label>
                <input type="text" id="manifest" class="form-control" value="{{ manifest }}" placeholder="build/manifest.json">
                <small style="color:var(--text-secondary);">Path to Vite/Webpack manifest.json (if using manifest strategy).</small>
            </div>
            <div class="form-group">
                <label for="minify">Auto-Minify</label>
                <select id="minify" class="form-control">
                    <option value="0" {% if not minify %}selected{% endif %}>Disabled</option>
                    <option value="1" {% if minify %}selected{% endif %}>Enabled</option>
                </select>
                <small style="color:var(--text-secondary);">Serve .min.css/.min.js versions in production automatically.</small>
            </div>
            <div class="form-group" style="display:flex; flex-direction:column; justify-content:center;">
                <label>Minify Assets</label>
                <button class="btn btn-outline" id="minifyBtn" style="width:fit-content;">Minify Now</button>
                <small id="minifyResult" style="color:var(--text-secondary); margin-top:4px;"></small>
            </div>
        </div>
    </div>
</div>

<div style="display:flex; justify-content:flex-end; gap:8px; margin-bottom:40px;">
    <a href="/cms/settings/system" class="btn btn-outline">Back to System Settings</a>
    <button class="btn btn-primary" id="saveBtn2">Save Changes</button>
</div>

<p style="color:var(--text-secondary); font-size:0.8125rem; margin-bottom:40px;">
    <strong>Note:</strong> Theme-specific assets (CSS, JS, preload, preconnect, CSP) are configured per-theme in <code>theme.json</code>.
    These global settings apply to all asset URLs across the site.
</p>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    // ===== Save Settings =====
    function saveSettings() {
        var data = {
            version_strategy: document.getElementById('versionStrategy').value,
            global_version: document.getElementById('globalVersion').value.trim(),
            cdn_url: document.getElementById('cdnUrl').value.trim(),
            manifest: document.getElementById('manifest').value.trim(),
            minify: document.getElementById('minify').value === '1'
        };

        var btn = document.getElementById('saveBtn');
        var btn2 = document.getElementById('saveBtn2');
        btn.disabled = true; btn2.disabled = true;
        btn.textContent = 'Saving...'; btn2.textContent = 'Saving...';

        var csrfMeta = document.querySelector('meta[name="csrf-token"]');
        fetch('/cms/settings/assets', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': csrfMeta ? csrfMeta.content : ''
            },
            body: JSON.stringify(data)
        })
        .then(function(r) { return r.json(); })
        .then(function(resp) {
            btn.disabled = false; btn2.disabled = false;
            btn.textContent = 'Save Changes'; btn2.textContent = 'Save Changes';
            if (resp.success) {
                btn.textContent = 'Saved!'; btn2.textContent = 'Saved!';
                setTimeout(function() { btn.textContent = 'Save Changes'; btn2.textContent = 'Save Changes'; }, 2000);
            } else {
                alert(resp.error || 'Save failed');
            }
        })
        .catch(function() {
            btn.disabled = false; btn2.disabled = false;
            btn.textContent = 'Save Changes'; btn2.textContent = 'Save Changes';
            alert('Network error');
        });
    }

    document.getElementById('saveBtn').addEventListener('click', saveSettings);
    document.getElementById('saveBtn2').addEventListener('click', saveSettings);

    // ===== Minify Now =====
    document.getElementById('minifyBtn').addEventListener('click', function() {
        var btn = this;
        var result = document.getElementById('minifyResult');
        btn.disabled = true;
        btn.textContent = 'Minifying...';
        result.textContent = '';

        var csrfMeta = document.querySelector('meta[name="csrf-token"]');
        fetch('/cms/settings/assets/minify', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': csrfMeta ? csrfMeta.content : ''
            }
        })
        .then(function(r) { return r.json(); })
        .then(function(resp) {
            btn.disabled = false;
            btn.textContent = 'Minify Now';
            if (resp.success) {
                var msg = resp.minified + ' file(s) minified, ' + resp.skipped + ' skipped';
                if (resp.errors && resp.errors.length > 0) {
                    msg += ' (' + resp.errors.length + ' error(s))';
                }
                result.textContent = msg;
                result.style.color = 'var(--color-success, green)';
            } else {
                result.textContent = resp.error || 'Minification failed';
                result.style.color = 'var(--color-critical, red)';
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = 'Minify Now';
            result.textContent = 'Network error';
            result.style.color = 'var(--color-critical, red)';
        });
    });

    // ===== File Upload =====
    var fileInput = document.getElementById('assetFileInput');
    var uploadBtn = document.getElementById('assetUploadBtn');
    var fileNameDisplay = document.getElementById('assetFileName');
    var csrfMeta = document.querySelector('meta[name="csrf-token"]');

    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files.length > 0) {
                fileNameDisplay.textContent = this.files[0].name;
                uploadBtn.style.display = '';
                var ext = this.files[0].name.split('.').pop().toLowerCase();
                var catMap = { css: 'css', js: 'js', map: 'js', woff: 'fonts', woff2: 'fonts', ttf: 'fonts', otf: 'fonts', eot: 'fonts' };
                if (catMap[ext]) document.getElementById('assetCategory').value = catMap[ext];
            } else {
                fileNameDisplay.textContent = 'or drag & drop files here';
                uploadBtn.style.display = 'none';
            }
        });
    }

    if (uploadBtn) {
        uploadBtn.addEventListener('click', function() {
            if (!fileInput.files.length) return;
            var formData = new FormData();
            formData.append('asset_file', fileInput.files[0]);
            formData.append('category', document.getElementById('assetCategory').value);

            var progressWrap = document.getElementById('assetUploadProgress');
            var progressBar = document.getElementById('assetProgressBar');
            progressWrap.style.display = '';
            uploadBtn.disabled = true;
            uploadBtn.textContent = 'Uploading...';

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/cms/settings/assets/upload');
            if (csrfMeta) xhr.setRequestHeader('X-CSRF-TOKEN', csrfMeta.content);

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) progressBar.style.width = Math.round(e.loaded / e.total * 100) + '%';
            });

            xhr.addEventListener('load', function() {
                progressWrap.style.display = 'none';
                progressBar.style.width = '0%';
                uploadBtn.disabled = false;
                uploadBtn.textContent = 'Upload';
                try {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) { window.location.reload(); }
                    else { alert(data.error || 'Upload failed'); }
                } catch (e) { alert('Upload failed'); }
            });

            xhr.addEventListener('error', function() {
                progressWrap.style.display = 'none';
                uploadBtn.disabled = false;
                uploadBtn.textContent = 'Upload';
                alert('Network error');
            });

            xhr.send(formData);
        });
    }

    // Drag and drop
    var dropZone = document.getElementById('assetDropZone');
    if (dropZone) {
        ['dragenter', 'dragover'].forEach(function(evt) {
            dropZone.addEventListener(evt, function(e) { e.preventDefault(); dropZone.style.borderColor = 'var(--color-primary, #008060)'; dropZone.style.background = 'rgba(0,128,96,0.04)'; });
        });
        ['dragleave', 'drop'].forEach(function(evt) {
            dropZone.addEventListener(evt, function(e) { e.preventDefault(); dropZone.style.borderColor = ''; dropZone.style.background = ''; });
        });
        dropZone.addEventListener('drop', function(e) {
            if (e.dataTransfer.files.length > 0) { fileInput.files = e.dataTransfer.files; fileInput.dispatchEvent(new Event('change')); }
        });
    }

    // ===== File Deletion =====
    document.querySelectorAll('.delete-file-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var path = this.dataset.path;
            var name = this.dataset.name;
            if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
            fetch('/cms/settings/assets/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfMeta ? csrfMeta.content : '' },
                body: JSON.stringify({ path: path })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) { window.location.reload(); }
                else { alert(data.error || 'Delete failed'); }
            })
            .catch(function() { alert('Network error'); });
        });
    });
})();
</script>
{% endblock %}
