{% extends "@cms/layouts/cms.twig" %}

{% block title %}System Settings{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Settings / System
</div>

<div class="page-header">
    <h1>System Settings</h1>
</div>

{# Application Settings #}
<div class="card" style="margin-bottom: var(--sp-5);">
    <div class="card-header">
        <h3 style="margin: 0; font-size: 1rem;">Application Settings</h3>
    </div>
    <div class="card-body">
        <form method="POST" action="{{ admin_url('settings/system') }}">
            {{ csrf_field() | raw }}

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);">
                <div class="form-group">
                    <label for="APP_NAME">App Name</label>
                    <input type="text" id="APP_NAME" name="APP_NAME" class="form-control"
                           value="{{ appSettings.APP_NAME }}">
                </div>

                <div class="form-group">
                    <label for="APP_URL">App URL</label>
                    <input type="text" id="APP_URL" name="APP_URL" class="form-control"
                           value="{{ appSettings.APP_URL }}" placeholder="https://example.com">
                </div>

                <div class="form-group">
                    <label for="APP_ENV">Environment</label>
                    <select id="APP_ENV" name="APP_ENV" class="form-control">
                        <option value="dev" {% if appSettings.APP_ENV == 'dev' %}selected{% endif %}>Development</option>
                        <option value="staging" {% if appSettings.APP_ENV == 'staging' %}selected{% endif %}>Staging</option>
                        <option value="production" {% if appSettings.APP_ENV == 'production' %}selected{% endif %}>Production</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="APP_DEBUG">Debug Mode</label>
                    <select id="APP_DEBUG" name="APP_DEBUG" class="form-control">
                        <option value="true" {% if appSettings.APP_DEBUG == 'true' %}selected{% endif %}>Enabled</option>
                        <option value="false" {% if appSettings.APP_DEBUG == 'false' %}selected{% endif %}>Disabled</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="APP_TIMEZONE">Timezone</label>
                    <input type="text" id="APP_TIMEZONE" name="APP_TIMEZONE" class="form-control"
                           value="{{ appSettings.APP_TIMEZONE }}" placeholder="UTC">
                </div>
            </div>

            <h4 style="margin: var(--sp-5) 0 var(--sp-3); font-size: 0.9rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Authentication & Session</h4>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);">
                <div class="form-group">
                    <label for="AUTH_HOME">Post-Login Redirect (Customers)</label>
                    <input type="text" id="AUTH_HOME" name="AUTH_HOME" class="form-control"
                           value="{{ authSettings.AUTH_HOME }}" placeholder="/">
                    <small style="color: var(--text-secondary);">Where non-admin users go after login. Admins always go to /cms.</small>
                </div>

                <div class="form-group">
                    <label for="SESSION_LIFETIME">Session Lifetime (minutes)</label>
                    <input type="number" id="SESSION_LIFETIME" name="SESSION_LIFETIME" class="form-control"
                           value="{{ authSettings.SESSION_LIFETIME }}" placeholder="120" min="1" max="10080">
                </div>

                <div class="form-group">
                    <label for="SESSION_DRIVER">Session Driver</label>
                    <select id="SESSION_DRIVER" name="SESSION_DRIVER" class="form-control">
                        <option value="file" {% if authSettings.SESSION_DRIVER == 'file' %}selected{% endif %}>File</option>
                        <option value="database" {% if authSettings.SESSION_DRIVER == 'database' %}selected{% endif %}>Database</option>
                    </select>
                </div>
            </div>

            <h4 style="margin: var(--sp-5) 0 var(--sp-3); font-size: 0.9rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">CMS Configuration</h4>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);">
                <div class="form-group">
                    <label for="CMS_THEME">Fallback Theme</label>
                    <input type="text" id="CMS_THEME" name="CMS_THEME" class="form-control"
                           value="{{ cmsSettings.CMS_THEME }}" placeholder="starter">
                    <small style="color: var(--text-secondary);">Used when no live theme is set in the database.</small>
                </div>

                <div class="form-group">
                    <label for="VIEWS_PATH">Views Path</label>
                    <input type="text" id="VIEWS_PATH" name="VIEWS_PATH" class="form-control"
                           value="{{ cmsSettings.VIEWS_PATH }}" placeholder="pages">
                    <small style="color: var(--text-secondary);">Relative path to the templates directory.</small>
                </div>
            </div>

            <h4 style="margin: var(--sp-5) 0 var(--sp-3); font-size: 0.9rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Security & CSP</h4>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-4);">
                <div class="form-group">
                    <label for="CSP_ENABLED">Content Security Policy</label>
                    <select id="CSP_ENABLED" name="CSP_ENABLED" class="form-control">
                        <option value="true" {% if securitySettings.CSP_ENABLED == 'true' %}selected{% endif %}>Enabled</option>
                        <option value="false" {% if securitySettings.CSP_ENABLED == 'false' %}selected{% endif %}>Disabled</option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="CSP_LEVEL">CSP Level</label>
                    <select id="CSP_LEVEL" name="CSP_LEVEL" class="form-control">
                        <option value="strict" {% if securitySettings.CSP_LEVEL == 'strict' %}selected{% endif %}>Strict (Production)</option>
                        <option value="moderate" {% if securitySettings.CSP_LEVEL == 'moderate' %}selected{% endif %}>Moderate (Default)</option>
                        <option value="relaxed" {% if securitySettings.CSP_LEVEL == 'relaxed' %}selected{% endif %}>Relaxed (Development)</option>
                    </select>
                    <small style="color: var(--text-secondary);">Strict uses nonces only. Moderate allows Google Fonts. Relaxed allows unsafe-inline.</small>
                </div>

                <div class="form-group">
                    <label for="CSP_REPORT_URI">CSP Report URI</label>
                    <input type="text" id="CSP_REPORT_URI" name="CSP_REPORT_URI" class="form-control"
                           value="{{ securitySettings.CSP_REPORT_URI }}" placeholder="/api/csp-report">
                    <small style="color: var(--text-secondary);">Endpoint for CSP violation reports.</small>
                </div>

                <div class="form-group">
                    <label for="HSTS_MAX_AGE">HSTS Max Age (seconds)</label>
                    <input type="number" id="HSTS_MAX_AGE" name="HSTS_MAX_AGE" class="form-control"
                           value="{{ securitySettings.HSTS_MAX_AGE }}" placeholder="31536000" min="0">
                    <small style="color: var(--text-secondary);">HTTP Strict Transport Security duration. 31536000 = 1 year.</small>
                </div>

                <div class="form-group">
                    <label for="HSTS_PRELOAD">HSTS Preload</label>
                    <select id="HSTS_PRELOAD" name="HSTS_PRELOAD" class="form-control">
                        <option value="false" {% if securitySettings.HSTS_PRELOAD == 'false' %}selected{% endif %}>Disabled</option>
                        <option value="true" {% if securitySettings.HSTS_PRELOAD == 'true' %}selected{% endif %}>Enabled</option>
                    </select>
                    <small style="color: var(--text-secondary);">Include preload directive in HSTS header.</small>
                </div>

                <div class="form-group">
                    <label for="USE_ISOLATION_HEADERS">Isolation Headers (COEP/COOP/CORP)</label>
                    <select id="USE_ISOLATION_HEADERS" name="USE_ISOLATION_HEADERS" class="form-control">
                        <option value="false" {% if securitySettings.USE_ISOLATION_HEADERS == 'false' %}selected{% endif %}>Disabled</option>
                        <option value="true" {% if securitySettings.USE_ISOLATION_HEADERS == 'true' %}selected{% endif %}>Enabled</option>
                    </select>
                    <small style="color: var(--text-secondary);">Cross-Origin isolation headers. May break third-party embeds.</small>
                </div>
            </div>

            {# ── Quick Presets ── #}
            <div style="margin: var(--sp-5) 0 var(--sp-3);">
                <h5 style="font-size: 0.8rem; color: var(--text-secondary); margin-bottom: var(--sp-2);">Quick Add — Common Services</h5>
                <div style="display: flex; flex-wrap: wrap; gap: 6px;">
                    <button type="button" class="csp-preset-btn" data-preset="google-fonts" title="Adds fonts.googleapis.com + fonts.gstatic.com">Google Fonts</button>
                    <button type="button" class="csp-preset-btn" data-preset="google-analytics" title="Adds googletagmanager.com + google-analytics.com">Google Analytics</button>
                    <button type="button" class="csp-preset-btn" data-preset="youtube" title="Adds youtube.com + youtube-nocookie.com">YouTube Embeds</button>
                    <button type="button" class="csp-preset-btn" data-preset="cdnjs" title="Adds cdnjs.cloudflare.com">cdnjs</button>
                    <button type="button" class="csp-preset-btn" data-preset="jsdelivr" title="Adds cdn.jsdelivr.net">jsDelivr</button>
                    <button type="button" class="csp-preset-btn" data-preset="unpkg" title="Adds unpkg.com">unpkg</button>
                    <button type="button" class="csp-preset-btn" data-preset="stripe" title="Adds js.stripe.com + api.stripe.com">Stripe</button>
                    <button type="button" class="csp-preset-btn" data-preset="recaptcha" title="Adds google.com/recaptcha + gstatic.com">reCAPTCHA</button>
                    <button type="button" class="csp-preset-btn" data-preset="vimeo" title="Adds player.vimeo.com">Vimeo</button>
                    <button type="button" class="csp-preset-btn" data-preset="cloudinary" title="Adds res.cloudinary.com">Cloudinary</button>
                </div>
            </div>

            {# ── CSP Source Directives with Tag UI ── #}
            <h5 style="margin: var(--sp-3) 0 var(--sp-2); font-size: 0.8rem; color: var(--text-secondary);">Allowed External Sources</h5>

            {% set cspFields = [
                { id: 'CSP_SCRIPT_SRC', label: 'Scripts', icon: '&lt;/&gt;', help: 'External JavaScript files (CDNs, analytics, payment)' },
                { id: 'CSP_STYLE_SRC', label: 'Styles', icon: '&#x1f3a8;', help: 'External CSS files and font stylesheets' },
                { id: 'CSP_IMG_SRC', label: 'Images', icon: '&#x1f5bc;', help: 'External image sources (CDN, data: for inline images)' },
                { id: 'CSP_FONT_SRC', label: 'Fonts', icon: 'Aa', help: 'External font file downloads' },
                { id: 'CSP_CONNECT_SRC', label: 'Connect (API/WS)', icon: '&#x21c4;', help: 'Fetch, XHR, WebSocket destinations' },
                { id: 'CSP_FRAME_SRC', label: 'Frames (Embeds)', icon: '&#x25a3;', help: 'Allowed iframe sources (YouTube, Vimeo, maps)' },
                { id: 'CSP_MEDIA_SRC', label: 'Media (Audio/Video)', icon: '&#x25b6;', help: 'External audio and video sources' }
            ] %}

            {% for field in cspFields %}
            <div class="csp-directive-group" data-directive="{{ field.id }}">
                <div class="csp-directive-header">
                    <span class="csp-directive-icon">{{ field.icon|raw }}</span>
                    <span class="csp-directive-label">{{ field.label }}</span>
                    <small class="csp-directive-help">{{ field.help }}</small>
                </div>
                <div class="csp-tags-container" id="tags_{{ field.id }}">
                    {# Tags populated by JS from hidden input #}
                </div>
                <div class="csp-add-row">
                    <input type="text" class="csp-add-input" id="addInput_{{ field.id }}" placeholder="https://example.com" autocomplete="off">
                    <button type="button" class="csp-add-btn" data-target="{{ field.id }}">Add</button>
                </div>
                <input type="hidden" id="{{ field.id }}" name="{{ field.id }}" value="{{ attribute(securitySettings, field.id) }}">
            </div>
            {% endfor %}

            <h4 style="margin: var(--sp-5) 0 var(--sp-3); font-size: 0.9rem; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.05em;">Asset Configuration</h4>

            <div style="background: var(--bg-subdued); border: 1px solid var(--border); border-radius: 8px; padding: 16px; margin-bottom: 16px;">
                <p style="margin: 0 0 8px; font-size: 0.875rem;">Manage asset collections, preloads, preconnects, CDN, and versioning in the dedicated Asset Settings page.</p>
                <a href="{{ admin_url('settings/assets') }}" class="btn btn-sm btn-primary">Open Asset Settings</a>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Settings</button>
            </div>
        </form>
    </div>
</div>

{# System Information #}
<div class="card" style="margin-bottom: var(--sp-5);">
    <div class="card-header">
        <h3 style="margin: 0; font-size: 1rem;">System Information</h3>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <tbody>
                    {% for label, value in systemInfo %}
                    <tr>
                        <td style="width: 200px;"><strong>{{ label|replace({'_': ' '})|title }}</strong></td>
                        <td><code>{{ value }}</code></td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{# PHP Extensions #}
<div class="card">
    <div class="card-header">
        <h3 style="margin: 0; font-size: 1rem;">Loaded PHP Extensions ({{ extensions|length }})</h3>
    </div>
    <div class="card-body">
        <div style="display: flex; flex-wrap: wrap; gap: var(--sp-2);">
            {% for ext in extensions %}
                <span class="badge" style="background: var(--bg-subdued); color: var(--text-secondary);">{{ ext }}</span>
            {% endfor %}
        </div>
    </div>
</div>

<style>
    .csp-preset-btn {
        padding: 5px 12px; font-size: 12px; border-radius: 6px;
        border: 1px solid var(--border); background: var(--bg-subdued);
        color: var(--text-secondary); cursor: pointer; transition: all 0.15s;
    }
    .csp-preset-btn:hover { border-color: var(--zui-primary-500); color: var(--zui-primary-500); background: var(--bg-app); }
    .csp-preset-btn.applied { border-color: var(--zui-success-600); color: var(--zui-success-600); background: rgba(4,123,93,0.06); }

    .csp-directive-group {
        background: var(--bg-subdued); border: 1px solid var(--border);
        border-radius: 8px; padding: 12px 14px; margin-bottom: 8px;
    }
    .csp-directive-header { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
    .csp-directive-icon { font-size: 14px; width: 22px; text-align: center; opacity: 0.6; }
    .csp-directive-label { font-weight: 600; font-size: 13px; color: var(--text); }
    .csp-directive-help { color: var(--text-secondary); font-size: 11px; margin-left: auto; }

    .csp-tags-container { display: flex; flex-wrap: wrap; gap: 6px; min-height: 28px; margin-bottom: 8px; }
    .csp-tags-container:empty::after {
        content: 'No external sources \2014 only self allowed'; font-size: 11px;
        color: var(--text-secondary); font-style: italic; padding: 4px 0;
    }

    .csp-tag {
        display: inline-flex; align-items: center; gap: 4px; padding: 3px 8px 3px 10px;
        background: var(--bg-app); border: 1px solid var(--border); border-radius: 5px;
        font-size: 12px; color: var(--text); font-family: monospace;
    }
    .csp-tag-remove {
        border: none; background: none; color: var(--text-secondary); cursor: pointer;
        font-size: 14px; padding: 0 2px; line-height: 1; border-radius: 3px;
    }
    .csp-tag-remove:hover { color: var(--zui-error-600); background: rgba(215,44,13,0.08); }

    .csp-add-row { display: flex; gap: 6px; }
    .csp-add-input {
        flex: 1; padding: 5px 10px; font-size: 12px; border-radius: 6px;
        border: 1px solid var(--border); background: var(--bg-app); color: var(--text);
        font-family: monospace;
    }
    .csp-add-input:focus { outline: none; border-color: var(--zui-primary-500); box-shadow: 0 0 0 2px rgba(26,123,168,0.15); }
    .csp-add-btn {
        padding: 5px 14px; font-size: 12px; border-radius: 6px; border: 1px solid var(--zui-primary-500);
        background: var(--zui-primary-500); color: #fff; cursor: pointer; white-space: nowrap;
    }
    .csp-add-btn:hover { opacity: 0.9; }
</style>

<script>
(function() {
    var PRESETS = {
        'google-fonts': { CSP_STYLE_SRC: ['https://fonts.googleapis.com'], CSP_FONT_SRC: ['https://fonts.gstatic.com'] },
        'google-analytics': { CSP_SCRIPT_SRC: ['https://www.googletagmanager.com','https://www.google-analytics.com'], CSP_IMG_SRC: ['https://www.google-analytics.com'], CSP_CONNECT_SRC: ['https://www.google-analytics.com','https://analytics.google.com'] },
        'youtube': { CSP_FRAME_SRC: ['https://www.youtube.com','https://www.youtube-nocookie.com'], CSP_IMG_SRC: ['https://img.youtube.com','https://i.ytimg.com'] },
        'cdnjs': { CSP_SCRIPT_SRC: ['https://cdnjs.cloudflare.com'], CSP_STYLE_SRC: ['https://cdnjs.cloudflare.com'] },
        'jsdelivr': { CSP_SCRIPT_SRC: ['https://cdn.jsdelivr.net'], CSP_STYLE_SRC: ['https://cdn.jsdelivr.net'] },
        'unpkg': { CSP_SCRIPT_SRC: ['https://unpkg.com'], CSP_STYLE_SRC: ['https://unpkg.com'] },
        'stripe': { CSP_SCRIPT_SRC: ['https://js.stripe.com'], CSP_FRAME_SRC: ['https://js.stripe.com'], CSP_CONNECT_SRC: ['https://api.stripe.com'] },
        'recaptcha': { CSP_SCRIPT_SRC: ['https://www.google.com','https://www.gstatic.com'], CSP_FRAME_SRC: ['https://www.google.com'] },
        'vimeo': { CSP_FRAME_SRC: ['https://player.vimeo.com'], CSP_IMG_SRC: ['https://i.vimeocdn.com'] },
        'cloudinary': { CSP_IMG_SRC: ['https://res.cloudinary.com'], CSP_MEDIA_SRC: ['https://res.cloudinary.com'] }
    };

    var DIRECTIVES = ['CSP_SCRIPT_SRC','CSP_STYLE_SRC','CSP_IMG_SRC','CSP_FONT_SRC','CSP_CONNECT_SRC','CSP_FRAME_SRC','CSP_MEDIA_SRC'];

    function getTags(id) {
        var el = document.getElementById(id);
        if (!el) return [];
        var val = el.value.trim();
        if (!val) return [];
        return val.split(',').map(function(s) { return s.trim(); }).filter(Boolean);
    }

    function setTags(id, tags) {
        var el = document.getElementById(id);
        if (el) el.value = tags.join(',');
        renderTags(id);
    }

    function renderTags(id) {
        var container = document.getElementById('tags_' + id);
        if (!container) return;
        var tags = getTags(id);
        container.innerHTML = '';
        tags.forEach(function(tag) {
            var el = document.createElement('span');
            el.className = 'csp-tag';
            el.textContent = tag;
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'csp-tag-remove';
            btn.innerHTML = '&times;';
            btn.addEventListener('click', function() {
                var updated = getTags(id).filter(function(t) { return t !== tag; });
                setTags(id, updated);
                checkPresets();
            });
            el.appendChild(btn);
            container.appendChild(el);
        });
    }

    function addTag(id, value) {
        value = value.trim();
        if (!value) return;
        var tags = getTags(id);
        if (tags.indexOf(value) === -1) {
            tags.push(value);
            setTags(id, tags);
        }
    }

    DIRECTIVES.forEach(function(id) { renderTags(id); });

    document.querySelectorAll('.csp-add-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var targetId = btn.getAttribute('data-target');
            var input = document.getElementById('addInput_' + targetId);
            addTag(targetId, input.value);
            input.value = '';
            input.focus();
            checkPresets();
        });
    });

    document.querySelectorAll('.csp-add-input').forEach(function(input) {
        input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                e.preventDefault();
                var targetId = input.id.replace('addInput_', '');
                addTag(targetId, input.value);
                input.value = '';
                checkPresets();
            }
        });
    });

    document.querySelectorAll('.csp-preset-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var preset = PRESETS[btn.getAttribute('data-preset')];
            if (!preset) return;
            for (var directive in preset) {
                preset[directive].forEach(function(domain) {
                    addTag(directive, domain);
                });
            }
            checkPresets();
        });
    });

    function checkPresets() {
        document.querySelectorAll('.csp-preset-btn').forEach(function(btn) {
            var key = btn.getAttribute('data-preset');
            var preset = PRESETS[key];
            if (!preset) return;
            var allApplied = true;
            for (var directive in preset) {
                var tags = getTags(directive);
                preset[directive].forEach(function(domain) {
                    if (tags.indexOf(domain) === -1) allApplied = false;
                });
            }
            btn.classList.toggle('applied', allApplied);
        });
    }
    checkPresets();
})();
</script>
{% endblock %}
