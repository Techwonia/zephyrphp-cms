{% extends "@cms/layouts/cms.twig" %}

{% block title %}Profile{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> / Settings / Profile
</div>

<div class="page-header">
    <h1>Profile Settings</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="{{ admin_url('settings/profile') }}">
            {{ csrf_field() | raw }}

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-400);">
                <div class="form-group">
                    <label for="name">Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ flash('_old_input').name ?? profile.getName() }}"
                           placeholder="Your name" required>
                    {% if flash('errors').name is defined %}
                        <div class="invalid-feedback">{{ flash('errors').name }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" class="form-control"
                           value="{{ flash('_old_input').email ?? profile.getEmail() }}"
                           placeholder="your@email.com" required>
                    {% if flash('errors').email is defined %}
                        <div class="invalid-feedback">{{ flash('errors').email }}</div>
                    {% endif %}
                </div>
            </div>

            <hr style="margin: var(--space-500) 0; border: none; border-top: 1px solid var(--border-default);">

            <h3 style="margin-bottom: var(--space-400); font-size: 1rem;">Change Password</h3>
            <p style="color: var(--text-secondary); margin-bottom: var(--space-400); font-size: 0.875rem;">Leave blank to keep your current password.</p>

            <div class="form-group">
                <label for="current_password">Current Password</label>
                <input type="password" id="current_password" name="current_password" class="form-control"
                       placeholder="Enter current password">
                {% if flash('errors').current_password is defined %}
                    <div class="invalid-feedback">{{ flash('errors').current_password }}</div>
                {% endif %}
            </div>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-400);">
                <div class="form-group">
                    <label for="new_password">New Password</label>
                    <input type="password" id="new_password" name="new_password" class="form-control"
                           placeholder="Minimum 6 characters">
                    {% if flash('errors').new_password is defined %}
                        <div class="invalid-feedback">{{ flash('errors').new_password }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label for="confirm_password">Confirm New Password</label>
                    <input type="password" id="confirm_password" name="confirm_password" class="form-control"
                           placeholder="Repeat new password">
                    {% if flash('errors').confirm_password is defined %}
                        <div class="invalid-feedback">{{ flash('errors').confirm_password }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
            </div>
        </form>
    </div>
</div>

{# ── Two-Factor Authentication ── #}
<div class="card" style="margin-top: var(--space-500);">
    <div class="card-body">
        <h3 style="margin-bottom: var(--space-300); font-size: 1rem;">Two-Factor Authentication</h3>

        {% if profile.isTwoFactorEnabled is defined and profile.isTwoFactorEnabled() %}
            <div style="display: flex; align-items: center; gap: var(--space-300); margin-bottom: var(--space-400);">
                <span style="display: inline-flex; align-items: center; gap: 6px; padding: 6px 12px; background: rgba(34,197,94,0.1); border: 1px solid rgba(34,197,94,0.2); border-radius: 6px; font-size: 0.8125rem; color: #22c55e; font-weight: 500;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>
                    2FA is active
                </span>
            </div>
            <p style="color: var(--text-secondary); font-size: 0.8125rem; margin-bottom: var(--space-400); line-height: 1.6;">
                Your account is protected with two-factor authentication. To disable it, enter your current password below.
            </p>

            {% if flash('2fa_recovery_codes') %}
                <div style="background: rgba(6,182,212,0.06); border: 1px solid rgba(6,182,212,0.15); border-radius: 8px; padding: var(--space-400); margin-bottom: var(--space-400);">
                    <h4 style="font-size: 0.875rem; font-weight: 600; margin-bottom: var(--space-200); color: var(--accent-primary);">Recovery Codes</h4>
                    <p style="color: var(--text-secondary); font-size: 0.8125rem; margin-bottom: var(--space-300); line-height: 1.6;">
                        Save these recovery codes in a safe place. Each code can only be used once. <strong style="color: var(--text-primary);">These will not be shown again.</strong>
                    </p>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 6px; max-width: 320px; font-family: monospace; font-size: 0.875rem;">
                        {% for code in flash('2fa_recovery_codes') %}
                            <div style="padding: 6px 10px; background: var(--bg-secondary); border: 1px solid var(--border-default); border-radius: 4px; text-align: center;">{{ code }}</div>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}

            <form method="POST" action="{{ admin_url('settings/profile/2fa/disable') }}" style="max-width: 380px;">
                {{ csrf_field() | raw }}

                <div class="form-group">
                    <label for="2fa_current_password">Current Password</label>
                    <input type="password" id="2fa_current_password" name="current_password" class="form-control"
                           placeholder="Enter your password to disable 2FA" required>
                    {% if flash('errors')['2fa_password'] is defined %}
                        <div class="invalid-feedback">{{ flash('errors')['2fa_password'] }}</div>
                    {% endif %}
                </div>

                <button type="submit" class="btn btn-danger" onclick="return confirm('Are you sure you want to disable two-factor authentication? Your account will be less secure.')">
                    Disable Two-Factor Authentication
                </button>
            </form>
        {% else %}
            <p style="color: var(--text-secondary); font-size: 0.8125rem; margin-bottom: var(--space-400); line-height: 1.6;">
                Add an extra layer of security to your account by enabling two-factor authentication (2FA).
                You will need an authenticator app such as Google Authenticator, Authy, or 1Password.
            </p>
            <form method="POST" action="{{ admin_url('settings/profile/2fa/enable') }}">
                {{ csrf_field() | raw }}
                <button type="submit" class="btn btn-primary">Enable Two-Factor Authentication</button>
            </form>
        {% endif %}
    </div>
</div>
{% endblock %}
