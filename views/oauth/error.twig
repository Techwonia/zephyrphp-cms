{% extends "@cms/layouts/cms.twig" %}

{% block title %}Authorization Error{% endblock %}

{% block content %}
<div style="max-width:480px;margin:40px auto;">
    <div class="card">
        <div class="card-header">
            <h3>Authorization Error</h3>
        </div>
        <div class="card-body">
            <p>{{ error }}</p>
            <a href="{{ admin_url() }}" class="btn btn-outline" style="margin-top:16px;">Back to Dashboard</a>
        </div>
    </div>
</div>
{% endblock %}
