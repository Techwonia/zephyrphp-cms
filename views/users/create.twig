{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create User{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> <a href="{{ admin_url('users') }}">Users</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Create
</div>

<div class="page-header">
    <h1>Create User</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="{{ admin_url('users') }}">
            {{ csrf_field() | raw }}

            <div class="grid grid-2 gap-4">
                <div class="form-group">
                    <label for="name">Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ flash('_old_input').name ?? '' }}"
                           placeholder="Full name" required>
                    {% if flash('errors').name is defined %}
                        <div class="invalid-feedback">{{ flash('errors').name }}</div>
                    {% endif %}
                </div>

                <div class="form-group">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" class="form-control"
                           value="{{ flash('_old_input').email ?? '' }}"
                           placeholder="user@example.com" required>
                    {% if flash('errors').email is defined %}
                        <div class="invalid-feedback">{{ flash('errors').email }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label for="password">Password *</label>
                <input type="password" id="password" name="password" class="form-control"
                       placeholder="Minimum 6 characters" required>
                {% if flash('errors').password is defined %}
                    <div class="invalid-feedback">{{ flash('errors').password }}</div>
                {% endif %}
            </div>

            {% if roles|length > 0 %}
            <div class="form-group">
                <label>Roles</label>
                <div style="display: flex; flex-wrap: wrap; gap: var(--sp-3);">
                    {% for role in roles %}
                    <label style="display: flex; align-items: center; gap: var(--sp-1); cursor: pointer; font-weight: normal;">
                        <input type="checkbox" name="roles[]" value="{{ role.getId() }}">
                        {{ role.getName() }}
                    </label>
                    {% endfor %}
                </div>
            </div>
            {% endif %}

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create User</button>
                <a href="{{ admin_url('users') }}" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
