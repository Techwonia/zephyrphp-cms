{% extends "@cms/layouts/cms.twig" %}

{% block title %}{{ item.name ?? 'Item' }} — Marketplace{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> /
    <a href="{{ admin_url('marketplace') }}">Marketplace</a> /
    {{ item.name ?? 'Item' }}
</div>

<div class="page-header">
    <h1>{{ item.name }}</h1>
    <div class="page-actions">
        <a href="{{ admin_url('marketplace') }}" class="btn btn-secondary">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Back to Marketplace
        </a>
        {% if item.install_url is defined and item.install_url %}
        <form method="POST" action="{{ admin_url('marketplace/' ~ item.slug ~ '/install') }}" style="display:inline;">
            {{ csrf_field()|raw }}
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                Install
            </button>
        </form>
        {% endif %}
    </div>
</div>

<div style="display:grid; grid-template-columns:2fr 1fr; gap:var(--space-500);">
    {# Main Content #}
    <div>
        <div class="card">
            <div class="card-body">
                <h3 style="margin-bottom:var(--space-300);">Description</h3>
                <p style="color:var(--text-secondary); line-height:1.7;">{{ item.description ?? 'No description available.' }}</p>

                {% if item.features is defined and item.features %}
                <h3 style="margin-top:var(--space-500); margin-bottom:var(--space-300);">Features</h3>
                <ul style="color:var(--text-secondary); padding-left:20px;">
                    {% for feature in item.features %}
                    <li style="margin-bottom:8px;">{{ feature }}</li>
                    {% endfor %}
                </ul>
                {% endif %}
            </div>
        </div>

        {% if reviews is not empty %}
        <div class="card" style="margin-top:var(--space-500);">
            <div class="card-header"><h3>Reviews</h3></div>
            <div class="card-body">
                {% for review in reviews %}
                <div style="padding:var(--space-300) 0; border-bottom:1px solid var(--border-default); {% if loop.last %}border-bottom:none;{% endif %}">
                    <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
                        <strong>{{ review.author ?? 'Anonymous' }}</strong>
                        <span style="color:var(--text-secondary); font-size:0.8rem;">{{ review.created_at ?? '' }}</span>
                    </div>
                    <p style="color:var(--text-secondary);">{{ review.content ?? '' }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    {# Sidebar Info #}
    <div>
        <div class="card">
            <div class="card-body">
                <table style="width:100%; font-size:0.875rem;">
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">Version</td><td style="padding:8px 0; text-align:right;">{{ item.version ?? '—' }}</td></tr>
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">Author</td><td style="padding:8px 0; text-align:right;">{{ item.author ?? '—' }}</td></tr>
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">Type</td><td style="padding:8px 0; text-align:right;">{{ item.type ?? '—' }}</td></tr>
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">License</td><td style="padding:8px 0; text-align:right;">{{ item.license ?? 'MIT' }}</td></tr>
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">Downloads</td><td style="padding:8px 0; text-align:right;">{{ item.downloads ?? 0 }}</td></tr>
                    {% if item.github_url is defined and item.github_url %}
                    <tr><td style="padding:8px 0; color:var(--text-secondary);">Source</td><td style="padding:8px 0; text-align:right;"><a href="{{ item.github_url }}" target="_blank" rel="noopener">GitHub</a></td></tr>
                    {% endif %}
                </table>
            </div>
        </div>

        {% if item.requires is defined and item.requires %}
        <div class="card" style="margin-top:var(--space-300);">
            <div class="card-body">
                <h4 style="margin-bottom:8px;">Requirements</h4>
                <ul style="font-size:0.8rem; color:var(--text-secondary); padding-left:16px;">
                    {% for req in item.requires %}
                    <li>{{ req }}</li>
                    {% endfor %}
                </ul>
            </div>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}
