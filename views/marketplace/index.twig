{% extends "@cms/layouts/cms.twig" %}

{% block title %}Marketplace{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/marketplace-index.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Marketplace
</div>

<div class="page-header">
    <h1>Marketplace</h1>
    <div class="page-actions">
    </div>
</div>

{# Search & Filters #}
<div class="card" style="margin-bottom:var(--sp-5);">
    <div class="card-body">
        <form method="GET" action="{{ admin_url('marketplace') }}" class="mp-filters">
            <div class="mp-search">
                <input type="text" name="search" value="{{ filters.search }}" placeholder="Search themes..." class="form-control">
            </div>
            <select name="sort" class="form-control mp-select">
                <option value="popular" {{ filters.sort == 'popular' ? 'selected' : '' }}>Most Popular</option>
                <option value="newest" {{ filters.sort == 'newest' ? 'selected' : '' }}>Newest</option>
                <option value="rating" {{ filters.sort == 'rating' ? 'selected' : '' }}>Top Rated</option>
                <option value="name" {{ filters.sort == 'name' ? 'selected' : '' }}>Name A-Z</option>
            </select>
            <button type="submit" class="btn btn-primary">Search</button>
        </form>
    </div>
</div>

{% if error %}
<div class="alert alert-danger" style="margin-bottom:16px;">{{ error }}</div>
{% endif %}

{% if items|length > 0 %}
<div class="mp-grid">
    {% for item in items %}
    <div class="mp-card">
        <div class="mp-preview">
            {% if item.preview_image %}
                <img src="{{ item.preview_image }}" alt="{{ item.name }}" loading="lazy">
            {% else %}
                <div class="mp-preview-placeholder">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                        {% if item.type == 'theme' %}
                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="9" x2="9" y2="21"/>
                        {% elseif item.type == 'section' %}
                        <rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/>
                        {% else %}
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                        {% endif %}
                    </svg>
                </div>
            {% endif %}
        </div>
        <div class="mp-info">
            <div class="mp-header">
                <h3 class="mp-name">{{ item.name }}</h3>
                <span class="mp-type badge badge-{{ item.type }}">{{ item.type|capitalize }}</span>
            </div>
            <p class="mp-desc">{{ item.description|slice(0, 100) }}{% if item.description|length > 100 %}...{% endif %}</p>
            <div class="mp-meta">
                <span class="mp-seller">{{ item.seller_name }}</span>
                {% if item.avg_rating > 0 %}
                <span class="mp-rating">{{ item.avg_rating }} / 5 ({{ item.review_count }})</span>
                {% endif %}
                <span class="mp-downloads">{{ item.downloads }} downloads</span>
            </div>
            <div class="mp-footer">
                <span class="mp-price {{ item.pricing == 'free' ? 'mp-free' : '' }}">{{ item.price }}</span>
                <form method="POST" action="{{ admin_url('marketplace/' ~ item.slug ~ '/install') }}" style="display:inline">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="btn btn-sm btn-primary">Install</button>
                </form>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{# Pagination #}
{% if pagination.last_page is defined and pagination.last_page > 1 %}
<div class="mp-pagination" style="margin-top:20px;display:flex;gap:8px;justify-content:center;">
    {% for p in 1..pagination.last_page %}
        {% if p == pagination.current_page %}
            <span class="btn btn-sm btn-primary">{{ p }}</span>
        {% else %}
            <a href="{{ admin_url('marketplace?page=' ~ p ~ '&type=' ~ filters.type ~ '&search=' ~ filters.search ~ '&sort=' ~ filters.sort) }}" class="btn btn-sm btn-outline">{{ p }}</a>
        {% endif %}
    {% endfor %}
</div>
{% endif %}

{% else %}
<div class="card">
    <div class="card-body empty-state">
        <h3>No items found</h3>
        <p>Try adjusting your search or filters, or check back later for new listings.</p>
    </div>
</div>
{% endif %}
{% endblock %}

{% block styles %}
{% endblock %}
