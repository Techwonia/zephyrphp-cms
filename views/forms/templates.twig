{% extends "@cms/layouts/cms.twig" %}

{% block title %}Form Templates{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/forms">Forms</a> / Templates
</div>

<div class="page-header">
    <h1>Form Templates</h1>
    <div class="page-actions">
        <a href="/cms/forms/create" class="btn btn-outline">Blank Form</a>
    </div>
</div>

{% if templates|length > 0 %}
<div class="template-grid">
    {% for slug, template in templates %}
    <div class="card template-card">
        <div class="card-body">
            <h3>{{ template.name ?? slug }}</h3>
            <p class="text-muted">{{ template.description ?? 'No description' }}</p>
            <div class="template-meta">
                {% set fieldCount = template.fields is defined ? template.fields|length : 0 %}
                <span>{{ fieldCount }} field{{ fieldCount != 1 ? 's' : '' }}</span>
                {% if template.is_multi_step ?? false %}
                    <span class="badge badge-info">Multi-step</span>
                {% endif %}
                {% if template.settings.payment_enabled ?? false %}
                    <span class="badge badge-warning">Payment</span>
                {% endif %}
            </div>
            <form method="POST" action="/cms/forms/templates/{{ slug }}/create" style="margin-top: var(--space-300);">
                {{ csrf_field() | raw }}
                <button type="submit" class="btn btn-primary btn-sm">Use Template</button>
            </form>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="empty-state">
    <h3>No templates available</h3>
    <p>No pre-built form templates were found.</p>
    <a href="/cms/forms/create" class="btn btn-primary">Create a Blank Form</a>
</div>
{% endif %}

<style nonce="{{ csp_nonce() }}">
.template-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-400);
}
.template-card .card-body h3 { margin-bottom: var(--space-200); }
.template-card .card-body p { font-size: 0.9rem; margin-bottom: var(--space-300); }
.template-meta {
    display: flex;
    gap: var(--space-200);
    align-items: center;
    font-size: 0.85rem;
    color: var(--text-secondary);
}
</style>
{% endblock %}
