{% extends "@cms/layouts/cms.twig" %}

{% block title %}Forms{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / Forms
</div>

<div class="page-header">
    <h1>Forms</h1>
    <div class="page-actions">
        <a href="/cms/forms/templates" class="btn btn-outline">Templates</a>
        <a href="/cms/forms/create" class="btn btn-primary">+ Create Form</a>
    </div>
</div>

{% if forms|length > 0 %}
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Slug</th>
                        <th>Status</th>
                        <th>Fields</th>
                        <th>Submissions</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for form in forms %}
                    <tr>
                        <td><a href="/cms/forms/{{ form.slug }}"><strong>{{ form.name }}</strong></a></td>
                        <td><code>{{ form.slug }}</code></td>
                        <td>
                            {% if form.status == 'active' %}
                                <span class="badge badge-success">Active</span>
                            {% elseif form.status == 'archived' %}
                                <span class="badge badge-default">Archived</span>
                            {% else %}
                                <span class="badge badge-draft">Draft</span>
                            {% endif %}
                        </td>
                        <td>{{ form.fields|length }}</td>
                        <td>{{ submission_counts[form.id] ?? 0 }}</td>
                        <td>{{ form.createdAt ? form.createdAt|date('M d, Y') : '&mdash;' }}</td>
                        <td class="actions-cell">
                            <a href="/cms/forms/{{ form.slug }}" class="btn btn-sm btn-outline">Edit</a>
                            <a href="/cms/forms/{{ form.slug }}/submissions" class="btn btn-sm btn-outline">Submissions</a>
                            <form method="POST" action="/cms/forms/{{ form.slug }}/delete"
                                  style="display:inline" class="confirm-delete" data-message="Delete form '{{ form.name }}'? All fields and submissions will be lost!">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="empty-state">
    <h3>No forms yet</h3>
    <p>Create your first form to start collecting data from visitors.</p>
    <a href="/cms/forms/create" class="btn btn-primary">+ Create Your First Form</a>
</div>
{% endif %}
{% endblock %}
