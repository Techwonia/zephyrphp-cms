{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create Form{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/forms">Forms</a> / Create
</div>

<div class="page-header">
    <h1>Create Form</h1>
</div>

<form method="POST" action="/cms/forms">
    {{ csrf_field() | raw }}

    {# ===== Basic Info ===== #}
    <div class="card" style="margin-bottom: var(--space-500);">
        <div class="card-header">
            <h3>Basic Information</h3>
        </div>
        <div class="card-body">
            <div class="form-row">
                <div class="form-group">
                    <label for="name">Form Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ flash('_old_input').name ?? '' }}"
                           placeholder="e.g. Contact Form" required>
                    {% if flash('errors').name is defined %}
                        <div class="invalid-feedback">{{ flash('errors').name }}</div>
                    {% endif %}
                </div>
                <div class="form-group">
                    <label for="slug">Slug</label>
                    <input type="text" id="slug" name="slug" class="form-control"
                           value="{{ flash('_old_input').slug ?? '' }}"
                           placeholder="Auto-generated from name">
                    {% if flash('errors').slug is defined %}
                        <div class="invalid-feedback">{{ flash('errors').slug }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="form-control"
                          rows="3" placeholder="Optional description of this form">{{ flash('_old_input').description ?? '' }}</textarea>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="status">Status</label>
                    <select id="status" name="status" class="form-control">
                        <option value="draft" {{ (flash('_old_input').status ?? '') == 'draft' ? 'selected' : '' }}>Draft</option>
                        <option value="active" {{ (flash('_old_input').status ?? '') == 'active' ? 'selected' : '' }}>Active</option>
                        <option value="archived" {{ (flash('_old_input').status ?? '') == 'archived' ? 'selected' : '' }}>Archived</option>
                    </select>
                </div>
                <div class="form-group">
                    <label class="toggle-label">
                        Multi-step Form
                        <span class="toggle-switch">
                            <input type="checkbox" name="is_multi_step" value="1"
                                   {{ (flash('_old_input').is_multi_step ?? '') ? 'checked' : '' }}>
                            <span class="toggle-slider"></span>
                        </span>
                    </label>
                    <small class="text-muted">Split the form into multiple steps/pages.</small>
                </div>
            </div>
        </div>
    </div>

    {# ===== Settings ===== #}
    <div class="card" style="margin-bottom: var(--space-500);">
        <div class="card-header">
            <h3>Settings</h3>
        </div>
        <div class="card-body">
            <div class="form-row">
                <div class="form-group">
                    <label for="submit_button_text">Submit Button Text</label>
                    <input type="text" id="submit_button_text" name="settings[submit_button_text]" class="form-control"
                           value="{{ flash('_old_input').settings.submit_button_text ?? 'Submit' }}"
                           placeholder="Submit">
                </div>
                <div class="form-group">
                    <label for="redirect_url">Redirect URL</label>
                    <input type="url" id="redirect_url" name="settings[redirect_url]" class="form-control"
                           value="{{ flash('_old_input').settings.redirect_url ?? '' }}"
                           placeholder="https://example.com/thank-you (optional)">
                </div>
            </div>

            <div class="form-group">
                <label for="success_message">Success Message</label>
                <textarea id="success_message" name="settings[success_message]" class="form-control"
                          rows="2" placeholder="Thank you for your submission!">{{ flash('_old_input').settings.success_message ?? '' }}</textarea>
                <small class="text-muted">Shown after successful submission if no redirect URL is set.</small>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="toggle-label">
                        Email Notifications
                        <span class="toggle-switch">
                            <input type="checkbox" name="settings[notify_email]" value="1" id="notify_email_toggle"
                                   {{ (flash('_old_input').settings.notify_email ?? '') ? 'checked' : '' }}>
                            <span class="toggle-slider"></span>
                        </span>
                    </label>
                </div>
                <div class="form-group" id="email_to_group" style="{{ (flash('_old_input').settings.notify_email ?? '') ? '' : 'display:none;' }}">
                    <label for="notify_email_to">Email To</label>
                    <input type="email" id="notify_email_to" name="settings[notify_email_to]" class="form-control"
                           value="{{ flash('_old_input').settings.notify_email_to ?? '' }}"
                           placeholder="admin@example.com">
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="storage_mode">Storage Mode</label>
                    <select id="storage_mode" name="settings[storage_mode]" class="form-control">
                        <option value="submissions" {{ (flash('_old_input').settings.storage_mode ?? '') == 'submissions' ? 'selected' : '' }}>Submissions (Form Builder table)</option>
                        <option value="collection" {{ (flash('_old_input').settings.storage_mode ?? '') == 'collection' ? 'selected' : '' }}>Collection (CMS collection)</option>
                    </select>
                    <small class="text-muted">Where form data is stored after submission.</small>
                </div>
                <div class="form-group">
                    <label for="rate_limit">Rate Limit (per hour)</label>
                    <input type="number" id="rate_limit" name="settings[rate_limit]" class="form-control"
                           value="{{ flash('_old_input').settings.rate_limit ?? '60' }}"
                           min="0" max="1000" placeholder="60">
                    <small class="text-muted">Max submissions per IP per hour. 0 = unlimited.</small>
                </div>
            </div>

            <div class="form-group">
                <label class="toggle-label">
                    Honeypot Protection
                    <span class="toggle-switch">
                        <input type="checkbox" name="settings[honeypot]" value="1"
                               {{ (flash('_old_input').settings.honeypot ?? '1') ? 'checked' : '' }}>
                        <span class="toggle-slider"></span>
                    </span>
                </label>
                <small class="text-muted">Adds a hidden field to catch bots. Recommended.</small>
            </div>
        </div>
    </div>

    {# ===== Payment (Collapsible) ===== #}
    <div class="card" style="margin-bottom: var(--space-500);">
        <div class="card-header" style="cursor: pointer;" id="payment-toggle">
            <h3 style="display: flex; align-items: center; justify-content: space-between;">
                Payment Settings
                <span id="payment-chevron" style="font-size: 0.75rem; color: var(--text-secondary);">&#9660;</span>
            </h3>
        </div>
        <div class="card-body" id="payment-section" style="display: none;">
            <div class="form-group">
                <label class="toggle-label">
                    Enable Payment
                    <span class="toggle-switch">
                        <input type="checkbox" name="settings[payment_enabled]" value="1" id="payment_enabled_toggle"
                               {{ (flash('_old_input').settings.payment_enabled ?? '') ? 'checked' : '' }}>
                        <span class="toggle-slider"></span>
                    </span>
                </label>
            </div>

            <div id="payment-fields" style="{{ (flash('_old_input').settings.payment_enabled ?? '') ? '' : 'display:none;' }}">
                <div class="form-row">
                    <div class="form-group">
                        <label for="payment_gateway">Payment Gateway</label>
                        <select id="payment_gateway" name="settings[payment_gateway]" class="form-control">
                            <option value="stripe" {{ (flash('_old_input').settings.payment_gateway ?? '') == 'stripe' ? 'selected' : '' }}>Stripe</option>
                            <option value="paypal" {{ (flash('_old_input').settings.payment_gateway ?? '') == 'paypal' ? 'selected' : '' }}>PayPal</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="payment_currency">Currency</label>
                        <input type="text" id="payment_currency" name="settings[payment_currency]" class="form-control"
                               value="{{ flash('_old_input').settings.payment_currency ?? 'USD' }}"
                               placeholder="USD" maxlength="3">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="payment_amount_field">Amount Field Slug</label>
                        <input type="text" id="payment_amount_field" name="settings[payment_amount_field]" class="form-control"
                               value="{{ flash('_old_input').settings.payment_amount_field ?? '' }}"
                               placeholder="e.g. amount (leave empty for fixed)">
                        <small class="text-muted">Slug of a number field that holds the amount. Leave empty to use fixed amount.</small>
                    </div>
                    <div class="form-group">
                        <label for="payment_fixed_amount">Fixed Amount</label>
                        <input type="number" id="payment_fixed_amount" name="settings[payment_fixed_amount]" class="form-control"
                               value="{{ flash('_old_input').settings.payment_fixed_amount ?? '' }}"
                               step="0.01" min="0" placeholder="0.00">
                        <small class="text-muted">Used when no amount field is specified.</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">Create Form</button>
        <a href="/cms/forms" class="btn btn-outline">Cancel</a>
    </div>
</form>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    // Auto-slug from name
    var nameEl = document.getElementById('name');
    var slugEl = document.getElementById('slug');
    if (nameEl && slugEl) {
        nameEl.addEventListener('input', function() {
            if (!slugEl.dataset.manual) {
                slugEl.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            }
        });
        slugEl.addEventListener('input', function() {
            this.dataset.manual = '1';
        });
    }

    // Toggle email-to field
    var notifyToggle = document.getElementById('notify_email_toggle');
    var emailGroup = document.getElementById('email_to_group');
    if (notifyToggle && emailGroup) {
        notifyToggle.addEventListener('change', function() {
            emailGroup.style.display = this.checked ? '' : 'none';
        });
    }

    // Toggle payment section collapse
    var paymentToggle = document.getElementById('payment-toggle');
    var paymentSection = document.getElementById('payment-section');
    var paymentChevron = document.getElementById('payment-chevron');
    if (paymentToggle && paymentSection) {
        paymentToggle.addEventListener('click', function() {
            var hidden = paymentSection.style.display === 'none';
            paymentSection.style.display = hidden ? '' : 'none';
            paymentChevron.innerHTML = hidden ? '&#9650;' : '&#9660;';
        });
    }

    // Toggle payment fields
    var paymentEnabled = document.getElementById('payment_enabled_toggle');
    var paymentFields = document.getElementById('payment-fields');
    if (paymentEnabled && paymentFields) {
        paymentEnabled.addEventListener('change', function() {
            paymentFields.style.display = this.checked ? '' : 'none';
        });
    }
});
</script>
{% endblock %}
{% endblock %}
