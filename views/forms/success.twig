<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ form.name }} - Submission Received</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #f5f7fa;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
        }
        .success-container {
            background: #fff;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,0.08);
            padding: 3rem;
            max-width: 500px;
            width: 100%;
            text-align: center;
        }
        .success-icon {
            width: 64px; height: 64px;
            border-radius: 50%;
            background: #22c55e;
            color: #fff; font-size: 2rem;
            display: flex; align-items: center; justify-content: center;
            margin: 0 auto 1.5rem;
        }
        .error-icon { background: #ef4444; }
        h1 { font-size: 1.5rem; margin-bottom: 0.75rem; color: #111; }
        p { color: #555; line-height: 1.6; margin-bottom: 1.5rem; }
        .btn {
            display: inline-block; padding: 0.6rem 1.5rem;
            border-radius: 6px; text-decoration: none;
            font-size: 0.95rem; font-weight: 500;
            background: #3b82f6; color: #fff;
            transition: background 0.2s;
        }
        .btn:hover { background: #2563eb; }
    </style>
</head>
<body>
    <div class="success-container">
        {% if errors is defined and errors.payment is defined %}
            <div class="success-icon error-icon">&#10007;</div>
            <h1>Payment Issue</h1>
            <p>{{ errors.payment }}</p>
        {% else %}
            <div class="success-icon">&#10003;</div>
            <h1>Thank You!</h1>
            <p>{{ message }}</p>
        {% endif %}
        <a href="/" class="btn">Back to Home</a>
    </div>
</body>
</html>
