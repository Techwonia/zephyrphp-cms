{% extends "@cms/layouts/cms.twig" %}

{% block title %}Submission #{{ submission.id }} - {{ form.name }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/forms">Forms</a> /
    <a href="/cms/forms/{{ form.slug }}">{{ form.name }}</a> /
    <a href="/cms/forms/{{ form.slug }}/submissions">Submissions</a> /
    #{{ submission.id }}
</div>

<div class="page-header">
    <h1>Submission #{{ submission.id }}</h1>
    <div class="page-actions">
        <a href="/cms/forms/{{ form.slug }}/submissions" class="btn btn-outline">Back to Submissions</a>
        <form method="POST" action="/cms/forms/{{ form.slug }}/submissions/{{ submission.id }}/delete"
              style="display:inline" class="confirm-delete"
              data-message="Delete this submission? This cannot be undone.">
            {{ csrf_field() | raw }}
            <button type="submit" class="btn btn-danger">Delete Submission</button>
        </form>
    </div>
</div>

{# ===== Submission Data ===== #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header">
        <h3>Form Data</h3>
    </div>
    <div class="card-body">
        {% for field in fields %}
        <div class="field-row">
            <div class="field-info">
                <div class="field-name">{{ field.label }}</div>
                <div class="field-meta">
                    <code>{{ field.slug }}</code>
                    &middot; <span class="field-badge">{{ field.type }}</span>
                </div>
            </div>
            <div style="flex: 1; text-align: right; font-size: var(--font-sm); word-break: break-word;">
                {% set value = submission[field.slug] ?? null %}
                {% if value is not null and value != '' %}
                    {{ value }}
                {% else %}
                    <span class="text-muted">&mdash;</span>
                {% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
</div>

{# ===== Metadata ===== #}
<div class="card" style="margin-bottom: var(--space-500);">
    <div class="card-header">
        <h3>Submission Metadata</h3>
    </div>
    <div class="card-body">
        <div class="field-row">
            <div class="field-info"><div class="field-name">Status</div></div>
            <div>
                {% set status = submission._status ?? 'completed' %}
                {% if status == 'completed' %}
                    <span class="badge badge-success">Completed</span>
                {% elseif status == 'pending_payment' %}
                    <span class="badge badge-warning">Pending Payment</span>
                {% else %}
                    <span class="badge badge-default">{{ status }}</span>
                {% endif %}
            </div>
        </div>
        <div class="field-row">
            <div class="field-info"><div class="field-name">Submitted At</div></div>
            <div style="font-size: var(--font-sm);">{{ submission.created_at ? submission.created_at|date('F d, Y \\a\\t H:i:s') : '&mdash;' }}</div>
        </div>
        <div class="field-row">
            <div class="field-info"><div class="field-name">IP Address</div></div>
            <div><code>{{ submission._ip ?? '&mdash;' }}</code></div>
        </div>
        <div class="field-row">
            <div class="field-info"><div class="field-name">User Agent</div></div>
            <div style="font-size: var(--font-xs); max-width: 400px; word-break: break-word;">{{ submission._user_agent ?? '&mdash;' }}</div>
        </div>
    </div>
</div>
{% endblock %}
