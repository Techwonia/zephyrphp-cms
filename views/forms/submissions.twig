{% extends "@cms/layouts/cms.twig" %}

{% block title %}Submissions - {{ form.name }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/forms">Forms</a> / <a href="/cms/forms/{{ form.slug }}">{{ form.name }}</a> / Submissions
</div>

<div class="page-header">
    <h1>Submissions &mdash; {{ form.name }}</h1>
    <div class="page-actions">
        <a href="/cms/forms/{{ form.slug }}/submissions/export" class="btn btn-outline">Export CSV</a>
        <a href="/cms/forms/{{ form.slug }}" class="btn btn-outline">Back to Form</a>
    </div>
</div>

{% if submissions|length > 0 %}
<div class="card">
    <div class="card-body">
        <div class="table-responsive">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Status</th>
                        {% for field in display_fields %}
                        <th>{{ field.label }}</th>
                        {% endfor %}
                        <th>Submitted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for submission in submissions %}
                    <tr>
                        <td><code>#{{ submission.id }}</code></td>
                        <td>
                            {% set status = submission._status ?? 'completed' %}
                            {% if status == 'completed' %}
                                <span class="badge badge-success">Completed</span>
                            {% elseif status == 'pending_payment' %}
                                <span class="badge badge-warning">Pending</span>
                            {% else %}
                                <span class="badge badge-default">{{ status }}</span>
                            {% endif %}
                        </td>
                        {% for field in display_fields %}
                        <td>
                            <span class="truncate">{{ submission[field.slug] ?? '&mdash;' }}</span>
                        </td>
                        {% endfor %}
                        <td>{{ submission.created_at ? submission.created_at|date('M d, Y H:i') : '&mdash;' }}</td>
                        <td class="actions-cell">
                            <a href="/cms/forms/{{ form.slug }}/submissions/{{ submission.id }}" class="btn btn-sm btn-outline">View</a>
                            <form method="POST" action="/cms/forms/{{ form.slug }}/submissions/{{ submission.id }}/delete"
                                  style="display:inline" class="confirm-delete"
                                  data-message="Delete submission #{{ submission.id }}? This cannot be undone.">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                            </form>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% else %}
<div class="empty-state">
    <h3>No submissions yet</h3>
    <p>Submissions will appear here once visitors start filling out your form.</p>
    <a href="/cms/forms/{{ form.slug }}" class="btn btn-outline">Back to Form</a>
</div>
{% endif %}
{% endblock %}
