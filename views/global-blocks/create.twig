{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create Global Block{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> /
    <a href="{{ admin_url('global-blocks') }}">Global Blocks</a> / New
</div>

<div class="page-header">
    <h1>Create Global Block</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="{{ admin_url('global-blocks') }}">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="name">Name *</label>
                <input type="text" id="name" name="name" class="form-control" required
                       placeholder="e.g. Announcement Bar" value="{{ flash('_old_input').name ?? '' }}">
            </div>

            <div class="form-group">
                <label for="slug">Slug *</label>
                <input type="text" id="slug" name="slug" class="form-control"
                       placeholder="auto-generated-from-name" value="{{ flash('_old_input').slug ?? '' }}">
                <p class="text-muted">Lowercase letters, numbers, and hyphens only. Auto-generated from name if left empty.</p>
            </div>

            <div class="form-group">
                <label for="type">Type</label>
                <select id="type" name="type" class="form-control">
                    <option value="html">HTML - Static HTML content</option>
                    <option value="twig">Twig - Dynamic content with Twig syntax</option>
                </select>
            </div>

            <div class="form-group">
                <label for="content">Content</label>
                <textarea id="content" name="content" class="form-control" rows="15"
                          style="font-family: monospace; font-size: var(--font-sm);"
                          placeholder="Enter your HTML or Twig content here...">{{ flash('_old_input').content ?? '' }}</textarea>
            </div>

            <div class="form-group">
                <label style="display: flex; align-items: center; gap: var(--space-200); cursor: pointer;">
                    <input type="hidden" name="active" value="0">
                    <input type="checkbox" name="active" value="1" checked>
                    <span>Active</span>
                </label>
                <p class="text-muted">Inactive blocks will not render on the frontend.</p>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Block</button>
                <a href="{{ admin_url('global-blocks') }}" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

<script nonce="{{ csp_nonce() }}">
document.getElementById('name').addEventListener('input', function() {
    var slugField = document.getElementById('slug');
    if (slugField.dataset.manual === 'true') return;
    var slug = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
    slugField.value = slug;
});

document.getElementById('slug').addEventListener('input', function() {
    this.dataset.manual = 'true';
});
</script>
{% endblock %}
