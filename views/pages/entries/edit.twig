{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Page — {{ pageType.getName() }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/pages">Pages</a> /
    <a href="/cms/pages/{{ pageType.getSlug() }}/list">{{ pageType.getName() }}</a> / Edit
</div>

<div class="page-header">
    <h1>Edit Page</h1>
    <div class="page-actions">
        {% if entry.status == 'published' %}
            <a href="{{ pageType.getPublicUrl(entry.slug) }}" class="btn btn-outline" target="_blank">View Page</a>
        {% endif %}
        <a href="/cms/pages/{{ pageType.getSlug() }}/preview/{{ entry.id }}" class="btn btn-outline" target="_blank">Preview</a>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="/cms/pages/{{ pageType.getSlug() }}/{{ entry.id }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="title">Title *</label>
                <input type="text" id="title" name="title" class="form-control"
                       value="{{ entry.title }}" required>
                {% if flash('errors').title is defined %}
                    <div class="invalid-feedback">{{ flash('errors').title }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="slug">URL Slug *</label>
                <input type="text" id="slug" name="slug" class="form-control"
                       value="{{ entry.slug }}">
                <p class="text-muted">
                    {% if pageType.getUrlPrefix() %}
                        Page URL: {{ pageType.getPublicUrl(entry.slug) }}
                    {% else %}
                        Page URL: /page/{{ entry.slug }}
                    {% endif %}
                </p>
                {% if flash('errors').slug is defined %}
                    <div class="invalid-feedback">{{ flash('errors').slug }}</div>
                {% endif %}
            </div>

            {# Custom Fields #}
            {% for field in fields %}
            <div class="form-group">
                <label for="field_{{ field.getSlug() }}">{{ field.getName() }}{% if field.isRequired() %} *{% endif %}</label>
                {% if field.getType() == 'textarea' or field.getType() == 'richtext' %}
                    <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control"
                              rows="5" {% if field.isRequired() %}required{% endif %}>{{ entry[field.getSlug()] ?? '' }}</textarea>
                {% elseif field.getType() == 'boolean' %}
                    <div>
                        <label><input type="checkbox" name="{{ field.getSlug() }}" value="1"
                                      {% if entry[field.getSlug()] %}checked{% endif %}> Yes</label>
                    </div>
                {% elseif field.getType() == 'select' and field.getOptions().choices is defined %}
                    <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control">
                        <option value="">— Select —</option>
                        {% for choice in field.getOptions().choices %}
                            <option value="{{ choice }}" {% if entry[field.getSlug()] == choice %}selected{% endif %}>{{ choice }}</option>
                        {% endfor %}
                    </select>
                {% elseif field.getType() == 'image' or field.getType() == 'file' %}
                    {% if entry[field.getSlug()] %}
                        <div style="margin-bottom: 8px;">
                            {% if field.getType() == 'image' %}
                                <img src="/{{ entry[field.getSlug()] }}" alt="" style="max-height: 100px; border-radius: 4px;">
                            {% else %}
                                <a href="/{{ entry[field.getSlug()] }}" target="_blank">{{ entry[field.getSlug()] }}</a>
                            {% endif %}
                        </div>
                    {% endif %}
                    <input type="file" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control">
                {% elseif field.getType() == 'number' %}
                    <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control"
                           value="{{ entry[field.getSlug()] ?? '' }}"
                           {% if field.isRequired() %}required{% endif %}>
                {% elseif field.getType() == 'date' %}
                    <input type="date" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control"
                           value="{{ entry[field.getSlug()] ?? '' }}"
                           {% if field.isRequired() %}required{% endif %}>
                {% elseif field.getType() == 'datetime' %}
                    <input type="datetime-local" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control"
                           value="{{ entry[field.getSlug()] is defined ? entry[field.getSlug()]|date('Y-m-d\\TH:i') : '' }}"
                           {% if field.isRequired() %}required{% endif %}>
                {% else %}
                    <input type="text" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" class="form-control"
                           value="{{ entry[field.getSlug()] ?? '' }}"
                           {% if field.isRequired() %}required{% endif %}>
                {% endif %}
                {% if flash('errors')[field.getSlug()] is defined %}
                    <div class="invalid-feedback">{{ flash('errors')[field.getSlug()] }}</div>
                {% endif %}
            </div>
            {% endfor %}

            {# SEO Fields #}
            {% if pageType.hasSeo() %}
            <div style="margin-top: var(--space-400); padding-top: var(--space-400); border-top: 1px solid var(--border-color);">
                <h3 style="margin-bottom: var(--space-200);">SEO</h3>
                <div class="form-group">
                    <label for="seo_title">SEO Title</label>
                    <input type="text" id="seo_title" name="seo_title" class="form-control"
                           value="{{ entry.seo_title ?? '' }}"
                           placeholder="Override page title for search engines">
                </div>
                <div class="form-group">
                    <label for="seo_description">SEO Description</label>
                    <textarea id="seo_description" name="seo_description" class="form-control"
                              rows="3" placeholder="Meta description">{{ entry.seo_description ?? '' }}</textarea>
                </div>
                <div class="form-group">
                    <label for="seo_image">SEO Image</label>
                    {% if entry.seo_image %}
                        <div style="margin-bottom: 8px;">
                            <img src="/{{ entry.seo_image }}" alt="" style="max-height: 80px; border-radius: 4px;">
                        </div>
                    {% endif %}
                    <input type="file" id="seo_image" name="seo_image" class="form-control" accept="image/*">
                </div>
            </div>
            {% endif %}

            {# Status #}
            {% if pageType.isPublishable() %}
            <div class="form-group" style="margin-top: var(--space-400);">
                <label for="status">Status</label>
                <select id="status" name="status" class="form-control">
                    <option value="draft" {% if (entry.status ?? 'draft') == 'draft' %}selected{% endif %}>Draft</option>
                    <option value="published" {% if (entry.status ?? '') == 'published' %}selected{% endif %}>Published</option>
                </select>
                {% if entry.published_at %}
                    <p class="text-muted">Published at: {{ entry.published_at }}</p>
                {% endif %}
            </div>
            {% endif %}

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Page</button>
                <a href="/cms/pages/{{ pageType.getSlug() }}/list" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>
{% endblock %}
