{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create Page Type{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/pages">Pages</a> / Create Page Type
</div>

<div class="page-header">
    <h1>Create Page Type</h1>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="/cms/pages/types">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="name">Page Type Name *</label>
                <input type="text" id="name" name="name" class="form-control"
                       value="{{ flash('_old_input').name ?? '' }}"
                       placeholder="e.g. Blog Post" required>
                {% if flash('errors').name is defined %}
                    <div class="invalid-feedback">{{ flash('errors').name }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label for="slug">Slug</label>
                <input type="text" id="slug" name="slug" class="form-control"
                       value="{{ flash('_old_input').slug ?? '' }}"
                       placeholder="Auto-generated from name">
                <p class="text-muted">Used for table name and template. Leave empty to auto-generate.</p>
                {% if flash('errors').slug is defined %}
                    <div class="invalid-feedback">{{ flash('errors').slug }}</div>
                {% endif %}
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label for="page_mode">Page Mode *</label>
                    <select id="page_mode" name="page_mode" class="form-control">
                        <option value="static" {% if (flash('_old_input').page_mode ?? 'static') == 'static' %}selected{% endif %}>Static</option>
                        <option value="dynamic" {% if (flash('_old_input').page_mode ?? '') == 'dynamic' %}selected{% endif %}>Dynamic (Collection)</option>
                    </select>
                    <p class="text-muted">Static: single page with fields. Dynamic: listing + detail pages.</p>
                </div>
                <div class="form-group">
                    <label for="layout">Layout</label>
                    <select id="layout" name="layout" class="form-control">
                        {% for key, label in layouts %}
                            <option value="{{ key }}" {% if (flash('_old_input').layout ?? 'base') == key %}selected{% endif %}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="form-group">
                <label for="url_prefix">URL Prefix</label>
                <input type="text" id="url_prefix" name="url_prefix" class="form-control"
                       value="{{ flash('_old_input').url_prefix ?? '' }}"
                       placeholder="e.g. /blog or /about">
                <p class="text-muted">Custom URL path. Leave empty to use /page/{slug} fallback.</p>
            </div>

            <div class="form-group" id="items-per-page-group" style="display:none;">
                <label for="items_per_page">Items Per Page</label>
                <input type="number" id="items_per_page" name="items_per_page" class="form-control"
                       value="{{ flash('_old_input').items_per_page ?? 10 }}" min="1" max="100">
            </div>

            <div class="form-group">
                <label for="template">Template Name</label>
                <input type="text" id="template" name="template" class="form-control"
                       value="{{ flash('_old_input').template ?? '' }}"
                       placeholder="Auto-generated from slug">
                <p class="text-muted">Template file name. Auto-generated in your theme's templates/ directory.</p>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="form-control"
                          rows="3" placeholder="Optional description">{{ flash('_old_input').description ?? '' }}</textarea>
            </div>

            <div class="form-inline-checks">
                <label>
                    <input type="checkbox" name="has_seo" value="1" checked>
                    Enable SEO fields (title, description, image)
                </label>
                <label>
                    <input type="checkbox" name="is_publishable" value="1" checked>
                    Publishable (draft/published status)
                </label>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Create Page Type</button>
                <a href="/cms/pages" class="btn btn-outline">Cancel</a>
            </div>
        </form>
    </div>
</div>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.getElementById('name').addEventListener('input', function() {
    var slugField = document.getElementById('slug');
    if (!slugField.dataset.manual) {
        slugField.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
    }
});
document.getElementById('slug').addEventListener('input', function() {
    this.dataset.manual = '1';
});
document.getElementById('page_mode').addEventListener('change', function() {
    var ippGroup = document.getElementById('items-per-page-group');
    ippGroup.style.display = this.value === 'dynamic' ? 'block' : 'none';
});
document.getElementById('page_mode').dispatchEvent(new Event('change'));
</script>
{% endblock %}
{% endblock %}
