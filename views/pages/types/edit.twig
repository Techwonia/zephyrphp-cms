{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit {{ pageType.getName() }}{% endblock %}

{% block styles %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css">
<style nonce="{{ csp_nonce() }}">
    .field-system {
        opacity: 0.7;
        border-left: 3px solid var(--accent-color);
        padding-left: var(--spacing-sm);
    }
    .field-system .field-name {
        font-size: 0.9rem;
    }
    .template-editor-wrap {
        display: grid;
        grid-template-columns: 1fr 220px;
        gap: 1rem;
    }
    .template-sub-tabs {
        display: flex;
        gap: 0;
        margin-bottom: 0;
    }
    .template-sub-tab {
        padding: 0.5rem 1rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-bottom: none;
        cursor: pointer;
        font-size: 0.85rem;
        color: var(--text-muted);
    }
    .template-sub-tab.active {
        background: #282a36;
        color: #f8f8f2;
        font-weight: 600;
    }
    .CodeMirror {
        height: 500px;
        border: 1px solid var(--border-color);
        border-radius: 0 0 6px 6px;
        font-size: 13px;
    }
    .snippet-sidebar {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }
    .snippet-sidebar h4 {
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin-bottom: 0.25rem;
    }
    .snippet-btn {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.75rem;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        cursor: pointer;
        font-size: 0.8rem;
        text-align: left;
        transition: background 0.15s;
    }
    .snippet-btn:hover {
        background: var(--bg-color);
        border-color: var(--accent-color);
    }
    .snippet-icon {
        font-size: 1.1rem;
        width: 24px;
        text-align: center;
    }
    .save-status {
        display: inline-block;
        margin-left: 1rem;
        font-size: 0.85rem;
        opacity: 0;
        transition: opacity 0.3s;
    }
    .save-status.show {
        opacity: 1;
    }
    @media (max-width: 768px) {
        .template-editor-wrap {
            grid-template-columns: 1fr;
        }
    }
</style>
{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/pages">Pages</a> / {{ pageType.getName() }}
</div>

<div class="page-header">
    <h1>{{ pageType.getName() }}</h1>
    <div class="page-actions">
        <a href="/cms/pages/{{ pageType.getSlug() }}/list" class="btn btn-outline">View Pages ({{ pageCount }})</a>
    </div>
</div>

<div class="tab-nav">
    <button class="tab-btn active" data-tab="tab-settings">Settings</button>
    <button class="tab-btn" data-tab="tab-fields">Fields ({{ fields|length }})</button>
    <button class="tab-btn" data-tab="tab-template">Template Editor</button>
</div>

{# ===== SETTINGS TAB ===== #}
<div id="tab-settings" class="tab-panel active">
    <div class="card">
        <div class="card-body">
            <form method="POST" action="/cms/pages/types/{{ pageType.getSlug() }}">
                {{ csrf_field() | raw }}

                <div class="form-group">
                    <label for="name">Page Type Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ pageType.getName() }}" required>
                </div>

                <div class="form-group">
                    <label>Slug</label>
                    <input type="text" class="form-control" value="{{ pageType.getSlug() }}" disabled>
                    <p class="text-muted">Slug cannot be changed after creation (table: cms_pt_{{ pageType.getSlug() }}).</p>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label for="page_mode">Page Mode</label>
                        <select id="page_mode" name="page_mode" class="form-control">
                            <option value="static" {% if pageType.getPageMode() == 'static' %}selected{% endif %}>Static</option>
                            <option value="dynamic" {% if pageType.getPageMode() == 'dynamic' %}selected{% endif %}>Dynamic (Collection)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="layout">Layout</label>
                        <select id="layout" name="layout" class="form-control">
                            {% for key, label in layouts %}
                                <option value="{{ key }}" {% if pageType.getLayout() == key %}selected{% endif %}>{{ label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="url_prefix">URL Prefix</label>
                    <input type="text" id="url_prefix" name="url_prefix" class="form-control"
                           value="{{ pageType.getUrlPrefix() ?? '' }}"
                           placeholder="e.g. /blog or /about">
                    <p class="text-muted">Custom URL path. Leave empty to use /page/{slug} fallback.</p>
                </div>

                <div class="form-group" id="edit-items-per-page" {% if pageType.getPageMode() != 'dynamic' %}style="display:none;"{% endif %}>
                    <label for="items_per_page">Items Per Page</label>
                    <input type="number" id="items_per_page" name="items_per_page" class="form-control"
                           value="{{ pageType.getItemsPerPage() }}" min="1" max="100">
                </div>

                <div class="form-group">
                    <label for="template">Template Name</label>
                    <input type="text" id="template" name="template" class="form-control"
                           value="{{ pageType.getTemplate() }}">
                    <p class="text-muted">Template file in your theme's templates/ directory.</p>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" class="form-control"
                              rows="3">{{ pageType.getDescription() }}</textarea>
                </div>

                <div class="form-inline-checks">
                    <label>
                        <input type="checkbox" name="has_seo" value="1"
                               {% if pageType.hasSeo() %}checked{% endif %}>
                        Enable SEO fields
                    </label>
                    <label>
                        <input type="checkbox" name="is_publishable" value="1"
                               {% if pageType.isPublishable() %}checked{% endif %}>
                        Publishable
                    </label>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Settings</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ===== FIELDS TAB ===== #}
<div id="tab-fields" class="tab-panel">
    <div class="card">
        <div class="card-header">
            <h3>Fields</h3>
        </div>
        <div class="card-body">
            {# System fields #}
            <div class="system-fields-section">
                <h4 class="text-muted" style="margin-bottom: var(--spacing-sm); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">System Fields</h4>

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">ID</div>
                        <div class="field-meta"><code>id</code> &middot; <span class="field-badge">integer (auto-increment)</span> <span class="field-badge">primary key</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Title</div>
                        <div class="field-meta"><code>title</code> &middot; <span class="field-badge">string (255)</span> <span class="field-badge required">required</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Slug (URL)</div>
                        <div class="field-meta"><code>slug</code> &middot; <span class="field-badge">string (255)</span> <span class="field-badge">unique</span> <span class="field-badge required">required</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                {% if pageType.hasSeo() %}
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">SEO Title</div>
                        <div class="field-meta"><code>seo_title</code> &middot; <span class="field-badge">string</span> <span class="field-badge">nullable</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">SEO Description</div>
                        <div class="field-meta"><code>seo_description</code> &middot; <span class="field-badge">text</span> <span class="field-badge">nullable</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">SEO Image</div>
                        <div class="field-meta"><code>seo_image</code> &middot; <span class="field-badge">string</span> <span class="field-badge">nullable</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                {% endif %}
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Status</div>
                        <div class="field-meta"><code>status</code> &middot; <span class="field-badge">string</span> <span class="field-badge">default: draft</span></div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
            </div>

            {# Custom fields #}
            {% if fields|length > 0 %}
                <h4 class="text-muted" style="margin: var(--spacing-md) 0 var(--spacing-sm); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">Custom Fields</h4>
                {% for field in fields %}
                <div class="field-row">
                    <div class="field-info">
                        <div class="field-name">{{ field.getName() }}</div>
                        <div class="field-meta">
                            <code>{{ field.getSlug() }}</code>
                            &middot; <span class="field-badge">{{ field.getType() }}</span>
                            {% if field.isRequired() %}<span class="field-badge required">required</span>{% endif %}
                            {% if field.isSearchable() %}<span class="field-badge">searchable</span>{% endif %}
                            {% if not field.isListable() %}<span class="field-badge">hidden</span>{% endif %}
                        </div>
                    </div>
                    <div>
                        <form method="POST" action="/cms/pages/types/{{ pageType.getSlug() }}/fields/{{ field.getId() }}/delete"
                              style="display:inline"
                              class="confirm-delete" data-message="Delete field '{{ field.getName() }}'? Column data will be lost!">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="empty-state" style="margin-top: var(--spacing-md);">
                    <p>No custom fields defined yet. Add your first field below.</p>
                </div>
            {% endif %}

            {# Add Field Form #}
            <div class="add-field-form">
                <h4>Add New Field</h4>
                <form method="POST" action="/cms/pages/types/{{ pageType.getSlug() }}/fields">
                    {{ csrf_field() | raw }}

                    <div class="form-row">
                        <div class="form-group">
                            <label for="field_name">Name *</label>
                            <input type="text" id="field_name" name="field_name" class="form-control"
                                   placeholder="e.g. Hero Title" required>
                        </div>
                        <div class="form-group">
                            <label for="field_slug">Slug</label>
                            <input type="text" id="field_slug" name="field_slug" class="form-control"
                                   placeholder="Auto from name">
                        </div>
                        <div class="form-group">
                            <label for="field_type">Type</label>
                            <select id="field_type" name="field_type" class="form-control">
                                {% for typeKey, typeLabel in fieldTypes %}
                                    <option value="{{ typeKey }}">{{ typeLabel }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="form-inline-checks">
                        <label><input type="checkbox" name="field_required" value="1"> Required</label>
                        <label><input type="checkbox" name="field_listable" value="1" checked> Show in list</label>
                        <label><input type="checkbox" name="field_searchable" value="1"> Searchable</label>
                    </div>

                    <div class="form-group" id="select-options-group" style="display: none;">
                        <label for="field_options">Options (one per line)</label>
                        <textarea id="field_options" name="field_options" class="form-control" rows="3"
                                  placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                    </div>

                    <div class="form-group">
                        <label for="field_default">Default Value</label>
                        <input type="text" id="field_default" name="field_default" class="form-control"
                               placeholder="Optional">
                    </div>

                    <button type="submit" class="btn btn-primary">Add Field</button>
                </form>
            </div>
        </div>
    </div>
</div>

{# ===== TEMPLATE EDITOR TAB ===== #}
<div id="tab-template" class="tab-panel">
    <div class="card">
        <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
            <h3>Template Editor</h3>
            <div>
                <button id="save-template-btn" class="btn btn-primary btn-sm">Save Template</button>
                <span id="save-status" class="save-status"></span>
            </div>
        </div>
        <div class="card-body" style="padding:0;">
            <div class="template-editor-wrap" style="padding:1rem;">
                <div class="editor-main">
                    <div class="template-sub-tabs">
                        <button class="template-sub-tab active" data-editor="page">Page Template</button>
                        {% if pageType.isDynamic() %}
                        <button class="template-sub-tab" data-editor="detail">Detail Template</button>
                        {% endif %}
                    </div>
                    <div id="editor-page-wrap">
                        <textarea id="editor-page">{{ templateContent }}</textarea>
                    </div>
                    <div id="editor-detail-wrap" style="display:none;">
                        <textarea id="editor-detail">{{ detailTemplateContent }}</textarea>
                    </div>
                </div>
                <div class="snippet-sidebar">
                    <h4>Blocks / Snippets</h4>
                    {% for snippet in snippets %}
                    <button class="snippet-btn" data-snippet="{{ loop.index0 }}">
                        <span class="snippet-icon">{{ snippet.icon|raw }}</span>
                        <span>{{ snippet.name }}</span>
                    </button>
                    {% endfor %}
                </div>
            </div>
        </div>
    </div>
</div>

{% block scripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/edit/closetag.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/edit/closebrackets.min.js"></script>
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    // Field slug auto-gen
    document.getElementById('field_name').addEventListener('input', function() {
        var slugField = document.getElementById('field_slug');
        if (!slugField.dataset.manual) {
            slugField.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
        }
    });
    document.getElementById('field_slug').addEventListener('input', function() {
        this.dataset.manual = '1';
    });
    document.getElementById('field_type').addEventListener('change', function() {
        var selectGroup = document.getElementById('select-options-group');
        selectGroup.style.display = this.value === 'select' ? 'block' : 'none';
    });

    // Page mode toggle for items_per_page
    var pageModeSelect = document.getElementById('page_mode');
    if (pageModeSelect) {
        pageModeSelect.addEventListener('change', function() {
            var ippGroup = document.getElementById('edit-items-per-page');
            if (ippGroup) ippGroup.style.display = this.value === 'dynamic' ? 'block' : 'none';
        });
    }

    // ===== CodeMirror Setup =====
    var cmOptions = {
        mode: 'htmlmixed',
        theme: 'dracula',
        lineNumbers: true,
        lineWrapping: true,
        autoCloseTags: true,
        autoCloseBrackets: true,
        indentUnit: 4,
        tabSize: 4,
        indentWithTabs: false
    };

    var editorPage = CodeMirror.fromTextArea(document.getElementById('editor-page'), cmOptions);
    var editorDetail = null;

    var detailWrap = document.getElementById('editor-detail');
    if (detailWrap) {
        editorDetail = CodeMirror.fromTextArea(detailWrap, cmOptions);
    }

    var activeEditor = 'page';

    // Template sub-tab switching
    document.querySelectorAll('.template-sub-tab').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var target = btn.dataset.editor;
            document.querySelectorAll('.template-sub-tab').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');

            document.getElementById('editor-page-wrap').style.display = target === 'page' ? 'block' : 'none';
            document.getElementById('editor-detail-wrap').style.display = target === 'detail' ? 'block' : 'none';

            activeEditor = target;

            if (target === 'page') editorPage.refresh();
            if (target === 'detail' && editorDetail) editorDetail.refresh();
        });
    });

    // Snippets data
    var snippets = {{ snippets|json_encode|raw }};

    document.querySelectorAll('.snippet-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var idx = parseInt(btn.dataset.snippet);
            var code = snippets[idx].code;
            var editor = activeEditor === 'detail' && editorDetail ? editorDetail : editorPage;
            var cursor = editor.getCursor();
            editor.replaceRange('\n' + code + '\n', cursor);
            editor.focus();
        });
    });

    // Save template
    var saveBtn = document.getElementById('save-template-btn');
    var saveStatus = document.getElementById('save-status');

    function saveTemplate(type) {
        var content = type === 'detail' && editorDetail ? editorDetail.getValue() : editorPage.getValue();

        saveStatus.textContent = 'Saving...';
        saveStatus.classList.add('show');

        fetch('/cms/pages/types/{{ pageType.getSlug() }}/template', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': '{{ csrf_token() }}'
            },
            body: JSON.stringify({ type: type, content: content })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                saveStatus.textContent = 'Saved!';
                saveStatus.style.color = '#4caf50';
            } else {
                saveStatus.textContent = 'Error: ' + (data.error || 'Unknown');
                saveStatus.style.color = '#f44336';
            }
            setTimeout(function() { saveStatus.classList.remove('show'); }, 2000);
        })
        .catch(function(err) {
            saveStatus.textContent = 'Network error';
            saveStatus.style.color = '#f44336';
            setTimeout(function() { saveStatus.classList.remove('show'); }, 2000);
        });
    }

    saveBtn.addEventListener('click', function() {
        saveTemplate(activeEditor);
    });

    // Ctrl+S to save
    document.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
            var templateTab = document.getElementById('tab-template');
            if (templateTab && templateTab.classList.contains('active')) {
                e.preventDefault();
                saveTemplate(activeEditor);
            }
        }
    });

    // Refresh editors when template tab becomes visible
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (btn.dataset.tab === 'tab-template') {
                setTimeout(function() {
                    editorPage.refresh();
                    if (editorDetail) editorDetail.refresh();
                }, 50);
            }
        });
    });
});
</script>
{% endblock %}
{% endblock %}
