{% extends "@cms/layouts/cms.twig" %}

{% block title %}Relationship Graph{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/relationships-index.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Relationships
</div>

<div class="page-header">
    <h1>Relationship Graph</h1>
    <p style="color: var(--text-secondary); margin: var(--sp-1) 0 0;">Visual map of how your collections relate to each other.</p>
</div>

{% if nodes|length == 0 %}
<div class="card" style="text-align: center; padding: var(--sp-8);">
    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled)" stroke-width="1.5" style="margin-bottom: var(--sp-3);">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </svg>
    <h3 style="color: var(--text-secondary); margin-bottom: var(--sp-2);">No Collections Yet</h3>
    <p style="color: var(--text-disabled); margin-bottom: var(--sp-4);">Create some collections and add relation fields to see the relationship graph.</p>
    <a href="{{ admin_url('collections/create') }}" class="btn btn-primary">Create Collection</a>
</div>

{% elseif edges|length == 0 %}
<div class="card" style="margin-bottom: var(--sp-4);">
    <div class="card-body" style="text-align: center; padding: var(--sp-6);">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled)" stroke-width="1.5" style="margin-bottom: var(--sp-2);">
            <circle cx="12" cy="12" r="10"></circle>
            <line x1="12" y1="8" x2="12" y2="12"></line>
            <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <h3 style="color: var(--text-secondary); margin-bottom: var(--sp-1);">No Relationships Found</h3>
        <p style="color: var(--text-disabled);">Your collections exist but none have relation fields yet. Add a "relation" field type to a collection to see connections here.</p>
    </div>
</div>

{# Still show collections as isolated nodes #}
<div class="card">
    <div class="card-header">
        <h3>Collections ({{ nodes|length }})</h3>
    </div>
    <div class="card-body">
        <div id="graph-canvas" class="relationship-graph">
            <svg id="graph-svg" class="graph-svg"></svg>
            <div id="graph-nodes" class="graph-nodes"></div>
        </div>
    </div>
</div>

{% else %}
{# Legend #}
<div class="card" style="margin-bottom: var(--sp-4);">
    <div class="card-body" style="display: flex; align-items: center; gap: var(--sp-4); flex-wrap: wrap; padding: var(--sp-2) var(--sp-4);">
        <span style="font-weight: 600; color: var(--text-secondary); font-size: 0.85rem;">Legend:</span>
        <span class="legend-item">
            <svg width="40" height="12"><line x1="0" y1="6" x2="40" y2="6" stroke="var(--zui-primary-500)" stroke-width="2"/></svg>
            <span>one-to-one</span>
        </span>
        <span class="legend-item">
            <svg width="40" height="12"><line x1="0" y1="6" x2="40" y2="6" stroke="var(--zui-success-600)" stroke-width="2" stroke-dasharray="6,3"/></svg>
            <span>one-to-many</span>
        </span>
        <span class="legend-item">
            <svg width="40" height="12"><line x1="0" y1="6" x2="40" y2="6" stroke="var(--zui-warning-600)" stroke-width="2" stroke-dasharray="3,3"/></svg>
            <span>many-to-many</span>
        </span>
    </div>
</div>

{# Graph #}
<div class="card">
    <div class="card-header" style="display: flex; justify-content: space-between; align-items: center;">
        <h3>Collections ({{ nodes|length }}) &mdash; Relations ({{ edges|length }})</h3>
        <button type="button" class="btn btn-outline btn-sm" id="reset-layout-btn">Reset Layout</button>
    </div>
    <div class="card-body" style="padding: 0; overflow: hidden;">
        <div id="graph-canvas" class="relationship-graph">
            <svg id="graph-svg" class="graph-svg">
                <defs>
                    <marker id="arrow-one-to-one" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="var(--zui-primary-500)" />
                    </marker>
                    <marker id="arrow-one-to-many" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="var(--zui-success-600)" />
                    </marker>
                    <marker id="arrow-many-to-many" markerWidth="10" markerHeight="7" refX="10" refY="3.5" orient="auto">
                        <polygon points="0 0, 10 3.5, 0 7" fill="var(--zui-warning-600)" />
                    </marker>
                </defs>
            </svg>
            <div id="graph-nodes" class="graph-nodes"></div>
        </div>
    </div>
</div>
{% endif %}


<script nonce="{{ csp_nonce() }}">
(function() {
    'use strict';

    var nodes = {{ nodesJson|raw }};
    var edges = {{ edgesJson|raw }};

    if (nodes.length === 0) return;

    var canvas = document.getElementById('graph-canvas');
    var svg = document.getElementById('graph-svg');
    var nodesContainer = document.getElementById('graph-nodes');

    if (!canvas || !svg || !nodesContainer) return;

    var NODE_WIDTH = 170;
    var NODE_HEIGHT = 80;
    var nodePositions = {};
    var nodeElements = {};
    var edgeElements = [];
    var labelElements = [];

    // Icon SVG paths for common Lucide icons
    var iconPaths = {
        'database': '<rect x="2" y="3" width="20" height="4" rx="1"/><rect x="2" y="10" width="20" height="4" rx="1"/><rect x="2" y="17" width="20" height="4" rx="1"/>',
        'file-text': '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>',
        'users': '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
        'box': '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/>',
        'folder': '<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>',
        'tag': '<path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/>',
        'shopping-cart': '<circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>',
        'image': '<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>',
        'list': '<line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>',
        'star': '<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>',
        'heart': '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
        'settings': '<circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/>'
    };

    function getIconSvg(icon) {
        var path = iconPaths[icon] || iconPaths['database'];
        return '<svg viewBox="0 0 24 24">' + path + '</svg>';
    }

    // Calculate initial positions using circular layout
    function calculatePositions() {
        var canvasRect = canvas.getBoundingClientRect();
        var w = canvasRect.width || 800;
        var h = canvasRect.height || 600;
        var cx = w / 2;
        var cy = h / 2;
        var count = nodes.length;

        if (count === 1) {
            nodePositions[nodes[0].id] = { x: cx - NODE_WIDTH / 2, y: cy - NODE_HEIGHT / 2 };
            return;
        }

        var radiusX = Math.min(w * 0.38, 350);
        var radiusY = Math.min(h * 0.35, 250);

        for (var i = 0; i < count; i++) {
            var angle = (2 * Math.PI * i / count) - Math.PI / 2;
            nodePositions[nodes[i].id] = {
                x: cx + radiusX * Math.cos(angle) - NODE_WIDTH / 2,
                y: cy + radiusY * Math.sin(angle) - NODE_HEIGHT / 2
            };
        }
    }

    // Render nodes
    function renderNodes() {
        nodesContainer.innerHTML = '';
        nodes.forEach(function(node) {
            var el = document.createElement('div');
            el.className = 'graph-node';
            el.setAttribute('data-id', node.id);
            el.innerHTML =
                '<div class="graph-node-icon">' + getIconSvg(node.icon) + '</div>' +
                '<div class="graph-node-name">' + escapeHtml(node.name) + '</div>' +
                '<div class="graph-node-meta">' + node.fieldCount + ' field' + (node.fieldCount !== 1 ? 's' : '') + '</div>';

            var pos = nodePositions[node.id];
            el.style.left = pos.x + 'px';
            el.style.top = pos.y + 'px';

            nodeElements[node.id] = el;
            nodesContainer.appendChild(el);

            // Make draggable
            makeDraggable(el, node.id);
        });
    }

    // Render edges (SVG lines + labels)
    function renderEdges() {
        // Clear existing
        edgeElements.forEach(function(el) { el.remove(); });
        labelElements.forEach(function(el) { el.remove(); });
        edgeElements = [];
        labelElements = [];

        edges.forEach(function(edge) {
            if (!nodePositions[edge.from] || !nodePositions[edge.to]) return;

            var line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
            var fromPos = nodePositions[edge.from];
            var toPos = nodePositions[edge.to];

            // Calculate center points of nodes
            var x1 = fromPos.x + NODE_WIDTH / 2;
            var y1 = fromPos.y + NODE_HEIGHT / 2;
            var x2 = toPos.x + NODE_WIDTH / 2;
            var y2 = toPos.y + NODE_HEIGHT / 2;

            // Clip to node edge
            var clipped = clipLineToNodeEdge(x1, y1, x2, y2);

            line.setAttribute('x1', clipped.x1);
            line.setAttribute('y1', clipped.y1);
            line.setAttribute('x2', clipped.x2);
            line.setAttribute('y2', clipped.y2);
            line.setAttribute('stroke-width', '2');

            var color, dash, marker;
            switch (edge.type) {
                case 'one-to-many':
                    color = 'var(--zui-success-600)';
                    dash = '6,3';
                    marker = 'url(#arrow-one-to-many)';
                    break;
                case 'many-to-many':
                    color = 'var(--zui-warning-600)';
                    dash = '3,3';
                    marker = 'url(#arrow-many-to-many)';
                    break;
                default: // one-to-one
                    color = 'var(--zui-primary-500)';
                    dash = '';
                    marker = 'url(#arrow-one-to-one)';
                    break;
            }

            line.setAttribute('stroke', color);
            if (dash) line.setAttribute('stroke-dasharray', dash);
            line.setAttribute('marker-end', marker);

            svg.appendChild(line);
            edgeElements.push(line);

            // Label at midpoint
            var label = document.createElement('div');
            label.className = 'graph-edge-label';
            label.textContent = edge.field + ' (' + edge.type.replace(/-/g, ' ') + ')';
            var mx = (clipped.x1 + clipped.x2) / 2;
            var my = (clipped.y1 + clipped.y2) / 2;
            label.style.left = mx + 'px';
            label.style.top = my + 'px';
            nodesContainer.appendChild(label);
            labelElements.push(label);
        });
    }

    // Clip line endpoints to the rectangular boundary of nodes
    function clipLineToNodeEdge(x1, y1, x2, y2) {
        var hw = NODE_WIDTH / 2 + 4;
        var hh = NODE_HEIGHT / 2 + 4;

        var dx = x2 - x1;
        var dy = y2 - y1;
        var len = Math.sqrt(dx * dx + dy * dy);
        if (len === 0) return { x1: x1, y1: y1, x2: x2, y2: y2 };

        var ux = dx / len;
        var uy = dy / len;

        // Offset from center of 'from' node
        var t1 = clipRayToRect(ux, uy, hw, hh);
        // Offset from center of 'to' node (reverse direction)
        var t2 = clipRayToRect(-ux, -uy, hw, hh);

        return {
            x1: x1 + ux * t1,
            y1: y1 + uy * t1,
            x2: x2 - ux * t2,
            y2: y2 - uy * t2
        };
    }

    function clipRayToRect(ux, uy, hw, hh) {
        var tx = (ux !== 0) ? Math.abs(hw / ux) : Infinity;
        var ty = (uy !== 0) ? Math.abs(hh / uy) : Infinity;
        return Math.min(tx, ty);
    }

    // Dragging
    function makeDraggable(el, nodeId) {
        var startX, startY, origX, origY;

        function onMouseDown(e) {
            e.preventDefault();
            el.classList.add('dragging');
            startX = e.clientX;
            startY = e.clientY;
            origX = nodePositions[nodeId].x;
            origY = nodePositions[nodeId].y;
            document.addEventListener('mousemove', onMouseMove);
            document.addEventListener('mouseup', onMouseUp);
        }

        function onMouseMove(e) {
            var dx = e.clientX - startX;
            var dy = e.clientY - startY;
            nodePositions[nodeId].x = origX + dx;
            nodePositions[nodeId].y = origY + dy;
            el.style.left = nodePositions[nodeId].x + 'px';
            el.style.top = nodePositions[nodeId].y + 'px';
            renderEdges();
        }

        function onMouseUp() {
            el.classList.remove('dragging');
            document.removeEventListener('mousemove', onMouseMove);
            document.removeEventListener('mouseup', onMouseUp);
        }

        el.addEventListener('mousedown', onMouseDown);

        // Touch support
        el.addEventListener('touchstart', function(e) {
            var touch = e.touches[0];
            el.classList.add('dragging');
            startX = touch.clientX;
            startY = touch.clientY;
            origX = nodePositions[nodeId].x;
            origY = nodePositions[nodeId].y;

            function onTouchMove(e2) {
                e2.preventDefault();
                var t = e2.touches[0];
                var dx = t.clientX - startX;
                var dy = t.clientY - startY;
                nodePositions[nodeId].x = origX + dx;
                nodePositions[nodeId].y = origY + dy;
                el.style.left = nodePositions[nodeId].x + 'px';
                el.style.top = nodePositions[nodeId].y + 'px';
                renderEdges();
            }

            function onTouchEnd() {
                el.classList.remove('dragging');
                document.removeEventListener('touchmove', onTouchMove);
                document.removeEventListener('touchend', onTouchEnd);
            }

            document.addEventListener('touchmove', onTouchMove, { passive: false });
            document.addEventListener('touchend', onTouchEnd);
        }, { passive: true });
    }

    function escapeHtml(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }

    // Reset layout button
    var resetBtn = document.getElementById('reset-layout-btn');
    if (resetBtn) {
        resetBtn.addEventListener('click', function() {
            calculatePositions();
            nodes.forEach(function(node) {
                var el = nodeElements[node.id];
                if (el) {
                    el.style.left = nodePositions[node.id].x + 'px';
                    el.style.top = nodePositions[node.id].y + 'px';
                }
            });
            renderEdges();
        });
    }

    // Initialize
    calculatePositions();
    renderNodes();
    renderEdges();

    // Recalculate on resize
    var resizeTimer;
    window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
            calculatePositions();
            nodes.forEach(function(node) {
                var el = nodeElements[node.id];
                if (el) {
                    el.style.left = nodePositions[node.id].x + 'px';
                    el.style.top = nodePositions[node.id].y + 'px';
                }
            });
            renderEdges();
        }, 200);
    });
})();
</script>
{% endblock %}
