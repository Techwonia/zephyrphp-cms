{% extends "@cms/layouts/cms.twig" %}

{% block title %}Submit to Marketplace{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/marketplace">Marketplace</a> / <a href="/cms/seller">Seller Portal</a> / Submit
</div>

<div class="page-header">
    <h1>Submit New Item</h1>
</div>

{% set old = flash('_old_input') ?? {} %}

<form method="POST" action="/cms/seller/submit" enctype="multipart/form-data">
    {{ csrf_field() | raw }}

    <div class="card" style="margin-bottom:var(--space-500);">
        <div class="card-header"><h3>Item Details</h3></div>
        <div class="card-body">
            <div class="form-group">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" value="{{ old.name ?? '' }}" required class="form-control" maxlength="100" placeholder="My Awesome Theme">
            </div>

            <div class="form-row" style="display:flex;gap:16px;margin-top:12px;">
                <div class="form-group" style="flex:1;">
                    <label for="type">Type</label>
                    <select id="type" name="type" class="form-control">
                        <option value="theme" {{ old.type == 'theme' ? 'selected' : '' }}>Theme</option>
                        <option value="app" {{ old.type == 'app' ? 'selected' : '' }}>App</option>
                        <option value="section" {{ old.type == 'section' ? 'selected' : '' }}>Section</option>
                    </select>
                </div>
                <div class="form-group" style="flex:1;">
                    <label for="category">Category</label>
                    <input type="text" id="category" name="category" value="{{ old.category ?? '' }}" class="form-control" placeholder="e.g. blog, ecommerce">
                </div>
            </div>

            <div class="form-group" style="margin-top:12px;">
                <label for="description">Description</label>
                <textarea id="description" name="description" rows="4" class="form-control" maxlength="5000" placeholder="Describe what your item does, its features, and requirements...">{{ old.description ?? '' }}</textarea>
            </div>
        </div>
    </div>

    <div class="card" style="margin-bottom:var(--space-500);">
        <div class="card-header"><h3>Pricing</h3></div>
        <div class="card-body">
            <div class="form-row" style="display:flex;gap:16px;">
                <div class="form-group" style="flex:1;">
                    <label for="pricing">Pricing Model</label>
                    <select id="pricing" name="pricing" class="form-control" onchange="document.getElementById('price-field').style.display = this.value === 'free' ? 'none' : 'block'">
                        <option value="free" {{ old.pricing == 'free' ? 'selected' : '' }}>Free</option>
                        <option value="paid" {{ old.pricing == 'paid' ? 'selected' : '' }}>One-time Purchase</option>
                        <option value="subscription" {{ old.pricing == 'subscription' ? 'selected' : '' }}>Subscription</option>
                    </select>
                </div>
                <div class="form-group" style="flex:1;" id="price-field" style="{{ old.pricing != 'free' and old.pricing ? '' : 'display:none;' }}">
                    <label for="price">Price (USD)</label>
                    <input type="number" id="price" name="price" value="{{ old.price ?? '0' }}" min="1" step="0.01" class="form-control" placeholder="9.99">
                    <small class="text-muted">Minimum $1.00. Platform takes 20-30% commission.</small>
                </div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-bottom:var(--space-500);">
        <div class="card-header"><h3>Files</h3></div>
        <div class="card-body">
            <div class="form-group">
                <label for="package">Package ZIP</label>
                <input type="file" id="package" name="package" accept=".zip" required class="form-control">
                <small class="text-muted">Maximum 50MB. Must contain theme.json or app.json.</small>
            </div>
            <div class="form-group" style="margin-top:12px;">
                <label for="preview_image">Preview Image (optional)</label>
                <input type="file" id="preview_image" name="preview_image" accept="image/png,image/jpeg,image/webp" class="form-control">
                <small class="text-muted">Recommended: 600x400px. PNG, JPG, or WebP.</small>
            </div>
        </div>
    </div>

    <div style="display:flex;gap:8px;justify-content:flex-end;">
        <a href="/cms/seller" class="btn btn-outline">Cancel</a>
        <button type="submit" class="btn btn-primary">Submit for Review</button>
    </div>
</form>
{% endblock %}
