{% extends "@cms/layouts/cms.twig" %}

{% block title %}Seller Portal{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/marketplace">Marketplace</a> / Seller Portal
</div>

<div class="page-header">
    <h1>Seller Portal</h1>
    <div class="page-actions">
        <a href="/cms/seller/submit" class="btn btn-primary btn-sm">Submit New Item</a>
    </div>
</div>

{# Stats #}
<div class="stats-grid" style="margin-bottom:var(--space-500);">
    <div class="stat-card">
        <div class="stat-icon stat-icon-blue">&#128230;</div>
        <div>
            <div class="stat-value">{{ items|length }}</div>
            <div class="stat-label">Total Items</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-green">&#9989;</div>
        <div>
            <div class="stat-value">{{ publishedCount }}</div>
            <div class="stat-label">Published</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon stat-icon-purple">&#128229;</div>
        <div>
            <div class="stat-value">{{ totalDownloads }}</div>
            <div class="stat-label">Total Downloads</div>
        </div>
    </div>
</div>

{% if items|length > 0 %}
<div class="card">
    <div class="card-header"><h3>Your Items</h3></div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Version</th>
                    <th>Pricing</th>
                    <th>Status</th>
                    <th>Downloads</th>
                    <th>Rating</th>
                </tr>
            </thead>
            <tbody>
                {% for item in items %}
                <tr>
                    <td><strong>{{ item.getName() }}</strong></td>
                    <td><span class="badge badge-{{ item.getType() }}">{{ item.getType()|capitalize }}</span></td>
                    <td><code>{{ item.getVersion() }}</code></td>
                    <td>{{ item.getFormattedPrice() }}</td>
                    <td>
                        {% if item.getStatus() == 'published' %}
                            <span class="badge badge-success">Published</span>
                        {% elseif item.getStatus() == 'pending' %}
                            <span class="badge badge-warning">Pending Review</span>
                        {% elseif item.getStatus() == 'rejected' %}
                            <span class="badge badge-danger">Rejected</span>
                        {% else %}
                            <span class="badge badge-muted">{{ item.getStatus()|capitalize }}</span>
                        {% endif %}
                    </td>
                    <td>{{ item.getDownloads() }}</td>
                    <td>
                        {% if item.getReviewCount() > 0 %}
                            {{ item.getAvgRating() }} / 5 ({{ item.getReviewCount() }})
                        {% else %}
                            <span class="text-muted">&mdash;</span>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% else %}
<div class="card">
    <div class="card-body empty-state">
        <h3>No items submitted yet</h3>
        <p>Submit your first theme, app, or section to the marketplace.</p>
        <a href="/cms/seller/submit" class="btn btn-primary">Submit Item</a>
    </div>
</div>
{% endif %}
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
.badge-theme { background: rgba(128,0,255,0.1); color: #7c3aed; border: 1px solid rgba(128,0,255,0.2); }
.badge-app { background: rgba(0,123,255,0.1); color: #0056b3; border: 1px solid rgba(0,123,255,0.2); }
.badge-section { background: rgba(255,140,0,0.1); color: #c77800; border: 1px solid rgba(255,140,0,0.2); }
.badge-success { background: rgba(4,123,93,0.1); color: #047B5D; border: 1px solid rgba(4,123,93,0.2); }
.badge-warning { background: rgba(255,184,0,0.1); color: #b8860b; border: 1px solid rgba(255,184,0,0.2); }
.badge-danger { background: rgba(220,53,69,0.1); color: #dc3545; border: 1px solid rgba(220,53,69,0.2); }
.badge-muted { background: var(--bg-subdued, #f5f5f5); color: var(--text-disabled, #999); border: 1px solid var(--border-color, #e5e5e5); }
</style>
{% endblock %}
