{% if counts|length > 0 %}
<div style="display: flex; flex-wrap: wrap; gap: 12px;">
    {% for item in counts %}
    <a href="{{ admin_url('collections/' ~ item.slug ~ '/entries') }}" style="text-decoration: none; flex: 1; min-width: 120px;">
        <div style="padding: 12px; background: var(--bg-subdued); border-radius: 8px; text-align: center;">
            <div style="font-size: 1.5em; font-weight: 700; color: var(--text-heading);">{{ item.count }}</div>
            <div style="font-size: 0.85em; color: var(--text-secondary); margin-top: 2px;">{{ item.name }}</div>
        </div>
    </a>
    {% endfor %}
</div>
{% else %}
<p class="text-secondary text-sm">No collections yet.</p>
{% endif %}
