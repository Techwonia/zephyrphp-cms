{% if counts|length > 0 %}
<div class="flex flex-wrap gap-3">
    {% for item in counts %}
    <a href="{{ admin_url('collections/' ~ item.slug ~ '/entries') }}" class="flex-1" style="text-decoration:none;min-width:120px">
        <div style="padding:var(--sp-3);background:var(--bg-subdued);border-radius:var(--radius);text-align:center">
            <div class="stat-value" style="font-size:var(--text-2xl)">{{ item.count }}</div>
            <div class="text-secondary text-sm mt-1">{{ item.name }}</div>
        </div>
    </a>
    {% endfor %}
</div>
{% else %}
<p class="text-secondary text-sm">No collections yet.</p>
{% endif %}
