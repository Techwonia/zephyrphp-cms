<div style="display: flex; gap: 8px; flex-wrap: wrap;">
    <a href="{{ admin_url('collections/create') }}" class="btn btn-primary btn-sm">New Collection</a>
    {% for collection in collections %}
    <a href="{{ admin_url('collections/{{ collection.getSlug() }}/entries/create') }}" class="btn btn-outline btn-sm">
        + {{ collection.getName() }}
    </a>
    {% endfor %}
    <a href="{{ admin_url('media') }}" class="btn btn-outline btn-sm">Media</a>
    <a href="{{ admin_url('themes') }}" class="btn btn-outline btn-sm">Themes</a>
</div>
