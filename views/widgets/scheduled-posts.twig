<div class="text-center" style="padding:var(--sp-2) 0">
    <div class="stat-value">{{ count }}</div>
    <div class="text-secondary text-sm mt-1">Scheduled</div>
</div>
{% if entries|length > 0 %}
<div class="mt-3 border-b" style="padding-top:var(--sp-2)">
    {% for entry in entries %}
    <div class="info-row">
        <a href="{{ admin_url('collections/' ~ entry.collection_slug ~ '/entries/' ~ entry.id) }}" class="text-sm truncate">
            {{ entry.label|length > 25 ? entry.label[:25] ~ '...' : entry.label }}
        </a>
        <span class="text-secondary text-xs">{{ entry.scheduled_at[:10] }}</span>
    </div>
    {% endfor %}
</div>
{% endif %}
