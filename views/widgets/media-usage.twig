<div class="text-center" style="padding:var(--sp-2) 0">
    <div class="stat-value">{{ stats.total }}</div>
    <div class="text-secondary text-sm mt-1">Media files</div>
</div>
{% if stats.types|length > 0 %}
<div class="mt-2" style="border-top:1px solid var(--border);padding-top:var(--sp-2)">
    {% for type, cnt in stats.types %}
    <div class="info-row" style="padding:var(--sp-1) 0">
        <span class="text-sm">{{ type|capitalize }}</span>
        <span class="text-secondary text-sm">{{ cnt }}</span>
    </div>
    {% endfor %}
</div>
{% endif %}
<div class="mt-2">
    <a href="{{ admin_url('media') }}" class="text-sm">Manage media &rarr;</a>
</div>
