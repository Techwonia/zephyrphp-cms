{% if chart_data|length > 0 %}
{% set max_val = 1 %}
{% for day, cnt in chart_data %}
    {% if cnt > max_val %}{% set max_val = cnt %}{% endif %}
{% endfor %}
<div class="flex items-end" style="gap:2px;height:120px;padding:0 var(--sp-1)">
    {% for day, cnt in chart_data %}
    {% set height = max_val > 0 ? (cnt / max_val * 100) : 0 %}
    <div style="flex:1;display:flex;flex-direction:column;align-items:center;justify-content:flex-end;height:100%" title="{{ day }}: {{ cnt }} entries">
        <div style="width:100%;min-height:2px;background:var(--zui-primary-500);border-radius:2px 2px 0 0;height:{{ height > 0 ? height : 2 }}%;transition:height .3s ease"></div>
    </div>
    {% endfor %}
</div>
<div class="flex justify-between mt-2 text-xs text-secondary">
    {% set days = chart_data|keys %}
    <span>{{ days|first }}</span>
    <span>{{ days|last }}</span>
</div>
{% else %}
<p class="text-secondary text-sm">No data available.</p>
{% endif %}
