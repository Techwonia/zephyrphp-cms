{% if entries|length > 0 %}
<div class="table-responsive">
    <table class="data-table" class="p-0">
        <thead>
            <tr>
                <th>Entry</th>
                <th>Collection</th>
                <th>Created</th>
            </tr>
        </thead>
        <tbody>
            {% for entry in entries %}
            <tr>
                <td>
                    <a href="{{ admin_url('collections/' ~ entry.collection_slug ~ '/entries/' ~ entry.id) }}">
                        {{ entry.label|length > 40 ? entry.label[:40] ~ '...' : entry.label }}
                    </a>
                </td>
                <td><span class="badge" style="background: var(--bg-subdued); color: var(--text-secondary);">{{ entry.collection_name }}</span></td>
                <td style="white-space: nowrap; font-size: 0.85em; color: var(--text-secondary);">{{ entry.created_at ? entry.created_at[:10] : '-' }}</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% else %}
<p class="text-secondary text-sm">No entries yet.</p>
{% endif %}
