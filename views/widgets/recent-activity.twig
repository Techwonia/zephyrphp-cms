{% if logs|length > 0 %}
<div class="flex flex-col gap-1">
    {% for log in logs %}
    <div class="flex items-center gap-3" style="padding:var(--sp-2) 0;border-bottom:1px solid var(--border)">
        {% set badgeClass = {
            'created': 'badge-success',
            'updated': 'badge-warning',
            'deleted': 'badge-error',
            'published': 'badge-info',
            'login': 'badge-default'
        } %}
        <span class="badge {{ badgeClass[log.action] ?? 'badge-default' }}">{{ log.action }}</span>
        <span class="flex-1 text-sm truncate">{{ log.resource_label ?? log.resource_type }}</span>
        <span class="text-xs text-secondary shrink-0">{{ log.createdAt ? log.createdAt[:10] : '' }}</span>
    </div>
    {% endfor %}
</div>
<div class="mt-2">
    <a href="{{ admin_url('activity-log') }}" class="text-sm">View all activity &rarr;</a>
</div>
{% else %}
<p class="text-secondary text-sm">No activity recorded yet.</p>
{% endif %}
