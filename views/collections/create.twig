{% extends "@cms/layouts/cms.twig" %}

{% block title %}Create Collection{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/collections-create.css">{% endblock %}

{% block content %}

{# ── Page Header ── #}
<div class="create-header">
    <a href="{{ admin_url('collections') }}" class="create-header-back" title="Back to Collections">
        <svg viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
    </a>
    <div class="create-header-text">
        <p class="create-breadcrumb"><a href="{{ admin_url('collections') }}">Collections</a></p>
        <h1>Create New Collection</h1>
    </div>
</div>

<form method="POST" action="{{ admin_url('collections') }}" id="createForm">
    {{ csrf_field() | raw }}

    <div class="create-layout">
        {# ── Left: Form Panel ── #}
        <div class="create-form-panel">

            {# Section: Basic Information #}
            <div class="form-section">
                <h2 class="form-section-title">Basic Information</h2>
                <p class="form-section-desc">Define the identity of your collection. The name and slug determine how it appears and how the database table is named.</p>

                <div class="fg">
                    <label for="name">Collection Name <span class="required">*</span></label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ flash('_old_input').name ?? '' }}"
                           placeholder="e.g. Blog Posts" required autocomplete="off">
                    {% if flash('errors').name is defined %}
                        <div class="form-error">{{ flash('errors').name }}</div>
                    {% endif %}
                </div>

                <div class="fg">
                    <label for="slug">API Identifier</label>
                    <input type="text" id="slug" name="slug" class="form-control"
                           value="{{ flash('_old_input').slug ?? '' }}"
                           placeholder="blog_posts" autocomplete="off">
                    <p class="form-hint">Auto-generated from name. Used for the database table <code id="tableHint">{{ tablePrefix ?? 'app_' }}...</code> and API endpoints.</p>
                    {% if flash('errors').slug is defined %}
                        <div class="form-error">{{ flash('errors').slug }}</div>
                    {% endif %}
                </div>

                <div class="fg">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" class="form-control"
                              rows="3" placeholder="Briefly describe what this collection stores...">{{ flash('_old_input').description ?? '' }}</textarea>
                </div>
            </div>

            {# Section: Configuration #}
            <div class="form-section">
                <h2 class="form-section-title">Configuration</h2>
                <p class="form-section-desc">Choose how primary keys are generated. This cannot be changed after entries are created.</p>

                <div class="fg">
                    <label>Primary Key Type</label>
                    <div class="pk-options">
                        <label class="pk-option">
                            <input type="radio" name="primary_key_type" value="integer" checked>
                            <div class="pk-option-card">
                                <svg class="pk-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="3" x2="8" y2="21"/><line x1="16" y1="3" x2="14" y2="21"/></svg>
                                <span class="pk-name">Auto-increment</span>
                                <span class="pk-desc">Sequential integer IDs (1, 2, 3...)</span>
                            </div>
                        </label>
                        <label class="pk-option">
                            <input type="radio" name="primary_key_type" value="uuid">
                            <div class="pk-option-card">
                                <svg class="pk-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                                <span class="pk-name">UUID</span>
                                <span class="pk-desc">Universally unique identifiers (CHAR 36)</span>
                            </div>
                        </label>
                    </div>
                </div>
            </div>

            {# Section: Features #}
            <div class="form-section">
                <h2 class="form-section-title">Features</h2>
                <p class="form-section-desc">Enable optional capabilities for this collection. These add extra fields and functionality.</p>

                <div class="toggle-row">
                    <div class="toggle-icon icon-api">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">REST API</div>
                        <div class="toggle-desc">Expose CRUD endpoints for this collection</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="is_api_enabled" value="1" data-feature="api">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-icon icon-publish">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">Publishable</div>
                        <div class="toggle-desc">Add draft/published status to entries</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="is_publishable" value="1" data-feature="publish">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-icon icon-slug">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">URL Slugs</div>
                        <div class="toggle-desc">Auto-generate URL-friendly slugs for each entry</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="has_slug" value="1" data-feature="slug">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-icon icon-seo">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">SEO Fields</div>
                        <div class="toggle-desc">Add meta title, description, and OG fields</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="has_seo" value="1" data-feature="seo">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-icon icon-i18n">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">Translatable (i18n)</div>
                        <div class="toggle-desc">Enable multi-language content support</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="is_translatable" value="1" data-feature="i18n">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                <div class="toggle-row">
                    <div class="toggle-icon icon-hierarchy">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="toggle-info">
                        <div class="toggle-name">Hierarchy (Parent/Child)</div>
                        <div class="toggle-desc">Enable tree structure with parent-child relationships</div>
                    </div>
                    <label class="toggle">
                        <input type="checkbox" name="has_hierarchy" value="1" data-feature="hierarchy">
                        <div class="toggle-track"></div>
                        <div class="toggle-thumb"></div>
                    </label>
                </div>

                {# Submit #}
                <div class="create-actions">
                    <button type="submit" class="btn btn-primary">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Create Collection
                    </button>
                    <a href="{{ admin_url('collections') }}" class="btn btn-outline">Cancel</a>
                </div>
            </div>

        </div>

        {# ── Right: Preview Panel ── #}
        <div class="create-preview-wrapper">
            <div class="preview-card">
                <div class="preview-header">Preview</div>
                <div class="preview-body">

                    <div class="preview-collection-name">
                        <div class="preview-collection-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
                        </div>
                        <div id="previewName" class="preview-name-text preview-name-placeholder">Untitled Collection</div>
                    </div>

                    <div class="preview-meta">
                        <div class="preview-meta-row">
                            <span class="preview-meta-label">Table</span>
                            <span class="preview-meta-value" id="previewTable">{{ tablePrefix ?? 'app_' }}...</span>
                        </div>
                        <div class="preview-meta-row">
                            <span class="preview-meta-label">Primary Key</span>
                            <span class="preview-meta-value" id="previewPK">Integer (AI)</span>
                        </div>
                    </div>

                    <div style="margin-bottom: var(--sp-4);">
                        <div class="preview-section-label">Features</div>
                        <div class="preview-features" id="previewFeatures">
                            <span class="preview-no-features" id="noFeaturesMsg">No features enabled</span>
                        </div>
                    </div>

                    <div>
                        <div class="preview-section-label">System Fields</div>
                        <ul class="preview-fields" id="previewFields">
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/></svg>
                                <span class="preview-field-name">id</span>
                                <span class="preview-field-type" id="previewIdType">integer</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/></svg>
                                <span class="preview-field-name">created_at</span>
                                <span class="preview-field-type">timestamp</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/></svg>
                                <span class="preview-field-name">updated_at</span>
                                <span class="preview-field-type">timestamp</span>
                            </li>
                            <li>
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/></svg>
                                <span class="preview-field-name">created_by</span>
                                <span class="preview-field-type">integer</span>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>
        </div>
    </div>
</form>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var nameInput = document.getElementById('name');
    var slugInput = document.getElementById('slug');
    var tableHint = document.getElementById('tableHint');
    var previewName = document.getElementById('previewName');
    var previewTable = document.getElementById('previewTable');
    var previewPK = document.getElementById('previewPK');
    var previewIdType = document.getElementById('previewIdType');
    var previewFeatures = document.getElementById('previewFeatures');
    var noFeaturesMsg = document.getElementById('noFeaturesMsg');
    var previewFields = document.getElementById('previewFields');

    var featureConfig = {
        api:       { label: 'REST API',     badgeClass: 'badge-api' },
        publish:   { label: 'Publishable',  badgeClass: 'badge-publish' },
        slug:      { label: 'URL Slugs',    badgeClass: 'badge-slug' },
        seo:       { label: 'SEO Fields',   badgeClass: 'badge-seo' },
        i18n:      { label: 'Translatable', badgeClass: 'badge-i18n' },
        hierarchy: { label: 'Hierarchy',    badgeClass: 'badge-slug' }
    };

    var extraFields = {
        publish: [
            { name: 'status', type: 'enum' },
            { name: 'published_at', type: 'timestamp' }
        ],
        slug: [
            { name: 'slug', type: 'varchar' }
        ],
        seo: [
            { name: 'meta_title', type: 'varchar' },
            { name: 'meta_description', type: 'text' }
        ],
        i18n: [
            { name: 'locale', type: 'varchar' }
        ],
        hierarchy: [
            { name: 'parent_id', type: 'integer/char(36)' }
        ]
    };

    function toSlug(str) {
        return str.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
    }

    function updatePreview() {
        var name = nameInput.value.trim();
        var slug = slugInput.value.trim() || toSlug(nameInput.value);

        // Name
        if (name) {
            previewName.textContent = name;
            previewName.classList.remove('preview-name-placeholder');
        } else {
            previewName.textContent = 'Untitled Collection';
            previewName.classList.add('preview-name-placeholder');
        }

        // Table
        var tblPrefix = '{{ tablePrefix ?? "app_" }}';
        var tableName = slug ? tblPrefix + slug : tblPrefix + '...';
        previewTable.textContent = tableName;
        tableHint.textContent = tableName;

        // Primary key
        var pkRadios = document.querySelectorAll('input[name="primary_key_type"]');
        var pkVal = 'integer';
        for (var i = 0; i < pkRadios.length; i++) {
            if (pkRadios[i].checked) { pkVal = pkRadios[i].value; break; }
        }
        previewPK.textContent = pkVal === 'uuid' ? 'UUID (CHAR 36)' : 'Integer (AI)';
        previewIdType.textContent = pkVal === 'uuid' ? 'char(36)' : 'integer';

        // Features
        var toggles = document.querySelectorAll('[data-feature]');
        var enabledFeatures = [];
        for (var j = 0; j < toggles.length; j++) {
            if (toggles[j].checked) {
                enabledFeatures.push(toggles[j].getAttribute('data-feature'));
            }
        }

        // Feature badges
        previewFeatures.innerHTML = '';
        if (enabledFeatures.length === 0) {
            var span = document.createElement('span');
            span.className = 'preview-no-features';
            span.textContent = 'No features enabled';
            previewFeatures.appendChild(span);
        } else {
            for (var k = 0; k < enabledFeatures.length; k++) {
                var feat = enabledFeatures[k];
                var cfg = featureConfig[feat];
                var badge = document.createElement('span');
                badge.className = 'preview-feature-badge ' + cfg.badgeClass;
                badge.textContent = cfg.label;
                previewFeatures.appendChild(badge);
            }
        }

        // System fields
        var dotSvg = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="2"/></svg>';
        var baseFields = [
            { name: 'id', type: pkVal === 'uuid' ? 'char(36)' : 'integer' },
            { name: 'created_at', type: 'timestamp' },
            { name: 'updated_at', type: 'timestamp' },
            { name: 'created_by', type: 'integer' }
        ];

        for (var m = 0; m < enabledFeatures.length; m++) {
            var ef = extraFields[enabledFeatures[m]];
            if (ef) {
                for (var n = 0; n < ef.length; n++) {
                    baseFields.push(ef[n]);
                }
            }
        }

        previewFields.innerHTML = '';
        for (var p = 0; p < baseFields.length; p++) {
            var li = document.createElement('li');
            li.innerHTML = dotSvg + '<span class="preview-field-name">' + baseFields[p].name + '</span><span class="preview-field-type">' + baseFields[p].type + '</span>';
            previewFields.appendChild(li);
        }
    }

    // Slug auto-generation
    nameInput.addEventListener('input', function() {
        if (!slugInput.dataset.manual) {
            slugInput.value = toSlug(this.value);
        }
        updatePreview();
    });

    slugInput.addEventListener('input', function() {
        this.dataset.manual = '1';
        updatePreview();
    });

    // Primary key radios
    var pkRadios = document.querySelectorAll('input[name="primary_key_type"]');
    for (var i = 0; i < pkRadios.length; i++) {
        pkRadios[i].addEventListener('change', updatePreview);
    }

    // Feature toggles
    var toggleInputs = document.querySelectorAll('[data-feature]');
    for (var j = 0; j < toggleInputs.length; j++) {
        toggleInputs[j].addEventListener('change', updatePreview);
    }

    // Initial state
    updatePreview();
})();
</script>
{% endblock %}
{% endblock %}
