{% extends "@cms/layouts/cms.twig" %}

{% block title %}Collections{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'home'} only %} Dashboard</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">Collections</span>
</div>

<div class="page-header">
    <div>
        <h1>Collections</h1>
        <p class="page-header-sub">Manage your content types</p>
    </div>
    <div class="page-header-actions">
        <a href="{{ admin_url('collections/create') }}" class="btn btn-primary">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %}
            New Collection
        </a>
    </div>
</div>

{% if collections|length > 0 %}
<div class="collections-grid">
    {% for collection in collections %}
    <div class="collection-card">
        <div class="collection-card-body">
            {# Top: icon + name/slug #}
            <div class="collection-card-top">
                <div class="collection-card-icon">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: collection.getIcon() ?? 'layers'} only %}
                </div>
                <div class="collection-card-info">
                    <div class="collection-card-name">{{ collection.getName() }}</div>
                    <div class="collection-card-slug">{{ collection.getSlug() }}</div>
                </div>
            </div>

            {# Description #}
            {% if collection.getDescription() %}
                <p class="collection-card-desc">{{ collection.getDescription() }}</p>
            {% endif %}

            {# Meta: stats + badges #}
            <div class="collection-card-meta">
                <div class="collection-card-stat">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'grid'} only %}
                    <strong>{{ collection.getFields()|length }}</strong> fields
                </div>
                <div class="collection-card-stat">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}
                    <strong>{{ stats[collection.getSlug()] ?? 0 }}</strong> entries
                </div>
                <div class="collection-card-badges">
                    {% if collection.isPublishable() %}
                        <span class="badge badge-success"><span class="badge-dot"></span> Publish</span>
                    {% endif %}
                    {% if collection.isSeoEnabled() is defined and collection.isSeoEnabled() %}
                        <span class="badge badge-warning">SEO</span>
                    {% endif %}
                    {% if collection.isTranslatable() is defined and collection.isTranslatable() %}
                        <span class="badge badge-primary">i18n</span>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Footer actions #}
        <div class="collection-card-footer">
            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-sm btn-soft">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}
                Entries
            </a>
            <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}" class="btn btn-sm btn-ghost">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}
                Settings
            </a>
            <div class="dropdown ml-auto">
                <button type="button" class="btn btn-sm btn-icon btn-ghost" data-dropdown="dd-{{ collection.getSlug() }}">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="5" r="1"/><circle cx="12" cy="12" r="1"/><circle cx="12" cy="19" r="1"/></svg>
                </button>
                <div class="dropdown-menu up" id="dd-{{ collection.getSlug() }}">
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="dropdown-item">
                        {% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %}
                        New Entry
                    </a>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}" class="dropdown-item">
                        {% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}
                        Edit Collection
                    </a>
                    <div class="dropdown-divider"></div>
                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/delete') }}">
                        {{ csrf_field() | raw }}
                        <button type="submit" class="dropdown-item danger" data-confirm="Delete collection '{{ collection.getName() }}'? This will drop the table and all data permanently!">
                            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}
                            Delete Collection
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% else %}
{# Empty state #}
<div class="card">
    <div class="card-body">
        <div class="empty-state">
            <div class="empty-state-icon">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'layers'} only %}
            </div>
            <h2>No collections yet</h2>
            <p>Collections define your content structure — like blog posts, products, or pages. Create your first one to start managing content.</p>
            <a href="{{ admin_url('collections/create') }}" class="btn btn-primary">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %}
                Create Your First Collection
            </a>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}
