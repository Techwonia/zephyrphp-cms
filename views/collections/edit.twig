{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit {{ collection.getName() }}{% endblock %}
{% block styles %}
<style nonce="{{ csp_nonce() }}">
.tab-panel{display:none !important}.tab-panel.active{display:block !important}
.system-fields-toggle{display:flex;align-items:center;gap:var(--sp-2);padding:var(--sp-3) var(--sp-4);background:var(--zui-gray-50);border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;font-size:var(--text-sm);font-weight:500;color:var(--text-secondary);margin-bottom:var(--sp-3)}
.system-fields-toggle .chevron{width:14px;height:14px;transition:transform 150ms ease}
.system-fields-toggle.open .chevron{transform:rotate(90deg)}
.system-fields-body{display:none;border:1px solid var(--border);border-radius:var(--radius);margin-bottom:var(--sp-4);overflow:hidden}
.system-fields-body.open{display:block}
.system-field-row{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-2) var(--sp-4);border-bottom:1px solid var(--zui-gray-100);font-size:var(--text-sm)}
.system-field-row:last-child{border-bottom:none}
.sf-icon{width:24px;height:24px;display:flex;align-items:center;justify-content:center;background:var(--zui-gray-100);border-radius:var(--radius-sm);font-size:11px;font-weight:700;color:var(--text-secondary);flex-shrink:0}
.sf-name{font-weight:600;color:var(--text-heading)}
.sf-slug{font-family:var(--font-mono);font-size:11px;color:var(--text-secondary)}
.sf-badges{display:flex;gap:4px;margin-left:auto;flex-wrap:wrap}
.badge-type{background:var(--zui-gray-100);color:var(--text-secondary);font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-system{background:var(--zui-info-50);color:var(--zui-info-600);font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-required{background:var(--zui-error-50);color:var(--zui-error-600);font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.field-card{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-4);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:var(--sp-2);background:var(--bg-surface);transition:border-color 120ms ease}
.field-card:hover{border-color:var(--border-hover)}
.field-card .field-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;background:var(--zui-primary-50);color:var(--zui-primary-600);border-radius:var(--radius-sm);font-size:11px;font-weight:700;flex-shrink:0}
.field-card .field-info{flex:1;min-width:0}
.field-card .field-name{font-weight:600;font-size:var(--text-sm);color:var(--text-heading)}
.field-card .field-meta{display:flex;gap:var(--sp-2);flex-wrap:wrap;margin-top:2px}
.field-card .field-actions{display:flex;gap:var(--sp-1)}
.field-drag{cursor:grab;color:var(--text-disabled);display:flex;align-items:center}
.add-field-bar{text-align:center;padding:var(--sp-3) 0}
.btn-add-field{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-2) var(--sp-4);font-size:var(--text-sm);font-weight:500;color:var(--zui-primary-600);background:none;border:1px dashed var(--zui-primary-200);border-radius:var(--radius);cursor:pointer;transition:background 120ms ease,border-color 120ms ease;font-family:var(--font-sans)}
.btn-add-field:hover{background:var(--zui-primary-50);border-color:var(--zui-primary-400)}
.btn-add-field svg{width:14px;height:14px}
.modal-section-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin:var(--sp-4) 0 var(--sp-2)}
.form-row-2{display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-4)}
.perm-table{width:100%;border-collapse:collapse;font-size:var(--text-sm)}
.perm-table th{text-align:left;padding:var(--sp-2) var(--sp-3);font-weight:500;color:var(--text-secondary);border-bottom:1px solid var(--border)}
.perm-table td{padding:var(--sp-2) var(--sp-3);text-align:center;border-bottom:1px solid var(--zui-gray-100)}
.perm-table td:first-child{text-align:left;font-weight:500;color:var(--text-heading)}
.workflow-stage-row{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-2) 0}
.stage-label{font-size:var(--text-sm);font-weight:500;color:var(--text-heading);min-width:80px}
.save-bar{display:none}
.custom-field-row{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-4);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:var(--sp-2);background:var(--bg-surface);transition:border-color 120ms ease}
.custom-field-row:hover{border-color:var(--border-hover)}
.drag-handle{cursor:grab;color:var(--text-disabled);display:flex;align-items:center;flex-shrink:0}
.drag-handle svg{width:14px;height:14px}
.field-type-icon{width:28px;height:28px;display:flex;align-items:center;justify-content:center;background:var(--zui-primary-50);color:var(--zui-primary-600);border-radius:var(--radius-sm);font-size:11px;font-weight:700;font-family:var(--font-mono);flex-shrink:0}
.field-type-icon svg{width:14px;height:14px}
.field-info-block{flex:1;min-width:0}
.field-name-line{display:flex;align-items:baseline;gap:var(--sp-2)}
.field-name-text{font-weight:600;font-size:var(--text-sm);color:var(--text-heading)}
.field-slug-text{font-family:var(--font-mono);font-size:11px;color:var(--text-secondary)}
.field-badges-line{display:flex;gap:4px;flex-wrap:wrap;margin-top:2px}
.field-actions{display:flex;gap:var(--sp-1);flex-shrink:0}
.field-actions button{background:none;border:none;cursor:pointer;color:var(--text-secondary);padding:var(--sp-1);border-radius:var(--radius-sm);transition:color 120ms ease,background 120ms ease}
.field-actions button:hover{color:var(--text-heading);background:var(--zui-gray-100)}
.field-actions button svg{width:16px;height:16px}
.badge-unique{background:rgba(147,51,234,0.08);color:#7C3AED;font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-searchable{background:rgba(14,165,233,0.08);color:#0EA5E9;font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-sortable{background:rgba(217,119,6,0.08);color:#D97706;font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-hidden{background:var(--zui-gray-100);color:var(--text-secondary);font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-slug-source{background:rgba(22,163,74,0.08);color:#16A34A;font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-validation{background:var(--zui-gray-100);color:var(--text-secondary);font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.badge-relation{background:rgba(14,165,233,0.08);color:#0EA5E9;font-size:10px;padding:1px 6px;border-radius:var(--radius-full)}
.slug-warning{padding:var(--sp-3) var(--sp-4);background:var(--zui-warning-50);border:1px solid var(--zui-warning-100);border-radius:var(--radius);font-size:var(--text-sm);color:var(--zui-warning-700);margin-bottom:var(--sp-3)}
.field-list{margin-bottom:var(--sp-3)}
.empty-fields-message{text-align:center;padding:var(--sp-6);color:var(--text-secondary);font-size:var(--text-sm)}
</style>
{% endblock %}

{% block content %}

<div class="breadcrumb">
    <a href="{{ admin_url() }}">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'home'} only %} Dashboard</a>
    <span class="breadcrumb-sep">/</span>
    <a href="{{ admin_url('collections') }}">Collections</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">{{ collection.getName() }}</span>
</div>

<div class="page-header">
    <div>
        <h1>{{ collection.getName() }}</h1>
        <p class="page-header-sub">Collection settings and field configuration</p>
    </div>
    <div class="page-header-actions">
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-outline">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}
            View Entries ({{ entryCount }})
        </a>
    </div>
</div>

{# ===== TAB LAYOUT ===== #}
<div data-tab-group="collection-edit">
<div class="tab-nav" id="collectionTabs">
    <button class="tab-btn active" data-tab="general">General</button>
    <button class="tab-btn" data-tab="fields">Fields</button>
    <button class="tab-btn" data-tab="routing">Routing</button>
    <button class="tab-btn" data-tab="permissions">Access Control</button>
    <button class="tab-btn" data-tab="workflow">Workflow</button>
</div>

{# ===== GENERAL TAB ===== #}
<div class="tab-panel active" data-tab-panel="general">
    <form id="main-settings-form" method="POST" action="{{ admin_url('collections/' ~ collection.getSlug()) }}">
        {{ csrf_field() | raw }}

        <div class="form-section">
                        <div class="form-group">
                            <label for="name">Collection Name</label>
                            <input type="text" id="name" name="name" class="form-control"
                                   value="{{ collection.getName() }}" required>
                        </div>

                        <div class="form-group">
                            <label>Slug</label>
                            <input type="text" class="form-control" value="{{ collection.getSlug() }}" disabled readonly>
                            <div class="form-hint">Slug cannot be changed after creation. Table: <code>{{ collection.getTableName() }}</code></div>
                        </div>

                        <div class="form-group">
                            <label for="description">Description</label>
                            <textarea id="description" name="description" class="form-control"
                                      rows="3">{{ collection.getDescription() }}</textarea>
                        </div>

                        <div class="form-group">
                            <label for="primary_key_type">Primary Key Type</label>
                            <select id="primary_key_type" name="primary_key_type" class="form-control"
                                    {% if entryCount > 0 %}disabled{% endif %}>
                                <option value="integer" {% if collection.getPrimaryKeyType() == 'integer' %}selected{% endif %}>Integer (Auto-Increment)</option>
                                <option value="uuid" {% if collection.getPrimaryKeyType() == 'uuid' %}selected{% endif %}>UUID (CHAR 36)</option>
                            </select>
                            {% if entryCount > 0 %}
                                <div class="form-hint">Cannot be changed when entries exist ({{ entryCount }} entries).</div>
                                <input type="hidden" name="primary_key_type" value="{{ collection.getPrimaryKeyType() }}">
                            {% else %}
                                <div class="form-hint">Choose how entry IDs are generated. UUID provides globally unique identifiers.</div>
                            {% endif %}
                        </div>

                        <div class="form-group">
                            <label for="display_field">Display Field</label>
                            <select id="display_field" name="display_field" class="form-control">
                                <option value="">Auto-detect (title, name, slug, id)</option>
                                {% for field in fields %}
                                    <option value="{{ field.getSlug() }}" {% if collection.getDisplayField() == field.getSlug() %}selected{% endif %}>{{ field.getName() }} ({{ field.getSlug() }})</option>
                                {% endfor %}
                            </select>
                            <div class="form-hint">Which field represents this entry's title. Used in lists, breadcrumbs, relations, and tree view.</div>
                        </div>

                        {# Feature toggles #}
                        <div class="toggle-row">
                            <div class="toggle-icon icon-publish">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">Publishable</div><div class="toggle-desc">Add draft/published status to entries</div></div>
                            <label class="toggle"><input type="checkbox" name="is_publishable" value="1" {% if collection.isPublishable() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-icon icon-slug">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'link'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">URL Slugs</div><div class="toggle-desc">Auto-generate URL-friendly slugs</div></div>
                            <label class="toggle"><input type="checkbox" name="has_slug" value="1" id="has_slug_check" {% if collection.hasSlug() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-icon icon-seo">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'search'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">SEO Meta Fields</div><div class="toggle-desc">Add meta title, description, and OG fields</div></div>
                            <label class="toggle"><input type="checkbox" name="seo_enabled" value="1" {% if collection.isSeoEnabled() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-icon icon-i18n">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'globe'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">Translatable</div><div class="toggle-desc">Enable multi-language content support</div></div>
                            <label class="toggle"><input type="checkbox" name="is_translatable" value="1" {% if collection.isTranslatable() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-icon icon-warning">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'users'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">Public Submit</div><div class="toggle-desc">Allow public form submissions to this collection</div></div>
                            <label class="toggle"><input type="checkbox" name="is_submittable" value="1" id="is_submittable_check" {% if collection.isSubmittable() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="toggle-row">
                            <div class="toggle-icon icon-hierarchy">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'git-branch'} only %}</div>
                            <div class="toggle-info"><div class="toggle-name">Hierarchy</div><div class="toggle-desc">Enable parent-child tree structure</div></div>
                            <label class="toggle"><input type="checkbox" name="has_hierarchy" value="1" id="has_hierarchy_check" {% if collection.hasHierarchy() %}checked{% endif %}><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>

                        {# Hierarchy max depth config #}
                        <div id="hierarchy-depth-group" style="{% if not collection.hasHierarchy() %}display:none;{% endif %}margin-top:var(--sp-3);">
                            <div class="form-group">
                                <label>Max Depth</label>
                                <input type="number" name="hierarchy_max_depth" class="form-control" min="0" max="20"
                                       value="{{ collection.getHierarchyMaxDepth() }}" style="width: 120px;">
                                <div class="form-hint">0 = unlimited depth. Limits how deep the tree can go.</div>
                            </div>
                        </div>

                        {# Slug source info #}
                        <div id="slug-source-group" style="{% if not collection.hasSlug() %}display:none;{% endif %}margin-top:var(--sp-3);">
                            <div class="form-hint">
                                {% if collection.getSlugSourceField() %}
                                    Slug is auto-generated from the <strong>{{ collection.getSlugSourceField() }}</strong> field.
                                {% else %}
                                    Add a field with type <strong>slug</strong> to auto-generate URL-friendly slugs for entries.
                                {% endif %}
                            </div>
                        </div>

                        {# Public Submit Settings — collapsible #}
                        <div id="submit-settings-group" style="{% if not collection.isSubmittable() %}display:none;{% endif %}">
                            {% set ss = collection.getSubmitSettings() ?? {} %}
                            <div class="submit-settings-panel">
                                <h4>Public Submit Settings</h4>
                                <div class="form-hint" class="mb-3">
                                    Allow visitors to submit entries via <code>POST /collections/{{ collection.getSlug() }}/submit</code>
                                    or use <code>{{ '{{' }} render_collection_form('{{ collection.getSlug() }}') {{ '}}' }}</code> in Twig templates.
                                </div>

                                <div class="form-row-2">
                                    <div class="form-group">
                                        <label for="submit_button_text">Submit Button Text</label>
                                        <input type="text" id="submit_button_text" name="submit_button_text" class="form-control"
                                               value="{{ ss.submit_button_text ?? 'Submit' }}">
                                    </div>
                                    <div class="form-group">
                                        <label for="submit_success_message">Success Message</label>
                                        <input type="text" id="submit_success_message" name="submit_success_message" class="form-control"
                                               value="{{ ss.success_message ?? 'Thank you for your submission.' }}">
                                    </div>
                                </div>

                                <div class="form-group">
                                    <label for="submit_redirect_url">Redirect URL (optional)</label>
                                    <input type="text" id="submit_redirect_url" name="submit_redirect_url" class="form-control"
                                           value="{{ ss.redirect_url ?? '' }}" placeholder="e.g. /thank-you">
                                    <div class="form-hint">Redirect after submission instead of showing success message.</div>
                                </div>

                                <div class="form-row-2" class="mb-3">
                                    <div class="feature-toggle">
                                        <span class="feature-label" class="text-sm">Email Notification</span>
                                        <label class="toggle-switch">
                                            <input type="checkbox" name="submit_email_notify" value="1"
                                                   {% if ss.email_notify ?? false %}checked{% endif %}>
                                            <span class="toggle-slider"></span>
                                        </label>
                                    </div>
                                    <div class="feature-toggle">
                                        <span class="feature-label" class="text-sm">Honeypot (Bot Protection)</span>
                                        <label class="toggle-switch">
                                            <input type="checkbox" name="submit_honeypot_enabled" value="1"
                                                   {% if ss.honeypot_enabled ?? false %}checked{% endif %}>
                                            <span class="toggle-slider"></span>
                                        </label>
                                    </div>
                                </div>

                                <div class="form-row-2">
                                    <div class="form-group">
                                        <label for="submit_email_to">Notify Email</label>
                                        <input type="email" id="submit_email_to" name="submit_email_to" class="form-control"
                                               value="{{ ss.email_to ?? '' }}" placeholder="admin@example.com">
                                    </div>
                                    <div class="form-group">
                                        <label for="submit_rate_limit">Rate Limit (per IP, per hour)</label>
                                        <input type="number" id="submit_rate_limit" name="submit_rate_limit" class="form-control"
                                               value="{{ ss.rate_limit_per_ip ?? 0 }}" min="0">
                                        <div class="form-hint">0 = no limit. Recommended: 5-10 for contact forms.</div>
                                    </div>
                                </div>
                            </div>
                        </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Save General</button>
            </div>
        </div>
    </form>
</div>

{# ===== FIELDS TAB ===== #}
<div class="tab-panel" data-tab-panel="fields">
    <form id="main-settings-form-fields" method="POST" action="{{ admin_url('collections/' ~ collection.getSlug()) }}">
        {{ csrf_field() | raw }}
        <div class="form-section">

                    {# System fields — collapsible #}
                    {% set systemFieldCount = 4 + (collection.hasSlug() ? 1 : 0) + (collection.isPublishable() ? 2 : 0) %}
                    <div class="system-fields-toggle" id="system-fields-toggle">
                        <svg class="chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                        System Fields ({{ systemFieldCount }})
                    </div>
                    <div class="system-fields-body" id="system-fields-body">
                        <div class="system-field-row">
                            <div class="sf-icon">#</div>
                            <div class="sf-name">ID</div>
                            <div class="sf-slug">id</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">{{ collection.isUuid() ? 'uuid' : 'integer' }}</span>
                                <span class="badge badge-system">primary key</span>
                                <span class="badge badge-required">required</span>
                            </div>
                        </div>

                        {% if collection.hasSlug() %}
                        <div class="system-field-row">
                            <div class="sf-icon">/</div>
                            <div class="sf-name">Slug</div>
                            <div class="sf-slug">slug</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">string (255)</span>
                                <span class="badge badge-unique">unique</span>
                                {% if collection.getSlugSourceField() %}
                                    <span class="badge badge-slug-source">source: {{ collection.getSlugSourceField() }}</span>
                                {% else %}
                                    <span class="badge badge-required">no source set</span>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}

                        <div class="system-field-row">
                            <div class="sf-icon">U</div>
                            <div class="sf-name">Created By</div>
                            <div class="sf-slug">created_by</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">integer</span>
                                <span class="badge badge-system">nullable</span>
                            </div>
                        </div>

                        <div class="system-field-row">
                            <div class="sf-icon">C</div>
                            <div class="sf-name">Created At</div>
                            <div class="sf-slug">created_at</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">datetime</span>
                                <span class="badge badge-system">auto</span>
                            </div>
                        </div>

                        <div class="system-field-row">
                            <div class="sf-icon">U</div>
                            <div class="sf-name">Updated At</div>
                            <div class="sf-slug">updated_at</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">datetime</span>
                                <span class="badge badge-system">auto</span>
                            </div>
                        </div>

                        {% if collection.isPublishable() %}
                        <div class="system-field-row">
                            <div class="sf-icon">S</div>
                            <div class="sf-name">Status</div>
                            <div class="sf-slug">status</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">string</span>
                                <span class="badge badge-system">default: draft</span>
                            </div>
                        </div>

                        <div class="system-field-row">
                            <div class="sf-icon">P</div>
                            <div class="sf-name">Published At</div>
                            <div class="sf-slug">published_at</div>
                            <div class="sf-badges">
                                <span class="badge badge-type">datetime</span>
                                <span class="badge badge-system">nullable</span>
                            </div>
                        </div>
                        {% endif %}
                    </div>

                    {% if collection.hasSlug() and not collection.getSlugSourceField() %}
                    <div class="slug-warning">
                        <strong>Slug source not set.</strong> Add a field with type <strong>slug</strong> below to auto-generate URL-friendly slugs from that field's value.
                    </div>
                    {% endif %}

                    {# Custom fields — draggable #}
                    <div class="field-list" id="field-list">
                        {% if fields|length > 0 %}
                            {% for field in fields %}
                            <div class="custom-field-row" draggable="true" data-field-id="{{ field.getId() }}">
                                <div class="drag-handle" title="Drag to reorder">
                                    <svg viewBox="0 0 16 16" fill="currentColor"><circle cx="5" cy="3" r="1.2"/><circle cx="11" cy="3" r="1.2"/><circle cx="5" cy="8" r="1.2"/><circle cx="11" cy="8" r="1.2"/><circle cx="5" cy="13" r="1.2"/><circle cx="11" cy="13" r="1.2"/></svg>
                                </div>

                                {% set fType = field.getType() %}
                                <div class="field-type-icon fti-{{ fType }}">
                                    {% if fType == 'text' %}Aa
                                    {% elseif fType == 'textarea' %}&para;
                                    {% elseif fType == 'richtext' %}T
                                    {% elseif fType == 'number' %}#
                                    {% elseif fType == 'decimal' %}#.0
                                    {% elseif fType == 'boolean' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><rect x="1" y="4" width="14" height="8" rx="4"/><circle cx="11" cy="8" r="2.5" fill="white"/></svg>
                                    {% elseif fType == 'date' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="11" rx="1.5"/><line x1="2" y1="7" x2="14" y2="7"/><line x1="5" y1="1" x2="5" y2="4"/><line x1="11" y1="1" x2="11" y2="4"/></svg>
                                    {% elseif fType == 'datetime' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8,4 8,8 11,10"/></svg>
                                    {% elseif fType == 'email' %}@
                                    {% elseif fType == 'url' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 9.5a3.5 3.5 0 005-5l-1-1a3.5 3.5 0 00-5 0"/><path d="M9.5 6.5a3.5 3.5 0 00-5 5l1 1a3.5 3.5 0 005 0"/></svg>
                                    {% elseif fType == 'select' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="4" x2="13" y2="4"/><line x1="3" y1="8" x2="13" y2="8"/><line x1="3" y1="12" x2="13" y2="12"/></svg>
                                    {% elseif fType == 'image' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1.5"/><circle cx="5.5" cy="5.5" r="1.5"/><path d="M14 10l-3-3-7 7"/></svg>
                                    {% elseif fType == 'file' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9.5V14a1 1 0 01-1 1H3a1 1 0 01-1-1V2a1 1 0 011-1h7l4 4v4.5z"/></svg>
                                    {% elseif fType == 'slug' %}/
                                    {% elseif fType == 'json' %}{}
                                    {% elseif fType == 'relation' %}<svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="4" cy="8" r="2.5"/><circle cx="12" cy="8" r="2.5"/><line x1="6.5" y1="8" x2="9.5" y2="8"/></svg>
                                    {% else %}?{% endif %}
                                </div>

                                <div class="field-info-block">
                                    <div class="field-name-line">
                                        <span class="field-name-text">{{ field.getName() }}</span>
                                        <span class="field-slug-text">{{ field.getSlug() }}</span>
                                    </div>
                                    <div class="field-badges-line">
                                        <span class="badge badge-type">{{ fType }}</span>
                                        {% if fType == 'relation' and field.getOptions().relation_type is defined %}
                                            <span class="badge badge-relation">{{ field.getOptions().relation_type|replace({'_': ' '}) }}</span>
                                            {% if field.getOptions().relation_collection is defined %}
                                                <span class="badge badge-relation">&rarr; {{ field.getOptions().relation_collection }}</span>
                                            {% endif %}
                                            {% if field.getOptions().display_field is defined and field.getOptions().display_field %}
                                                <span class="badge badge-system">display: {{ field.getOptions().display_field }}</span>
                                            {% endif %}
                                        {% endif %}
                                        {% if field.isRequired() %}<span class="badge badge-required">required</span>{% endif %}
                                        {% if field.isUnique() %}<span class="badge badge-unique">unique</span>{% endif %}
                                        {% if field.isSearchable() %}<span class="badge badge-searchable">searchable</span>{% endif %}
                                        {% if field.isSortable() %}<span class="badge badge-sortable">sortable</span>{% endif %}
                                        {% if not field.isListable() %}<span class="badge badge-hidden">hidden</span>{% endif %}
                                        {% if collection.hasSlug() and collection.getSlugSourceField() == field.getSlug() %}
                                            <span class="badge badge-slug-source">slug source</span>
                                        {% endif %}
                                        {% set fOpts = field.getOptions() ?? {} %}
                                        {% if fOpts.min_length is defined %}<span class="badge badge-validation">min: {{ fOpts.min_length }} chars</span>{% endif %}
                                        {% if fOpts.max_length is defined %}<span class="badge badge-validation">max: {{ fOpts.max_length }} chars</span>{% endif %}
                                        {% if fOpts.min_value is defined %}<span class="badge badge-validation">min: {{ fOpts.min_value }}</span>{% endif %}
                                        {% if fOpts.max_value is defined %}<span class="badge badge-validation">max: {{ fOpts.max_value }}</span>{% endif %}
                                        {% if fOpts.pattern is defined %}<span class="badge badge-validation">pattern</span>{% endif %}
                                        {% if fOpts.field_permissions is defined %}
                                            {% if fOpts.field_permissions.view is defined and fOpts.field_permissions.view is not empty %}
                                                <span class="badge badge-perm-view">view: {{ fOpts.field_permissions.view|join(', ') }}</span>
                                            {% endif %}
                                            {% if fOpts.field_permissions.edit is defined and fOpts.field_permissions.edit is not empty %}
                                                <span class="badge badge-perm-edit">edit: {{ fOpts.field_permissions.edit|join(', ') }}</span>
                                            {% endif %}
                                        {% endif %}
                                    </div>
                                </div>

                                <div class="field-actions">
                                    <button type="button" class="field-action-btn btn-edit-field"
                                            data-field-id="{{ field.getId() }}"
                                            data-field-slug="{{ collection.getSlug() }}"
                                            title="Edit field">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                    </button>
                                    <button type="button" class="field-action-btn btn-delete"
                                            data-field-name="{{ field.getName() }}"
                                            data-delete-url="{{ admin_url('collections/' ~ collection.getSlug() ~ '/fields/' ~ field.getId() ~ '/delete') }}"
                                            data-is-slug-source="{{ (collection.hasSlug() and collection.getSlugSourceField() == field.getSlug()) ? '1' : '0' }}"
                                            title="Delete field">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                    </button>
                                </div>
                            </div>
                            {% endfor %}
                        {% else %}
                            <div class="empty-fields-message">
                                No custom fields defined yet. Add your first field below.
                            </div>
                        {% endif %}
                    </div>

                    <div class="add-field-bar">
                        <button type="button" class="btn-add-field" id="btn-open-add-field">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Add Field
                        </button>
                    </div>
        </div>{# close form-section #}
    </form>
</div>{# close tab-panel fields #}

{# ===== ROUTING TAB ===== #}
<div class="tab-panel" data-tab-panel="routing">
    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug()) }}">
        {{ csrf_field() | raw }}
        <div class="form-section">
            <div class="form-group">
                <label for="url_prefix">URL Prefix</label>
                <input type="text" id="url_prefix" name="url_prefix" class="form-control"
                       value="{{ collection.getUrlPrefix() }}"
                       placeholder="e.g. blog, products, news">
                <div class="form-hint">Auto-creates frontend routes: <code>/prefix</code> (list) and <code>/prefix/{slug}</code> (detail). Leave empty for no auto-routing.</div>
            </div>

            <div class="form-group">
                <label for="items_per_page">Items Per Page</label>
                <input type="number" id="items_per_page" name="items_per_page" class="form-control"
                       value="{{ collection.getItemsPerPage() }}" min="1" max="100">
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Save Routing</button>
            </div>
        </div>
    </form>
</div>

{# ===== ACCESS CONTROL TAB ===== #}
<div class="tab-panel" data-tab-panel="permissions">
    <div class="form-section">
        <p class="text-sm text-secondary mb-5">
            Override global entry permissions for this collection. When configured, only roles
            with explicitly granted actions can interact with entries. Leave unchecked to use global permissions.
            Admin role always has full access.
        </p>

        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug()) }}">
            {{ csrf_field() | raw }}
            <input type="hidden" name="_save_permissions" value="1">

            {% set collPerms = collection.getPermissions() ?? {} %}
            {% set actions = ['view', 'create', 'edit', 'delete', 'publish'] %}

            <div class="toggle-row">
                <div class="toggle-icon icon-primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'shield'} only %}</div>
                <div class="toggle-info">
                    <div class="toggle-name">Enable per-collection permissions</div>
                    <div class="toggle-desc">Override global permissions for this collection</div>
                </div>
                <label class="toggle">
                    <input type="checkbox" name="enable_custom_permissions" value="1"
                           id="enable_custom_perms"
                           {% if collPerms is not empty %}checked{% endif %}>
                    <div class="toggle-track"></div>
                    <div class="toggle-thumb"></div>
                </label>
            </div>

                        <div id="permissions-grid" style="{% if collPerms is empty %}display:none;{% endif %}">
                            {% if roles is not empty %}
                            <table class="perm-table">
                                <thead>
                                    <tr>
                                        <th>Role</th>
                                        {% for action in actions %}
                                            <th>{{ action }}</th>
                                        {% endfor %}
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for role in roles %}
                                        {% if role.slug != 'admin' %}
                                        <tr>
                                            <td><strong>{{ role.name }}</strong></td>
                                            {% set rolePerms = collPerms[role.slug] ?? [] %}
                                            {% for action in actions %}
                                                <td>
                                                    <input type="checkbox"
                                                           name="perms[{{ role.slug }}][]"
                                                           value="{{ action }}"
                                                           {% if action in rolePerms %}checked{% endif %}>
                                                </td>
                                            {% endfor %}
                                        </tr>
                                        {% endif %}
                                    {% endfor %}
                                </tbody>
                            </table>
                            {% else %}
                                <div class="form-hint">No roles found. Create roles in <a href="{{ admin_url('roles') }}">Roles</a> first.</div>
                            {% endif %}
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Save Permissions</button>
            </div>
        </form>
    </div>
</div>

{# ===== WORKFLOW TAB ===== #}
<div class="tab-panel" data-tab-panel="workflow">
    <div class="form-section">
        <p class="text-sm text-secondary mb-5">
            Enable workflow to require entries to pass through approval stages before publishing.
            The entry's status field becomes the workflow stage name.
        </p>

        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug()) }}">
            {{ csrf_field() | raw }}
            <input type="hidden" name="_save_workflow" value="1">

            <div class="toggle-row">
                <div class="toggle-icon icon-info">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'git-branch'} only %}</div>
                <div class="toggle-info">
                    <div class="toggle-name">Enable Workflow</div>
                    <div class="toggle-desc">Require approval stages before publishing</div>
                </div>
                <label class="toggle">
                    <input type="checkbox" name="workflow_enabled" value="1"
                           id="workflow_enabled_check"
                           {% if collection.isWorkflowEnabled() %}checked{% endif %}>
                    <div class="toggle-track"></div>
                    <div class="toggle-thumb"></div>
                </label>
                        </div>

                        <div id="workflow-config" style="{% if not collection.isWorkflowEnabled() %}display:none;{% endif %}">
                            <div class="form-group" class="mb-4">
                                <label>Stages (comma-separated)</label>
                                <input type="text" name="workflow_stages" class="form-control"
                                       value="{{ collection.getWorkflowStages()|join(', ') }}"
                                       placeholder="draft, review, approved, published">
                                <div class="form-hint">Minimum 2 stages. First stage is the entry default, last is the final published state.</div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label mb-2">Reviewers per Stage</label>
                                <div class="form-hint mb-2">
                                    Enter user IDs (comma-separated) who can advance/reject entries at each stage. Leave empty to allow any user.
                                </div>
                                {% for stage in collection.getWorkflowStages() %}
                                {% if not loop.last %}
                                <div class="workflow-stage-row">
                                    <span class="stage-label">{{ stage }}:</span>
                                    <input type="text" name="reviewers_{{ stage }}" class="form-control"
                                           value="{{ collection.getWorkflowReviewers()[stage] is defined ? collection.getWorkflowReviewers()[stage]|join(', ') : '' }}"
                                           placeholder="e.g., 1, 3, 5">
                                </div>
                                {% endif %}
                                {% endfor %}
                            </div>
                        </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Save Workflow</button>
            </div>
        </form>
    </div>
</div>
</div>{# close data-tab-group #}

{# ===== FIELD MODAL ===== #}
<div class="zui-modal-overlay" id="field-modal">
    <div class="zui-modal" style="max-width:640px">
        <div class="zui-modal-header">
            <h2 id="modal-title">Add New Field</h2>
            <button type="button" class="sidebar-panel-close" id="modal-close-btn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
            </button>
        </div>
        <form method="POST" id="field-form" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/fields') }}">
            {{ csrf_field() | raw }}
            <input type="hidden" name="_method" value="POST" id="field-form-method">

            <div class="zui-modal-body">
                <div class="form-row mb-5">
                    <div class="form-group">
                        <label class="form-label">Field Name <span style="color:var(--zui-error-500)">*</span></label>
                        <input type="text" id="modal_field_name" name="field_name" class="form-control"
                               placeholder="e.g. Title" required>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Identifier</label>
                        <input type="text" id="modal_field_slug" name="field_slug" class="form-control"
                               placeholder="Auto-generated">
                        <div class="form-hint">Database column name</div>
                    </div>
                </div>

                <div class="form-group mb-5">
                    <label class="form-label">Type</label>
                    <input type="hidden" name="field_type" id="modal_field_type" value="text">
                    <div class="type-selector-grid">
                        {% for typeKey, typeLabel in fieldTypes %}
                        <div class="type-selector-btn{% if typeKey == 'text' %} selected{% endif %}" data-type="{{ typeKey }}">
                            <div class="type-icon fti-{{ typeKey }}">
                                {% if typeKey == 'text' %}Aa
                                {% elseif typeKey == 'textarea' %}&para;
                                {% elseif typeKey == 'richtext' %}T
                                {% elseif typeKey == 'markdown' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="14" height="10" rx="1.5"/><path d="M4 10V6l2 2.5L8 6v4"/><path d="M11 8.5l1.5 1.5L14 8.5"/></svg>
                                {% elseif typeKey == 'slug' %}/
                                {% elseif typeKey == 'password' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="7" width="10" height="7" rx="1.5"/><path d="M5 7V5a3 3 0 016 0v2"/></svg>
                                {% elseif typeKey == 'number' %}#
                                {% elseif typeKey == 'decimal' %}#.0
                                {% elseif typeKey == 'boolean' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="currentColor"><rect x="1" y="4" width="14" height="8" rx="4"/><circle cx="11" cy="8" r="2.5" fill="white"/></svg>
                                {% elseif typeKey == 'date' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="12" height="11" rx="1.5"/><line x1="2" y1="7" x2="14" y2="7"/></svg>
                                {% elseif typeKey == 'datetime' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="6"/><polyline points="8,4 8,8 11,10"/></svg>
                                {% elseif typeKey == 'email' %}@
                                {% elseif typeKey == 'url' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6.5 9.5a3.5 3.5 0 005-5l-1-1a3.5 3.5 0 00-5 0"/><path d="M9.5 6.5a3.5 3.5 0 00-5 5l1 1a3.5 3.5 0 005 0"/></svg>
                                {% elseif typeKey == 'color' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="8" r="5"/><circle cx="8" cy="8" r="2" fill="currentColor"/></svg>
                                {% elseif typeKey == 'select' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="4" x2="13" y2="4"/><line x1="3" y1="8" x2="13" y2="8"/><line x1="3" y1="12" x2="13" y2="12"/></svg>
                                {% elseif typeKey == 'tags' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M1.5 3.5h5l7 7-5 5-7-7z"/><circle cx="5" cy="6" r="1" fill="currentColor"/></svg>
                                {% elseif typeKey == 'checkbox_group' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="5" height="5" rx="1"/><path d="M3 4.5l1.5 1.5 2-2"/><rect x="2" y="9" width="5" height="5" rx="1"/><line x1="9" y1="4.5" x2="14" y2="4.5"/><line x1="9" y1="11.5" x2="14" y2="11.5"/></svg>
                                {% elseif typeKey == 'media' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="12" height="12" rx="1.5"/><circle cx="5.5" cy="5.5" r="1.5"/><path d="M14 10l-3-3-7 7"/></svg>
                                {% elseif typeKey == 'json' %}{}
                                {% elseif typeKey == 'repeater' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="3" y1="3" x2="13" y2="3"/><line x1="3" y1="7" x2="13" y2="7"/><line x1="3" y1="11" x2="13" y2="11"/><circle cx="2" cy="3" r="1" fill="currentColor"/><circle cx="2" cy="7" r="1" fill="currentColor"/><circle cx="2" cy="11" r="1" fill="currentColor"/></svg>
                                {% elseif typeKey == 'relation' %}<svg viewBox="0 0 16 16" width="12" height="12" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="4" cy="8" r="2.5"/><circle cx="12" cy="8" r="2.5"/><line x1="6.5" y1="8" x2="9.5" y2="8"/></svg>
                                {% else %}?{% endif %}
                            </div>
                            <span class="type-name">{{ typeLabel }}</span>
                        </div>
                        {% endfor %}
                    </div>
                </div>

                {# ── Properties (toggles) ── #}
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-2) var(--sp-5);margin-bottom:var(--sp-5);">
                    <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                        <div class="toggle-info"><div class="toggle-name text-sm">Required</div></div>
                        <label class="toggle"><input type="checkbox" name="field_required" value="1" id="modal_field_required"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                    </div>
                    <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                        <div class="toggle-info"><div class="toggle-name text-sm">Show in list</div></div>
                        <label class="toggle"><input type="checkbox" name="field_listable" value="1" id="modal_field_listable" checked><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                    </div>
                    <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                        <div class="toggle-info"><div class="toggle-name text-sm">Searchable</div></div>
                        <label class="toggle"><input type="checkbox" name="field_searchable" value="1" id="modal_field_searchable"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                    </div>
                    <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                        <div class="toggle-info"><div class="toggle-name text-sm">Sortable</div></div>
                        <label class="toggle"><input type="checkbox" name="field_sortable" value="1" id="modal_field_sortable"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                    </div>
                    <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                        <div class="toggle-info"><div class="toggle-name text-sm">Unique</div></div>
                        <label class="toggle"><input type="checkbox" name="field_unique" value="1" id="modal_field_unique"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                    </div>
                </div>

                {# ── Type-Specific Options (shown right after type, context-sensitive) ── #}

                {# Select/Dropdown options #}
                <div id="modal-select-options-group" style="display:none;">
                    <div class="form-group">
                        <label for="modal_field_options_select">Options (one per line)</label>
                        <textarea id="modal_field_options_select" name="" class="form-control" rows="3"
                                  placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                    </div>
                </div>

                {# Checkbox Group options #}
                <div id="modal-checkbox-group-options" style="display:none;">
                    <div class="form-group">
                        <label for="modal_field_options_checkbox">Options (one per line)</label>
                        <textarea id="modal_field_options_checkbox" name="" class="form-control" rows="3"
                                  placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                    </div>
                </div>

                {# Relation options #}
                <div id="modal-relation-options-group" style="display:none;">
                    <div class="form-group">
                        <label for="modal_field_relation_type">Relation Type</label>
                        <select id="modal_field_relation_type" name="field_relation_type" class="form-control">
                            <option value="one_to_one">One to One</option>
                            <option value="one_to_many">One to Many</option>
                            <option value="many_to_many">Many to Many</option>
                        </select>
                        <div class="form-hint" id="modal-relation-type-hint">One to One: Pick a single related entry.</div>
                    </div>
                    <div class="form-row-2">
                        <div class="form-group">
                            <label for="modal_field_options_relation">Related Collection</label>
                            <select id="modal_field_options_relation" name="" class="form-control">
                                <option value="">-- Select --</option>
                                {% for col in collections %}
                                    {% if col.getSlug() != collection.getSlug() %}
                                    <option value="{{ col.getSlug() }}">{{ col.getName() }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="modal_field_display_field">Display Field</label>
                            <select id="modal_field_display_field" name="field_display_field" class="form-control">
                                <option value="">-- Select collection first --</option>
                            </select>
                        </div>
                    </div>
                </div>

                {# Media options #}
                <div id="modal-file-options-group" style="display:none;">
                    <div class="form-group">
                        <label for="modal_field_accept_preset">Accepted file types</label>
                        <select name="field_accept_preset" id="modal_field_accept_preset" class="form-control">
                            <option value="images">Images only (PNG, JPG, GIF, WEBP)</option>
                            <option value="documents">Documents (PDF, DOC, XLS)</option>
                            <option value="media">Media (Images + Video + Audio)</option>
                            <option value="all">All file types</option>
                        </select>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:var(--sp-3);margin-bottom:var(--sp-3);">
                        <div class="toggle-row" style="padding:var(--sp-2) 0;border:0;">
                            <div class="toggle-info"><div class="toggle-name text-sm">Allow multiple</div></div>
                            <label class="toggle"><input type="checkbox" name="field_multiple" value="1" id="modal_field_multiple"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                        </div>
                        <div class="form-group" id="modal-max-files-group" style="display:none;margin:0;">
                            <label for="modal_field_max_files" class="text-sm">Max files</label>
                            <input type="number" id="modal_field_max_files" name="field_max_files" class="form-control form-control-sm" value="10" min="1" max="50">
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="modal_field_max_file_size">Max file size (MB)</label>
                        <input type="number" id="modal_field_max_file_size" name="field_max_file_size" class="form-control" value="" min="0" step="0.5" placeholder="No limit">
                    </div>
                </div>

                {# Repeater sub-fields #}
                <div id="modal-repeater-options" style="display:none;">
                    <input type="hidden" name="field_sub_fields" id="modal_field_sub_fields" value="">
                    <div id="repeater-sub-fields-list"></div>
                    <button type="button" class="btn btn-sm btn-outline" id="btn-add-sub-field" style="margin-top:var(--sp-2)">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Sub-Field
                    </button>
                    <div class="form-hint" style="margin-top:var(--sp-1)">Define the fields for each repeatable row.</div>
                </div>

                {# ── Default Value (type-aware) ── #}
                <div class="form-group" style="margin-top:var(--sp-4);">
                    <label class="form-label">Default Value</label>
                    <div id="modal-default-wrapper">
                        <div id="modal-default-text">
                            <input type="text" id="modal_field_default" name="field_default" class="form-control" placeholder="Optional">
                        </div>
                        <div id="modal-default-textarea" style="display:none;">
                            <textarea id="modal_field_default_textarea" name="" class="form-control" rows="2" placeholder="Optional"></textarea>
                        </div>
                        <div id="modal-default-number" style="display:none;">
                            <input type="number" id="modal_field_default_number" name="" class="form-control" step="1" placeholder="0">
                        </div>
                        <div id="modal-default-decimal" style="display:none;">
                            <input type="number" id="modal_field_default_decimal" name="" class="form-control" step="0.01" placeholder="0.00">
                        </div>
                        <div id="modal-default-boolean" style="display:none;">
                            <label class="toggle"><input type="checkbox" id="modal_field_default_boolean" name="" value="1"><div class="toggle-track"></div><div class="toggle-thumb"></div></label>
                            <span class="text-sm text-secondary" style="margin-left:var(--sp-2)">Default on</span>
                        </div>
                        <div id="modal-default-date" style="display:none;">
                            <input type="date" id="modal_field_default_date" name="" class="form-control">
                        </div>
                        <div id="modal-default-datetime" style="display:none;">
                            <input type="datetime-local" id="modal_field_default_datetime" name="" class="form-control">
                        </div>
                        <div id="modal-default-color" style="display:none;">
                            <input type="color" id="modal_field_default_color" name="" class="form-control" style="width:60px;height:36px;padding:2px;">
                        </div>
                        <div id="modal-default-select" style="display:none;">
                            <select id="modal_field_default_select" name="" class="form-control">
                                <option value="">-- No default --</option>
                            </select>
                        </div>
                        <div id="modal-default-none" style="display:none;">
                            <span class="text-sm text-secondary">No default value for this type.</span>
                        </div>
                    </div>
                </div>

                {# ── Advanced Settings (collapsible) ── #}
                <details id="modal-advanced-settings" style="margin-top:var(--sp-4);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;">
                    <summary style="padding:var(--sp-3) var(--sp-4);cursor:pointer;font-weight:600;font-size:var(--text-sm);background:var(--bg-subdued);user-select:none;">
                        Advanced Settings
                    </summary>
                    <div style="padding:var(--sp-4);">

                        {# Type settings (DB config) #}
                        <div id="modal-type-settings" style="display:none;">
                            <div class="form-label mb-3" style="font-weight:600;">Column Configuration</div>
                            <div id="modal-text-settings" style="display:none;">
                                <div class="form-group">
                                    <label for="modal_field_db_length">Max Characters</label>
                                    <input type="number" name="field_db_length" id="modal_field_db_length" class="form-control"
                                           value="255" min="0" max="65535" placeholder="255">
                                    <div class="form-hint">0 or empty = unlimited text. 1-65,535 = fixed max length.</div>
                                </div>
                            </div>
                            <div id="modal-number-settings" style="display:none;">
                                <div class="form-group">
                                    <label for="modal_field_db_int_type">Number Range</label>
                                    <select name="field_db_int_type" id="modal_field_db_int_type" class="form-control">
                                        <option value="INT">Standard (up to ~2 billion)</option>
                                        <option value="SMALLINT">Small (up to ~32 thousand)</option>
                                        <option value="BIGINT">Large (unlimited)</option>
                                        <option value="TINYINT">Tiny (up to 127)</option>
                                    </select>
                                </div>
                            </div>
                            <div id="modal-decimal-settings" style="display:none;">
                                <div class="form-row-2">
                                    <div class="form-group">
                                        <label for="modal_field_db_precision">Total Digits</label>
                                        <input type="number" name="field_db_precision" id="modal_field_db_precision" class="form-control"
                                               value="10" min="1" max="65" placeholder="10">
                                        <div class="form-hint">e.g. 10 = up to 99,999,999.99</div>
                                    </div>
                                    <div class="form-group">
                                        <label for="modal_field_db_scale">Decimal Places</label>
                                        <input type="number" name="field_db_scale" id="modal_field_db_scale" class="form-control"
                                               value="2" min="0" max="30" placeholder="2">
                                        <div class="form-hint">2 = prices, 4 = rates</div>
                                    </div>
                                </div>
                            </div>
                            <div id="modal-url-settings" style="display:none;">
                                <div class="form-group">
                                    <label for="modal_field_db_url_length">Max URL Length</label>
                                    <input type="number" name="field_db_length" id="modal_field_db_url_length" class="form-control"
                                           value="500" min="1" max="2048" placeholder="500">
                                </div>
                            </div>
                        </div>

                        {# Validation rules #}
                        <div id="modal-validation-group" style="display:none;margin-top:var(--sp-3);">
                            <div class="form-label mb-3" style="font-weight:600;">Validation Rules</div>
                            <div id="modal-validation-presets" style="display:none;margin-bottom:var(--sp-3);">
                                <label class="form-label text-xs" style="color:var(--text-secondary);margin-bottom:var(--sp-1);">Quick Presets</label>
                                <div id="modal-preset-buttons" style="display:flex;flex-wrap:wrap;"></div>
                            </div>
                            <div class="form-row-2" id="modal-validation-length" style="display:none;">
                                <div class="form-group">
                                    <label for="modal_field_min_length">Min Length</label>
                                    <input type="number" id="modal_field_min_length" name="field_min_length" class="form-control" min="0" placeholder="e.g. 5">
                                </div>
                                <div class="form-group">
                                    <label for="modal_field_max_length">Max Length</label>
                                    <input type="number" id="modal_field_max_length" name="field_max_length" class="form-control" min="0" placeholder="e.g. 500">
                                </div>
                            </div>
                            <div class="form-row-2" id="modal-validation-value" style="display:none;">
                                <div class="form-group">
                                    <label for="modal_field_min_value">Min Value</label>
                                    <input type="number" id="modal_field_min_value" name="field_min_value" class="form-control" step="any" placeholder="e.g. 0">
                                </div>
                                <div class="form-group">
                                    <label for="modal_field_max_value">Max Value</label>
                                    <input type="number" id="modal_field_max_value" name="field_max_value" class="form-control" step="any" placeholder="e.g. 1000">
                                </div>
                            </div>
                            <div id="modal-validation-pattern" style="display:none;">
                                <div class="form-row-2">
                                    <div class="form-group">
                                        <label for="modal_field_pattern">Pattern (Regex)</label>
                                        <input type="text" id="modal_field_pattern" name="field_pattern" class="form-control" placeholder="e.g. ^[a-zA-Z]+$">
                                    </div>
                                    <div class="form-group">
                                        <label for="modal_field_pattern_message">Error Message</label>
                                        <input type="text" id="modal_field_pattern_message" name="field_pattern_message" class="form-control" placeholder="e.g. Only letters allowed">
                                    </div>
                                </div>
                            </div>
                            <div class="form-group">
                                <label for="modal_field_custom_message">Custom Required Message</label>
                                <input type="text" id="modal_field_custom_message" name="field_custom_message" class="form-control"
                                       placeholder="Override default message">
                            </div>
                        </div>

                        {# Field-level permissions #}
                        {% if roles is not empty %}
                        <div style="margin-top:var(--sp-3);">
                            <div class="form-label mb-3" style="font-weight:600;">Field Permissions</div>
                            <div class="form-row-2">
                                <div class="form-group">
                                    <label for="modal_field_perm_view">Restrict View to Roles</label>
                                    <select id="modal_field_perm_view" name="field_perm_view[]" class="form-control" multiple size="3">
                                        {% for role in roles %}
                                            {% if role.slug != 'admin' %}
                                            <option value="{{ role.slug }}">{{ role.name }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <div class="form-hint">Empty = all roles.</div>
                                </div>
                                <div class="form-group">
                                    <label for="modal_field_perm_edit">Restrict Edit to Roles</label>
                                    <select id="modal_field_perm_edit" name="field_perm_edit[]" class="form-control" multiple size="3">
                                        {% for role in roles %}
                                            {% if role.slug != 'admin' %}
                                            <option value="{{ role.slug }}">{{ role.name }}</option>
                                            {% endif %}
                                        {% endfor %}
                                    </select>
                                    <div class="form-hint">Empty = all roles.</div>
                                </div>
                            </div>
                        </div>
                        {% endif %}

                    </div>{# /details padding div #}
                </details>{# /advanced settings #}

            </div>

            <div class="zui-modal-footer">
                <button type="button" class="btn btn-outline" id="modal-cancel-btn">Cancel</button>
                <button type="submit" class="btn btn-primary" id="modal-save-btn">Save Field</button>
            </div>
        </form>
    </div>
</div>

{# Hidden delete form — reused via JS #}
<form id="delete-field-form" method="POST" action="" style="display:none;">
    {{ csrf_field() | raw }}
</form>

<script nonce="{{ csp_nonce() }}">
(function() {
    'use strict';

    var adminBase = '{{ admin_url("") }}/';
    var collectionSlug = '{{ collection.getSlug() }}';

    // ========================================================================
    // Tab URL Hash Sync
    // ========================================================================
    var tabGroup = document.querySelector('[data-tab-group="collection-edit"]');
    if (tabGroup) {
        // Restore tab from URL hash on load
        var hash = window.location.hash.replace('#', '');
        if (hash) {
            var targetPanel = tabGroup.querySelector('[data-tab-panel="' + hash + '"]');
            var targetBtn = tabGroup.querySelector('[data-tab="' + hash + '"]');
            if (targetPanel && targetBtn) {
                tabGroup.querySelectorAll('[data-tab]').forEach(function(b) { b.classList.remove('active'); });
                tabGroup.querySelectorAll('[data-tab-panel]').forEach(function(p) { p.classList.remove('active'); });
                targetBtn.classList.add('active');
                targetPanel.classList.add('active');
            }
        }

        // Update hash on tab click
        tabGroup.addEventListener('click', function(e) {
            var btn = e.target.closest('[data-tab]');
            if (btn) {
                history.replaceState(null, '', '#' + btn.getAttribute('data-tab'));
            }
        });
    }

    // ========================================================================
    // System Fields Toggle
    // ========================================================================
    var sysToggle = document.getElementById('system-fields-toggle');
    var sysBody = document.getElementById('system-fields-body');
    if (sysToggle && sysBody) {
        sysToggle.addEventListener('click', function() {
            sysToggle.classList.toggle('open');
            sysBody.classList.toggle('open');
        });
    }

    // ========================================================================
    // Toggle visibility helpers
    // ========================================================================
    function toggleVisibility(checkId, targetId) {
        var check = document.getElementById(checkId);
        var target = document.getElementById(targetId);
        if (check && target) {
            check.addEventListener('change', function() {
                target.style.display = this.checked ? '' : 'none';
            });
        }
    }
    toggleVisibility('has_slug_check', 'slug-source-group');
    toggleVisibility('is_submittable_check', 'submit-settings-group');
    toggleVisibility('has_hierarchy_check', 'hierarchy-depth-group');
    toggleVisibility('enable_custom_perms', 'permissions-grid');
    toggleVisibility('workflow_enabled_check', 'workflow-config');

    // ========================================================================
    // Field Modal
    // ========================================================================
    var modal = document.getElementById('field-modal');
    var fieldForm = document.getElementById('field-form');
    var modalTitle = document.getElementById('modal-title');
    var modalSaveBtn = document.getElementById('modal-save-btn');
    var editingFieldId = null;

    function openModal() { modal.classList.add('open'); }
    function closeModal() {
        modal.classList.remove('open');
        resetModal();
    }

    function resetModal() {
        editingFieldId = null;
        modalTitle.textContent = 'Add New Field';
        modalSaveBtn.textContent = 'Save Field';
        fieldForm.action = adminBase + 'collections/' + collectionSlug + '/fields';

        document.getElementById('modal_field_name').value = '';
        document.getElementById('modal_field_slug').value = '';
        document.getElementById('modal_field_slug').dataset.manual = '';
        document.getElementById('modal_field_type').value = 'text';
        document.getElementById('modal_field_required').checked = false;
        document.getElementById('modal_field_listable').checked = true;
        document.getElementById('modal_field_searchable').checked = false;
        document.getElementById('modal_field_sortable').checked = false;
        document.getElementById('modal_field_unique').checked = false;
        document.getElementById('modal_field_default').value = '';
        document.getElementById('modal_field_min_length') && (document.getElementById('modal_field_min_length').value = '');
        document.getElementById('modal_field_max_length') && (document.getElementById('modal_field_max_length').value = '');
        document.getElementById('modal_field_min_value') && (document.getElementById('modal_field_min_value').value = '');
        document.getElementById('modal_field_max_value') && (document.getElementById('modal_field_max_value').value = '');
        document.getElementById('modal_field_pattern') && (document.getElementById('modal_field_pattern').value = '');
        document.getElementById('modal_field_pattern_message') && (document.getElementById('modal_field_pattern_message').value = '');
        document.getElementById('modal_field_custom_message') && (document.getElementById('modal_field_custom_message').value = '');
        document.getElementById('modal_field_options_select') && (document.getElementById('modal_field_options_select').value = '');
        document.getElementById('modal_field_relation_type') && (document.getElementById('modal_field_relation_type').value = 'one_to_one');
        document.getElementById('modal_field_options_relation') && (document.getElementById('modal_field_options_relation').value = '');
        document.getElementById('modal_field_multiple') && (document.getElementById('modal_field_multiple').checked = false);
        document.getElementById('modal_field_max_files') && (document.getElementById('modal_field_max_files').value = '10');
        document.getElementById('modal_field_accept_preset') && (document.getElementById('modal_field_accept_preset').value = 'images');
        document.getElementById('modal_field_max_file_size') && (document.getElementById('modal_field_max_file_size').value = '');
        document.getElementById('modal-max-files-group') && (document.getElementById('modal-max-files-group').style.display = 'none');
        document.getElementById('modal_field_display_field') && (document.getElementById('modal_field_display_field').innerHTML = '<option value="">-- Select collection first --</option>');

        // Reset type-specific config
        document.getElementById('modal_field_db_length').value = '255';
        document.getElementById('modal_field_db_int_type').value = 'INT';
        document.getElementById('modal_field_db_precision').value = '10';
        document.getElementById('modal_field_db_scale').value = '2';
        document.getElementById('modal_field_options_checkbox') && (document.getElementById('modal_field_options_checkbox').value = '');
        document.getElementById('repeater-sub-fields-list').innerHTML = '';
        document.getElementById('modal_field_sub_fields').value = '';
        // Reset all default inputs
        document.getElementById('modal_field_default_textarea') && (document.getElementById('modal_field_default_textarea').value = '');
        document.getElementById('modal_field_default_number') && (document.getElementById('modal_field_default_number').value = '');
        document.getElementById('modal_field_default_decimal') && (document.getElementById('modal_field_default_decimal').value = '');
        document.getElementById('modal_field_default_boolean') && (document.getElementById('modal_field_default_boolean').checked = false);
        document.getElementById('modal_field_default_date') && (document.getElementById('modal_field_default_date').value = '');
        document.getElementById('modal_field_default_datetime') && (document.getElementById('modal_field_default_datetime').value = '');
        document.getElementById('modal_field_default_color') && (document.getElementById('modal_field_default_color').value = '#000000');
        document.getElementById('modal_field_default_select') && (document.getElementById('modal_field_default_select').innerHTML = '<option value="">-- No default --</option>');

        // Reset role selects
        var permView = document.getElementById('modal_field_perm_view');
        var permEdit = document.getElementById('modal_field_perm_edit');
        if (permView) { Array.from(permView.options).forEach(function(o) { o.selected = false; }); }
        if (permEdit) { Array.from(permEdit.options).forEach(function(o) { o.selected = false; }); }

        // Reset type selector visual
        document.querySelectorAll('.type-selector-btn').forEach(function(btn) {
            btn.classList.toggle('selected', btn.dataset.type === 'text');
        });
        updateTypeSpecificFields('text');
    }

    document.getElementById('btn-open-add-field').addEventListener('click', function() {
        resetModal();
        openModal();
    });
    document.getElementById('modal-close-btn').addEventListener('click', closeModal);
    document.getElementById('modal-cancel-btn').addEventListener('click', closeModal);

    // Close on backdrop click
    modal.addEventListener('click', function(e) {
        if (e.target === modal) closeModal();
    });

    // Close on Escape
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape' && modal.classList.contains('open')) closeModal();
    });

    // ========================================================================
    // Type Selector
    // ========================================================================
    document.querySelectorAll('.type-selector-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.type-selector-btn').forEach(function(b) { b.classList.remove('selected'); });
            btn.classList.add('selected');
            var type = btn.dataset.type;
            document.getElementById('modal_field_type').value = type;
            updateTypeSpecificFields(type);
        });
    });

    function updateTypeSpecificFields(type) {
        // Type-specific option panels
        var panels = {
            'modal-select-options-group': type === 'select',
            'modal-checkbox-group-options': type === 'checkbox_group',
            'modal-relation-options-group': type === 'relation',
            'modal-file-options-group': type === 'media',
            'modal-repeater-options': type === 'repeater'
        };
        var selectInput = document.getElementById('modal_field_options_select');
        var relationInput = document.getElementById('modal_field_options_relation');
        var checkboxInput = document.getElementById('modal_field_options_checkbox');
        selectInput.name = type === 'select' ? 'field_options' : '';
        relationInput.name = type === 'relation' ? 'field_options' : '';
        checkboxInput.name = type === 'checkbox_group' ? 'field_options' : '';
        Object.keys(panels).forEach(function(id) {
            document.getElementById(id).style.display = panels[id] ? '' : 'none';
        });

        // Column config in advanced settings
        var ts = document.getElementById('modal-type-settings');
        var cfgs = { 'modal-text-settings': false, 'modal-number-settings': false, 'modal-decimal-settings': false, 'modal-url-settings': false };
        if (['text','email','slug','select','password','checkbox_group'].includes(type)) cfgs['modal-text-settings'] = true;
        else if (type === 'number') cfgs['modal-number-settings'] = true;
        else if (type === 'decimal') cfgs['modal-decimal-settings'] = true;
        else if (type === 'url') cfgs['modal-url-settings'] = true;
        var hasTs = Object.values(cfgs).some(Boolean);
        ts.style.display = hasTs ? '' : 'none';
        Object.keys(cfgs).forEach(function(id) { document.getElementById(id).style.display = cfgs[id] ? '' : 'none'; });

        // Validation — show relevant sections per type
        var vg = document.getElementById('modal-validation-group');
        var vl = document.getElementById('modal-validation-length');
        var vv = document.getElementById('modal-validation-value');
        var vp = document.getElementById('modal-validation-pattern');
        var vPreset = document.getElementById('modal-validation-presets');

        var textTypes = ['text','textarea','richtext','email','url','slug','markdown','password'];
        var numberTypes = ['number','decimal'];
        var presetTypes = ['text','email','url','password'];
        var hasLength = textTypes.includes(type);
        var hasValue = numberTypes.includes(type);
        var hasPattern = textTypes.includes(type);
        var hasPreset = presetTypes.includes(type);
        var showValidation = hasLength || hasValue || hasPattern || hasPreset;

        if (vg) vg.style.display = showValidation ? '' : 'none';
        if (vl) vl.style.display = hasLength ? '' : 'none';
        if (vv) vv.style.display = hasValue ? '' : 'none';
        if (vp) vp.style.display = hasPattern ? '' : 'none';
        if (vPreset) {
            vPreset.style.display = hasPreset ? '' : 'none';
            updatePresetOptions(type);
        }

        // Toggle relevant properties
        var uniqueToggle = document.getElementById('modal_field_unique').closest('.toggle-row');
        var searchToggle = document.getElementById('modal_field_searchable').closest('.toggle-row');
        var sortToggle = document.getElementById('modal_field_sortable').closest('.toggle-row');
        var noUnique = ['boolean','media','relation','repeater','json','checkbox_group'];
        var noSearch = ['boolean','media','relation','repeater','color'];
        var noSort = ['richtext','textarea','markdown','json','repeater','checkbox_group','media','relation'];
        if (uniqueToggle) uniqueToggle.style.display = noUnique.includes(type) ? 'none' : '';
        if (searchToggle) searchToggle.style.display = noSearch.includes(type) ? 'none' : '';
        if (sortToggle) sortToggle.style.display = noSort.includes(type) ? 'none' : '';

        updateDefaultInput(type);
    }

    // Predefined validation presets per type
    function updatePresetOptions(type) {
        var container = document.getElementById('modal-preset-buttons');
        if (!container) return;
        container.innerHTML = '';
        var presets = [];
        if (type === 'email') {
            presets = [
                { label: 'Standard email', pattern: '', msg: '', desc: 'Built-in email validation' }
            ];
        } else if (type === 'url') {
            presets = [
                { label: 'HTTPS only', pattern: '^https://', msg: 'URL must use HTTPS', desc: 'Require secure URLs' },
                { label: 'Any URL', pattern: '', msg: '', desc: 'Built-in URL validation' }
            ];
        } else if (type === 'password') {
            presets = [
                { label: 'Strong', pattern: '^(?=.*[a-z])(?=.*[A-Z])(?=.*\\d)(?=.*[@$!%*?&]).{8,}$', msg: 'Must contain uppercase, lowercase, number, and symbol', desc: '8+ chars, mixed' },
                { label: 'Medium', pattern: '^(?=.*[a-zA-Z])(?=.*\\d).{6,}$', msg: 'Must contain letters and numbers', desc: '6+ chars, letters+numbers' }
            ];
        } else if (type === 'text') {
            presets = [
                { label: 'Letters only', pattern: '^[a-zA-Z\\s]+$', msg: 'Only letters and spaces allowed', desc: 'No numbers or symbols' },
                { label: 'Alphanumeric', pattern: '^[a-zA-Z0-9\\s]+$', msg: 'Only letters, numbers and spaces', desc: 'No special characters' },
                { label: 'Phone', pattern: '^[\\+]?[0-9\\s\\-\\(\\)]{7,15}$', msg: 'Enter a valid phone number', desc: 'International format' },
                { label: 'No HTML', pattern: '^[^<>]*$', msg: 'HTML tags are not allowed', desc: 'Prevent HTML injection' }
            ];
        }
        presets.forEach(function(p) {
            var btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'btn btn-sm btn-outline';
            btn.textContent = p.label;
            btn.title = p.desc;
            btn.style.marginRight = 'var(--sp-1)';
            btn.style.marginBottom = 'var(--sp-1)';
            btn.addEventListener('click', function() {
                if (p.pattern) document.getElementById('modal_field_pattern').value = p.pattern;
                if (p.msg) document.getElementById('modal_field_pattern_message').value = p.msg;
                container.querySelectorAll('.btn').forEach(function(b) { b.classList.remove('btn-primary'); b.classList.add('btn-outline'); });
                btn.classList.remove('btn-outline');
                btn.classList.add('btn-primary');
            });
            container.appendChild(btn);
        });
    }

    function updateDefaultInput(type) {
        var all = ['text','textarea','number','decimal','boolean','date','datetime','color','select','none'];
        all.forEach(function(k) {
            var el = document.getElementById('modal-default-' + k);
            if (el) el.style.display = 'none';
        });
        // Disable all default name attrs
        ['modal_field_default','modal_field_default_textarea','modal_field_default_number',
         'modal_field_default_decimal','modal_field_default_boolean','modal_field_default_date',
         'modal_field_default_datetime','modal_field_default_color','modal_field_default_select'].forEach(function(id) {
            var el = document.getElementById(id);
            if (el) el.name = '';
        });

        var show = 'text'; var nameId = 'modal_field_default';
        if (['textarea','richtext','markdown','json'].includes(type)) { show = 'textarea'; nameId = 'modal_field_default_textarea'; }
        else if (type === 'number') { show = 'number'; nameId = 'modal_field_default_number'; }
        else if (type === 'decimal') { show = 'decimal'; nameId = 'modal_field_default_decimal'; }
        else if (type === 'boolean') { show = 'boolean'; nameId = 'modal_field_default_boolean'; }
        else if (type === 'date') { show = 'date'; nameId = 'modal_field_default_date'; }
        else if (type === 'datetime') { show = 'datetime'; nameId = 'modal_field_default_datetime'; }
        else if (type === 'color') { show = 'color'; nameId = 'modal_field_default_color'; }
        else if (type === 'select' || type === 'checkbox_group') { show = 'select'; nameId = 'modal_field_default_select'; }
        else if (['media','relation','repeater','tags'].includes(type)) { show = 'none'; nameId = ''; }
        else { show = 'text'; nameId = 'modal_field_default'; }

        var el = document.getElementById('modal-default-' + show);
        if (el) el.style.display = '';
        if (nameId) {
            var inp = document.getElementById(nameId);
            if (inp) inp.name = 'field_default';
        }
    }

    // Update select default dropdown when choices change
    function syncDefaultChoices() {
        var sel = document.getElementById('modal_field_default_select');
        if (!sel) return;
        var type = document.getElementById('modal_field_type').value;
        var src = type === 'checkbox_group' ? 'modal_field_options_checkbox' : 'modal_field_options_select';
        var textarea = document.getElementById(src);
        if (!textarea) return;
        var choices = textarea.value.split('\n').map(function(s){return s.trim();}).filter(Boolean);
        var current = sel.value;
        sel.innerHTML = '<option value="">-- No default --</option>';
        choices.forEach(function(c) {
            var opt = document.createElement('option');
            opt.value = c; opt.textContent = c;
            if (c === current) opt.selected = true;
            sel.appendChild(opt);
        });
    }
    document.getElementById('modal_field_options_select').addEventListener('input', syncDefaultChoices);
    document.getElementById('modal_field_options_checkbox').addEventListener('input', syncDefaultChoices);

    // Repeater sub-field management
    var subFieldCount = 0;
    function addSubField(name, slug, type) {
        subFieldCount++;
        var list = document.getElementById('repeater-sub-fields-list');
        var div = document.createElement('div');
        div.className = 'flex gap-2 mb-2 items-center';
        div.style.cssText = 'background:var(--bg-subdued);padding:var(--sp-2);border-radius:var(--radius);border:1px solid var(--border);';

        var nameInput = document.createElement('input');
        nameInput.type = 'text'; nameInput.className = 'form-control form-control-sm';
        nameInput.placeholder = 'Field name'; nameInput.value = name || '';
        nameInput.setAttribute('data-sf', 'name'); nameInput.style.flex = '2';

        var slugInput = document.createElement('input');
        slugInput.type = 'text'; slugInput.className = 'form-control form-control-sm';
        slugInput.placeholder = 'slug'; slugInput.value = slug || '';
        slugInput.setAttribute('data-sf', 'slug'); slugInput.style.flex = '1';

        var typeSelect = document.createElement('select');
        typeSelect.className = 'form-control form-control-sm';
        typeSelect.setAttribute('data-sf', 'type'); typeSelect.style.flex = '1';
        [['text','Text'],['textarea','Textarea'],['number','Number'],['boolean','Toggle'],['select','Dropdown'],['date','Date'],['media','Media']].forEach(function(opt) {
            var o = document.createElement('option');
            o.value = opt[0]; o.textContent = opt[1];
            if (opt[0] === (type || 'text')) o.selected = true;
            typeSelect.appendChild(o);
        });

        var delBtn = document.createElement('button');
        delBtn.type = 'button';
        delBtn.className = 'btn btn-sm btn-icon btn-ghost';
        delBtn.style.cssText = 'color:var(--zui-error-500);flex-shrink:0;';
        delBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';
        delBtn.addEventListener('click', function() {
            div.remove();
            syncSubFields();
        });

        div.appendChild(nameInput);
        div.appendChild(slugInput);
        div.appendChild(typeSelect);
        div.appendChild(delBtn);
        list.appendChild(div);

        nameInput.addEventListener('input', function() {
            if (!slugInput.dataset.manual) slugInput.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
            syncSubFields();
        });
        slugInput.addEventListener('input', function() { this.dataset.manual = '1'; syncSubFields(); });
        typeSelect.addEventListener('change', syncSubFields);
        syncSubFields();
    }
    function syncSubFields() {
        var rows = document.querySelectorAll('#repeater-sub-fields-list > div');
        var fields = [];
        rows.forEach(function(row) {
            var n = row.querySelector('[data-sf="name"]').value.trim();
            var s = row.querySelector('[data-sf="slug"]').value.trim();
            var t = row.querySelector('[data-sf="type"]').value;
            if (n && s) fields.push({name:n, slug:s, type:t});
        });
        document.getElementById('modal_field_sub_fields').value = JSON.stringify(fields);
    }
    document.getElementById('btn-add-sub-field').addEventListener('click', function() { addSubField('','','text'); });

    // ========================================================================
    // File options — multiple toggle
    // ========================================================================
    var multipleCheckbox = document.getElementById('modal_field_multiple');
    var maxFilesGroup = document.getElementById('modal-max-files-group');
    if (multipleCheckbox) {
        multipleCheckbox.addEventListener('change', function() {
            maxFilesGroup.style.display = this.checked ? '' : 'none';
        });
    }

    // ========================================================================
    // Slug auto-generation in modal
    // ========================================================================
    var modalName = document.getElementById('modal_field_name');
    var modalSlug = document.getElementById('modal_field_slug');
    modalName.addEventListener('input', function() {
        if (!modalSlug.dataset.manual) {
            modalSlug.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
        }
    });
    modalSlug.addEventListener('input', function() {
        this.dataset.manual = '1';
    });

    // ========================================================================
    // Relation type hints
    // ========================================================================
    var relationTypeHints = {
        'one_to_one': 'One to One: Pick a single related entry.',
        'one_to_many': 'One to Many: This entry can link to multiple entries in the related collection.',
        'many_to_many': 'Many to Many: Entries in both collections can link to each other.'
    };
    var relTypeSelect = document.getElementById('modal_field_relation_type');
    if (relTypeSelect) {
        relTypeSelect.addEventListener('change', function() {
            var hint = document.getElementById('modal-relation-type-hint');
            if (hint) hint.textContent = relationTypeHints[this.value] || '';
        });
    }

    // ========================================================================
    // Load related collection fields
    // ========================================================================
    var relCollSelect = document.getElementById('modal_field_options_relation');
    var displayFieldSelect = document.getElementById('modal_field_display_field');
    if (relCollSelect && displayFieldSelect) {
        relCollSelect.addEventListener('change', function() {
            var collSlug = this.value;
            displayFieldSelect.innerHTML = '<option value="">-- Loading... --</option>';
            if (!collSlug) {
                displayFieldSelect.innerHTML = '<option value="">-- Select collection first --</option>';
                return;
            }
            fetch(adminBase + 'collections/' + collSlug + '/fields-json')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    displayFieldSelect.innerHTML = '<option value="">-- Auto-detect --</option>';
                    (data.fields || []).forEach(function(f) {
                        var opt = document.createElement('option');
                        opt.value = f.slug;
                        opt.textContent = f.name + ' (' + f.type + ')';
                        displayFieldSelect.appendChild(opt);
                    });
                })
                .catch(function() {
                    displayFieldSelect.innerHTML = '<option value="">-- Failed to load --</option>';
                });
        });
    }

    // ========================================================================
    // Edit field — load data into modal
    // ========================================================================
    document.querySelectorAll('.btn-edit-field').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var fieldId = this.dataset.fieldId;
            var slug = this.dataset.fieldSlug;
            editingFieldId = fieldId;

            modalTitle.textContent = 'Edit Field';
            modalSaveBtn.textContent = 'Update Field';
            fieldForm.action = adminBase + 'collections/' + slug + '/fields/' + fieldId;

            // Fetch field data
            fetch(adminBase + 'collections/' + slug + '/fields/' + fieldId + '/json')
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    document.getElementById('modal_field_name').value = data.name || '';
                    document.getElementById('modal_field_slug').value = data.slug || '';
                    document.getElementById('modal_field_slug').dataset.manual = '1';

                    // Set type
                    document.getElementById('modal_field_type').value = data.type || 'text';
                    document.querySelectorAll('.type-selector-btn').forEach(function(b) {
                        b.classList.toggle('selected', b.dataset.type === data.type);
                    });
                    updateTypeSpecificFields(data.type);

                    // Properties
                    document.getElementById('modal_field_required').checked = !!data.is_required;
                    document.getElementById('modal_field_listable').checked = data.is_listable !== false;
                    document.getElementById('modal_field_searchable').checked = !!data.is_searchable;
                    document.getElementById('modal_field_sortable').checked = !!data.is_sortable;
                    document.getElementById('modal_field_unique').checked = !!data.is_unique;

                    // Default value
                    document.getElementById('modal_field_default').value = data.default_value || '';

                    var opts = data.options || {};

                    // Select options
                    if (data.type === 'select' && opts.choices) {
                        document.getElementById('modal_field_options_select').value = opts.choices.join('\n');
                    }

                    // Relation options
                    if (data.type === 'relation') {
                        if (opts.relation_type) {
                            document.getElementById('modal_field_relation_type').value = opts.relation_type;
                            var hint = document.getElementById('modal-relation-type-hint');
                            if (hint) hint.textContent = relationTypeHints[opts.relation_type] || '';
                        }
                        if (opts.relation_collection) {
                            document.getElementById('modal_field_options_relation').value = opts.relation_collection;
                            // Trigger loading of display fields
                            fetch(adminBase + 'collections/' + opts.relation_collection + '/fields-json')
                                .then(function(r) { return r.json(); })
                                .then(function(fd) {
                                    var dfs = document.getElementById('modal_field_display_field');
                                    dfs.innerHTML = '<option value="">-- Auto-detect --</option>';
                                    (fd.fields || []).forEach(function(f) {
                                        var opt = document.createElement('option');
                                        opt.value = f.slug;
                                        opt.textContent = f.name + ' (' + f.type + ')';
                                        if (opts.display_field === f.slug) opt.selected = true;
                                        dfs.appendChild(opt);
                                    });
                                }).catch(function() {});
                        }
                    }

                    // Validation
                    if (opts.min_length !== undefined) document.getElementById('modal_field_min_length').value = opts.min_length;
                    if (opts.max_length !== undefined) document.getElementById('modal_field_max_length').value = opts.max_length;
                    if (opts.min_value !== undefined) document.getElementById('modal_field_min_value').value = opts.min_value;
                    if (opts.max_value !== undefined) document.getElementById('modal_field_max_value').value = opts.max_value;
                    if (opts.pattern) document.getElementById('modal_field_pattern').value = opts.pattern;
                    if (opts.pattern_message) document.getElementById('modal_field_pattern_message').value = opts.pattern_message;
                    if (opts.custom_message) document.getElementById('modal_field_custom_message').value = opts.custom_message;

                    // File/Media options
                    if (data.type === 'image' || data.type === 'file' || data.type === 'media') {
                        if (opts.multiple) {
                            document.getElementById('modal_field_multiple').checked = true;
                            document.getElementById('modal-max-files-group').style.display = '';
                        }
                        if (opts.max_files) document.getElementById('modal_field_max_files').value = opts.max_files;
                        if (opts.accept_preset) document.getElementById('modal_field_accept_preset').value = opts.accept_preset;
                        if (opts.max_file_size) document.getElementById('modal_field_max_file_size').value = (opts.max_file_size / 1024 / 1024).toFixed(1).replace(/\.0$/, '');
                    }

                    // Checkbox group options
                    if (data.type === 'checkbox_group' && opts.choices) {
                        document.getElementById('modal_field_options_checkbox').value = opts.choices.join('\n');
                    }

                    // Repeater sub-fields
                    if (data.type === 'repeater' && opts.sub_fields) {
                        document.getElementById('repeater-sub-fields-list').innerHTML = '';
                        opts.sub_fields.forEach(function(sf) { addSubField(sf.name, sf.slug, sf.type); });
                    }

                    // Type-specific DB config
                    if (opts.db_length) document.getElementById('modal_field_db_length').value = opts.db_length;
                    if (opts.db_int_type) document.getElementById('modal_field_db_int_type').value = opts.db_int_type;
                    if (opts.db_precision) document.getElementById('modal_field_db_precision').value = opts.db_precision;
                    if (opts.db_scale) document.getElementById('modal_field_db_scale').value = opts.db_scale;

                    // Field permissions
                    if (opts.field_permissions) {
                        var permView = document.getElementById('modal_field_perm_view');
                        var permEdit = document.getElementById('modal_field_perm_edit');
                        if (permView && opts.field_permissions.view) {
                            Array.from(permView.options).forEach(function(o) {
                                o.selected = opts.field_permissions.view.indexOf(o.value) !== -1;
                            });
                        }
                        if (permEdit && opts.field_permissions.edit) {
                            Array.from(permEdit.options).forEach(function(o) {
                                o.selected = opts.field_permissions.edit.indexOf(o.value) !== -1;
                            });
                        }
                    }

                    openModal();
                })
                .catch(function(err) {
                    console.error('Failed to load field data:', err);
                    alert('Failed to load field data. Please try again.');
                });
        });
    });

    // ========================================================================
    // Delete field
    // ========================================================================
    document.querySelectorAll('.btn-delete').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var name = this.dataset.fieldName;
            var url = this.dataset.deleteUrl;
            var isSlugSource = this.dataset.isSlugSource === '1';
            var msg = isSlugSource
                ? 'WARNING: This field is the slug source. Deleting it will also remove the slug column and all slug data from entries. Continue?'
                : 'Delete field "' + name + '"? Column data will be lost!';
            if (confirm(msg)) {
                var form = document.getElementById('delete-field-form');
                form.action = url;
                form.submit();
            }
        });
    });

    // ========================================================================
    // Drag and Drop Reorder
    // ========================================================================
    var fieldList = document.getElementById('field-list');
    var dragItem = null;

    fieldList.addEventListener('dragstart', function(e) {
        var row = e.target.closest('.custom-field-row');
        if (!row) return;
        dragItem = row;
        row.classList.add('dragging');
        e.dataTransfer.effectAllowed = 'move';
        e.dataTransfer.setData('text/plain', '');
    });

    fieldList.addEventListener('dragend', function(e) {
        var row = e.target.closest('.custom-field-row');
        if (row) row.classList.remove('dragging');
        document.querySelectorAll('.custom-field-row').forEach(function(r) { r.classList.remove('drag-over'); });
        dragItem = null;
    });

    fieldList.addEventListener('dragover', function(e) {
        e.preventDefault();
        e.dataTransfer.dropEffect = 'move';
        var row = e.target.closest('.custom-field-row');
        if (row && row !== dragItem) {
            document.querySelectorAll('.custom-field-row').forEach(function(r) { r.classList.remove('drag-over'); });
            row.classList.add('drag-over');
        }
    });

    fieldList.addEventListener('drop', function(e) {
        e.preventDefault();
        var row = e.target.closest('.custom-field-row');
        if (!row || !dragItem || row === dragItem) return;

        var rows = Array.from(fieldList.querySelectorAll('.custom-field-row'));
        var dragIdx = rows.indexOf(dragItem);
        var dropIdx = rows.indexOf(row);

        if (dragIdx < dropIdx) {
            row.parentNode.insertBefore(dragItem, row.nextSibling);
        } else {
            row.parentNode.insertBefore(dragItem, row);
        }

        document.querySelectorAll('.custom-field-row').forEach(function(r) { r.classList.remove('drag-over'); });

        // Save new order
        var newOrder = Array.from(fieldList.querySelectorAll('.custom-field-row')).map(function(r) {
            return parseInt(r.dataset.fieldId, 10);
        });

        fetch(adminBase + 'collections/' + collectionSlug + '/fields/reorder', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ order: newOrder })
        }).catch(function(err) {
            console.error('Failed to save field order:', err);
        });
    });

})();
</script>
{% endblock %}
