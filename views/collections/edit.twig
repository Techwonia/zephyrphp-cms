{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit {{ collection.getName() }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms/collections">Collections</a> / {{ collection.getName() }}
</div>

<div class="page-header">
    <h1>{{ collection.getName() }}</h1>
    <div class="page-actions">
        <a href="/cms/collections/{{ collection.getSlug() }}/entries" class="btn btn-outline">View Entries ({{ entryCount }})</a>
    </div>
</div>

<div class="tab-nav">
    <button class="tab-btn active" data-tab="tab-settings">Settings</button>
    <button class="tab-btn" data-tab="tab-fields">Fields ({{ fields|length }})</button>
</div>

{# ===== SETTINGS TAB ===== #}
<div id="tab-settings" class="tab-panel active">
    <div class="card">
        <div class="card-body">
            <form method="POST" action="/cms/collections/{{ collection.getSlug() }}">
                {{ csrf_field() | raw }}

                <div class="form-group">
                    <label for="name">Collection Name *</label>
                    <input type="text" id="name" name="name" class="form-control"
                           value="{{ collection.getName() }}" required>
                </div>

                <div class="form-group">
                    <label>Slug</label>
                    <input type="text" class="form-control" value="{{ collection.getSlug() }}" disabled>
                    <p class="text-muted">Slug cannot be changed after creation (table: cms_{{ collection.getSlug() }}).</p>
                </div>

                <div class="form-group">
                    <label for="description">Description</label>
                    <textarea id="description" name="description" class="form-control"
                              rows="3">{{ collection.getDescription() }}</textarea>
                </div>

                <div class="form-group">
                    <label for="primary_key_type">Primary Key Type</label>
                    <select id="primary_key_type" name="primary_key_type" class="form-control"
                            {% if entryCount > 0 %}disabled{% endif %}>
                        <option value="integer" {% if collection.getPrimaryKeyType() == 'integer' %}selected{% endif %}>Integer (Auto-Increment)</option>
                        <option value="uuid" {% if collection.getPrimaryKeyType() == 'uuid' %}selected{% endif %}>UUID (CHAR 36)</option>
                    </select>
                    {% if entryCount > 0 %}
                        <p class="text-muted">Primary key type cannot be changed when entries exist ({{ entryCount }} entries).</p>
                        <input type="hidden" name="primary_key_type" value="{{ collection.getPrimaryKeyType() }}">
                    {% else %}
                        <p class="text-muted">Choose how entry IDs are generated. UUID provides globally unique identifiers.</p>
                    {% endif %}
                </div>

                <div class="form-inline-checks">
                    <label>
                        <input type="checkbox" name="is_api_enabled" value="1"
                               {% if collection.isApiEnabled() %}checked{% endif %}>
                        Enable REST API
                    </label>
                    <label>
                        <input type="checkbox" name="is_publishable" value="1"
                               {% if collection.isPublishable() %}checked{% endif %}>
                        Publishable
                    </label>
                    <label>
                        <input type="checkbox" name="has_slug" value="1" id="has_slug_check"
                               {% if collection.hasSlug() %}checked{% endif %}>
                        Enable Slug Field
                    </label>
                </div>

                <div id="slug-source-group" style="{% if not collection.hasSlug() %}display:none;{% endif %}">
                    <div class="form-group">
                        <label for="slug_source_field">Generate Slug From</label>
                        <select name="slug_source_field" id="slug_source_field" class="form-control">
                            <option value="">-- Select field --</option>
                            {% for field in fields %}
                                {% if field.getType() in ['text', 'email', 'url'] %}
                                <option value="{{ field.getSlug() }}"
                                        {% if collection.getSlugSourceField() == field.getSlug() %}selected{% endif %}>
                                    {{ field.getName() }} ({{ field.getSlug() }})
                                </option>
                                {% endif %}
                            {% endfor %}
                        </select>
                        <p class="text-muted">Which text field to auto-generate slugs from. Leave empty to require manual slugs.</p>
                    </div>
                </div>

                <div class="form-actions">
                    <button type="submit" class="btn btn-primary">Save Settings</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ===== FIELDS TAB ===== #}
<div id="tab-fields" class="tab-panel">
    <div class="card">
        <div class="card-header">
            <h3>Fields</h3>
        </div>
        <div class="card-body">
            {# ===== SYSTEM FIELDS (read-only) ===== #}
            <div class="system-fields-section">
                <h4 class="text-muted" style="margin-bottom: var(--space-200); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">System Fields</h4>

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">ID</div>
                        <div class="field-meta">
                            <code>id</code>
                            &middot; <span class="field-badge">{{ collection.isUuid() ? 'uuid (CHAR 36)' : 'integer (auto-increment)' }}</span>
                            <span class="field-badge">primary key</span>
                            <span class="field-badge required">required</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>

                {% if collection.hasSlug() %}
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Slug</div>
                        <div class="field-meta">
                            <code>slug</code>
                            &middot; <span class="field-badge">string (255)</span>
                            <span class="field-badge unique">unique</span>
                            <span class="field-badge">auto-generated{% if collection.getSlugSourceField() %} from {{ collection.getSlugSourceField() }}{% endif %}</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                {% endif %}

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Created By</div>
                        <div class="field-meta">
                            <code>created_by</code>
                            &middot; <span class="field-badge">integer</span>
                            <span class="field-badge">nullable</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Created At</div>
                        <div class="field-meta">
                            <code>created_at</code>
                            &middot; <span class="field-badge">datetime</span>
                            <span class="field-badge">auto</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Updated At</div>
                        <div class="field-meta">
                            <code>updated_at</code>
                            &middot; <span class="field-badge">datetime</span>
                            <span class="field-badge">auto</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>

                {% if collection.isPublishable() %}
                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Status</div>
                        <div class="field-meta">
                            <code>status</code>
                            &middot; <span class="field-badge">string</span>
                            <span class="field-badge">default: draft</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>

                <div class="field-row field-system">
                    <div class="field-info">
                        <div class="field-name">Published At</div>
                        <div class="field-meta">
                            <code>published_at</code>
                            &middot; <span class="field-badge">datetime</span>
                            <span class="field-badge">nullable</span>
                        </div>
                    </div>
                    <div><span class="field-badge" style="opacity: 0.5;">system</span></div>
                </div>
                {% endif %}
            </div>

            {# ===== USER-DEFINED FIELDS ===== #}
            {% if fields|length > 0 %}
                <h4 class="text-muted" style="margin: var(--space-400) 0 var(--space-200); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em;">Custom Fields</h4>
                {% for field in fields %}
                <div class="field-row">
                    <div class="field-info">
                        <div class="field-name">{{ field.getName() }}</div>
                        <div class="field-meta">
                            <code>{{ field.getSlug() }}</code>
                            &middot; <span class="field-badge">{{ field.getType() }}</span>
                            {% if field.getType() == 'relation' and field.getOptions().relation_type is defined %}
                                <span class="field-badge">{{ field.getOptions().relation_type|replace({'_': ' '}) }}</span>
                                {% if field.getOptions().relation_collection is defined %}
                                    <span class="field-badge">&rarr; {{ field.getOptions().relation_collection }}</span>
                                {% endif %}
                                {% if field.getOptions().display_field is defined and field.getOptions().display_field %}
                                    <span class="field-badge">display: {{ field.getOptions().display_field }}</span>
                                {% endif %}
                            {% endif %}
                            {% if field.isRequired() %}<span class="field-badge required">required</span>{% endif %}
                            {% if field.isUnique() %}<span class="field-badge">unique</span>{% endif %}
                            {% if field.isSearchable() %}<span class="field-badge">searchable</span>{% endif %}
                            {% if field.isSortable() %}<span class="field-badge">sortable</span>{% endif %}
                            {% if not field.isListable() %}<span class="field-badge">hidden</span>{% endif %}
                            {% if collection.hasSlug() and collection.getSlugSourceField() == field.getSlug() %}
                                <span class="field-badge slug-source">slug source</span>
                            {% endif %}
                        </div>
                    </div>
                    <div>
                        <form method="POST" action="/cms/collections/{{ collection.getSlug() }}/fields/{{ field.getId() }}/delete"
                              style="display:inline"
                              class="confirm-delete"
                              data-message="{% if collection.hasSlug() and collection.getSlugSourceField() == field.getSlug() %}WARNING: This field is the slug source. Deleting it will also remove the slug column and all slug data from entries. Continue?{% else %}Delete field {{ field.getName() }}? Column data will be lost!{% endif %}">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                        </form>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="empty-state" style="margin-top: var(--space-400);">
                    <p>No custom fields defined yet. Add your first field below.</p>
                </div>
            {% endif %}

            {# ADD FIELD FORM #}
            <div class="add-field-form">
                <h4>Add New Field</h4>
                <form method="POST" action="/cms/collections/{{ collection.getSlug() }}/fields">
                    {{ csrf_field() | raw }}

                    <div class="form-row">
                        <div class="form-group">
                            <label for="field_name">Name *</label>
                            <input type="text" id="field_name" name="field_name" class="form-control"
                                   placeholder="e.g. Title" required>
                        </div>
                        <div class="form-group">
                            <label for="field_slug">Slug</label>
                            <input type="text" id="field_slug" name="field_slug" class="form-control"
                                   placeholder="Auto from name">
                        </div>
                        <div class="form-group">
                            <label for="field_type">Type</label>
                            <select id="field_type" name="field_type" class="form-control">
                                {% for typeKey, typeLabel in fieldTypes %}
                                    <option value="{{ typeKey }}">{{ typeLabel }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>

                    <div class="form-inline-checks">
                        <label><input type="checkbox" name="field_required" value="1"> Required</label>
                        <label><input type="checkbox" name="field_listable" value="1" checked> Show in list</label>
                        <label><input type="checkbox" name="field_searchable" value="1"> Searchable</label>
                        <label><input type="checkbox" name="field_sortable" value="1"> Sortable</label>
                        <label><input type="checkbox" name="field_unique" value="1"> Unique</label>
                        {% if not collection.hasSlug() %}
                        <label id="use-as-slug-label" style="display:none;">
                            <input type="checkbox" name="use_as_slug" value="1" id="useAsSlugCheck">
                            Use as Slug
                            <small style="display:block;font-weight:normal;color:var(--text-secondary,#616161);">Auto-generates a URL-friendly slug from this field for each entry.</small>
                        </label>
                        {% endif %}
                    </div>

                    <div class="form-group" id="select-options-group" style="display: none;">
                        <label for="field_options_select">Options (one per line)</label>
                        <textarea id="field_options_select" name="field_options" class="form-control" rows="3"
                                  placeholder="Option 1&#10;Option 2&#10;Option 3"></textarea>
                    </div>

                    <div id="relation-options-group" style="display: none;">
                        <div class="form-row">
                            <div class="form-group">
                                <label for="field_relation_type">Relation Type</label>
                                <select id="field_relation_type" name="field_relation_type" class="form-control">
                                    <option value="one_to_one">One to One</option>
                                    <option value="one_to_many">One to Many</option>
                                    <option value="many_to_many">Many to Many</option>
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="field_options_relation">Related Collection</label>
                                <select id="field_options_relation" name="field_options" class="form-control">
                                    <option value="">-- Select a collection --</option>
                                    {% for col in collections %}
                                        {% if col.getSlug() != collection.getSlug() %}
                                        <option value="{{ col.getSlug() }}">{{ col.getName() }} ({{ col.getSlug() }})</option>
                                        {% endif %}
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="form-group">
                                <label for="field_display_field">Display Field</label>
                                <select id="field_display_field" name="field_display_field" class="form-control">
                                    <option value="">-- Select collection first --</option>
                                </select>
                                <p class="text-muted">Which field from the related collection to show as the label (e.g. title, name).</p>
                            </div>
                        </div>
                        <p class="text-muted" id="relation-type-hint">One to One: Pick a single related entry.</p>
                    </div>

                    <div class="form-group">
                        <label for="field_default">Default Value</label>
                        <input type="text" id="field_default" name="field_default" class="form-control"
                               placeholder="Optional">
                    </div>

                    <button type="submit" class="btn btn-primary">Add Field</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.getElementById('field_name').addEventListener('input', function() {
    const slugField = document.getElementById('field_slug');
    if (!slugField.dataset.manual) {
        slugField.value = this.value.toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
    }
});
document.getElementById('field_slug').addEventListener('input', function() {
    this.dataset.manual = '1';
});

var fieldTypeSelect = document.getElementById('field_type');
var slugTextTypes = ['text', 'email', 'url'];
var useAsSlugLabel = document.getElementById('use-as-slug-label');
var useAsSlugCheck = document.getElementById('useAsSlugCheck');

function toggleSlugCheckbox() {
    if (useAsSlugLabel) {
        useAsSlugLabel.style.display = slugTextTypes.indexOf(fieldTypeSelect.value) !== -1 ? '' : 'none';
        if (useAsSlugCheck && slugTextTypes.indexOf(fieldTypeSelect.value) === -1) {
            useAsSlugCheck.checked = false;
        }
    }
}
toggleSlugCheckbox();

fieldTypeSelect.addEventListener('change', function() {
    var selectGroup = document.getElementById('select-options-group');
    var relationGroup = document.getElementById('relation-options-group');
    var selectInput = document.getElementById('field_options_select');
    var relationInput = document.getElementById('field_options_relation');

    selectGroup.style.display = 'none';
    relationGroup.style.display = 'none';
    selectInput.name = '';
    relationInput.name = '';

    if (this.value === 'select') {
        selectGroup.style.display = 'block';
        selectInput.name = 'field_options';
    } else if (this.value === 'relation') {
        relationGroup.style.display = 'block';
        relationInput.name = 'field_options';
    }

    toggleSlugCheckbox();
});

var relationTypeHints = {
    'one_to_one': 'One to One: Pick a single related entry.',
    'one_to_many': 'One to Many: This entry can link to multiple entries in the related collection.',
    'many_to_many': 'Many to Many: Entries in both collections can link to each other.'
};
var relTypeSelect = document.getElementById('field_relation_type');
if (relTypeSelect) {
    relTypeSelect.addEventListener('change', function() {
        document.getElementById('relation-type-hint').textContent = relationTypeHints[this.value] || '';
    });
}

// Load related collection's fields when a collection is selected
var relCollSelect = document.getElementById('field_options_relation');
var displayFieldSelect = document.getElementById('field_display_field');
if (relCollSelect && displayFieldSelect) {
    relCollSelect.addEventListener('change', function() {
        var collSlug = this.value;
        displayFieldSelect.innerHTML = '<option value="">-- Loading... --</option>';
        if (!collSlug) {
            displayFieldSelect.innerHTML = '<option value="">-- Select collection first --</option>';
            return;
        }
        fetch('/cms/collections/' + collSlug + '/fields-json')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                displayFieldSelect.innerHTML = '<option value="">-- Auto-detect --</option>';
                (data.fields || []).forEach(function(f) {
                    var opt = document.createElement('option');
                    opt.value = f.slug;
                    opt.textContent = f.name + ' (' + f.type + ')';
                    displayFieldSelect.appendChild(opt);
                });
            })
            .catch(function() {
                displayFieldSelect.innerHTML = '<option value="">-- Failed to load --</option>';
            });
    });
}

// Toggle slug source dropdown when checkbox changes
var hasSlugCheck = document.getElementById('has_slug_check');
var slugSourceGroup = document.getElementById('slug-source-group');
if (hasSlugCheck && slugSourceGroup) {
    hasSlugCheck.addEventListener('change', function() {
        slugSourceGroup.style.display = this.checked ? '' : 'none';
    });
}

document.querySelectorAll('.confirm-delete').forEach(function(form) {
    form.addEventListener('submit', function(e) {
        if (!confirm(form.dataset.message || 'Are you sure?')) {
            e.preventDefault();
        }
    });
});
</script>

<style nonce="{{ csp_nonce() }}">
    .field-system {
        opacity: 0.7;
        border-left: 3px solid var(--color-primary);
        padding-left: var(--space-200);
    }
    .field-system .field-name {
        font-size: 0.9rem;
    }
    .field-badge.slug-source {
        background: var(--color-primary, #6366f1);
        color: #fff;
        font-weight: 600;
    }
</style>
{% endblock %}
{% endblock %}
