{% extends "@cms/layouts/cms.twig" %}

{% block title %}Plugins{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/plugins-index.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Plugins
</div>

<div class="page-header">
    <h1>Plugins</h1>
    <div class="page-actions">
        <a href="{{ admin_url('plugins/browse') }}" class="btn btn-outline">Browse Marketplace</a>
        <button type="button" class="btn btn-primary" onclick="document.getElementById('uploadModal').showModal()">Upload Plugin</button>
    </div>
</div>

{# Flash messages #}
{% if flash('success') %}
<div class="alert alert-success" class="mb-4">{{ flash('success') }}</div>
{% endif %}
{% if flash('errors') %}
{% for error in flash('errors') %}
<div class="alert alert-danger" class="mb-4">{{ error }}</div>
{% endfor %}
{% endif %}

{# Filter tabs + Search #}
<div class="card" class="mb-5">
    <div class="card-body">
        <div class="plugin-toolbar">
            <div class="plugin-tabs">
                <a href="{{ admin_url('plugins?filter=all&search=' ~ search|url_encode) }}" class="plugin-tab {{ filter == 'all' ? 'active' : '' }}">
                    All <span class="tab-count">{{ counts.all }}</span>
                </a>
                <a href="{{ admin_url('plugins?filter=active&search=' ~ search|url_encode) }}" class="plugin-tab {{ filter == 'active' ? 'active' : '' }}">
                    Active <span class="tab-count">{{ counts.active }}</span>
                </a>
                <a href="{{ admin_url('plugins?filter=inactive&search=' ~ search|url_encode) }}" class="plugin-tab {{ filter == 'inactive' ? 'active' : '' }}">
                    Inactive <span class="tab-count">{{ counts.inactive }}</span>
                </a>
            </div>
            <form method="GET" action="{{ admin_url('plugins') }}" class="plugin-search">
                <input type="hidden" name="filter" value="{{ filter }}">
                <input type="text" name="search" value="{{ search }}" placeholder="Search plugins..." class="form-control" style="width: 240px;">
                <button type="submit" class="btn btn-outline btn-sm">Search</button>
            </form>
        </div>
    </div>
</div>

{# Plugin Grid #}
{% if plugins|length > 0 %}
<div class="plugin-grid">
    {% for plugin in plugins %}
    {% set m = plugin.manifest %}
    <div class="plugin-card {{ plugin.enabled ? 'plugin-active' : 'plugin-inactive' }}">
        <div class="plugin-card-header">
            <div class="plugin-icon">
                {% if m.icon %}
                    <img src="{{ m.icon }}" alt="{{ m.name }}" width="40" height="40">
                {% else %}
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                    </svg>
                {% endif %}
            </div>
            <div class="plugin-status">
                <span class="badge {{ plugin.enabled ? 'badge-success' : 'badge-muted' }}">
                    {{ plugin.enabled ? 'Active' : 'Inactive' }}
                </span>
            </div>
        </div>

        <div class="plugin-card-body">
            <h3 class="plugin-name">{{ m.name }}</h3>
            <div class="plugin-meta">
                {% if m.version %}<span class="plugin-version">v{{ m.version }}</span>{% endif %}
                {% if m.author %}<span class="plugin-author">by {{ m.author }}</span>{% endif %}
            </div>
            <p class="plugin-desc">{{ m.description|default('No description available.')|slice(0, 120) }}{% if (m.description|default(''))|length > 120 %}...{% endif %}</p>
        </div>

        <div class="plugin-card-footer">
            <div class="plugin-actions">
                <form method="POST" action="{{ admin_url('plugins/' ~ plugin.slug ~ '/toggle') }}" style="display: inline;">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="btn btn-sm {{ plugin.enabled ? 'btn-outline' : 'btn-primary' }}">
                        {{ plugin.enabled ? 'Disable' : 'Enable' }}
                    </button>
                </form>

                {% if plugin.has_settings and plugin.enabled %}
                <a href="{{ admin_url('plugins/' ~ plugin.slug ~ '/settings') }}" class="btn btn-sm btn-outline">Settings</a>
                {% endif %}

                <form method="POST" action="{{ admin_url('plugins/' ~ plugin.slug ~ '/uninstall') }}"
                      onsubmit="return confirm('Are you sure you want to uninstall {{ m.name|e('js') }}? This will remove all plugin files.')"
                      style="display: inline;">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="btn btn-sm btn-danger-outline">Uninstall</button>
                </form>
            </div>
        </div>
    </div>
    {% endfor %}
</div>
{% else %}
<div class="card">
    <div class="card-body empty-state" style="text-align: center; padding: 60px 20px;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled, #ccc)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: 16px;">
            <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
        </svg>
        <h3 style="margin: 0 0 8px;">No plugins {% if filter != 'all' %}matching this filter{% else %}installed{% endif %}</h3>
        <p style="color: var(--text-secondary); margin: 0 0 20px;">
            {% if search %}
                No plugins match "{{ search }}". Try a different search term.
            {% elseif filter == 'active' %}
                No plugins are currently active.
            {% elseif filter == 'inactive' %}
                All plugins are active.
            {% else %}
                Install plugins from the marketplace or upload a ZIP file.
            {% endif %}
        </p>
        <div style="display: flex; gap: 8px; justify-content: center;">
            <a href="{{ admin_url('plugins/browse') }}" class="btn btn-outline">Browse Marketplace</a>
            <button type="button" class="btn btn-primary" onclick="document.getElementById('uploadModal').showModal()">Upload Plugin</button>
        </div>
    </div>
</div>
{% endif %}

{# Upload Modal #}
<dialog id="uploadModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2>Install Plugin</h2>
            <button type="button" onclick="document.getElementById('uploadModal').close()" class="modal-close">&times;</button>
        </div>
        <form method="POST" action="{{ admin_url('plugins/install') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="modal-body">
                <div class="form-group" class="mb-4">
                    <label class="form-label">Upload ZIP File</label>
                    <input type="file" name="plugin_zip" accept=".zip" class="form-control">
                    <small class="form-hint">Upload a plugin .zip archive (max 50 MB).</small>
                </div>

                <div class="divider-text" style="text-align: center; margin: 20px 0; color: var(--text-secondary); font-size: 0.85rem;">
                    <span style="background: var(--bg-surface); padding: 0 12px;">or</span>
                </div>

                <div class="form-group">
                    <label class="form-label">Install from URL</label>
                    <input type="url" name="download_url" placeholder="https://example.com/plugin.zip" class="form-control">
                    <small class="form-hint">Enter a direct HTTPS link to the plugin ZIP.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" onclick="document.getElementById('uploadModal').close()" class="btn btn-outline">Cancel</button>
                <button type="submit" class="btn btn-primary">Install Plugin</button>
            </div>
        </form>
    </div>
</dialog>
{% endblock %}

