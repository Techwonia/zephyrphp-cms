            </div>
            <div class="schema-panel-tabs">
                <button class="schema-panel-tab active" data-schema-tab="designer">Designer</button>
                <button class="schema-panel-tab" data-schema-tab="json">JSON</button>
            </div>
            <div class="schema-panel-body">
                <div class="schema-panel-view active" id="schemaDesignerView">
                    <div class="schema-designer" id="schemaDesigner"></div>
                </div>
                <div class="schema-panel-view" id="schemaJsonView">
                    <div class="schema-json-view" id="schemaJsonEditor"></div>
                </div>
