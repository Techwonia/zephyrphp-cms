    // ── Format ──
    window._formatCode = function() {
        if (!state.activeTab || !state.editorView) return;
        const ext = state.activeTab.split('.').pop().toLowerCase();
        let content = state.editorView.state.doc.toString();

        try {
            if (ext === 'json') {
                content = JSON.stringify(JSON.parse(content), null, 2);
            } else if (ext === 'css') {
                content = formatCSS(content);
            } else if (ext === 'js') {
                content = formatJS(content);
            } else if (ext === 'twig' || ext === 'html' || ext === 'htm') {
                content = formatHTML(content);
            } else {
                showToast('Format not available for this file type', 'error');
                return;
            }

            state.editorView.dispatch({
                changes: { from: 0, to: state.editorView.state.doc.length, insert: content }
            });
            onEditorChange();
            showToast('Code formatted');
        } catch (e) {
            showToast(`Format error: ${e.message}`, 'error');
        }
    };

    function formatCSS(css) {
        // Simple CSS formatter
        return css
            .replace(/\s*\{\s*/g, ' {\n    ')
            .replace(/\s*\}\s*/g, '\n}\n')
            .replace(/;\s*/g, ';\n    ')
            .replace(/\n\s*\n/g, '\n')
            .replace(/    \}/g, '}')
            .trim();
    }

    function formatJS(src) {
        let indent = 0;
        const lines = src.split('\n');
        const result = [];
        for (let i = 0; i < lines.length; i++) {
            let line = lines[i].trim();
            if (!line) { result.push(''); continue; }
            const closersOnly = /^[}\])]/.test(line);
            if (closersOnly) indent = Math.max(0, indent - 1);
            result.push('    '.repeat(indent) + line);
            const opens = (line.match(/[{(\[]/g) || []).length;
            const closes = (line.match(/[})\]]/g) || []).length;
            indent = Math.max(0, indent + opens - closes);
            if (closersOnly) indent = Math.max(0, indent);
        }
        return result.join('\n').trim();
    }

    function formatHTML(src) {
        const voidTags = new Set(['area','base','br','col','embed','hr','img','input','link','meta','param','source','track','wbr']);
        const rawTags = new Set(['script','style','pre','code','textarea']);
        let indent = 0;
        let inRaw = false;
        let rawTag = '';
        let inSchema = false;
        let schemaLines = [];
        const result = [];

        // Normalize: put each tag on its own line (but not inside attributes)
        src = src
            .replace(/>\s*</g, '>\n<')
            .replace(/^\s+|\s+$/g, '');

        const lines = src.split('\n');

        // Twig block tags that open/close indentation
        const twigBlockTags = 'block|for|if|macro|embed|autoescape|apply|verbatim';
        const twigOpenRe = new RegExp('^\\{' + '%[-\\s]+(' + twigBlockTags + ')\\b');
        const twigMidRe = new RegExp('^\\{' + '%[-\\s]+(else|elseif|elif)\\b');
        const twigCloseRe = new RegExp('^\\{' + '%[-\\s]+end(' + twigBlockTags + ')\\b');
        const twigSchemaOpenRe = new RegExp('^\\{' + '%[-\\s]+schema\\b');
        const twigSchemaCloseRe = new RegExp('^\\{' + '%[-\\s]+endschema\\b');
        // Single-line twig tags that do NOT create blocks (set, do, include, extends, use, from, import)
        const twigInlineRe = new RegExp('^\\{' + '%[-\\s]+(set|do|include|extends|use|from|import)\\b');

        for (let i = 0; i < lines.length; i++) {
            let line = lines[i].trim();
            if (!line) { result.push(''); continue; }

            // Collect schema JSON content between schema tags
            if (inSchema) {
                if (twigSchemaCloseRe.test(line)) {
                    // Format the collected JSON
                    const jsonStr = schemaLines.join('\n').trim();
                    if (jsonStr) {
                        try {
                            const parsed = JSON.parse(jsonStr);
                            const formatted = JSON.stringify(parsed, null, 2);
                            formatted.split('\n').forEach(jl => {
                                result.push('    '.repeat(indent) + jl);
                            });
                        } catch(e) {
                            // If JSON parse fails, just output as-is
                            schemaLines.forEach(sl => {
                                result.push('    '.repeat(indent) + sl.trim());
                            });
                        }
                    }
                    indent = Math.max(0, indent - 1);
                    result.push('    '.repeat(indent) + line);
                    inSchema = false;
                    schemaLines = [];
                } else {
                    schemaLines.push(line);
                }
                continue;
            }

            // Track raw HTML tags (don't re-indent contents of script/style/pre)
            if (inRaw) {
                result.push('    '.repeat(indent) + line);
                const closeRe = new RegExp('</' + rawTag, 'i');
                if (closeRe.test(line)) { inRaw = false; indent = Math.max(0, indent - 1); }
                continue;
            }

            // Twig schema open: treat like a block, collect JSON inside
            if (twigSchemaOpenRe.test(line)) {
                result.push('    '.repeat(indent) + line);
                indent++;
                inSchema = true;
                schemaLines = [];
                continue;
            }

            // Twig close tag: dedent then print
            if (twigCloseRe.test(line)) {
                indent = Math.max(0, indent - 1);
                result.push('    '.repeat(indent) + line);
                continue;
            }

            // Twig mid tag (else/elseif): dedent, print, stays at same indent
            if (twigMidRe.test(line)) {
                result.push('    '.repeat(Math.max(0, indent - 1)) + line);
                continue;
            }

            // Twig single-line tags (set, include, extends, etc.) — NO indent change
            if (twigInlineRe.test(line)) {
                result.push('    '.repeat(indent) + line);
                continue;
            }

            // Twig block-open tag: print then indent
            if (twigOpenRe.test(line)) {
                result.push('    '.repeat(indent) + line);
                indent++;
                continue;
            }

            // HTML closing tag
            if (/^<\//.test(line)) {
                indent = Math.max(0, indent - 1);
                result.push('    '.repeat(indent) + line);
                continue;
            }

            // HTML opening tag
            if (/^<[a-zA-Z]/.test(line)) {
                result.push('    '.repeat(indent) + line);
                const tagMatch = line.match(/^<([a-zA-Z][a-zA-Z0-9-]*)/);
                if (tagMatch) {
                    const tag = tagMatch[1].toLowerCase();
                    const selfClose = /\/\s*>$/.test(line);
                    if (!selfClose && !voidTags.has(tag)) {
                        if (rawTags.has(tag)) { inRaw = true; rawTag = tag; }
                        const closeOnSame = new RegExp('</' + tag + '\\s*>', 'i');
                        if (!closeOnSame.test(line)) indent++;
                    }
                }
                continue;
            }

            // Everything else (text, comments, Twig output tags)
            result.push('    '.repeat(indent) + line);
        }

        return result.join('\n').trim();
    }

    // ── Word Wrap ──
    window._toggleWordWrap = function() {
        state.wordWrap = !state.wordWrap;
        $('btnWrap').classList.toggle('active', state.wordWrap);
        // Recreate editor to apply wrap
        if (state.activeTab) {
            const tab = state.openTabs.find(t => t.path === state.activeTab);
            if (tab && state.editorView) {
                tab.content = state.editorView.state.doc.toString();
                createEditor($container1, tab.content, tab.path, 'main');
            }
        }
    };

    // ── Split View ──
    const $splitFilePicker = $('splitFilePicker');
    const $splitFileSelect = $('splitFileSelect');

    function updateSplitFilePicker() {
        // Populate dropdown with all file paths
        let html = '<option value="">— Select a file —</option>';
        for (const p of state.allFilePaths) {
            if (/\.(png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot)$/i.test(p)) continue;
            html += `<option value="${escAttr(p)}">${esc(p)}</option>`;
        }
        $splitFileSelect.innerHTML = html;
    }

    $splitFileSelect.addEventListener('change', () => {
        const path = $splitFileSelect.value;
        if (path) openInSplit(path);
    });

    window._toggleSplitView = function() {
        state.splitActive = !state.splitActive;
        $('btnSplit').classList.toggle('active', state.splitActive);
        $editorArea.classList.toggle('split-active', state.splitActive);
        $pane2.style.display = state.splitActive ? 'flex' : 'none';

        if (!state.splitActive) {
            if (state.splitView) { state.splitView.destroy(); state.splitView = null; }
            state.splitTab = null;
            $splitFilePicker.style.display = '';
        } else if (state.openTabs.length > 1 && !state.splitTab) {
            const other = state.openTabs.find(t => t.path !== state.activeTab);
            if (other) {
                openInSplit(other.path);
            } else {
                updateSplitFilePicker();
                $splitFilePicker.style.display = '';
            }
        } else {
            updateSplitFilePicker();
            $splitFilePicker.style.display = '';
        }
    };

    window._closeSplitPane = function() {
        state.splitActive = false;
        $('btnSplit').classList.remove('active');
        $editorArea.classList.remove('split-active');
        $pane2.style.display = 'none';
        if (state.splitView) { state.splitView.destroy(); state.splitView = null; }
        state.splitTab = null;
        $splitFilePicker.style.display = '';
    };

    // ══════════════════════════════════════════════
    // SCHEMA PANEL (for sections)
    // ══════════════════════════════════════════════

    const SETTING_TYPES = [
        { value: 'text', label: 'Text' },
        { value: 'textarea', label: 'Textarea' },
        { value: 'richtext', label: 'Rich Text' },
        { value: 'number', label: 'Number' },
        { value: 'range', label: 'Range' },
        { value: 'checkbox', label: 'Checkbox' },
        { value: 'select', label: 'Select' },
        { value: 'radio', label: 'Radio' },
        { value: 'color', label: 'Color' },
        { value: 'image_picker', label: 'Image Picker' },
        { value: 'url', label: 'URL' },
        { value: 'html', label: 'HTML' },
    ];

    let currentSchema = null;

    window._toggleSchemaPanel = function() {
        state.schemaPanelOpen = !state.schemaPanelOpen;
        $schemaPanel.classList.toggle('visible', state.schemaPanelOpen);
        $btnSchema.classList.toggle('active', state.schemaPanelOpen);

        if (state.schemaPanelOpen && state.activeTab) {
            const tab = state.openTabs.find(t => t.path === state.activeTab);
            if (tab) {
                currentSchema = parseSchema(tab.content);
                renderSchemaDesigner();
                renderSchemaJson();
            }
        } else {
            if (state.schemaView) { state.schemaView.destroy(); state.schemaView = null; }
            currentSchema = null;
        }
    };

    // Schema panel tab switching
    $schemaPanel.addEventListener('click', (e) => {
        const tabBtn = e.target.closest('[data-schema-tab]');
        if (!tabBtn) return;
        const tabName = tabBtn.dataset.schemaTab;
        $schemaPanel.querySelectorAll('.schema-panel-tab').forEach(t => t.classList.toggle('active', t.dataset.schemaTab === tabName));
        $('schemaDesignerView').classList.toggle('active', tabName === 'designer');
        $('schemaJsonView').classList.toggle('active', tabName === 'json');
        if (tabName === 'json') renderSchemaJson();
    });

    function extractSchemaRaw(twigContent) {
        const re = new RegExp('\\{' + '%\\s*schema\\s*%' + '\\}([\\s\\S]*?)\\{' + '%\\s*endschema\\s*%' + '\\}');
        return twigContent.match(re);
    }

    function parseSchema(twigContent) {
        const match = extractSchemaRaw(twigContent);
        if (!match) return { name: 'Section Name', tag: null, class: null, max_blocks: null, settings: [], blocks: [], presets: [] };
        try {
            const obj = JSON.parse(match[1].trim());
            return {
                name: obj.name || 'Section Name',
                tag: obj.tag || null,
                class: obj.class || null,
                max_blocks: obj.max_blocks || null,
                settings: Array.isArray(obj.settings) ? obj.settings : [],
                blocks: Array.isArray(obj.blocks) ? obj.blocks : [],
                presets: Array.isArray(obj.presets) ? obj.presets : [],
            };
        } catch {
            return { name: 'Section Name', tag: null, class: null, max_blocks: null, settings: [], blocks: [], presets: [] };
        }
    }

    function schemaToJson() {
        if (!currentSchema) return '{}';
        const obj = { name: currentSchema.name };
        if (currentSchema.tag) obj.tag = currentSchema.tag;
        if (currentSchema.class) obj.class = currentSchema.class;
        if (currentSchema.max_blocks) obj.max_blocks = currentSchema.max_blocks;
        obj.settings = currentSchema.settings;
        if (currentSchema.blocks.length > 0) obj.blocks = currentSchema.blocks;
        if (currentSchema.presets.length > 0) obj.presets = currentSchema.presets;
        return JSON.stringify(obj, null, 2);
    }

    function renderSchemaDesigner() {
        if (!currentSchema) return;
        const s = currentSchema;
        let html = '';

        // Section info
        html += `<div class="schema-section-info">
            <div class="field-group"><label>Section Name</label>
                <input type="text" data-schema-field="name" value="${escAttr(s.name)}">
            </div>
            <div class="field-group"><label>Tag</label>
                <input type="text" data-schema-field="tag" value="${escAttr(s.tag || '')}" placeholder="section">
            </div>
            <div class="field-group"><label>CSS Class</label>
                <input type="text" data-schema-field="class" value="${escAttr(s.class || '')}" placeholder="optional">
            </div>
        </div>`;

        // Settings
        html += `<div style="font-size:11px;font-weight:700;color:var(--text-secondary);text-transform:uppercase;letter-spacing:0.05em;margin-top:4px;">Settings (${s.settings.length})</div>`;

        for (let i = 0; i < s.settings.length; i++) {
            const setting = s.settings[i];
            const typeOpts = SETTING_TYPES.map(t =>
                `<option value="${t.value}"${t.value === setting.type ? ' selected' : ''}>${t.label}</option>`
            ).join('');

            html += `<div class="schema-field" data-setting-index="${i}">
                <div class="schema-field-header">
                    <span class="schema-field-type">${esc(setting.type || 'text')}</span>
                    <span class="schema-field-id">${esc(setting.id || '')}</span>
                    <div class="schema-field-actions">
                        <button class="schema-field-action-btn" data-move-setting="${i}" data-dir="up" title="Move up">&#9650;</button>
                        <button class="schema-field-action-btn" data-move-setting="${i}" data-dir="down" title="Move down">&#9660;</button>
                        <button class="schema-field-action-btn danger" data-delete-setting="${i}" title="Remove">&#10005;</button>
                    </div>
                </div>
                <div class="schema-field-row"><label>ID</label><input type="text" data-setting="${i}" data-prop="id" value="${escAttr(setting.id || '')}"></div>
                <div class="schema-field-row"><label>Type</label><select data-setting="${i}" data-prop="type">${typeOpts}</select></div>
                <div class="schema-field-row"><label>Label</label><input type="text" data-setting="${i}" data-prop="label" value="${escAttr(setting.label || '')}"></div>
                <div class="schema-field-row"><label>Default</label><input type="text" data-setting="${i}" data-prop="default" value="${escAttr(setting.default != null ? String(setting.default) : '')}"></div>
                ${setting.info ? `<div class="schema-field-row"><label>Info</label><input type="text" data-setting="${i}" data-prop="info" value="${escAttr(setting.info)}"></div>` : ''}
            </div>`;
        }

        html += `<button class="schema-add-setting" id="btnAddSetting">+ Add setting</button>`;
        html += `<button class="schema-apply-btn" id="btnApplySchema">Apply to file</button>`;

        $('schemaDesigner').innerHTML = html;
    }

    function renderSchemaJson() {
        if (!currentSchema) return;
        const jsonStr = schemaToJson();
        createEditor($('schemaJsonEditor'), jsonStr, 'schema.json', 'schema');
    }

    // Schema designer event delegation
    $('schemaDesigner').addEventListener('input', (e) => {
        if (!currentSchema) return;
        const el = e.target;

        // Section-level fields
        if (el.dataset.schemaField) {
            currentSchema[el.dataset.schemaField] = el.value || null;
            return;
        }

        // Setting fields
        if (el.dataset.setting !== undefined) {
            const idx = parseInt(el.dataset.setting);
            const prop = el.dataset.prop;
            if (currentSchema.settings[idx]) {
                currentSchema.settings[idx][prop] = el.value;
            }
        }
    });

    $('schemaDesigner').addEventListener('change', (e) => {
        if (!currentSchema) return;
        const el = e.target;
        if (el.dataset.setting !== undefined) {
            const idx = parseInt(el.dataset.setting);
            const prop = el.dataset.prop;
            if (currentSchema.settings[idx]) {
                currentSchema.settings[idx][prop] = el.value;
                if (prop === 'type') renderSchemaDesigner(); // re-render on type change
            }
        }
    });

    $('schemaDesigner').addEventListener('click', (e) => {
        if (!currentSchema) return;

        // Add setting
        if (e.target.closest('#btnAddSetting')) {
            currentSchema.settings.push({ type: 'text', id: 'new_setting', label: 'New Setting', default: '' });
            renderSchemaDesigner();
            return;
        }

        // Apply schema to file
        if (e.target.closest('#btnApplySchema')) {
            applySchemaToFile();
            return;
        }

        // Delete setting
        const delBtn = e.target.closest('[data-delete-setting]');
        if (delBtn) {
            const idx = parseInt(delBtn.dataset.deleteSetting);
            currentSchema.settings.splice(idx, 1);
            renderSchemaDesigner();
            return;
        }

        // Move setting
        const moveBtn = e.target.closest('[data-move-setting]');
        if (moveBtn) {
            const idx = parseInt(moveBtn.dataset.moveSetting);
            const dir = moveBtn.dataset.dir;
            const newIdx = dir === 'up' ? idx - 1 : idx + 1;
            if (newIdx >= 0 && newIdx < currentSchema.settings.length) {
                const tmp = currentSchema.settings[idx];
                currentSchema.settings[idx] = currentSchema.settings[newIdx];
                currentSchema.settings[newIdx] = tmp;
                renderSchemaDesigner();
            }
            return;
        }
    });

    function applySchemaToFile() {
        if (!currentSchema || !state.activeTab || !state.editorView) return;
        const content = state.editorView.state.doc.toString();
        const jsonStr = schemaToJson();

        const schemaOpen = '{' + '% schema %' + '}';
        const schemaClose = '{' + '% endschema %' + '}';
        const schemaBlock = `${schemaOpen}\n${jsonStr}\n${schemaClose}`;

        const match = extractSchemaRaw(content);
        let newContent;
        if (match) {
            newContent = content.substring(0, match.index) + schemaBlock + content.substring(match.index + match[0].length);
        } else {
            newContent = content + '\n\n' + schemaBlock + '\n';
        }

        state.editorView.dispatch({
            changes: { from: 0, to: state.editorView.state.doc.length, insert: newContent }
        });
        onEditorChange();
        showToast('Schema applied to file');
    }

    function syncSchemaPanel(twigContent) {
        if (!state.schemaPanelOpen) return;
        currentSchema = parseSchema(twigContent);
        renderSchemaDesigner();
        // Don't auto-sync JSON tab to avoid overwriting user edits
    }

    // ══════════════════════════════════════════════
    // QUICK SEARCH
    // ══════════════════════════════════════════════

    window._openQuickSearch = function() {
        $quickSearchOverlay.classList.add('visible');
        $quickSearchInput.value = '';
        $quickSearchInput.focus();
        renderQuickSearch('');
    };

    function closeQuickSearch() {
        $quickSearchOverlay.classList.remove('visible');
    }

    let qsIndex = 0;

    function renderQuickSearch(query) {
        const q = query.toLowerCase().trim();
        let matches = state.allFilePaths;
        if (q) matches = matches.filter(p => p.toLowerCase().includes(q));
        matches = matches.slice(0, 25);
        qsIndex = 0;

        let html = '';
        matches.forEach((path, i) => {
            const name = path.split('/').pop();
            const folder = path.includes('/') ? path.substring(0, path.lastIndexOf('/')) : '';
            html += `<div class="quick-search-item ${i === 0 ? 'selected' : ''}" data-path="${escAttr(path)}">
                ${fileIconSvg(name)}
                <span>${esc(name)}</span>
                ${folder ? `<span class="quick-search-item-path">${esc(folder)}</span>` : ''}
            </div>`;
        });
        if (!matches.length) html = `<div style="padding:20px;text-align:center;color:var(--text-disabled);">No files found</div>`;

        $quickSearchResults.innerHTML = html;
        $quickSearchResults.querySelectorAll('.quick-search-item').forEach(el => {
            el.addEventListener('click', () => { openFile(el.dataset.path); closeQuickSearch(); });
        });
    }

    $quickSearchInput.addEventListener('input', e => renderQuickSearch(e.target.value));

    $quickSearchInput.addEventListener('keydown', e => {
        const items = $quickSearchResults.querySelectorAll('.quick-search-item');
        if (e.key === 'Escape') { closeQuickSearch(); }
        else if (e.key === 'ArrowDown') {
            e.preventDefault();
            qsIndex = Math.min(qsIndex + 1, items.length - 1);
            items.forEach((el, i) => el.classList.toggle('selected', i === qsIndex));
            items[qsIndex]?.scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'ArrowUp') {
            e.preventDefault();
            qsIndex = Math.max(qsIndex - 1, 0);
            items.forEach((el, i) => el.classList.toggle('selected', i === qsIndex));
            items[qsIndex]?.scrollIntoView({ block: 'nearest' });
        } else if (e.key === 'Enter') {
            e.preventDefault();
            const sel = items[qsIndex];
            if (sel) { openFile(sel.dataset.path); closeQuickSearch(); }
        }
    });

    $quickSearchOverlay.addEventListener('click', e => { if (e.target === $quickSearchOverlay) closeQuickSearch(); });

    // ══════════════════════════════════════════════
    // KEYBOARD SHORTCUTS
    // ══════════════════════════════════════════════

    document.addEventListener('keydown', e => {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); window._saveFile(); }
        if ((e.ctrlKey || e.metaKey) && e.key === 'p') { e.preventDefault(); window._openQuickSearch(); }
        if ((e.ctrlKey || e.metaKey) && e.key === 'n') {
            e.preventDefault();
            window._showNewFileModal();
        }
    });

    window.addEventListener('beforeunload', e => {
        if (state.openTabs.some(t => t.modified)) { e.preventDefault(); e.returnValue = ''; }
    });

    // Handle Enter in modal inputs
    $('newFileName').addEventListener('keydown', e => { if (e.key === 'Enter') window._createNewFile(); });
    $('newFolderName').addEventListener('keydown', e => { if (e.key === 'Enter') window._createNewFolder(); });
    $('renameNewName').addEventListener('keydown', e => { if (e.key === 'Enter') window._renameFile(); });

    // ══════════════════════════════════════════════
    // EVENT BINDINGS (replacing inline handlers)
    // ══════════════════════════════════════════════

    // ── Static button bindings ──
    $btnSave.addEventListener('click', () => window._saveFile());
    $('btnNewFile').addEventListener('click', () => window._showNewFileModal());
    $('btnNewFolder').addEventListener('click', () => window._showNewFolderModal());
    $('btnSearch').addEventListener('click', () => window._openQuickSearch());
    $('btnFormat').addEventListener('click', () => window._formatCode());
    $('btnWrap').addEventListener('click', () => window._toggleWordWrap());
    $('btnSplit').addEventListener('click', () => window._toggleSplitView());
    $btnSchema.addEventListener('click', () => window._toggleSchemaPanel());
    $('btnCloseSplit').addEventListener('click', () => window._closeSplitPane());
    $('btnSchemaClose').addEventListener('click', () => window._toggleSchemaPanel());

    // ── Modal button bindings ──
    $('btnNewFileCancel').addEventListener('click', () => window._closeModal('newFileModal'));
    $('btnNewFileCreate').addEventListener('click', () => window._createNewFile());
    $('btnNewFolderCancel').addEventListener('click', () => window._closeModal('newFolderModal'));
    $('btnNewFolderCreate').addEventListener('click', () => window._createNewFolder());
    $('btnRenameCancel').addEventListener('click', () => window._closeModal('renameModal'));
    $('btnRenameSubmit').addEventListener('click', () => window._renameFile());

    // ── File tree event delegation ──
    $fileTree.addEventListener('click', (e) => {
        // File item click
        const fileItem = e.target.closest('.file-item');
        if (fileItem) {
            const path = fileItem.dataset.path;
            if (path) window._fileClick(path);
            return;
        }
        // Folder header click (toggle)
        const folderHeader = e.target.closest('.folder-header');
        if (folderHeader) {
            window._toggleFolder(folderHeader);
            return;
        }
    });

    $fileTree.addEventListener('contextmenu', (e) => {
        // File item right-click
        const fileItem = e.target.closest('.file-item');
        if (fileItem) {
            const path = fileItem.dataset.path;
            if (path) window._fileContext(e, path);
            return;
        }
        // Folder header right-click
        const folderHeader = e.target.closest('.folder-header');
        if (folderHeader) {
            const folderPath = folderHeader.dataset.folderPath;
            if (folderPath) window._folderContext(e, folderPath);
            return;
        }
    });

    // ── Tab bar event delegation ──
    $tabBar.addEventListener('click', (e) => {
        // Close button
        const closeBtn = e.target.closest('[data-tab-close]');
        if (closeBtn) {
            e.stopPropagation();
            window._closeTab(closeBtn.dataset.tabClose);
            return;
        }
        // Tab click
        const tab = e.target.closest('[data-tab-path]');
        if (tab) {
            window._switchTab(tab.dataset.tabPath);
            return;
        }
    });

    // ══════════════════════════════════════════════
    // INIT
    // ══════════════════════════════════════════════

    await loadFileTree();

    // ── Activity Bar Panel Switching ──
    var ceAbPanelMap = { files: 'abPanelFiles', pages: 'abPanelPages', settings: 'abPanelSettings' };
    document.querySelectorAll('[data-ab-panel]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('[data-ab-panel]').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            document.querySelectorAll('.ab-panel').forEach(function(p) { p.classList.remove('active'); });
            var targetId = ceAbPanelMap[btn.dataset.abPanel];
            if (targetId) document.getElementById(targetId).classList.add('active');
        });
    });

    </script>
</body>
</html>
