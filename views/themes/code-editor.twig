                    <div class="editor-container" id="editorContainer1">
                        <div class="editor-empty" id="editorEmpty">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M14.25 2.25H6.75A2.25 2.25 0 004.5 4.5v15a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V7.5L14.25 2.25z"/>
                                <path d="M14.25 2.25V7.5h5.25"/><path d="M9.75 12.75h4.5M9.75 15.75h4.5"/>
                            </svg>
                            <p>Select a file to start editing</p>
                            <div class="shortcut-hints">
                                <span><kbd>Ctrl+P</kbd> Search files</span>
                                <span><kbd>Ctrl+S</kbd> Save</span>
                                <span><kbd>Ctrl+N</kbd> New file</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="editor-pane" id="editorPane2" style="display:none;">
                    <div class="pane-tab-info">
                        <span class="pane-filename" id="pane2Name">—</span>
                        <button class="pane-close-btn" id="btnCloseSplit">&times;</button>
                    </div>
                    <div class="editor-container" id="editorContainer2">
