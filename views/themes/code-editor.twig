                <button class="toolbar-btn" id="btnSplit" title="Split editor">
                    <svg viewBox="0 0 16 16" fill="currentColor"><path d="M1 2.5A1.5 1.5 0 012.5 1h11A1.5 1.5 0 0115 2.5v11a1.5 1.5 0 01-1.5 1.5h-11A1.5 1.5 0 011 13.5v-11zM7.5 2v12h6a.5.5 0 00.5-.5v-11a.5.5 0 00-.5-.5h-6zM2 2.5v11a.5.5 0 00.5.5H6.5V2H2.5a.5.5 0 00-.5.5z"/></svg>
                    Split
