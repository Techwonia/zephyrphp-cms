        </div>
    </div>

    <!-- Toast Container -->
    <div class="toast-container" id="toastContainer"></div>

    <!-- Quick Search -->
    <div class="quick-search-overlay" id="quickSearchOverlay">
        <div class="quick-search">
            <input type="text" id="quickSearchInput" placeholder="Search files..." autocomplete="off">
            <div class="quick-search-results" id="quickSearchResults"></div>
        </div>
    </div>
    </div>{# /.page-body #}

    <!-- Context Menu -->
    <div class="context-menu" id="contextMenu"></div>

    <!-- New File Modal -->
    <div class="modal-overlay" id="newFileModal">
        <div class="modal-card">
            <div class="modal-header">New File</div>
            <div class="modal-body">
                <div class="field-group">
                    <label>Directory</label>
                    <select id="newFileDir">
                        <option value="sections/">sections/</option>
                        <option value="layouts/">layouts/</option>
                        <option value="templates/">templates/</option>
                        <option value="config/">config/</option>
                        <option value="public/css/">public / css/</option>
                        <option value="public/js/">public / js/</option>
                        <option value="">Root</option>
                    </select>
                </div>
                <div class="field-group">
                    <label>Filename</label>
                    <input type="text" id="newFileName" placeholder="e.g. my-section.twig">
                    <div class="field-hint">Allowed: .twig, .json, .css, .js, .html, .svg, .txt</div>
                </div>
            </div>
            <div class="modal-footer">
                <button class="modal-btn modal-btn-cancel" id="btnNewFileCancel">Cancel</button>
                <button class="modal-btn modal-btn-primary" id="btnNewFileCreate">Create</button>
            </div>
        </div>
    </div>

    <!-- New Folder Modal -->
    <div class="modal-overlay" id="newFolderModal">
        <div class="modal-card">
            <div class="modal-header">New Folder</div>
            <div class="modal-body">
                <div class="field-group">
                    <label>Parent directory</label>
                    <select id="newFolderParent">
                        <option value="">Theme root</option>
                        <option value="sections/">sections/</option>
                        <option value="templates/">templates/</option>
                        <option value="public/">public/</option>
                        <option value="public/css/">public / css/</option>
                        <option value="public/js/">public / js/</option>
                    </select>
                </div>
