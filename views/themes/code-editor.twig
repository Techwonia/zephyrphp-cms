    <script type="module" nonce="{{ csp_nonce() }}">

    // ── State ──
    const THEME_SLUG = '{{ theme.getSlug() }}';
    const BASE_URL = `/cms/themes/${THEME_SLUG}/code`;
    const CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content || '';

    const state = {
        files: {},
        allFilePaths: [],
        openTabs: [],        // [{path, content, original, modified}]
        activeTab: null,     // path of active tab in pane 1
        splitTab: null,      // path of file in pane 2
        editorView: null,    // CodeMirror for pane 1
        splitView: null,     // CodeMirror for pane 2
        schemaView: null,    // CodeMirror for schema panel
        cmAvailable: false,
        splitActive: false,
        schemaPanelOpen: false,
        wordWrap: false,
        contextTarget: null, // {path, isFolder, folderPath}
    };

    // ── DOM ──
    const $ = id => document.getElementById(id);
    const $fileTree = $('fileTree');
    const $tabBar = $('tabBar');
    const $editorArea = $('editorArea');
    const $pane1 = $('editorPane1');
    const $pane2 = $('editorPane2');
    const $container1 = $('editorContainer1');
    const $container2 = $('editorContainer2');
    const $editorEmpty = $('editorEmpty');
    const $unsaved = $('unsavedIndicator');
    const $btnSave = $('btnSave');
    const $toastContainer = $('toastContainer');
    const $quickSearchOverlay = $('quickSearchOverlay');
    const $quickSearchInput = $('quickSearchInput');
    const $quickSearchResults = $('quickSearchResults');
    const $contextMenu = $('contextMenu');
    const $schemaPanel = $('schemaPanel');
    const $toolbarLineCol = $('toolbarLineCol');
    const $toolbarLang = $('toolbarLang');
    const $btnSchema = $('btnSchema');

    // ── Load CodeMirror ──
    let EditorView, EditorState, basicSetup, keymap, langHtml, langJson, langCss, langJs, indentWithTab;
    let oneDark;
    let twigTheme, twigHighlighter;

    try {
        const cmView = await import('@codemirror/view');
        const cmState = await import('@codemirror/state');
        const cmLang = await import('@codemirror/language');
        const cmCommands = await import('@codemirror/commands');
        const cmSearch = await import('@codemirror/search');
        const cmAutocomplete = await import('@codemirror/autocomplete');
        const cmLint = await import('@codemirror/lint');
        const cmHtml = await import('@codemirror/lang-html');
        const cmJson = await import('@codemirror/lang-json');
        const cmCss = await import('@codemirror/lang-css');
        const cmJs = await import('@codemirror/lang-javascript');
        const cmTheme = await import('@codemirror/theme-one-dark');

        EditorView = cmView.EditorView;
        EditorState = cmState.EditorState;
        keymap = cmView.keymap;
        langHtml = cmHtml.html;
        langJson = cmJson.json;
        langCss = cmCss.css;
        langJs = cmJs.javascript;
        indentWithTab = cmCommands.indentWithTab;
        oneDark = cmTheme.oneDark;

        // ── Twig syntax overlay highlighting ──
        // CodeMirror's HTML parser doesn't know Twig, so we overlay decorations
        // for twig delimiters, keywords, filters, variables
        twigTheme = EditorView.baseTheme({
            '.tw-delim': { color: '#c678dd' },           // purple — twig delimiters
            '.tw-keyword': { color: '#c678dd', fontWeight: 'bold' },  // purple bold — if/for/block/set
            '.tw-comment': { color: '#5c6370', fontStyle: 'italic' }, // gray italic — twig comments
            '.tw-string': { color: '#98c379' },           // green — strings
            '.tw-number': { color: '#d19a66' },           // orange — numbers
            '.tw-operator': { color: '#56b6c2' },         // cyan — operators, |
            '.tw-filter': { color: '#61afef' },           // blue — filter names
            '.tw-variable': { color: '#e06c75' },         // red — variable names
            '.tw-property': { color: '#e5c07b' },         // yellow — .property
            '.tw-function': { color: '#61afef' },         // blue — function calls
            '.tw-tag-name': { color: '#e06c75' },         // red — HTML tag names
            '.tw-attr-name': { color: '#d19a66' },        // orange — HTML attributes
            '.tw-attr-value': { color: '#98c379' },       // green — HTML attribute values
        });

        const Decoration = cmView.Decoration;
        const ViewPlugin = cmView.ViewPlugin;
        const RangeSetBuilder = cmState.RangeSetBuilder;

        function buildTwigDecorations(view) {
            const builder = new RangeSetBuilder();
            const doc = view.state.doc;
            const text = doc.toString();

            // Twig keywords
            const twigKeywords = new Set([
                'autoescape','endautoescape','block','endblock','embed','endembed',
                'filter','endfilter','for','endfor','if','endif','macro','endmacro',
                'raw','endraw','sandbox','endsandbox','set','endset','spaceless',
                'endspaceless','trans','endtrans','verbatim','endverbatim',
                'as','do','else','elseif','extends','flush','from','ignore',
                'missing','import','include','only','use','with','schema','endschema',
                'apply','endapply','deprecated','pluralize','in','is','not','and','or',
                'true','false','null','none','defined','empty','even','odd','iterable',
            ]);

            // Twig built-in filters
            const twigFilters = new Set([
                'abs','batch','capitalize','column','convert_encoding','country_name',
                'currency_name','currency_symbol','date','date_modify','default','e',
                'escape','filter','first','format','format_currency','format_date',
                'format_datetime','format_number','format_time','html_to_markdown',
                'inline_css','join','json_encode','keys','language_name','last',
                'length','locale_name','lower','map','markdown_to_html','merge',
                'nl2br','number_format','raw','reduce','replace','reverse','round',
                'slice','slug','sort','spaceless','split','striptags','timezone_name',
                'title','trim','u','upper','url_encode',
            ]);

            const decos = [];

            // Process Twig comments
            const commentRe = new RegExp('\\{' + '#[\\s\\S]*?#' + '\\}', 'g');
            let cm;
            while ((cm = commentRe.exec(text)) !== null) {
                decos.push({ from: cm.index, to: cm.index + cm[0].length, cls: 'tw-comment' });
            }

            // Process Twig statement and expression blocks
            const blockRe = new RegExp('(\\{' + '[%{])-?\\s*([\\s\\S]*?)\\s*-?([%' + '}]\\})', 'g');
            let m;
            while ((m = blockRe.exec(text)) !== null) {
                const start = m.index;
                const delimOpen = m[1];
                const inner = m[2];
                const delimClose = m[3];
                const openEnd = start + delimOpen.length;
                const closeStart = start + m[0].length - delimClose.length;

                // Opening delimiter
                decos.push({ from: start, to: openEnd, cls: 'tw-delim' });
                // Closing delimiter
                decos.push({ from: closeStart, to: start + m[0].length, cls: 'tw-delim' });

                // Tokenize inner content
                const innerStart = openEnd;
                // Skip leading whitespace/dash
                const innerText = m[0].substring(delimOpen.length, m[0].length - delimClose.length);
                const tokenRe = /('(?:[^'\\]|\\.)*'|"(?:[^"\\]|\\.)*")|(\b\d+(?:\.\d+)?\b)|(\|)\s*([a-zA-Z_]\w*)|(\b[a-zA-Z_]\w*)\s*\(|\.([a-zA-Z_]\w*)|(==|!=|<=|>=|<|>|\+|-|\*|\/|~|\?|:|\.\.|and\b|or\b|not\b|in\b|is\b)|(\b[a-zA-Z_]\w*\b)/g;
                let t;
                const base = innerStart;
                // We need to find positions within the inner part
                const rawInner = m[0].substring(delimOpen.length, m[0].length - delimClose.length);
                const innerOffset = start + delimOpen.length;

                while ((t = tokenRe.exec(rawInner)) !== null) {
                    const tStart = innerOffset + t.index;
                    const tEnd = tStart + t[0].length;

                    if (t[1]) {
                        // String
                        decos.push({ from: tStart, to: tEnd, cls: 'tw-string' });
                    } else if (t[2]) {
                        // Number
                        decos.push({ from: tStart, to: tEnd, cls: 'tw-number' });
                    } else if (t[3] && t[4]) {
                        // Filter: | + name
                        decos.push({ from: tStart, to: tStart + 1, cls: 'tw-operator' });
                        const nameStart = tStart + t[0].indexOf(t[4]);
                        const nameEnd = nameStart + t[4].length;
                        if (twigFilters.has(t[4])) {
                            decos.push({ from: nameStart, to: nameEnd, cls: 'tw-filter' });
                        } else {
                            decos.push({ from: nameStart, to: nameEnd, cls: 'tw-filter' });
                        }
                    } else if (t[5]) {
                        // Function call: name(
                        const fnEnd = tStart + t[5].length;
                        decos.push({ from: tStart, to: fnEnd, cls: 'tw-function' });
                    } else if (t[6]) {
                        // Property access: .name
                        const dotPos = tStart;
                        const propStart = tStart + t[0].indexOf(t[6]);
                        decos.push({ from: dotPos, to: dotPos + 1, cls: 'tw-operator' });
                        decos.push({ from: propStart, to: propStart + t[6].length, cls: 'tw-property' });
                    } else if (t[7]) {
                        // Operator
                        decos.push({ from: tStart, to: tEnd, cls: 'tw-operator' });
                    } else if (t[8]) {
                        // Identifier / keyword
                        if (twigKeywords.has(t[8])) {
                            decos.push({ from: tStart, to: tEnd, cls: 'tw-keyword' });
                        } else {
                            decos.push({ from: tStart, to: tEnd, cls: 'tw-variable' });
                        }
                    }
                }
            }

            // Sort by position and add to builder (RangeSetBuilder requires sorted order)
            decos.sort((a, b) => a.from - b.from || a.to - b.to);
            for (const d of decos) {
                if (d.from < d.to && d.from >= 0 && d.to <= text.length) {
                    try {
                        builder.add(d.from, d.to, Decoration.mark({ class: d.cls }));
                    } catch(e) { /* skip overlapping */ }
                }
            }

            return builder.finish();
        }

        twigHighlighter = ViewPlugin.fromClass(class {
            constructor(view) { this.decorations = buildTwigDecorations(view); }
            update(update) {
                if (update.docChanged || update.viewportChanged) {
                    this.decorations = buildTwigDecorations(update.view);
                }
            }
        }, { decorations: v => v.decorations });

        // Build basicSetup from individual packages (replaces codemirror meta-package)
        basicSetup = [
            cmView.lineNumbers(),
            cmView.highlightActiveLineGutter(),
            cmView.highlightSpecialChars(),
            cmCommands.history(),
            cmLang.foldGutter(),
            cmView.drawSelection(),
            cmView.dropCursor(),
            EditorState.allowMultipleSelections.of(true),
            cmLang.indentOnInput(),
            cmLang.syntaxHighlighting(cmLang.defaultHighlightStyle, { fallback: true }),
            cmLang.bracketMatching(),
            cmAutocomplete.closeBrackets(),
            cmAutocomplete.autocompletion(),
            cmView.rectangularSelection(),
            cmView.crosshairCursor(),
            cmView.highlightActiveLine(),
            cmSearch.highlightSelectionMatches(),
            keymap.of([
                ...cmAutocomplete.closeBracketsKeymap,
                ...cmCommands.defaultKeymap,
                ...cmSearch.searchKeymap,
                ...cmCommands.historyKeymap,
                ...cmLang.foldKeymap,
                ...cmAutocomplete.completionKeymap,
                ...cmLint.lintKeymap,
            ]),
        ];

        if (!EditorView || !EditorState || !basicSetup.length) throw new Error('Core CodeMirror exports missing');

        state.cmAvailable = true;
    } catch (e) {
        console.warn('CodeMirror failed to load:', e);
    }

    // ── Icons ──
    const ICONS = {
        twig: '#e8a836',
        html: '#e34c26',
        json: '#f5de19',
        css: '#264de4',
        js: '#f0db4f',
        svg: '#ffb13b',
        php: '#777bb4',
        default: '#999',
    };

    function fileIconSvg(filename) {
        const ext = filename.split('.').pop().toLowerCase();
        const color = ICONS[ext] || ICONS.default;
        return `<svg class="file-icon" viewBox="0 0 16 16" width="14" height="14"><path d="M4 1h6l4 4v9a1 1 0 01-1 1H4a1 1 0 01-1-1V2a1 1 0 011-1z" fill="${color}" opacity="0.15"/><path d="M4 1h6l4 4v9a1 1 0 01-1 1H4a1 1 0 01-1-1V2a1 1 0 011-1zm5.5 0v4h4" fill="none" stroke="${color}" stroke-width="1"/><text x="8" y="12.5" text-anchor="middle" font-size="4.5" font-weight="700" fill="${color}" font-family="sans-serif">${ext.substring(0,4).toUpperCase()}</text></svg>`;
    }

    const FOLDER_ICON_OPEN = `<svg class="folder-icon" viewBox="0 0 16 16" fill="#e8a836"><path d="M1.75 2.5A.75.75 0 012.5 1.75h3.586a.75.75 0 01.53.22l1.414 1.414a.25.25 0 00.177.073h5.043a.75.75 0 01.75.75V5H1.5V2.5zM1.5 6v6.5a.75.75 0 00.75.75h11.5a.75.75 0 00.75-.75V6H1.5z"/></svg>`;
    const FOLDER_ICON_CLOSED = `<svg class="folder-icon" viewBox="0 0 16 16" fill="#e8a836"><path d="M1.75 2.5A.75.75 0 012.5 1.75h3.586a.75.75 0 01.53.22l1.414 1.414a.25.25 0 00.177.073h5.043a.75.75 0 01.75.75v8.041a.75.75 0 01-.75.75H2.5a.75.75 0 01-.75-.75V2.5z"/></svg>`;

    // ── API ──
    async function apiFetch(url, options = {}) {
        const headers = { 'X-CSRF-TOKEN': CSRF_TOKEN, ...options.headers };
        if (options.body && typeof options.body === 'object') {
            headers['Content-Type'] = 'application/json';
            options.body = JSON.stringify(options.body);
        }
        const res = await fetch(url, { ...options, headers });
        const data = await res.json();
        if (!res.ok) throw new Error(data.error || `HTTP ${res.status}`);
        return data;
    }

    // ── Toast ──
    function showToast(msg, type = 'success') {
        const el = document.createElement('div');
        el.className = `toast ${type}`;
        el.textContent = msg;
        $toastContainer.appendChild(el);
        setTimeout(() => { el.classList.add('fadeout'); setTimeout(() => el.remove(), 300); }, 3000);
    }

    // ── Escape helpers ──
    function esc(s) { const d = document.createElement('div'); d.textContent = s; return d.innerHTML; }
    function escAttr(s) { return s.replace(/&/g,'&amp;').replace(/"/g,'&quot;').replace(/'/g,'&#39;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    // ══════════════════════════════════════════════
    // FILE TREE
    // ══════════════════════════════════════════════

    async function loadFileTree() {
        try {
            const data = await apiFetch(`${BASE_URL}/files`);
            state.files = data.files || {};
            buildAllFilePaths();
            renderFileTree();
        } catch (e) {
            $fileTree.innerHTML = `<div style="padding:16px;color:var(--danger);font-size:12px;">Failed to load file tree.<br><small>${esc(e.message)}</small></div>`;
        }
    }

    function buildAllFilePaths() {
        state.allFilePaths = [];
        for (const [folder, items] of Object.entries(state.files)) {
            if (Array.isArray(items)) {
                for (const f of items) {
                    state.allFilePaths.push(f);
                }
            } else if (typeof items === 'object') {
                // Nested (public subfolder)
                for (const [sub, subFiles] of Object.entries(items)) {
                    if (Array.isArray(subFiles)) {
                        for (const f of subFiles) {
                            state.allFilePaths.push(f);
                        }
                    }
                }
            }
        }
    }

    function renderFileTree() {
        // Group files into a nested tree structure
        const tree = {};
        for (const path of state.allFilePaths) {
            const parts = path.split('/');
            let node = tree;
            for (let i = 0; i < parts.length - 1; i++) {
                if (!node[parts[i]]) node[parts[i]] = {};
                node = node[parts[i]];
            }
            if (!node.__files) node.__files = [];
            node.__files.push(parts[parts.length - 1]);
        }

        // Render order
        const order = ['config', 'layouts', 'sections', 'templates', 'assets', 'public', 'controllers'];
        const folders = Object.keys(tree).filter(k => k !== '__files').sort((a, b) => {
            const ai = order.indexOf(a), bi = order.indexOf(b);
            if (ai !== -1 && bi !== -1) return ai - bi;
            if (ai !== -1) return -1;
            if (bi !== -1) return 1;
            return a.localeCompare(b);
        });

        let html = '';

        // Theme files section
        html += `<div class="tree-section-label">Theme files</div>`;
        for (const folder of folders) {
            if (folder === 'public') continue;
            html += renderFolderNode(folder, tree[folder], folder);
        }

        // Root files
        if (tree.__files && tree.__files.length > 0) {
            for (const file of tree.__files) {
                html += fileItemHtml(file, file);
            }
        }

        // Public assets section
        if (tree.public) {
            html += `<div class="tree-section-label">Public assets</div>`;
            const pubFolders = Object.keys(tree.public).filter(k => k !== '__files').sort();
            for (const sub of pubFolders) {
                html += renderFolderNode(sub, tree.public[sub], `public/${sub}`);
            }
            if (tree.public.__files) {
                for (const file of tree.public.__files) {
                    html += fileItemHtml(file, `public/${file}`);
                }
            }
        }

        $fileTree.innerHTML = html;
        updateActiveFileHighlight();
    }

    function renderFolderNode(name, node, fullPath, depth = 0) {
        const files = node.__files || [];
        const subfolders = Object.keys(node).filter(k => k !== '__files');
        const totalCount = countFiles(node);

        let html = `<div class="folder-item">
            <div class="folder-header" data-folder-path="${escAttr(fullPath)}" style="padding-left:${10 + depth * 14}px;">
                <span class="folder-toggle">&#9662;</span>
                ${FOLDER_ICON_OPEN}
                <span class="folder-name">${esc(name)}</span>
                <span class="folder-count">${totalCount}</span>
            </div>
            <div class="folder-children">`;

        for (const sub of subfolders.sort()) {
            html += renderFolderNode(sub, node[sub], `${fullPath}/${sub}`, depth + 1);
        }
        for (const file of files.sort()) {
            const filePath = `${fullPath}/${file}`;
            html += fileItemHtml(file, filePath, depth + 1);
        }

        html += `</div></div>`;
        return html;
    }

    function fileItemHtml(name, path, depth = 0) {
        const indent = 28 + (depth * 14);
        const isBinary = /\.(png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot)$/i.test(name);
        return `<div class="file-item${isBinary ? ' binary' : ''}" data-path="${escAttr(path)}" style="padding-left:${indent}px;">
            ${fileIconSvg(name)}
            <span class="file-name">${esc(name)}</span>
        </div>`;
    }

    function countFiles(node) {
        let count = (node.__files || []).length;
        for (const k of Object.keys(node)) {
            if (k !== '__files') count += countFiles(node[k]);
        }
        return count;
    }

    window._toggleFolder = function(header) {
        const children = header.nextElementSibling;
        const toggle = header.querySelector('.folder-toggle');
        const icon = header.querySelector('.folder-icon');
        const collapsed = !children.classList.contains('collapsed');
        children.classList.toggle('collapsed', collapsed);
        toggle.classList.toggle('collapsed', collapsed);
        if (icon) icon.outerHTML = collapsed ? FOLDER_ICON_CLOSED : FOLDER_ICON_OPEN;
    };

    function updateActiveFileHighlight() {
        $fileTree.querySelectorAll('.file-item').forEach(el => {
            el.classList.toggle('active', el.dataset.path === state.activeTab);
        });
    }

    // ══════════════════════════════════════════════
    // CONTEXT MENU
    // ══════════════════════════════════════════════

    window._fileContext = function(e, path) {
        e.preventDefault();
        e.stopPropagation();
        state.contextTarget = { path, isFolder: false };

        const isSection = path.startsWith('sections/');
        const items = [
            { icon: '&#128194;', label: 'Open', action: () => openFile(path) },
        ];

        if (state.splitActive) {
            items.push({ icon: '&#8596;', label: 'Open in split', action: () => openInSplit(path) });
        }

        items.push({ sep: true });
        items.push({ icon: '&#9998;', label: 'Rename', action: () => showRenameModal(path) });
        items.push({ icon: '&#128465;', label: 'Delete', danger: true, action: () => deleteFile(path) });

        showContextMenu(e.clientX, e.clientY, items);
    };

    window._folderContext = function(e, folderPath) {
        e.preventDefault();
        e.stopPropagation();
        showContextMenu(e.clientX, e.clientY, [
            { icon: '+', label: 'New file here', action: () => { window._showNewFileModal(folderPath); } },
            { icon: '+', label: 'New folder here', action: () => { window._showNewFolderModal(folderPath); } },
        ]);
    };

    function showContextMenu(x, y, items) {
        let html = '';
        for (const item of items) {
            if (item.sep) { html += `<div class="context-menu-separator"></div>`; continue; }
            html += `<div class="context-menu-item ${item.danger ? 'danger' : ''}" data-idx="${items.indexOf(item)}">
                <span>${item.icon || ''}</span> ${esc(item.label)}
            </div>`;
        }
        $contextMenu.innerHTML = html;
        // Position
        const mw = 200, mh = items.length * 34;
        if (x + mw > window.innerWidth) x = window.innerWidth - mw - 8;
        if (y + mh > window.innerHeight) y = window.innerHeight - mh - 8;
        $contextMenu.style.left = x + 'px';
        $contextMenu.style.top = y + 'px';
        $contextMenu.classList.add('visible');

        $contextMenu.querySelectorAll('.context-menu-item').forEach((el) => {
            const idx = parseInt(el.dataset.idx);
            if (!isNaN(idx) && items[idx] && items[idx].action) {
                el.addEventListener('click', () => {
                    items[idx].action();
                    $contextMenu.classList.remove('visible');
                });
            }
        });
    }

    document.addEventListener('click', () => $contextMenu.classList.remove('visible'));

    // ══════════════════════════════════════════════
    // OPEN / SWITCH / CLOSE TABS
    // ══════════════════════════════════════════════

    window._fileClick = async function(path) {
        if (/\.(png|jpg|jpeg|gif|webp|ico|woff|woff2|ttf|eot)$/i.test(path)) {
            showToast('Binary files cannot be edited', 'error');
            return;
        }
        await openFile(path);
    };

    async function openFile(path) {
        let tab = state.openTabs.find(t => t.path === path);
        if (!tab) {
            try {
                const data = await apiFetch(`${BASE_URL}/file?path=${encodeURIComponent(path)}`);
                tab = { path: data.path || path, content: data.content || '', original: data.content || '', modified: false };
                state.openTabs.push(tab);
            } catch (e) {
                showToast(`Failed to open: ${e.message}`, 'error');
                return;
            }
        }
        switchTab(path);
    }

    async function openInSplit(path) {
        let tab = state.openTabs.find(t => t.path === path);
        if (!tab) {
            try {
                const data = await apiFetch(`${BASE_URL}/file?path=${encodeURIComponent(path)}`);
                tab = { path: data.path || path, content: data.content || '', original: data.content || '', modified: false };
                state.openTabs.push(tab);
            } catch (e) {
                showToast(`Failed to open: ${e.message}`, 'error');
                return;
            }
        }
        state.splitTab = path;
        $('pane2Name').textContent = path.split('/').pop();
        // Hide file picker, show editor
        if ($('splitFilePicker')) $('splitFilePicker').style.display = 'none';
        createEditor($container2, tab.content, path, 'split');
        renderTabs();
    }

    function switchTab(path) {
        // Save current content
        if (state.activeTab && state.editorView) {
            const cur = state.openTabs.find(t => t.path === state.activeTab);
            if (cur) {
                cur.content = state.editorView.state.doc.toString();
                cur.modified = cur.content !== cur.original;
            }
        }

        state.activeTab = path;
        const tab = state.openTabs.find(t => t.path === path);
        if (!tab) return;

        $editorEmpty.style.display = 'none';
        $('pane1Name').textContent = path.split('/').pop();
        createEditor($container1, tab.content, path, 'main');
        renderTabs();
        updateActiveFileHighlight();
        updateUnsavedState();
        updateToolbarInfo(path);
        updateSchemaButton(path);
    }

    function createEditor(container, content, path, role) {
        // Destroy existing
        if (role === 'main' && state.editorView) { state.editorView.destroy(); state.editorView = null; }
        if (role === 'split' && state.splitView) { state.splitView.destroy(); state.splitView = null; }
        if (role === 'schema' && state.schemaView) { state.schemaView.destroy(); state.schemaView = null; }

        // Remove any fallback textarea
        const existing = container.querySelector('.editor-fallback');
        if (existing) existing.remove();

        // Remove any previous CM
        const prevCm = container.querySelector('.cm-editor');
        if (prevCm) prevCm.remove();

        if (state.cmAvailable) {
            const langExt = getLanguage(path);
            const saveKeymap = keymap ? keymap.of([
                { key: 'Mod-s', run: () => { window._saveFile(); return true; } },
                ...(indentWithTab ? [indentWithTab] : []),
            ]) : null;

            const extensions = [
                basicSetup,
                saveKeymap,
                oneDark,
                EditorView.updateListener.of(update => {
                    if (update.docChanged && role === 'main') onEditorChange();
                    if (update.selectionSet && role === 'main') updateCursorPos(update.state);
                }),
                EditorView.theme({
                    '&': { height: '100%' },
                    '.cm-scroller': { overflow: 'auto', fontFamily: 'var(--font-mono)', fontSize: '13px', lineHeight: '1.6' },
                }),
            ].filter(Boolean);
            if (state.wordWrap) {
                extensions.push(EditorView.lineWrapping);
            }
            if (langExt) extensions.push(langExt);

            // Add Twig overlay highlighting for .twig files
            const fileExt = (path || '').split('.').pop().toLowerCase();
            if (fileExt === 'twig' || fileExt === 'html') {
                extensions.push(twigTheme);
                extensions.push(twigHighlighter);
            }

            const view = new EditorView({
                state: EditorState.create({ doc: content, extensions }),
                parent: container,
            });

            if (role === 'main') state.editorView = view;
            else if (role === 'split') state.splitView = view;
            else if (role === 'schema') state.schemaView = view;
        } else {
            // Fallback textarea
            const ta = document.createElement('textarea');
            ta.className = 'editor-fallback';
            ta.value = content;
            ta.addEventListener('input', () => { if (role === 'main') onEditorChange(); });
            ta.addEventListener('keydown', (e) => {
                if ((e.ctrlKey || e.metaKey) && e.key === 's') { e.preventDefault(); window._saveFile(); }
            });
            container.appendChild(ta);
        }
    }

    function getLanguage(path) {
        if (!state.cmAvailable) return null;
        const ext = path.split('.').pop().toLowerCase();
        switch (ext) {
            case 'twig': case 'html': case 'htm': return langHtml();
            case 'json': return langJson();
            case 'css': return langCss();
            case 'js': return langJs();
            default: return null;
        }
    }

    function getLanguageName(path) {
        const ext = path.split('.').pop().toLowerCase();
        const names = { twig: 'Twig/HTML', html: 'HTML', json: 'JSON', css: 'CSS', js: 'JavaScript', svg: 'SVG', txt: 'Plain Text', php: 'PHP' };
        return names[ext] || ext.toUpperCase();
    }

    function onEditorChange() {
        const tab = state.openTabs.find(t => t.path === state.activeTab);
        if (!tab) return;
        let content;
        if (state.cmAvailable && state.editorView) {
            content = state.editorView.state.doc.toString();
        } else {
            const ta = $container1.querySelector('.editor-fallback');
            content = ta ? ta.value : '';
        }
        tab.content = content;
        tab.modified = content !== tab.original;
        renderTabs();
        updateUnsavedState();

        // Sync schema panel if open
        if (state.schemaPanelOpen && state.activeTab?.startsWith('sections/')) {
            syncSchemaPanel(content);
        }
    }

    function updateCursorPos(editorState) {
        const sel = editorState.selection.main;
        const line = editorState.doc.lineAt(sel.head);
        $toolbarLineCol.textContent = `Ln ${line.number}, Col ${sel.head - line.from + 1}`;
    }

    function updateToolbarInfo(path) {
        $toolbarLang.textContent = getLanguageName(path);
        $toolbarLineCol.textContent = 'Ln 1, Col 1';
    }

    function updateSchemaButton(path) {
        $btnSchema.style.display = path.startsWith('sections/') && path.endsWith('.twig') ? '' : 'none';
    }

    function updateUnsavedState() {
        const anyMod = state.openTabs.some(t => t.modified);
        $unsaved.classList.toggle('visible', anyMod);
        const active = state.openTabs.find(t => t.path === state.activeTab);
        $btnSave.disabled = !active || !active.modified;
    }

    // ── Render Tabs ──
    function renderTabs() {
        let html = '';
        for (const tab of state.openTabs) {
            const name = tab.path.split('/').pop();
            const isActive = tab.path === state.activeTab;
            const cls = ['tab'];
            if (isActive) cls.push('active');
            if (tab.modified) cls.push('modified');
            html += `<div class="${cls.join(' ')}" data-tab-path="${escAttr(tab.path)}">
                <span class="tab-modified"></span>
                <span class="tab-name" title="${escAttr(tab.path)}">${esc(name)}</span>
                <button class="tab-close" data-tab-close="${escAttr(tab.path)}">&times;</button>
            </div>`;
        }
        $tabBar.innerHTML = html;
    }

    window._switchTab = function(path) { switchTab(path); };

    window._closeTab = function(path) {
        const tab = state.openTabs.find(t => t.path === path);
        if (!tab) return;
        if (tab.modified && !confirm(`"${path.split('/').pop()}" has unsaved changes. Close anyway?`)) return;

        state.openTabs = state.openTabs.filter(t => t.path !== path);
        if (state.activeTab === path) {
            if (state.openTabs.length > 0) {
                switchTab(state.openTabs[state.openTabs.length - 1].path);
            } else {
                state.activeTab = null;
                if (state.editorView) { state.editorView.destroy(); state.editorView = null; }
                $editorEmpty.style.display = 'flex';
            }
        }
        if (state.splitTab === path) {
            window._closeSplitPane();
        }
        renderTabs();
        updateActiveFileHighlight();
        updateUnsavedState();
    };

    // ══════════════════════════════════════════════
    // SAVE / DELETE / CREATE / RENAME
    // ══════════════════════════════════════════════

    window._saveFile = async function() {
        const tab = state.openTabs.find(t => t.path === state.activeTab);
        if (!tab || !tab.modified) return;

        // Sync editor content
        if (state.cmAvailable && state.editorView) {
            tab.content = state.editorView.state.doc.toString();
        }

        $btnSave.disabled = true;
        $btnSave.textContent = 'Saving...';
        try {
            await apiFetch(`${BASE_URL}/file`, { method: 'POST', body: { path: tab.path, content: tab.content } });
            tab.original = tab.content;
            tab.modified = false;
            renderTabs();
            updateUnsavedState();
            showToast('File saved');
        } catch (e) {
            showToast(`Save failed: ${e.message}`, 'error');
        } finally {
            $btnSave.textContent = 'Save';
            updateUnsavedState();
        }
    };

    async function deleteFile(path) {
        if (!confirm(`Delete "${path.split('/').pop()}"? This cannot be undone.`)) return;
        try {
            await apiFetch(`${BASE_URL}/file/delete`, { method: 'POST', body: { path } });
            state.openTabs = state.openTabs.filter(t => t.path !== path);
            if (state.activeTab === path) {
                state.activeTab = null;
                if (state.editorView) { state.editorView.destroy(); state.editorView = null; }
                if (state.openTabs.length > 0) switchTab(state.openTabs[state.openTabs.length - 1].path);
                else $editorEmpty.style.display = 'flex';
            }
            renderTabs(); updateUnsavedState();
            await loadFileTree();
            showToast('File deleted');
        } catch (e) {
            showToast(`Delete failed: ${e.message}`, 'error');
        }
    }

    // ── New File Modal ──
    window._showNewFileModal = function(folderPath) {
        const sel = $('newFileDir');
        if (folderPath) {
            // Try to select the matching option
            const val = folderPath.endsWith('/') ? folderPath : folderPath + '/';
            for (const opt of sel.options) {
                if (opt.value === val) { sel.value = val; break; }
            }
        }
        $('newFileName').value = '';
        $('newFileModal').classList.add('visible');
        setTimeout(() => $('newFileName').focus(), 100);
    };

    window._createNewFile = async function() {
        const dir = $('newFileDir').value;
        const name = $('newFileName').value.trim();
        if (!name) { showToast('Filename is required', 'error'); return; }
        const path = dir + name;
        try {
            await apiFetch(`${BASE_URL}/file/create`, { method: 'POST', body: { path, content: '' } });
            window._closeModal('newFileModal');
            await loadFileTree();
            await openFile(path);
            showToast('File created');
        } catch (e) {
            showToast(`Failed: ${e.message}`, 'error');
        }
    };

    // ── New Folder Modal ──
    window._showNewFolderModal = function(parentPath) {
        const sel = $('newFolderParent');
        if (parentPath) {
            const val = parentPath.endsWith('/') ? parentPath : parentPath + '/';
            for (const opt of sel.options) {
                if (opt.value === val) { sel.value = val; break; }
            }
        }
        $('newFolderName').value = '';
        $('newFolderModal').classList.add('visible');
        setTimeout(() => $('newFolderName').focus(), 100);
    };

    window._createNewFolder = async function() {
        const parent = $('newFolderParent').value;
        const name = $('newFolderName').value.trim().replace(/[^a-z0-9_-]/gi, '-').toLowerCase();
        if (!name) { showToast('Folder name is required', 'error'); return; }
        const path = parent + name;
        try {
            await apiFetch(`${BASE_URL}/folder`, { method: 'POST', body: { path } });
            window._closeModal('newFolderModal');
            await loadFileTree();
            showToast('Folder created');
        } catch (e) {
            showToast(`Failed: ${e.message}`, 'error');
        }
    };

    // ── Rename Modal ──
    function showRenameModal(path) {
        $('renameOldPath').value = path;
        const filename = path.split('/').pop();
        $('renameNewName').value = filename;
        $('renameModal').classList.add('visible');
        setTimeout(() => { $('renameNewName').focus(); $('renameNewName').select(); }, 100);
    }

    window._renameFile = async function() {
        const oldPath = $('renameOldPath').value;
        const newName = $('renameNewName').value.trim();
        if (!newName) { showToast('Name is required', 'error'); return; }

        // Build new path (same directory, new filename)
        const parts = oldPath.split('/');
        parts[parts.length - 1] = newName;
        const newPath = parts.join('/');

        if (newPath === oldPath) { window._closeModal('renameModal'); return; }

        try {
            await apiFetch(`${BASE_URL}/file/rename`, { method: 'POST', body: { oldPath, newPath } });

            // Update open tab if exists
            const tab = state.openTabs.find(t => t.path === oldPath);
            if (tab) tab.path = newPath;
            if (state.activeTab === oldPath) state.activeTab = newPath;
            if (state.splitTab === oldPath) state.splitTab = newPath;

            window._closeModal('renameModal');
            renderTabs();
            await loadFileTree();
            showToast('File renamed');
        } catch (e) {
            showToast(`Rename failed: ${e.message}`, 'error');
        }
    };

    // ── Modal helpers ──
    window._closeModal = function(id) {
        $(id).classList.remove('visible');
    };

    // Close modals on overlay click
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
        overlay.addEventListener('click', (e) => {
            if (e.target === overlay) overlay.classList.remove('visible');
        });
    });

    // ══════════════════════════════════════════════
    // TOOLBAR ACTIONS
