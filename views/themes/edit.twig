    if (isSectionFile) {
        setTimeout(function() { switchToDesigner(); }, 100);
    }

    // ════════════════════════════════════════════
    //  CONTROLLER REFERENCE PANEL (File Editor)
    // ════════════════════════════════════════════
    var editorRefVisible = false;
    var editorRefBtn = document.getElementById('editorRefToggleBtn');
    var editorRefPanel = document.getElementById('editorRefPanel');

    if (isControllerFile && editorRefBtn) {
        editorRefBtn.style.display = '';
        editorRefVisible = true;
        editorRefPanel.classList.remove('hidden');
        editorRefBtn.classList.add('active');
        renderControllerRefPanel();
    }

    editorRefBtn?.addEventListener('click', function() {
        editorRefVisible = !editorRefVisible;
        if (editorRefVisible) {
            editorRefPanel.classList.remove('hidden');
            this.classList.add('active');
        } else {
            editorRefPanel.classList.add('hidden');
            this.classList.remove('active');
        }
        setTimeout(function() { editor.refresh(); }, 50);
    });

    function renderControllerRefPanel() {
        var body = document.getElementById('editorRefPanelBody');
        if (!body) return;
        body.innerHTML = '';

        function makeRefSection(title, items, open) {
            var sec = document.createElement('div');
            sec.className = 'ref-section';
            var hdr = document.createElement('div');
            hdr.className = 'ref-section-title';
            hdr.innerHTML = title + ' <span style="font-size:10px;">' + (open ? '&#9660;' : '&#9654;') + '</span>';
            var bd = document.createElement('div');
            bd.className = 'ref-section-body';
            bd.style.display = open ? 'block' : 'none';
            hdr.addEventListener('click', function() {
                var showing = bd.style.display !== 'none';
                bd.style.display = showing ? 'none' : 'block';
                hdr.querySelector('span').innerHTML = showing ? '&#9654;' : '&#9660;';
            });
            items.forEach(function(item) {
                var row = document.createElement('div');
                row.className = 'ref-item';
                row.title = item.detail || '';
                if (item.badge) {
                    var b = document.createElement('span');
                    b.className = 'ref-item-badge';
                    b.style.cssText = item.badgeStyle || 'background:#6272a4;color:#fff;';
                    b.textContent = item.badge;
                    row.appendChild(b);
                }
                var code = document.createElement('code');
                code.textContent = item.text;
                row.appendChild(code);
                row.addEventListener('click', function() {
                    var cur = editor.getCursor();
                    editor.replaceRange(item.insert || item.text, cur);
                    editor.focus();
                });
                bd.appendChild(row);
            });
            sec.appendChild(hdr);
            sec.appendChild(bd);
            body.appendChild(sec);
        }

        makeRefSection('Route Parameters', [
            { text: "$params['slug']", badge: 'param', badgeStyle: 'background:#6272a4;color:#fff;', detail: 'Route parameter value', insert: "$params['slug']" },
            { text: "$params['id']", badge: 'param', badgeStyle: 'background:#6272a4;color:#fff;', detail: 'Route parameter value', insert: "$params['id']" },
            { text: "$params['_query']", badge: 'param', badgeStyle: 'background:#6272a4;color:#fff;', detail: 'Query string ($_GET)', insert: "$params['_query']" },
            { text: "$params['_query']['page']", badge: 'param', badgeStyle: 'background:#6272a4;color:#fff;', detail: 'Pagination query param', insert: "$params['_query']['page'] ?? 1" },
        ], true);

        makeRefSection('Data Functions', [
            { text: "entry(slug, id)", badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Fetch single entry by slug or ID', insert: "entry('collection_slug', $params['slug'])" },
            { text: "collection(slug, opts)", badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Query collection with pagination', insert: "collection('collection_slug', ['per_page' => 10, 'page' => $page])" },
            { text: "config(key, default)", badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Get app config value', insert: "config('app.name', 'Default')" },
            { text: "abort(404)", badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Return HTTP error (404, 500, etc.)', insert: "abort(404)" },
        ], true);

        makeRefSection('Return Data', [
            { text: "return ['key' => $val]", badge: 'return', badgeStyle: 'background:#50fa7b;color:#282a36;', detail: 'Pass variables to template', insert: "return ['items' => $items];" },
            { text: "return ['item' => $item]", badge: 'return', badgeStyle: 'background:#50fa7b;color:#282a36;', detail: 'Pass single item to template', insert: "return ['item' => $item];" },
            { text: "return ['page' => [...]]", badge: 'return', badgeStyle: 'background:#50fa7b;color:#282a36;', detail: 'Override page title etc.', insert: "return ['page' => ['title' => $item->getTitle()]];" },
        ], true);

        makeRefSection('Common Patterns', [
            { text: 'Detail page', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Fetch single entry with 404', insert: "$item = entry('blogs', $params['slug']);\nif (!$item) { abort(404); }\nreturn ['item' => $item];" },
            { text: 'Listing page', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Paginated collection listing', insert: "$page = max(1, (int)($params['_query']['page'] ?? 1));\n$items = collection('blogs', ['per_page' => 10, 'page' => $page, 'sort_by' => 'id', 'sort_dir' => 'DESC']);\nreturn ['items' => $items];" },
            { text: 'Filtered listing', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Filter by category param', insert: "$page = max(1, (int)($params['_query']['page'] ?? 1));\n$category = $params['_query']['category'] ?? null;\n$opts = ['per_page' => 10, 'page' => $page];\nif ($category) { $opts['where'] = ['category' => $category]; }\n$items = collection('blogs', $opts);\nreturn ['items' => $items];" },
        ], false);

        makeRefSection('Template Variables', [
            { text: '{' + '{ item.getTitle() }' + '}', badge: 'twig', badgeStyle: 'background:#ff79c6;color:#282a36;', detail: 'Access entry getter in template', insert: '{' + '{ item.getTitle() }' + '}' },
            { text: '{' + '{ attribute(item, "field") }' + '}', badge: 'twig', badgeStyle: 'background:#ff79c6;color:#282a36;', detail: 'Dynamic field access in template', insert: '{' + '{ attribute(item, "field_name") }' + '}' },
            { text: '{' + '% for item in items.data %' + '}', badge: 'twig', badgeStyle: 'background:#ff79c6;color:#282a36;', detail: 'Loop collection results', insert: '{' + '% for item in items.data %' + '}' },
            { text: '{' + '{ params.slug }' + '}', badge: 'twig', badgeStyle: 'background:#ff79c6;color:#282a36;', detail: 'Access route param in template', insert: '{' + '{ params.slug }' + '}' },
        ], false);
    }

    // ════════════════════════════════════════════
    //  SAVE FILE
    // ════════════════════════════════════════════
    document.getElementById('saveFileBtn').addEventListener('click', function() {
        if (!currentFile) return;

        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Saving...';

        fetch('/cms/themes/' + themeSlug + '/file', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': csrfToken
            },
            body: JSON.stringify({
                file: currentFile,
                content: getContentToSave()
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            if (data.success) {
                btn.textContent = 'Saved!';
                setTimeout(function() { btn.textContent = 'Save'; }, 1500);
            } else {
                btn.textContent = 'Error';
                setTimeout(function() { btn.textContent = 'Save'; }, 2000);
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = 'Error';
            setTimeout(function() { btn.textContent = 'Save'; }, 2000);
        });
    });

    // Ctrl+S shortcut in main editor
    editor.on('keydown', function(cm, e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
            e.preventDefault();
            document.getElementById('saveFileBtn').click();
        }
    });

    // ════════════════════════════════════════════
    //  PAGES MANAGEMENT (existing)
    // ════════════════════════════════════════════
    function showModal(isEdit) {
        var modal = document.getElementById('addPageModal');
        modal.style.display = 'flex';
        document.getElementById('pageModalTitle').textContent = isEdit ? 'Edit Page Settings' : 'Add New Page';
        document.getElementById('savePageBtn').textContent = isEdit ? 'Save Changes' : 'Create Page';
    }

    function hideModal() {
        var modal = document.getElementById('addPageModal');
        modal.style.display = 'none';
        document.getElementById('pageTitle').value = '';
        document.getElementById('pageSlug').value = '';
        document.getElementById('pageLayout').value = 'base';
        document.getElementById('pageCollection').value = '';
        document.getElementById('pageEditTemplate').value = '';
        document.getElementById('pageDynamicHint').style.display = 'none';
        document.getElementById('pageAuthRequired').checked = false;
        document.getElementById('pageAllowedRoles').value = '';
        document.getElementById('pageRolesGroup').style.display = 'none';
    }

    // Toggle roles field when auth checkbox changes
    document.getElementById('pageAuthRequired')?.addEventListener('change', function() {
        document.getElementById('pageRolesGroup').style.display = this.checked ? 'block' : 'none';
    });

    // Load collections for the dropdown
    function loadCollections() {
        fetch('/cms/themes/' + themeSlug + '/customize/collections', {
            headers: { 'X-CSRF-TOKEN': csrfToken }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var sel = document.getElementById('pageCollection');
            (data.collections || []).forEach(function(c) {
                var opt = document.createElement('option');
                opt.value = c.slug;
                opt.textContent = c.name;
                sel.appendChild(opt);
            });
        })
        .catch(function() { /* silent */ });
    }
    loadCollections();

    // Show/hide dynamic hint based on URL pattern
    document.getElementById('pageSlug')?.addEventListener('input', function() {
        var hint = document.getElementById('pageDynamicHint');
        hint.style.display = /\{(\w+)\}/.test(this.value) ? 'block' : 'none';
    });

    document.getElementById('addPageBtn')?.addEventListener('click', function() { showModal(false); });
    document.getElementById('closePageModal')?.addEventListener('click', hideModal);
    document.getElementById('cancelPageModal')?.addEventListener('click', hideModal);

    document.querySelectorAll('.edit-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById('pageEditTemplate').value = this.dataset.template;
            document.getElementById('pageTitle').value = this.dataset.title;
            document.getElementById('pageSlug').value = this.dataset.slug;
            document.getElementById('pageLayout').value = this.dataset.layout;
            var authReq = this.dataset.authRequired === '1' || this.dataset.authRequired === 'true';
            document.getElementById('pageAuthRequired').checked = authReq;
            document.getElementById('pageAllowedRoles').value = this.dataset.allowedRoles || '';
            document.getElementById('pageRolesGroup').style.display = authReq ? 'block' : 'none';
            showModal(true);
        });
    });

    document.getElementById('savePageBtn')?.addEventListener('click', function() {
        var btn = this;
        var editTemplate = document.getElementById('pageEditTemplate').value;
        var isEdit = !!editTemplate;
        var endpoint = isEdit ? '/cms/themes/' + themeSlug + '/pages/update' : '/cms/themes/' + themeSlug + '/pages/add';

        var authRequired = document.getElementById('pageAuthRequired').checked;
        var rolesStr = document.getElementById('pageAllowedRoles').value.trim();
        var allowedRoles = rolesStr ? rolesStr.split(',').map(function(r) { return r.trim(); }).filter(Boolean) : [];

        var payload = {
            title: document.getElementById('pageTitle').value,
            slug: document.getElementById('pageSlug').value,
            layout: document.getElementById('pageLayout').value,
            collection: document.getElementById('pageCollection').value,
            auth_required: authRequired,
            allowed_roles: allowedRoles
        };
        if (isEdit) payload.template = editTemplate;

        btn.disabled = true;
        btn.textContent = 'Saving...';

        fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.error || 'Failed to save page');
                btn.disabled = false;
                btn.textContent = isEdit ? 'Save Changes' : 'Create Page';
            }
        })
        .catch(function() {
            alert('Network error');
            btn.disabled = false;
            btn.textContent = isEdit ? 'Save Changes' : 'Create Page';
        });
    });

    document.querySelectorAll('.delete-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var template = this.dataset.template;
            var title = this.dataset.title;
            if (!confirm('Delete page "' + title + '"? This will also delete the template file.')) return;

            fetch('/cms/themes/' + themeSlug + '/pages/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
                body: JSON.stringify({ template: template })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.error || 'Failed to delete page');
                }
            });
        });
    });

    document.getElementById('pageTitle')?.addEventListener('input', function() {
        var editTemplate = document.getElementById('pageEditTemplate').value;
        if (editTemplate) return;
        var slug = '/' + this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        document.getElementById('pageSlug').value = slug;
    });

    // ── New Section Management ──
    document.getElementById('newSectionBtn')?.addEventListener('click', function() {
        document.getElementById('newSectionModal').style.display = 'flex';
        document.getElementById('sectionName').value = '';
        document.getElementById('sectionName').focus();
    });

    document.getElementById('closeNewSectionModal')?.addEventListener('click', function() {
        document.getElementById('newSectionModal').style.display = 'none';
    });
    document.getElementById('cancelNewSectionModal')?.addEventListener('click', function() {
        document.getElementById('newSectionModal').style.display = 'none';
    });

    document.getElementById('createSectionBtn')?.addEventListener('click', function() {
        var btn = this;
        var name = document.getElementById('sectionName').value.trim();
        if (!name) { alert('Section name is required'); return; }

        btn.disabled = true;
        btn.textContent = 'Creating...';

        fetch('/cms/themes/' + themeSlug + '/sections/create', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
            body: JSON.stringify({ name: name })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                window.location.href = '/cms/themes/' + themeSlug + '?file=sections/' + encodeURIComponent(data.type) + '.twig';
            } else {
                alert(data.error || 'Failed to create section');
                btn.disabled = false;
                btn.textContent = 'Create Section';
            }
        })
        .catch(function() {
            alert('Network error');
            btn.disabled = false;
            btn.textContent = 'Create Section';
        });
    });
    // ==================== ASSET MANAGEMENT ====================
    var themeSlug = '{{ theme.getSlug() }}';
    var assetsLoaded = false;

    // Load assets when Assets tab is clicked
    document.querySelectorAll('.tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (this.dataset.tab === 'tab-assets' && !assetsLoaded) {
                loadAssets();
                assetsLoaded = true;
            }
        });
    });

    function loadAssets() {
        fetch('/cms/themes/' + themeSlug + '/assets')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                renderAssets(data.assets || {});
            })
            .catch(function() {
                document.getElementById('assetsList').innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-secondary);">Failed to load assets.</div>';
            });
    }

    function renderAssets(assets) {
        var container = document.getElementById('assetsList');
        var categoryIcons = {
            css: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M9 9h6v6H9z"/></svg>',
            js: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16v16H4z"/><path d="M8 12l2 2 4-4"/></svg>',
            fonts: '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 7V4h16v3"/><path d="M9 20h6"/><path d="M12 4v16"/></svg>'
        };
        var categoryLabels = { css: 'Stylesheets', js: 'JavaScript', fonts: 'Fonts' };
        var html = '';

        ['css', 'js', 'fonts'].forEach(function(cat) {
            var files = assets[cat] || [];
            html += '<div class="asset-category" style="margin-bottom: 20px;">';
            html += '<h4 style="font-size:0.875rem; margin:0 0 8px; display:flex; align-items:center; gap:6px; color:var(--text-primary);">';
            html += (categoryIcons[cat] || '') + ' ' + categoryLabels[cat] + ' <span style="font-weight:normal; color:var(--text-secondary);">(' + files.length + ')</span></h4>';

            if (files.length === 0) {
                html += '<p style="color:var(--text-secondary); font-size:0.8125rem; margin:0 0 0 22px;">No ' + cat + ' files yet.</p>';
            } else {
                html += '<div style="display:grid; gap:4px;">';
                files.forEach(function(f) {
                    html += '<div class="asset-item" style="display:flex; align-items:center; justify-content:space-between; padding:8px 12px; background:var(--bg-surface,#fff); border:1px solid var(--border-default,#e3e3e3); border-radius:6px; font-size:0.8125rem;">';
                    html += '<div style="display:flex; align-items:center; gap:8px; min-width:0;">';
                    html += '<span style="font-family:monospace; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">' + escapeHtml(f.name) + '</span>';
                    html += '<span style="color:var(--text-secondary); flex-shrink:0;">' + f.size + '</span>';
                    html += '</div>';
                    html += '<div style="display:flex; gap:6px; flex-shrink:0;">';
                    html += '<button class="btn btn-xs btn-outline copy-path-btn" data-path="/theme/' + f.path.replace('assets/', '') + '" title="Copy URL">Copy URL</button>';
                    html += '<button class="btn btn-xs btn-danger delete-asset-btn" data-path="' + escapeHtml(f.path) + '" data-name="' + escapeHtml(f.name) + '">Delete</button>';
                    html += '</div>';
                    html += '</div>';
                });
                html += '</div>';
            }
            html += '</div>';
        });

        // Other files
        if (assets.other && assets.other.length > 0) {
            html += '<div class="asset-category" style="margin-bottom:20px;">';
            html += '<h4 style="font-size:0.875rem; margin:0 0 8px; color:var(--text-primary);">Other Files (' + assets.other.length + ')</h4>';
            html += '<div style="display:grid; gap:4px;">';
            assets.other.forEach(function(f) {
                html += '<div class="asset-item" style="display:flex; align-items:center; justify-content:space-between; padding:8px 12px; background:var(--bg-surface,#fff); border:1px solid var(--border-default,#e3e3e3); border-radius:6px; font-size:0.8125rem;">';
                html += '<span style="font-family:monospace;">' + escapeHtml(f.name) + '</span> <span style="color:var(--text-secondary);">' + f.size + '</span>';
                html += '<button class="btn btn-xs btn-danger delete-asset-btn" data-path="' + escapeHtml(f.path) + '" data-name="' + escapeHtml(f.name) + '">Delete</button>';
                html += '</div>';
            });
            html += '</div></div>';
        }

        container.innerHTML = html;

        // Bind delete buttons
        container.querySelectorAll('.delete-asset-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var path = this.dataset.path;
                var name = this.dataset.name;
                if (!confirm('Delete "' + name + '"? This cannot be undone.')) return;
                fetch('/cms/themes/' + themeSlug + '/assets/delete', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || '' },
                    body: JSON.stringify({ path: path })
                })
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (data.success) { loadAssets(); }
                    else { alert(data.error || 'Delete failed'); }
                })
                .catch(function() { alert('Network error'); });
            });
        });

        // Bind copy URL buttons
        container.querySelectorAll('.copy-path-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var url = window.location.origin + this.dataset.path;
                navigator.clipboard.writeText(url).then(function() {
                    btn.textContent = 'Copied!';
                    setTimeout(function() { btn.textContent = 'Copy URL'; }, 1500);
                });
            });
        });
    }

    function escapeHtml(text) {
        var d = document.createElement('div');
        d.textContent = text;
        return d.innerHTML;
    }

    // File upload handling
    var fileInput = document.getElementById('assetFileInput');
    var uploadBtn = document.getElementById('assetUploadBtn');
    var fileNameDisplay = document.getElementById('assetFileName');

    if (fileInput) {
        fileInput.addEventListener('change', function() {
            if (this.files.length > 0) {
                fileNameDisplay.textContent = this.files[0].name;
                uploadBtn.style.display = '';

                // Auto-detect category from extension
                var ext = this.files[0].name.split('.').pop().toLowerCase();
                var catMap = { css: 'css', js: 'js', map: 'js', woff: 'fonts', woff2: 'fonts', ttf: 'fonts', otf: 'fonts', eot: 'fonts' };
                if (catMap[ext]) {
                    document.getElementById('assetCategory').value = catMap[ext];
                }
            } else {
                fileNameDisplay.textContent = 'or drag & drop files here';
                uploadBtn.style.display = 'none';
            }
        });
    }

    if (uploadBtn) {
        uploadBtn.addEventListener('click', function() {
            if (!fileInput.files.length) return;
            var formData = new FormData();
            formData.append('asset_file', fileInput.files[0]);
            formData.append('category', document.getElementById('assetCategory').value);

            var progressWrap = document.getElementById('assetUploadProgress');
            var progressBar = document.getElementById('assetProgressBar');
            progressWrap.style.display = '';
            uploadBtn.disabled = true;
            uploadBtn.textContent = 'Uploading...';

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '/cms/themes/' + themeSlug + '/assets/upload');
            var csrfMeta = document.querySelector('meta[name="csrf-token"]');
            if (csrfMeta) xhr.setRequestHeader('X-CSRF-TOKEN', csrfMeta.content);

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    progressBar.style.width = Math.round(e.loaded / e.total * 100) + '%';
                }
            });

            xhr.addEventListener('load', function() {
                progressWrap.style.display = 'none';
                progressBar.style.width = '0%';
                uploadBtn.disabled = false;
                uploadBtn.textContent = 'Upload';

                try {
                    var data = JSON.parse(xhr.responseText);
                    if (data.success) {
                        fileInput.value = '';
                        fileNameDisplay.textContent = 'or drag & drop files here';
                        uploadBtn.style.display = 'none';
                        loadAssets();
                    } else {
                        alert(data.error || 'Upload failed');
                    }
                } catch (e) {
                    alert('Upload failed');
                }
            });

            xhr.addEventListener('error', function() {
                progressWrap.style.display = 'none';
                uploadBtn.disabled = false;
                uploadBtn.textContent = 'Upload';
                alert('Network error');
            });

            xhr.send(formData);
        });
    }

    // Drag and drop
    var dropZone = document.getElementById('assetDropZone');
    if (dropZone) {
        ['dragenter', 'dragover'].forEach(function(evt) {
            dropZone.addEventListener(evt, function(e) {
                e.preventDefault();
                dropZone.style.borderColor = 'var(--color-primary, #008060)';
                dropZone.style.background = 'rgba(0,128,96,0.04)';
            });
        });
        ['dragleave', 'drop'].forEach(function(evt) {
            dropZone.addEventListener(evt, function(e) {
                e.preventDefault();
                dropZone.style.borderColor = '';
                dropZone.style.background = '';
            });
        });
        dropZone.addEventListener('drop', function(e) {
            if (e.dataTransfer.files.length > 0) {
                fileInput.files = e.dataTransfer.files;
                fileInput.dispatchEvent(new Event('change'));
            }
        });
    }
});
</script>
{% endblock %}
