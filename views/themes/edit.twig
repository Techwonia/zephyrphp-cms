    // CodeMirror hint function
    function twigSectionHint(cm) {
        var cur = cm.getCursor();
        var line = cm.getLine(cur.line);
        var end = cur.ch;
        var start = end;

        // Walk back to find start of current word/expression
        while (start > 0 && /[\w.\|(]/.test(line.charAt(start - 1))) {
            start--;
        }
        var word = line.slice(start, end).toLowerCase();

        // Detect context
        var beforeWord = line.slice(0, start).trimEnd();
        var inTag = new RegExp('\\{' + '%\\s*$').test(beforeWord) || new RegExp('\\{' + '%-?\\s*$').test(beforeWord);
        var inPrint = new RegExp('\\{' + '\\{\\s*$').test(beforeWord);
        var afterPipe = /\|\s*$/.test(beforeWord);

        var allCompletions = getCompletions();
        var filtered;

        if (afterPipe) {
            // After | only show filters
            filtered = allCompletions.filter(function(c) { return c.kind === 'filter'; });
        } else if (inTag) {
            // After tag opener show tags and variables
            filtered = allCompletions.filter(function(c) { return c.kind === 'tag' || c.kind === 'var' || c.kind === 'fn'; });
        } else {
            filtered = allCompletions;
        }

        // Filter by typed word
        if (word) {
            filtered = filtered.filter(function(c) {
                return c.text.toLowerCase().indexOf(word) >= 0;
            });
        }

        var kindClass = { 'var': 'hint-kind-var', 'fn': 'hint-kind-fn', 'tag': 'hint-kind-tag', 'filter': 'hint-kind-filter', 'field': 'hint-kind-field' };
        var kindLabel = { 'var': 'VAR', 'fn': 'FN', 'tag': 'TAG', 'filter': 'FILTER', 'field': 'FIELD' };

        var list = filtered.map(function(c) {
            return {
                text: c.text,
                displayText: c.text,
                className: '',
                render: function(el, self, data) {
                    var badge = document.createElement('span');
                    badge.className = 'hint-kind ' + (kindClass[c.kind] || '');
                    badge.textContent = kindLabel[c.kind] || c.kind;
                    el.appendChild(badge);
                    var txt = document.createElement('span');
                    txt.textContent = c.text;
                    el.appendChild(txt);
                    if (c.detail) {
                        var det = document.createElement('span');
                        det.style.cssText = 'margin-left:auto;padding-left:12px;opacity:0.5;font-size:10px;';
                        det.textContent = c.detail;
                        el.appendChild(det);
                    }
                    el.style.display = 'flex';
                    el.style.alignItems = 'center';
                }
            };
        });

        return {
            list: list,
            from: CodeMirror.Pos(cur.line, start),
            to: CodeMirror.Pos(cur.line, end)
        };
    }

    // ── Render reference panel ──
    function renderRefPanel() {
        var body = document.getElementById('refPanelBody');
        if (!body) return;
        body.innerHTML = '';

        var settings = (schemaState && schemaState.settings) || [];
        var blocks = (schemaState && schemaState.blocks) || [];

        function makeSection(title, items, open) {
            var sec = document.createElement('div');
            sec.className = 'ref-section';
            var hdr = document.createElement('div');
            hdr.className = 'ref-section-title';
            hdr.innerHTML = title + ' <span style="font-size:10px;">' + (open ? '&#9660;' : '&#9654;') + '</span>';
            var bd = document.createElement('div');
            bd.className = 'ref-section-body';
            bd.style.display = open ? 'block' : 'none';
            hdr.addEventListener('click', function() {
                var showing = bd.style.display !== 'none';
                bd.style.display = showing ? 'none' : 'block';
                hdr.querySelector('span').innerHTML = showing ? '&#9654;' : '&#9660;';
            });
            items.forEach(function(item) {
                var row = document.createElement('div');
                row.className = 'ref-item';
                row.title = item.detail || '';
                if (item.badge) {
                    var b = document.createElement('span');
                    b.className = 'ref-item-badge';
                    b.style.cssText = item.badgeStyle || 'background:#6272a4;color:#fff;';
                    b.textContent = item.badge;
                    row.appendChild(b);
                }
                var code = document.createElement('code');
                code.textContent = item.text;
                row.appendChild(code);
                // Click to insert
                row.addEventListener('click', function() {
                    if (cmContent) {
                        var cur = cmContent.getCursor();
                        cmContent.replaceRange(item.insert || item.text, cur);
                        cmContent.focus();
                    }
                });
                bd.appendChild(row);
            });
            sec.appendChild(hdr);
            sec.appendChild(bd);
            body.appendChild(sec);
        }

        // Section settings
        if (settings.length) {
            makeSection('Settings (' + settings.length + ')', settings.map(function(s) {
                return {
                    text: s.id || '?',
                    badge: s.type,
                    badgeStyle: s.type === 'collection' ? 'background:#50fa7b;color:#282a36;' : 'background:#6272a4;color:#fff;',
                    detail: s.label || '',
                    insert: 'section.settings.' + (s.id || '')
                };
            }), true);
        }

        // Block settings
        if (blocks.length) {
            var blockItems = [];
            blocks.forEach(function(b) {
                blockItems.push({ text: b.type || '?', badge: 'block', badgeStyle: 'background:#ff79c6;color:#282a36;', detail: b.name || '', insert: 'block.type' });
                (b.settings || []).forEach(function(bs) {
                    blockItems.push({ text: bs.id || '?', badge: bs.type, badgeStyle: 'background:#bd93f9;color:#282a36;', detail: (b.name || b.type) + '.' + (bs.label || bs.id), insert: 'block.settings.' + (bs.id || '') });
                });
            });
            makeSection('Blocks (' + blocks.length + ')', blockItems, false);
        }

        // Collection patterns
        var collSettings = settings.filter(function(s) { return s.type === 'collection'; });
        if (collSettings.length) {
            var patterns = [];
            collSettings.forEach(function(cs) {
                patterns.push({ text: 'Load ' + (cs.label || cs.id), badge: 'snippet', badgeStyle: 'background:#50fa7b;color:#282a36;', detail: 'Fetch entries', insert: '{' + '% set items = collection(section.settings.' + cs.id + ', {per_page: 6}) %' + '}\n{' + '% for item in items.data %' + '}\n    <div>{' + '{ attribute(item, "title") }' + '}</div>\n{' + '% endfor %' + '}' });
            });
            makeSection('Collection Snippets', patterns, true);
        }

        // Functions reference
        makeSection('Functions', [
            { text: 'collection(slug, opts)', badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Fetch collection entries', insert: 'collection(section.settings.collection, {per_page: 6})' },
            { text: 'entry(slug, id)', badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Fetch single entry', insert: 'entry("posts", "my-slug")' },
            { text: 'attribute(obj, key)', badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'Dynamic property access', insert: 'attribute(item, field_name)' },
            { text: 'config(key, default)', badge: 'fn', badgeStyle: 'background:#bd93f9;color:#282a36;', detail: 'App config value', insert: 'config(\'app.name\', \'ZephyrPHP\')' },
        ], false);

        // Common patterns
        makeSection('Common Patterns', [
            { text: 'If setting exists', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Conditional setting', insert: '{' + '% if section.settings.heading %' + '}\n    {' + '{ section.settings.heading }' + '}\n{' + '% endif %' + '}' },
            { text: 'For each block', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Loop blocks', insert: '{' + '% for block in section.blocks %' + '}\n    <div>{' + '{ block.settings.title }' + '}</div>\n{' + '% endfor %' + '}' },
            { text: 'Default value', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Setting with fallback', insert: 'section.settings.color|default(\'#333\')' },
            { text: 'Style binding', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Inline CSS from setting', insert: 'style="color:{' + '{ section.settings.text_color|default(\'#333\') }' + '}; padding:{' + '{ section.settings.padding|default(40) }' + '}px 0;"' },
            { text: 'Collection grid', badge: 'pattern', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Full collection grid', insert: '{' + '% if section.settings.collection %' + '}\n    {' + '% set items = collection(section.settings.collection, {per_page: section.settings.items_count|default(6)}) %' + '}\n    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:24px;">\n        {' + '% for item in items.data %' + '}\n            <div style="padding:16px;border:1px solid #eee;border-radius:8px;">\n                <h3>{' + '{ attribute(item, section.settings.title_field|default(\'title\')) }' + '}</h3>\n            </div>\n        {' + '% endfor %' + '}\n    </div>\n{' + '% endif %' + '}' },
        ], false);

        // Filters
        makeSection('Filters', [
            { text: 'raw', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Unescaped HTML output', insert: '|raw' },
            { text: 'default(val)', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Fallback value', insert: '|default(\'\')' },
            { text: 'striptags', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Remove HTML tags', insert: '|striptags' },
            { text: 'slice(0, n)', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Substring/limit text', insert: '|slice(0, 120)' },
            { text: 'date("Y-m-d")', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Format date', insert: '|date("Y-m-d")' },
            { text: 'length', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'String/array length', insert: '|length' },
            { text: 'upper / lower', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Case transform', insert: '|upper' },
            { text: 'nl2br', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Newlines to BR tags', insert: '|nl2br' },
            { text: 'json_encode', badge: 'filter', badgeStyle: 'background:#ffb86c;color:#282a36;', detail: 'Convert to JSON', insert: '|json_encode' },
        ], false);
    }

    // ── Init designer (create 3 CodeMirror instances) ──
    function initDesigner() {
        if (designerInitialized) return;
        designerInitialized = true;

        cmContent = CodeMirror.fromTextArea(document.getElementById('designerContentEditor'), {
            mode: 'htmlmixed', theme: 'dracula', lineNumbers: true, indentUnit: 4, tabSize: 4, lineWrapping: true,
            extraKeys: { 'Ctrl-Space': 'autocomplete' },
            hintOptions: { hint: twigSectionHint, completeSingle: false }
        });
        cmStyle = CodeMirror.fromTextArea(document.getElementById('designerStyleEditor'), {
            mode: 'css', theme: 'dracula', lineNumbers: true, indentUnit: 4, tabSize: 4, lineWrapping: true
        });
        cmJs = CodeMirror.fromTextArea(document.getElementById('designerJsEditor'), {
            mode: 'javascript', theme: 'dracula', lineNumbers: true, indentUnit: 4, tabSize: 4, lineWrapping: true
        });

        // Auto-trigger hints on typing in content editor
        cmContent.on('inputRead', function(cm, change) {
            if (change.origin !== '+input') return;
            var cur = cm.getCursor();
            var line = cm.getLine(cur.line);
            var before = line.slice(0, cur.ch);
            // Trigger after print/tag openers, section., .settings., pipes, function calls
            var triggerRe = new RegExp('(\\{' + '\\{|\\{' + '%)\\s*\\w*$');
            if (triggerRe.test(before) || /section\.\w*$/.test(before) || /\.settings\.\w*$/.test(before) || /\|\s*\w+$/.test(before) || /collection\(/.test(before) || /attribute\(/.test(before)) {
                cm.showHint({ hint: twigSectionHint, completeSingle: false });
            }
        });

        // Ctrl+S in designer editors
        [cmContent, cmStyle, cmJs].forEach(function(cm) {
            cm.on('keydown', function(inst, e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 's') {
                    e.preventDefault();
                    document.getElementById('saveFileBtn').click();
                }
            });
        });

        // Reference panel toggle
        var refVisible = true;
        var refBtn = document.getElementById('refToggleBtn');
        if (refBtn) refBtn.classList.add('active');
        refBtn?.addEventListener('click', function() {
            refVisible = !refVisible;
            var panel = document.getElementById('refPanel');
            if (refVisible) { panel.classList.remove('hidden'); this.classList.add('active'); }
            else { panel.classList.add('hidden'); this.classList.remove('active'); }
            setTimeout(function() { if (cmContent) cmContent.refresh(); }, 50);
        });

        // Schema info listeners
        ['schemaName', 'schemaDescription', 'schemaIcon'].forEach(function(id) {
            document.getElementById(id).addEventListener('input', function() {
                updateJsonPreview();
            });
        });
        document.getElementById('schemaCollection').addEventListener('change', function() {
            if (this.value) {
                schemaState.collection = this.value;
            } else {
                delete schemaState.collection;
            }
            updateJsonPreview();
        });

        // Add setting
        document.getElementById('addSettingBtn').addEventListener('click', function() {
            if (!schemaState.settings) schemaState.settings = [];
            schemaState.settings.push({ type: 'text', id: '', label: '' });
            renderSettingsList(schemaState.settings, document.getElementById('settingsList'));
            updateJsonPreview();
            // Open the last card
            var cards = document.getElementById('settingsList').querySelectorAll('.setting-card-body');
            if (cards.length) cards[cards.length - 1].classList.add('open');
        });

        // Add block type
        document.getElementById('addBlockTypeBtn').addEventListener('click', function() {
            if (!schemaState.blocks) schemaState.blocks = [];
            schemaState.blocks.push({ type: '', name: '', settings: [] });
            renderBlockTypes();
            updateJsonPreview();
        });

        // Add preset
        document.getElementById('addPresetBtn').addEventListener('click', function() {
            if (!schemaState.presets) schemaState.presets = [];
            schemaState.presets.push({ name: 'Default', settings: {} });
            renderPresets();
            updateJsonPreview();
        });

        // JSON preview toggle
        document.getElementById('jsonPreviewToggle').addEventListener('click', function() {
            this.classList.toggle('open');
            var body = document.getElementById('jsonPreviewBody');
            body.style.display = body.style.display === 'none' ? 'block' : 'none';
        });

        // Designer tab switching
        document.querySelectorAll('.designer-tab').forEach(function(tab) {
            tab.addEventListener('click', function() {
                document.querySelectorAll('.designer-tab').forEach(function(t) { t.classList.remove('active'); });
                document.querySelectorAll('.designer-panel, .designer-panel-split').forEach(function(p) { p.classList.remove('active'); });
                tab.classList.add('active');
                document.getElementById(tab.dataset.dtab).classList.add('active');
                if (tab.dataset.dtab === 'dtab-content') setTimeout(function() { cmContent.refresh(); }, 10);
                if (tab.dataset.dtab === 'dtab-style') setTimeout(function() { cmStyle.refresh(); }, 10);
                if (tab.dataset.dtab === 'dtab-js') setTimeout(function() { cmJs.refresh(); }, 10);
            });
        });
    }

    // ── Switch to Designer mode ──
    function switchToDesigner() {
        initDesigner();
        var parsed = parseSectionFile(editor.getValue());
        cmContent.setValue(parsed.content);
        cmStyle.setValue(parsed.style);
        cmJs.setValue(parsed.js);
        schemaState = parsed.schema;
        if (!schemaState.settings) schemaState.settings = [];
        if (!schemaState.blocks) schemaState.blocks = [];
        if (!schemaState.presets) schemaState.presets = [];

        renderSchemaBuilder();
        updateJsonPreview();
        renderRefPanel();

        document.getElementById('sourceEditorPane').style.display = 'none';
        var dp = document.getElementById('designerPane');
        dp.style.display = 'flex';
        dp.style.flexDirection = 'column';
        dp.style.flex = '1';
        designerMode = true;

        document.getElementById('btnDesigner').classList.add('active');
        document.getElementById('btnSource').classList.remove('active');

        setTimeout(function() { cmContent.refresh(); }, 50);
    }

    // ── Switch to Source mode ──
    function switchToSource() {
        var combined = recombineSectionFile(
            cmContent.getValue(),
            cmStyle.getValue(),
            cmJs.getValue(),
            buildSchemaFromState()
        );
        editor.setValue(combined);
        document.getElementById('sourceEditorPane').style.display = '';
        document.getElementById('designerPane').style.display = 'none';
        designerMode = false;

        document.getElementById('btnSource').classList.add('active');
        document.getElementById('btnDesigner').classList.remove('active');

        setTimeout(function() { editor.refresh(); }, 50);
    }

    // Toggle button clicks
    document.getElementById('btnDesigner')?.addEventListener('click', function() {
        if (!designerMode) switchToDesigner();
    });
    document.getElementById('btnSource')?.addEventListener('click', function() {
        if (designerMode) switchToSource();
    });

    // ── Render schema builder ──
    function renderSchemaBuilder() {
        document.getElementById('schemaName').value = schemaState.name || '';
        document.getElementById('schemaDescription').value = schemaState.description || '';
        document.getElementById('schemaIcon').value = schemaState.icon || '';
        document.getElementById('schemaCollection').value = schemaState.collection || '';
        renderSettingsList(schemaState.settings, document.getElementById('settingsList'));
        renderBlockTypes();
        renderPresets();
    }

    // ════════════════════════════════════════════
    //  SETTINGS LIST RENDERING
    // ════════════════════════════════════════════
    function renderSettingsList(settings, container) {
        container.innerHTML = '';
        for (var i = 0; i < settings.length; i++) {
            (function(index) {
                var setting = settings[index];
                var card = document.createElement('div');
                card.className = 'setting-card';

                var header = document.createElement('div');
                header.className = 'setting-card-header';
                header.innerHTML =
                    '<span class="drag-handle" title="Drag to reorder">&#8942;&#8942;</span>' +
                    '<span class="type-badge">' + esc(setting.type || 'text') + '</span>' +
                    '<span class="setting-id">' + esc(setting.id || '') + '</span>' +
                    '<span class="setting-label-text">' + esc(setting.label || 'Untitled') + '</span>' +
                    '<button class="delete-btn" title="Remove">&times;</button>';

                var bodyWrap = document.createElement('div');
                bodyWrap.className = 'setting-card-body';

                renderSettingBody(bodyWrap, setting, index, settings, container);

                header.addEventListener('click', function(e) {
                    if (e.target.closest('.delete-btn')) {
                        e.stopPropagation();
                        settings.splice(index, 1);
                        renderSettingsList(settings, container);
                        updateJsonPreview();
                        return;
                    }
                    bodyWrap.classList.toggle('open');
                });

                card.appendChild(header);
                card.appendChild(bodyWrap);
                container.appendChild(card);
            })(i);
        }

        // Sortable
        if (container._sortable) container._sortable.destroy();
        if (typeof Sortable !== 'undefined' && settings.length > 1) {
            container._sortable = new Sortable(container, {
                handle: '.drag-handle',
                animation: 150,
                ghostClass: 'sortable-ghost',
                onEnd: function(evt) {
                    var item = settings.splice(evt.oldIndex, 1)[0];
                    settings.splice(evt.newIndex, 0, item);
                    renderSettingsList(settings, container);
                    updateJsonPreview();
                }
            });
        }
    }

    // ── Render setting body (fields) ──
    function renderSettingBody(bodyEl, setting, index, settingsArray, container) {
        bodyEl.innerHTML = '';

        // Row 1: Type + ID
        var row1 = document.createElement('div');
        row1.className = 'form-row';

        var typeField = makeField('Type');
        var typeSelect = document.createElement('select');
        typeSelect.className = 'form-control';
        SETTING_TYPES.forEach(function(t) {
            var opt = document.createElement('option');
            opt.value = t; opt.textContent = t;
            if (t === (setting.type || 'text')) opt.selected = true;
            typeSelect.appendChild(opt);
        });
        typeSelect.addEventListener('change', function() {
            setting.type = this.value;
            // Clean type-specific props
            if (setting.type !== 'range') { delete setting.min; delete setting.max; delete setting.step; }
            if (setting.type !== 'select' && setting.type !== 'layout_select') { delete setting.options; }
            if (setting.type !== 'field_select') { delete setting.collection_setting; }
            renderSettingBody(bodyEl, setting, index, settingsArray, container);
            bodyEl.classList.add('open');
            bodyEl.parentElement.querySelector('.type-badge').textContent = setting.type;
            updateJsonPreview();
        });
        typeField.appendChild(typeSelect);

        var idField = makeField('ID');
        var idInput = document.createElement('input');
        idInput.type = 'text'; idInput.className = 'form-control';
        idInput.value = setting.id || ''; idInput.placeholder = 'auto-generated';
        idInput.addEventListener('input', function() {
            setting.id = this.value;
            bodyEl.parentElement.querySelector('.setting-id').textContent = this.value;
            updateJsonPreview();
        });
        idField.appendChild(idInput);

        row1.appendChild(typeField);
        row1.appendChild(idField);
        bodyEl.appendChild(row1);

        // Row 2: Label + Group
        var row2 = document.createElement('div');
        row2.className = 'form-row';

        var labelField = makeField('Label');
        var labelInput = document.createElement('input');
        labelInput.type = 'text'; labelInput.className = 'form-control';
        labelInput.value = setting.label || '';
        labelInput.addEventListener('input', function() {
            setting.label = this.value;
            bodyEl.parentElement.querySelector('.setting-label-text').textContent = this.value || 'Untitled';
            // Auto-generate ID if empty
            if (!setting.id) {
                setting.id = autoSlug(this.value);
                idInput.value = setting.id;
                bodyEl.parentElement.querySelector('.setting-id').textContent = setting.id;
            }
            updateJsonPreview();
        });
        labelField.appendChild(labelInput);

        var groupField = makeField('Group');
        var groupInput = document.createElement('input');
        groupInput.type = 'text'; groupInput.className = 'form-control';
        groupInput.value = setting.group || ''; groupInput.placeholder = 'e.g. Content, Colors';
        groupInput.addEventListener('input', function() {
            if (this.value) { setting.group = this.value; }
            else { delete setting.group; }
            updateJsonPreview();
        });
        groupField.appendChild(groupInput);

        row2.appendChild(labelField);
        row2.appendChild(groupField);
        bodyEl.appendChild(row2);

        // Row 3: Default value (varies by type)
        var type = setting.type || 'text';
        var defRow = document.createElement('div');
        defRow.className = 'form-row';

        if (type === 'color') {
            var defField = makeField('Default');
            var colorWrap = document.createElement('div');
            colorWrap.style.cssText = 'display:flex;gap:6px;';
            var cInput = document.createElement('input');
            cInput.type = 'color'; cInput.value = setting.default || '#ffffff';
            cInput.style.cssText = 'width:36px;height:32px;padding:2px;border:1px solid #E3E3E3;border-radius:4px;cursor:pointer;';
            var hInput = document.createElement('input');
            hInput.type = 'text'; hInput.className = 'form-control';
            hInput.value = setting.default || '#ffffff'; hInput.style.flex = '1';
            cInput.addEventListener('input', function() { hInput.value = this.value; setting.default = this.value; updateJsonPreview(); });
            hInput.addEventListener('input', function() { if (/^#[0-9a-fA-F]{3,8}$/.test(this.value)) cInput.value = this.value; setting.default = this.value; updateJsonPreview(); });
            colorWrap.appendChild(cInput); colorWrap.appendChild(hInput);
            defField.appendChild(colorWrap);
            defRow.appendChild(defField);
        } else if (type === 'checkbox') {
            var defField = makeField('Default');
            var chkLabel = document.createElement('label');
            chkLabel.style.cssText = 'display:flex;align-items:center;gap:6px;font-weight:normal;cursor:pointer;';
            var chk = document.createElement('input');
            chk.type = 'checkbox'; chk.checked = !!setting.default;
            chk.addEventListener('change', function() { setting.default = this.checked; updateJsonPreview(); });
            chkLabel.appendChild(chk);
            chkLabel.appendChild(document.createTextNode('Checked by default'));
            defField.appendChild(chkLabel);
            defRow.appendChild(defField);
        } else if (type === 'range' || type === 'number') {
            var defField = makeField('Default');
            var numInput = document.createElement('input');
            numInput.type = 'number'; numInput.className = 'form-control';
            numInput.value = setting.default !== undefined ? setting.default : '';
            numInput.addEventListener('input', function() {
                setting.default = this.value !== '' ? parseFloat(this.value) : undefined;
                if (setting.default === undefined) delete setting.default;
                updateJsonPreview();
            });
            defField.appendChild(numInput);
            defRow.appendChild(defField);
        } else if (type === 'collection') {
            var defField = makeField('Default Collection');
            var colSel = document.createElement('select');
            colSel.className = 'form-control';
            var emptyOpt = document.createElement('option');
            emptyOpt.value = ''; emptyOpt.textContent = '— Select collection —';
            colSel.appendChild(emptyOpt);
            var _availableCollections = {{ collections|json_encode|raw }};
            (_availableCollections || []).forEach(function(col) {
                var opt = document.createElement('option');
                opt.value = col.slug; opt.textContent = col.name + ' (' + col.slug + ')';
                if (col.slug === (setting.default || '')) opt.selected = true;
                colSel.appendChild(opt);
            });
            colSel.addEventListener('change', function() {
                if (this.value) { setting.default = this.value; }
                else { delete setting.default; }
                updateJsonPreview();
            });
            defField.appendChild(colSel);
            defRow.appendChild(defField);
        } else {
            var defField = makeField('Default');
            var txtInput = document.createElement('input');
            txtInput.type = 'text'; txtInput.className = 'form-control';
            txtInput.value = setting.default !== undefined ? String(setting.default) : '';
            txtInput.addEventListener('input', function() {
                if (this.value) { setting.default = this.value; }
                else { delete setting.default; }
                updateJsonPreview();
            });
            defField.appendChild(txtInput);
            defRow.appendChild(defField);
        }
        bodyEl.appendChild(defRow);

        // Type-specific fields
        if (type === 'range') {
            var rangeRow = document.createElement('div');
            rangeRow.className = 'form-row';
            ['min', 'max', 'step'].forEach(function(prop) {
                var f = makeField(prop.charAt(0).toUpperCase() + prop.slice(1));
                var inp = document.createElement('input');
                inp.type = 'number'; inp.className = 'form-control';
                inp.value = setting[prop] !== undefined ? setting[prop] : '';
                inp.addEventListener('input', function() {
                    if (this.value !== '') { setting[prop] = parseFloat(this.value); }
                    else { delete setting[prop]; }
                    updateJsonPreview();
                });
                f.appendChild(inp);
                rangeRow.appendChild(f);
            });
            bodyEl.appendChild(rangeRow);
        }

        if (type === 'number') {
            var numRow = document.createElement('div');
            numRow.className = 'form-row';
            ['min', 'max'].forEach(function(prop) {
                var f = makeField(prop.charAt(0).toUpperCase() + prop.slice(1));
                var inp = document.createElement('input');
                inp.type = 'number'; inp.className = 'form-control';
                inp.value = setting[prop] !== undefined ? setting[prop] : '';
                inp.addEventListener('input', function() {
                    if (this.value !== '') { setting[prop] = parseFloat(this.value); }
                    else { delete setting[prop]; }
                    updateJsonPreview();
                });
                f.appendChild(inp);
                numRow.appendChild(f);
            });
            bodyEl.appendChild(numRow);
        }

        if (type === 'select' || type === 'layout_select') {
            renderOptionsEditor(bodyEl, setting);
        }

        if (type === 'field_select') {
            renderCollectionSettingPicker(bodyEl, setting, settingsArray);
        }

        if (type === 'collection') {
            var note = document.createElement('div');
            note.className = 'schema-field';
            note.innerHTML = '<small style="color:var(--text-secondary,#616161);">Adds a collection picker in the customizer. <strong>Tip:</strong> Use the top-level <em>Collection</em> dropdown in Section Info instead to auto-load data into <code>section.collection_data</code>.</small>';
            bodyEl.appendChild(note);
        }
    }

    // ── Helper: create field wrapper ──
    function makeField(label) {
        var f = document.createElement('div');
        f.className = 'schema-field';
        var lbl = document.createElement('label');
        lbl.textContent = label;
        f.appendChild(lbl);
        return f;
    }

    // ── Options editor for select/layout_select ──
    function renderOptionsEditor(bodyEl, setting) {
        if (!setting.options) setting.options = [];
        var wrap = document.createElement('div');
        wrap.className = 'schema-field';
        var lbl = document.createElement('label');
        lbl.textContent = 'Options';
        wrap.appendChild(lbl);

        var list = document.createElement('div');

        function renderOpts() {
            list.innerHTML = '';
            setting.options.forEach(function(opt, oi) {
                var row = document.createElement('div');
                row.className = 'option-row';
                var valInput = document.createElement('input');
                valInput.type = 'text'; valInput.placeholder = 'value'; valInput.value = opt.value || '';
                valInput.addEventListener('input', function() { opt.value = this.value; updateJsonPreview(); });
                var lblInput = document.createElement('input');
                lblInput.type = 'text'; lblInput.placeholder = 'label'; lblInput.value = opt.label || '';
                lblInput.addEventListener('input', function() { opt.label = this.value; updateJsonPreview(); });
                var removeBtn = document.createElement('button');
                removeBtn.className = 'delete-btn'; removeBtn.innerHTML = '&times;'; removeBtn.title = 'Remove';
                removeBtn.addEventListener('click', function() {
                    setting.options.splice(oi, 1);
                    renderOpts();
                    updateJsonPreview();
                });
                row.appendChild(valInput);
                row.appendChild(lblInput);
                row.appendChild(removeBtn);
                list.appendChild(row);
            });
        }
        renderOpts();

        var addBtn = document.createElement('button');
        addBtn.className = 'add-option-btn';
        addBtn.textContent = '+ Add Option';
        addBtn.addEventListener('click', function() {
            setting.options.push({ value: '', label: '' });
            renderOpts();
            updateJsonPreview();
        });

        wrap.appendChild(list);
        wrap.appendChild(addBtn);
        bodyEl.appendChild(wrap);
    }

    // ── Collection setting picker for field_select ──
    function renderCollectionSettingPicker(bodyEl, setting, allSettings) {
        var wrap = makeField('Collection Setting');
        var sel = document.createElement('select');
        sel.className = 'form-control';
        var emptyOpt = document.createElement('option');
        emptyOpt.value = ''; emptyOpt.textContent = '-- Select --';
        sel.appendChild(emptyOpt);

        // Find all settings of type "collection" in current schema
        (allSettings || []).forEach(function(s) {
            if (s.type === 'collection' && s.id) {
                var opt = document.createElement('option');
                opt.value = s.id; opt.textContent = s.id + (s.label ? ' (' + s.label + ')' : '');
                if (s.id === setting.collection_setting) opt.selected = true;
                sel.appendChild(opt);
            }
        });
        sel.addEventListener('change', function() {
            if (this.value) { setting.collection_setting = this.value; }
            else { delete setting.collection_setting; }
            updateJsonPreview();
        });
        wrap.appendChild(sel);
        bodyEl.appendChild(wrap);
    }

    // ════════════════════════════════════════════
    //  BLOCK TYPES RENDERING
    // ════════════════════════════════════════════
    function renderBlockTypes() {
        var container = document.getElementById('blockTypesList');
        container.innerHTML = '';
        if (!schemaState.blocks) return;

        schemaState.blocks.forEach(function(block, bi) {
            var card = document.createElement('div');
            card.className = 'block-type-card';

            var header = document.createElement('div');
            header.className = 'block-type-header';
            header.innerHTML =
                '<span class="type-badge">block</span>' +
                '<span class="block-type-name">' + esc(block.name || block.type || 'Untitled') + '</span>' +
                '<button class="delete-btn" title="Remove">&times;</button>';

            var body = document.createElement('div');
            body.className = 'block-type-body';

            // Type slug
            var row1 = document.createElement('div');
            row1.className = 'form-row';
            var typeField = makeField('Type (slug)');
            var typeInput = document.createElement('input');
            typeInput.type = 'text'; typeInput.className = 'form-control'; typeInput.value = block.type || '';
            typeInput.addEventListener('input', function() { block.type = this.value; updateJsonPreview(); });
            typeField.appendChild(typeInput);

            var nameField = makeField('Name');
            var nameInput = document.createElement('input');
            nameInput.type = 'text'; nameInput.className = 'form-control'; nameInput.value = block.name || '';
            nameInput.addEventListener('input', function() {
                block.name = this.value;
                header.querySelector('.block-type-name').textContent = this.value || 'Untitled';
                updateJsonPreview();
            });
            nameField.appendChild(nameInput);

            row1.appendChild(typeField);
            row1.appendChild(nameField);
            body.appendChild(row1);

            // Block settings
            if (!block.settings) block.settings = [];
            var settingsWrap = document.createElement('div');
            settingsWrap.className = 'block-settings-wrap';
            var settingsHeader = document.createElement('div');
            settingsHeader.style.cssText = 'display:flex;justify-content:space-between;align-items:center;margin-bottom:8px;';
            settingsHeader.innerHTML = '<h5 style="margin:0;">Settings</h5>';
            var addBlockSettingBtn = document.createElement('button');
            addBlockSettingBtn.className = 'btn btn-xs btn-primary';
            addBlockSettingBtn.textContent = '+ Add';
            addBlockSettingBtn.addEventListener('click', function() {
                block.settings.push({ type: 'text', id: '', label: '' });
                renderSettingsList(block.settings, blockSettingsList);
                updateJsonPreview();
                var cards = blockSettingsList.querySelectorAll('.setting-card-body');
                if (cards.length) cards[cards.length - 1].classList.add('open');
            });
            settingsHeader.appendChild(addBlockSettingBtn);
            settingsWrap.appendChild(settingsHeader);

            var blockSettingsList = document.createElement('div');
            renderSettingsList(block.settings, blockSettingsList);
            settingsWrap.appendChild(blockSettingsList);
            body.appendChild(settingsWrap);

            header.addEventListener('click', function(e) {
                if (e.target.closest('.delete-btn')) {
                    e.stopPropagation();
                    schemaState.blocks.splice(bi, 1);
                    renderBlockTypes();
                    updateJsonPreview();
                    return;
                }
                body.classList.toggle('open');
            });

            card.appendChild(header);
            card.appendChild(body);
            container.appendChild(card);
        });
    }

    // ════════════════════════════════════════════
    //  PRESETS RENDERING
    // ════════════════════════════════════════════
    function renderPresets() {
        var container = document.getElementById('presetsList');
        container.innerHTML = '';
        if (!schemaState.presets) return;

        schemaState.presets.forEach(function(preset, pi) {
            var card = document.createElement('div');
            card.className = 'preset-card';

            var header = document.createElement('div');
            header.className = 'preset-header';
            header.innerHTML =
                '<span class="preset-name">' + esc(preset.name || 'Untitled') + '</span>' +
                '<button class="delete-btn" title="Remove">&times;</button>';

            var body = document.createElement('div');
            body.className = 'preset-body';

            var nameField = makeField('Preset Name');
            var nameInput = document.createElement('input');
            nameInput.type = 'text'; nameInput.className = 'form-control'; nameInput.value = preset.name || '';
            nameInput.addEventListener('input', function() {
                preset.name = this.value;
                header.querySelector('.preset-name').textContent = this.value || 'Untitled';
                updateJsonPreview();
            });
            nameField.appendChild(nameInput);
            body.appendChild(nameField);

            var settingsField = makeField('Default Settings (JSON)');
            var ta = document.createElement('textarea');
            ta.value = JSON.stringify(preset.settings || {}, null, 2);
            ta.addEventListener('change', function() {
                try { preset.settings = JSON.parse(this.value); }
                catch(e) { /* keep old */ }
                updateJsonPreview();
            });
            settingsField.appendChild(ta);
            body.appendChild(settingsField);

            header.addEventListener('click', function(e) {
                if (e.target.closest('.delete-btn')) {
                    e.stopPropagation();
                    schemaState.presets.splice(pi, 1);
                    renderPresets();
                    updateJsonPreview();
                    return;
                }
                body.classList.toggle('open');
            });

            card.appendChild(header);
            card.appendChild(body);
            container.appendChild(card);
        });
    }

