{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Theme: {{ theme.getName() }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/themes">Themes</a> / {{ theme.getName() }}
</div>

<div class="page-header">
    <h1>
        {{ theme.getName() }}
        {% if theme.isLive() %}
            <span class="badge badge-success">Live</span>
        {% else %}
            <span class="badge badge-draft">Draft</span>
        {% endif %}
    </h1>
    <div class="page-actions">
        {% if not theme.isLive() %}
            <a href="/cms/themes/{{ theme.getSlug() }}/preview" class="btn btn-sm btn-outline">Preview</a>
            <form method="POST" action="/cms/themes/{{ theme.getSlug() }}/publish" style="display:inline">
                {{ csrf_field() | raw }}
                <button type="submit" class="btn btn-sm btn-primary">Publish</button>
            </form>
        {% endif %}
    </div>
</div>

<div class="card">
    <div class="tab-nav">
        <button class="tab-btn active" data-tab="tab-settings">Settings</button>
        <button class="tab-btn" data-tab="tab-pages">Pages</button>
        <button class="tab-btn" data-tab="tab-editor">File Editor</button>
    </div>

    {# Settings Tab #}
    <div class="tab-panel active" id="tab-settings">
        <form method="POST" action="/cms/themes/{{ theme.getSlug() }}">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="name">Theme Name *</label>
                <input type="text" id="name" name="name" class="form-control" required
                       value="{{ theme.getName() }}">
            </div>

            <div class="form-group">
                <label>Slug</label>
                <input type="text" class="form-control" value="{{ theme.getSlug() }}" disabled>
                <small class="text-muted">Cannot be changed after creation.</small>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="form-control" rows="3">{{ theme.getDescription() ?? '' }}</textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Settings</button>
            </div>
        </form>
    </div>

    {# Pages Tab #}
    <div class="tab-panel" id="tab-pages">
        <div class="pages-header">
            <p class="text-muted">Manage pages that belong to this theme. Each page has a URL, template, and layout.</p>
            <button class="btn btn-primary btn-sm" id="addPageBtn">Add Page</button>
        </div>

        <table class="data-table" id="pagesTable">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>URL</th>
                    <th>Template</th>
                    <th>Layout</th>
                    <th style="width:180px">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for page in pages %}
                <tr data-template="{{ page.template }}">
                    <td>{{ page.title }}</td>
                    <td><code>{{ page.slug }}</code></td>
                    <td><code>{{ page.template }}.twig</code></td>
                    <td>{{ page.layout ?? 'base' }}</td>
                    <td>
                        <a href="/cms/themes/{{ theme.getSlug() }}?file=templates/{{ page.template }}.twig" class="btn btn-xs btn-outline">Edit Content</a>
                        <button class="btn btn-xs btn-outline edit-page-btn"
                            data-template="{{ page.template }}"
                            data-title="{{ page.title }}"
                            data-slug="{{ page.slug }}"
                            data-layout="{{ page.layout ?? 'base' }}">Settings</button>
                        <button class="btn btn-xs btn-danger delete-page-btn" data-template="{{ page.template }}" data-title="{{ page.title }}">Delete</button>
                    </td>
                </tr>
                {% else %}
                <tr class="empty-row">
                    <td colspan="5" class="text-center text-muted" style="padding:40px">No pages yet. Click "Add Page" to create one.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {# Add Page Modal #}
        <div class="modal-overlay" id="addPageModal" style="display:none">
            <div class="modal-card">
                <div class="modal-header">
                    <h3 id="pageModalTitle">Add New Page</h3>
                    <button class="modal-close" id="closePageModal">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="pageEditTemplate" value="">
                    <div class="form-group">
                        <label for="pageTitle">Page Title *</label>
                        <input type="text" id="pageTitle" class="form-control" placeholder="About Us">
                    </div>
                    <div class="form-group">
                        <label for="pageSlug">URL Path *</label>
                        <input type="text" id="pageSlug" class="form-control" placeholder="/about">
                        <small class="text-muted">The URL where this page will be accessible.</small>
                    </div>
                    <div class="form-group">
                        <label for="pageLayout">Layout</label>
                        <select id="pageLayout" class="form-control">
                            {% for layout in layouts %}
                            <option value="{{ layout }}">{{ layout|capitalize }}</option>
                            {% endfor %}
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" id="cancelPageModal">Cancel</button>
                    <button class="btn btn-primary" id="savePageBtn">Create Page</button>
                </div>
            </div>
        </div>
    </div>

    {# File Editor Tab #}
    <div class="tab-panel" id="tab-editor">
        <div class="editor-layout">
            <div class="editor-sidebar">
                <h4>Files</h4>
                {% for folder, fileList in files %}
                <div class="file-folder">
                    <div class="folder-name">{{ folder }}/</div>
                    {% for file in fileList %}
                    <a href="#" class="file-item {% if activeFile == file %}active{% endif %}" data-file="{{ file }}">
                        {{ file|split('/')|last }}
                    </a>
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
            <div class="editor-main">
                <div class="editor-toolbar">
                    <span class="editor-file-name" id="editorFileName">{{ activeFile ?: 'Select a file to edit' }}</span>
                    <button class="btn btn-sm btn-primary" id="saveFileBtn" {% if not activeFile %}disabled{% endif %}>Save</button>
                </div>
                <textarea id="codeEditor" class="code-editor">{{ fileContent }}</textarea>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css">
<style nonce="{{ csp_nonce() }}">
.editor-layout {
    display: flex;
    min-height: 500px;
    border-top: 1px solid var(--border-default, #E3E3E3);
}
.editor-sidebar {
    width: 220px;
    border-right: 1px solid var(--border-default, #E3E3E3);
    padding: var(--space-300, 12px);
    overflow-y: auto;
}
.editor-sidebar h4 {
    margin: 0 0 var(--space-200, 8px) 0;
    font-size: var(--font-size-sm, 0.8125rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary, #616161);
}
.folder-name {
    font-weight: 600;
    font-size: var(--font-size-sm, 0.8125rem);
    padding: var(--space-100, 4px) 0;
    color: var(--text-primary, #303030);
}
.file-item {
    display: block;
    padding: var(--space-100, 4px) var(--space-200, 8px);
    margin-left: var(--space-200, 8px);
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--text-secondary, #616161);
    text-decoration: none;
    border-radius: var(--radius-100, 4px);
    transition: background 0.15s;
}
.file-item:hover {
    background: var(--bg-surface-hover, #F7F7F7);
    color: var(--text-primary, #303030);
}
.file-item.active {
    background: var(--color-primary, #008060);
    color: #fff;
}
.file-folder {
    margin-bottom: var(--space-300, 12px);
}
.editor-main {
    flex: 1;
    display: flex;
    flex-direction: column;
}
.editor-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-200, 8px) var(--space-300, 12px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
    background: var(--bg-subdued, #FAFAFA);
}
.editor-file-name {
    font-size: var(--font-size-sm, 0.8125rem);
    font-family: monospace;
    color: var(--text-secondary, #616161);
}
.CodeMirror {
    flex: 1;
    height: auto;
    font-size: 13px;
}
.code-editor {
    width: 100%;
    min-height: 450px;
    font-family: monospace;
    font-size: 13px;
    padding: var(--space-300, 12px);
    border: none;
    resize: none;
    background: #282a36;
    color: #f8f8f2;
}
.pages-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-400, 16px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.pages-header .text-muted {
    margin: 0;
}
.data-table {
    width: 100%;
    border-collapse: collapse;
}
.data-table th,
.data-table td {
    padding: var(--space-300, 12px) var(--space-400, 16px);
    text-align: left;
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.data-table th {
    font-size: var(--font-size-sm, 0.8125rem);
    font-weight: 600;
    color: var(--text-secondary, #616161);
    background: var(--bg-subdued, #FAFAFA);
}
.data-table td code {
    background: rgba(0,0,0,0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: var(--font-size-xs, 0.75rem);
}
.btn-xs {
    padding: 4px 8px;
    font-size: var(--font-size-xs, 0.75rem);
}
.btn-danger {
    background: #D72C0D;
    color: #fff;
    border: none;
}
.btn-danger:hover {
    background: #BC2200;
}
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}
.modal-card {
    background: #fff;
    border-radius: var(--radius-200, 8px);
    width: 480px;
    max-width: 90vw;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}
.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-400, 16px) var(--space-500, 20px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.modal-header h3 {
    margin: 0;
    font-size: 1rem;
}
.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-secondary, #616161);
    line-height: 1;
}
.modal-body {
    padding: var(--space-500, 20px);
}
.modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-200, 8px);
    padding: var(--space-400, 16px) var(--space-500, 20px);
    border-top: 1px solid var(--border-default, #E3E3E3);
}
.badge-success {
    background: rgba(4, 123, 93, 0.1);
    color: var(--color-success, #047B5D);
    border: 1px solid rgba(4, 123, 93, 0.2);
}
.badge-draft {
    background: rgba(255, 184, 0, 0.1);
    color: #b8860b;
    border: 1px solid rgba(255, 184, 0, 0.2);
}
</style>
{% endblock %}

{% block scripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/css/css.min.js"></script>
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    var textarea = document.getElementById('codeEditor');
    var editor = CodeMirror.fromTextArea(textarea, {
        mode: 'htmlmixed',
        theme: 'dracula',
        lineNumbers: true,
        indentUnit: 4,
        tabSize: 4,
        lineWrapping: true
    });

    var currentFile = '{{ activeFile }}';
    var themeSlug = '{{ theme.getSlug() }}';

    // File tree click
    document.querySelectorAll('.file-item').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var file = this.dataset.file;

            // Load file via AJAX (use GET with query param)
            fetch('/cms/themes/' + themeSlug + '?file=' + encodeURIComponent(file))
                .then(function(r) { return r.text(); })
                .then(function(html) {
                    // Extract file content from response — simpler: reload page
                    window.location.href = '/cms/themes/' + themeSlug + '?file=' + encodeURIComponent(file);
                });
        });
    });

    // Switch to editor tab if file is loaded
    if (currentFile) {
        document.querySelector('[data-tab="tab-editor"]').click();
    }

    // Save file
    document.getElementById('saveFileBtn').addEventListener('click', function() {
        if (!currentFile) return;

        var btn = this;
        btn.disabled = true;
        btn.textContent = 'Saving...';

        fetch('/cms/themes/' + themeSlug + '/file', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]')?.content || ''
            },
            body: JSON.stringify({
                file: currentFile,
                content: editor.getValue()
            })
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            btn.disabled = false;
            if (data.success) {
                btn.textContent = 'Saved!';
                setTimeout(function() { btn.textContent = 'Save'; }, 1500);
            } else {
                btn.textContent = 'Error';
                setTimeout(function() { btn.textContent = 'Save'; }, 2000);
            }
        })
        .catch(function() {
            btn.disabled = false;
            btn.textContent = 'Error';
            setTimeout(function() { btn.textContent = 'Save'; }, 2000);
        });
    });

    // Ctrl+S shortcut
    editor.on('keydown', function(cm, e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 's') {
            e.preventDefault();
            document.getElementById('saveFileBtn').click();
        }
    });

    // --- Pages Management ---
    var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

    function showModal(isEdit) {
        var modal = document.getElementById('addPageModal');
        modal.style.display = 'flex';
        document.getElementById('pageModalTitle').textContent = isEdit ? 'Edit Page Settings' : 'Add New Page';
        document.getElementById('savePageBtn').textContent = isEdit ? 'Save Changes' : 'Create Page';
    }

    function hideModal() {
        var modal = document.getElementById('addPageModal');
        modal.style.display = 'none';
        document.getElementById('pageTitle').value = '';
        document.getElementById('pageSlug').value = '';
        document.getElementById('pageLayout').value = 'base';
        document.getElementById('pageEditTemplate').value = '';
    }

    document.getElementById('addPageBtn')?.addEventListener('click', function() {
        showModal(false);
    });
    document.getElementById('closePageModal')?.addEventListener('click', hideModal);
    document.getElementById('cancelPageModal')?.addEventListener('click', hideModal);

    // Edit page settings
    document.querySelectorAll('.edit-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById('pageEditTemplate').value = this.dataset.template;
            document.getElementById('pageTitle').value = this.dataset.title;
            document.getElementById('pageSlug').value = this.dataset.slug;
            document.getElementById('pageLayout').value = this.dataset.layout;
            showModal(true);
        });
    });

    // Save page (add or update)
    document.getElementById('savePageBtn')?.addEventListener('click', function() {
        var btn = this;
        var editTemplate = document.getElementById('pageEditTemplate').value;
        var isEdit = !!editTemplate;
        var endpoint = isEdit ? '/cms/themes/' + themeSlug + '/pages/update' : '/cms/themes/' + themeSlug + '/pages/add';

        var payload = {
            title: document.getElementById('pageTitle').value,
            slug: document.getElementById('pageSlug').value,
            layout: document.getElementById('pageLayout').value
        };
        if (isEdit) {
            payload.template = editTemplate;
        }

        btn.disabled = true;
        btn.textContent = 'Saving...';

        fetch(endpoint, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
            body: JSON.stringify(payload)
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                window.location.reload();
            } else {
                alert(data.error || 'Failed to save page');
                btn.disabled = false;
                btn.textContent = isEdit ? 'Save Changes' : 'Create Page';
            }
        })
        .catch(function() {
            alert('Network error');
            btn.disabled = false;
            btn.textContent = isEdit ? 'Save Changes' : 'Create Page';
        });
    });

    // Delete page
    document.querySelectorAll('.delete-page-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var template = this.dataset.template;
            var title = this.dataset.title;
            if (!confirm('Delete page "' + title + '"? This will also delete the template file.')) return;

            fetch('/cms/themes/' + themeSlug + '/pages/delete', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken },
                body: JSON.stringify({ template: template })
            })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.success) {
                    window.location.reload();
                } else {
                    alert(data.error || 'Failed to delete page');
                }
            });
        });
    });

    // Auto-generate slug from title
    document.getElementById('pageTitle')?.addEventListener('input', function() {
        var editTemplate = document.getElementById('pageEditTemplate').value;
        if (editTemplate) return; // Don't auto-generate on edit
        var slug = '/' + this.value.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        document.getElementById('pageSlug').value = slug;
    });
});
</script>
{% endblock %}
