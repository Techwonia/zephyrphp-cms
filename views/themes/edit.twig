{% block scripts %}
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/htmlmixed/htmlmixed.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/xml/xml.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/javascript/javascript.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/css/css.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/clike/clike.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/mode/php/php.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.0/Sortable.min.js"></script>
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    var textarea = document.getElementById('codeEditor');
    var currentFile = '{{ activeFile }}';
    var isPhpFile = currentFile && currentFile.indexOf('.php') > 0;
    var isControllerFile = currentFile && currentFile.indexOf('controllers/') === 0;
    var editorMode = isPhpFile ? 'php' : 'htmlmixed';

    var editor = CodeMirror.fromTextArea(textarea, {
        mode: editorMode,
        theme: 'dracula',
        lineNumbers: true,
        indentUnit: 4,
        tabSize: 4,
        lineWrapping: true
    });

    var themeSlug = '{{ theme.getSlug() }}';
    var csrfToken = document.querySelector('meta[name="csrf-token"]')?.content || '';

    // File tree click
    document.querySelectorAll('.file-item').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var file = this.dataset.file;
            window.location.href = '/cms/themes/' + themeSlug + '?file=' + encodeURIComponent(file);
        });
    });

    // Switch to editor tab if file is loaded
    if (currentFile) {
        document.querySelector('[data-tab="tab-editor"]').click();
        setTimeout(function() { editor.refresh(); }, 50);
    }

    // Refresh CodeMirror whenever editor tab is clicked (tab may have been hidden)
    document.querySelector('[data-tab="tab-editor"]')?.addEventListener('click', function() {
        setTimeout(function() {
            editor.refresh();
            if (cmContent) cmContent.refresh();
            if (cmStyle) cmStyle.refresh();
            if (cmJs) cmJs.refresh();
        }, 50);
    });

    // ════════════════════════════════════════════
    //  SECTION DESIGNER
    // ════════════════════════════════════════════
    var isSectionFile = currentFile && currentFile.indexOf('sections/') === 0 && currentFile.indexOf('.twig') > 0;
    var designerMode = false;
    var designerInitialized = false;
    var cmContent = null, cmStyle = null, cmJs = null;
    var schemaState = null;
    var SETTING_TYPES = ['text','textarea','richtext','url','email','number','color','range','select','checkbox','image','collection','field_select','layout_select'];

    // Show toggle if section file
    if (isSectionFile) {
        document.getElementById('designerToggle').style.display = 'inline-flex';
    }

    // ── Escape HTML ──
    function esc(s) {
        var d = document.createElement('div');
        d.textContent = s || '';
        return d.innerHTML;
    }

    // ── Auto-slug from label ──
    function autoSlug(text) {
        return (text || '').toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_|_$/g, '');
    }

    // ── Parse section file into parts ──
    function parseSectionFile(raw) {
        var result = { content: '', style: '', js: '', schema: null };

        // Extract schema
        var schemaMatch = raw.match(new RegExp('\\{' + '%[-\\s]*schema\\s*[-\\s]*%' + '\\}([\\s\\S]*?)\\{' + '%[-\\s]*endschema\\s*[-\\s]*%' + '\\}'));
        var rest = raw;
        if (schemaMatch) {
            try { result.schema = JSON.parse(schemaMatch[1].trim()); }
            catch(e) { result.schema = { name: '', description: '', icon: '', settings: [], blocks: [], presets: [] }; }
            rest = raw.replace(schemaMatch[0], '');
        } else {
            result.schema = { name: '', description: '', icon: '', settings: [], blocks: [], presets: [] };
        }

        // Extract first inline <style> (no src)
        var styleMatch = rest.match(new RegExp('<style(?:\\s[^>]*)?>([\\s\\S]*?)</' + 'style>', 'i'));
        if (styleMatch) {
            result.style = (styleMatch[1] || '').trim();
            rest = rest.replace(styleMatch[0], '');
        }

        // Extract first inline <script> without src
        var scriptMatch = rest.match(new RegExp('<script(?![^>]*\\bsrc\\b)(?:\\s[^>]*)?>([\\s\\S]*?)</' + 'script>', 'i'));
        if (scriptMatch) {
            result.js = (scriptMatch[1] || '').trim();
            rest = rest.replace(scriptMatch[0], '');
        }

        result.content = rest.trim();
        return result;
    }

    // ── Recombine parts into file ──
    function recombineSectionFile(content, style, js, schema) {
        var parts = [content];
        if (style && style.trim()) {
            parts.push('\n<style nonce="' + '{' + '{ csp_nonce() }' + '}">\n' + style.trim() + '\n</' + 'style>');
        }
        if (js && js.trim()) {
            parts.push('\n<scr' + 'ipt nonce="' + '{' + '{ csp_nonce() }' + '}">\n' + js.trim() + '\n</' + 'script>');
        }
        if (schema) {
            parts.push('\n' + '{' + '% schema %' + '}\n' + JSON.stringify(schema, null, 4) + '\n' + '{' + '% endschema %' + '}\n');
        }
        return parts.join('\n');
    }

    // ── Build schema from current state ──
    function buildSchemaFromState() {
        var s = {
            name: document.getElementById('schemaName').value || '',
            description: document.getElementById('schemaDescription').value || '',
            icon: document.getElementById('schemaIcon').value || ''
        };
        var collVal = document.getElementById('schemaCollection').value;
        if (collVal) s.collection = collVal;
        if (schemaState.settings && schemaState.settings.length) {
            s.settings = schemaState.settings.map(function(st) {
                var clean = {};
                ['type','id','label','default','group','min','max','step','options','collection_setting','placeholder'].forEach(function(k) {
                    if (st[k] !== undefined && st[k] !== '' && st[k] !== null) clean[k] = st[k];
                });
                return clean;
            });
        } else {
            s.settings = [];
        }
        if (schemaState.blocks && schemaState.blocks.length) {
            s.blocks = schemaState.blocks.map(function(b) {
                var clean = { type: b.type || '', name: b.name || '' };
                if (b.settings && b.settings.length) {
                    clean.settings = b.settings.map(function(st) {
                        var c = {};
                        ['type','id','label','default','group','min','max','step','options','collection_setting','placeholder'].forEach(function(k) {
                            if (st[k] !== undefined && st[k] !== '' && st[k] !== null) c[k] = st[k];
                        });
                        return c;
                    });
                }
                return clean;
            });
        }
        if (schemaState.presets && schemaState.presets.length) {
            s.presets = schemaState.presets;
        }
        return s;
    }

    // ── Update JSON preview ──
    function updateJsonPreview() {
        var el = document.getElementById('jsonPreviewContent');
        if (el) el.textContent = JSON.stringify(buildSchemaFromState(), null, 4);
        // Refresh reference panel when schema changes
        if (designerInitialized) renderRefPanel();
    }

    // ── Get content to save ──
    function getContentToSave() {
        if (designerMode) {
            return recombineSectionFile(
                cmContent.getValue(),
                cmStyle.getValue(),
                cmJs.getValue(),
                buildSchemaFromState()
            );
        }
        return editor.getValue();
    }

    // ════════════════════════════════════════════
    //  AUTOCOMPLETE & REFERENCE
    // ════════════════════════════════════════════

    // Build completions list from current schema state
    function getCompletions() {
        var completions = [];
        var settings = (schemaState && schemaState.settings) || [];
        var blocks = (schemaState && schemaState.blocks) || [];

        // Section settings
        settings.forEach(function(s) {
            if (!s.id) return;
            completions.push({ text: 'section.settings.' + s.id, kind: 'var', detail: s.type + (s.label ? ' — ' + s.label : '') });
        });

        // Core section variables
        completions.push({ text: 'section.settings', kind: 'var', detail: 'All section settings object' });
        completions.push({ text: 'section.type', kind: 'var', detail: 'Section type name' });
        completions.push({ text: 'section.blocks', kind: 'var', detail: 'Array of blocks' });
        completions.push({ text: 'theme_settings', kind: 'var', detail: 'Global theme settings object' });

        // Block variables (for use inside for block in section.blocks loop)
        completions.push({ text: 'block.type', kind: 'var', detail: 'Block type name' });
        completions.push({ text: 'block.id', kind: 'var', detail: 'Block unique ID' });
        completions.push({ text: 'block.settings', kind: 'var', detail: 'Block settings object' });
        blocks.forEach(function(b) {
            (b.settings || []).forEach(function(bs) {
                if (!bs.id) return;
