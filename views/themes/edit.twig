{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Theme: {{ theme.getName() }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/themes">Themes</a> / {{ theme.getName() }}
</div>

<div class="page-header">
    <h1>
        {{ theme.getName() }}
        {% if theme.isLive() %}
            <span class="badge badge-success">Live</span>
        {% else %}
            <span class="badge badge-draft">Draft</span>
        {% endif %}
    </h1>
    <div class="page-actions">
        <a href="/cms/themes/{{ theme.getSlug() }}/customize" class="btn btn-sm btn-primary" style="display:inline-flex; align-items:center; gap:4px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
            Customize
        </a>
        {% if not theme.isLive() %}
            <a href="/cms/themes/{{ theme.getSlug() }}/preview" class="btn btn-sm btn-outline">Preview</a>
            <form method="POST" action="/cms/themes/{{ theme.getSlug() }}/publish" style="display:inline">
                {{ csrf_field() | raw }}
                <button type="submit" class="btn btn-sm btn-primary">Publish</button>
            </form>
        {% endif %}
    </div>
</div>

<div class="card">
    <div class="tab-nav">
        <button class="tab-btn active" data-tab="tab-settings">Settings</button>
        <button class="tab-btn" data-tab="tab-pages">Pages</button>
        <button class="tab-btn" data-tab="tab-assets">Assets</button>
        <button class="tab-btn" data-tab="tab-editor">File Editor</button>
    </div>

    {# Settings Tab #}
    <div class="tab-panel active" id="tab-settings">
        <form method="POST" action="/cms/themes/{{ theme.getSlug() }}">
            {{ csrf_field() | raw }}

            <div class="form-group">
                <label for="name">Theme Name *</label>
                <input type="text" id="name" name="name" class="form-control" required
                       value="{{ theme.getName() }}">
            </div>

            <div class="form-group">
                <label>Slug</label>
                <input type="text" class="form-control" value="{{ theme.getSlug() }}" disabled>
                <small class="text-muted">Cannot be changed after creation.</small>
            </div>

            <div class="form-group">
                <label for="description">Description</label>
                <textarea id="description" name="description" class="form-control" rows="3">{{ theme.getDescription() ?? '' }}</textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Settings</button>
            </div>
        </form>
    </div>

    {# Pages Tab #}
    <div class="tab-panel" id="tab-pages">
        <div class="pages-header">
            <p class="text-muted">Manage pages that belong to this theme. Each page has a URL, template, and layout.</p>
            <button class="btn btn-primary btn-sm" id="addPageBtn">Add Page</button>
        </div>

        <table class="data-table" id="pagesTable">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>URL</th>
                    <th>Type</th>
                    <th>Template</th>
                    <th>Layout</th>
                    <th style="width:200px">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for page in pages %}
                <tr data-template="{{ page.template }}">
                    <td>{{ page.title }}</td>
                    <td><code>{{ page.slug }}</code></td>
                    <td>
                        {% if '{' in page.slug %}
                            <span class="badge badge-dynamic">Dynamic</span>
                        {% else %}
                            <span class="badge badge-static">Static</span>
                        {% endif %}
                        {% if page.auth_required is defined and page.auth_required %}
                            <span class="badge" style="background:rgba(255,152,0,0.1); color:#e65100; font-size:0.7rem;">Protected</span>
                        {% endif %}
                        {% if page.controller is defined and page.controller %}
                            <a href="/cms/themes/{{ theme.getSlug() }}?file=controllers/{{ page.controller }}.php" class="controller-link" title="Edit controller">{{ page.controller }}.php</a>
                        {% endif %}
                    </td>
                    <td><code>{{ page.template }}.twig</code></td>
                    <td>{{ page.layout ?? 'base' }}</td>
                    <td>
                        <a href="/cms/themes/{{ theme.getSlug() }}?file=templates/{{ page.template }}.twig" class="btn btn-xs btn-outline">Edit Template</a>
                        {% if page.controller is defined and page.controller %}
                            <a href="/cms/themes/{{ theme.getSlug() }}?file=controllers/{{ page.controller }}.php" class="btn btn-xs btn-outline">Edit Controller</a>
                        {% endif %}
                        <button class="btn btn-xs btn-outline edit-page-btn"
                            data-template="{{ page.template }}"
                            data-title="{{ page.title }}"
                            data-slug="{{ page.slug }}"
                            data-layout="{{ page.layout ?? 'base' }}"
                            data-auth-required="{{ page.auth_required is defined and page.auth_required ? '1' : '0' }}"
                            data-allowed-roles="{{ page.allowed_roles is defined ? page.allowed_roles|join(', ') : '' }}">Settings</button>
                        <button class="btn btn-xs btn-danger delete-page-btn" data-template="{{ page.template }}" data-title="{{ page.title }}">Delete</button>
                    </td>
                </tr>
                {% else %}
                <tr class="empty-row">
                    <td colspan="6" class="text-center text-muted" style="padding:40px">No pages yet. Click "Add Page" to create one.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {# Add Page Modal #}
        <div class="modal-overlay" id="addPageModal" style="display:none">
            <div class="modal-card">
                <div class="modal-header">
                    <h3 id="pageModalTitle">Add New Page</h3>
                    <button class="modal-close" id="closePageModal">&times;</button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="pageEditTemplate" value="">
                    <div class="form-group">
                        <label for="pageTitle">Page Title *</label>
                        <input type="text" id="pageTitle" class="form-control" placeholder="About Us">
                    </div>
                    <div class="form-group">
                        <label for="pageSlug">URL Path *</label>
                        <input type="text" id="pageSlug" class="form-control" placeholder="/about">
                        <small class="text-muted">Use <code>{slug}</code> for dynamic parameters, e.g. <code>/blog/{slug}</code></small>
                    </div>
                    <div style="display:grid; grid-template-columns:1fr 1fr; gap:var(--space-400,16px);">
                        <div class="form-group">
                            <label for="pageLayout">Layout</label>
                            <select id="pageLayout" class="form-control">
                                {% for layout in layouts %}
                                <option value="{{ layout }}">{{ layout|capitalize }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="form-group">
                            <label for="pageCollection">Collection <small class="text-muted">(optional)</small></label>
                            <select id="pageCollection" class="form-control">
                                <option value="">-- None --</option>
                            </select>
                            <small class="text-muted">Auto-generates a controller for data fetching.</small>
                        </div>
                    </div>
                    <div style="margin-top:var(--space-300,12px); padding:12px 14px; background:var(--bg-subdued,#f7f7f7); border:1px solid var(--border-subdued,#e1e1e1); border-radius:8px;">
                        <div class="form-group" style="margin-bottom:8px;">
                            <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
                                <input type="checkbox" id="pageAuthRequired" style="width:16px; height:16px;">
                                <span>Require Login (Protected Page)</span>
                            </label>
                            <small class="text-muted" style="margin-left:24px;">Only authenticated users can access this page.</small>
                        </div>
                        <div id="pageRolesGroup" style="display:none; margin-top:8px; margin-left:24px;">
                            <label style="font-size:0.8125rem; margin-bottom:4px; display:block;">Allowed Roles <small class="text-muted">(leave empty = any logged-in user)</small></label>
                            <input type="text" id="pageAllowedRoles" class="form-control" placeholder="customer, admin" style="font-size:0.8125rem;">
                            <small class="text-muted">Comma-separated role slugs. Empty means all authenticated users.</small>
                        </div>
                    </div>
                    <div id="pageDynamicHint" style="display:none; padding:10px 12px; background:rgba(0,128,96,0.06); border:1px solid rgba(0,128,96,0.15); border-radius:6px; font-size:0.8125rem; color:var(--text-primary,#303030); margin-top:8px;">
                        <strong>Dynamic page</strong> &mdash; A PHP controller will be auto-generated to handle data fetching. You can edit it in the File Editor after creation.
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-outline" id="cancelPageModal">Cancel</button>
                    <button class="btn btn-primary" id="savePageBtn">Create Page</button>
                </div>
            </div>
        </div>
    </div>

    {# New Section Modal #}
    <div class="modal-overlay" id="newSectionModal" style="display:none">
        <div class="modal-card">
            <div class="modal-header">
                <h3>Create New Section</h3>
                <button class="modal-close" id="closeNewSectionModal">&times;</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label for="sectionName">Section Name *</label>
                    <input type="text" id="sectionName" class="form-control" placeholder="e.g. Pricing Table">
                    <small class="text-muted">A .twig file will be created in the sections/ directory.</small>
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn btn-outline" id="cancelNewSectionModal">Cancel</button>
                <button class="btn btn-primary" id="createSectionBtn">Create Section</button>
            </div>
        </div>
    </div>

    {# Assets Tab #}
    <div class="tab-panel" id="tab-assets">
        <div class="pages-header">
            <p class="text-muted" style="margin:0;">Manage theme assets — CSS, JavaScript, and fonts. Use <a href="/cms/media">Media</a> for images.</p>
        </div>

        <div style="padding: var(--space-400, 16px);">
            {# Upload Form #}
            <div style="background: var(--bg-subdued, #fafafa); border: 2px dashed var(--border-default, #e3e3e3); border-radius: 8px; padding: 24px; margin-bottom: 24px; text-align: center;" id="assetDropZone">
                <form id="assetUploadForm" enctype="multipart/form-data" style="display: inline-flex; align-items: center; gap: 12px; flex-wrap: wrap; justify-content: center;">
                    <select id="assetCategory" name="category" class="form-control" style="width: auto;">
                        <option value="css" selected>CSS</option>
                        <option value="js">JavaScript</option>
                        <option value="fonts">Fonts</option>
                    </select>
                    <label class="btn btn-primary btn-sm" style="cursor: pointer; margin: 0;">
                        Choose File
                        <input type="file" id="assetFileInput" name="asset_file" style="display: none;"
                               accept=".css,.js,.woff,.woff2,.ttf,.otf,.eot,.map">
                    </label>
                    <span id="assetFileName" style="color: var(--text-secondary); font-size: 0.8125rem;">or drag & drop files here</span>
                    <button type="button" class="btn btn-sm btn-outline" id="assetUploadBtn" style="display: none;">Upload</button>
                </form>
                <div id="assetUploadProgress" style="display: none; margin-top: 12px;">
                    <div style="background: var(--border-default); border-radius: 4px; height: 4px; overflow: hidden;">
                        <div id="assetProgressBar" style="background: var(--color-primary, #008060); height: 100%; width: 0%; transition: width 0.3s;"></div>
                    </div>
                </div>
            </div>

            {# Asset Categories #}
            <div id="assetsList">
                <div style="text-align: center; padding: 40px; color: var(--text-secondary);">
                    Loading assets...
                </div>
            </div>
        </div>
    </div>

    {# File Editor Tab #}
    <div class="tab-panel" id="tab-editor">
        <div class="editor-layout">
            <div class="editor-sidebar">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <h4 style="margin:0;">Files</h4>
                    <button class="btn btn-xs btn-primary" id="newSectionBtn" title="Create new section">+ Section</button>
                </div>
                {% for folder, fileList in files %}
                <div class="file-folder">
                    <div class="folder-name">{{ folder }}/</div>
                    {% for file in fileList %}
                    <a href="#" class="file-item {% if activeFile == file %}active{% endif %}" data-file="{{ file }}">
                        {{ file|split('/')|last }}
                    </a>
                    {% endfor %}
                </div>
                {% endfor %}
            </div>
            <div class="editor-main">
                <div class="editor-toolbar">
                    <span class="editor-file-name" id="editorFileName">{{ activeFile ?: 'Select a file to edit' }}</span>
                    <div class="editor-toolbar-right">
                        <div class="designer-toggle" id="designerToggle" style="display:none;">
                            <button class="toggle-btn active" id="btnDesigner">Designer</button>
                            <button class="toggle-btn" id="btnSource">Source</button>
                        </div>
                        <button class="btn btn-sm btn-outline" id="editorRefToggleBtn" style="display:none;">Reference</button>
                        <button class="btn btn-sm btn-primary" id="saveFileBtn" {% if not activeFile %}disabled{% endif %}>Save</button>
                    </div>
                </div>
                <div id="sourceEditorPane" style="display:flex;">
                    <div style="flex:1;display:flex;flex-direction:column;min-width:0;">
                        <textarea id="codeEditor" class="code-editor">{{ fileContent }}</textarea>
                    </div>
                    <div class="editor-ref-panel hidden" id="editorRefPanel">
                        <div class="ref-side-header">Controller Reference</div>
                        <div id="editorRefPanelBody"></div>
                    </div>
                </div>
                <div id="designerPane" style="display:none;">
                    <div class="designer-tabs">
                        <button class="designer-tab active" data-dtab="dtab-content">Content</button>
                        <button class="designer-tab" data-dtab="dtab-style">Style</button>
                        <button class="designer-tab" data-dtab="dtab-js">JavaScript</button>
                        <button class="designer-tab" data-dtab="dtab-schema">Schema</button>
                        <button class="designer-tab-ref" id="refToggleBtn" title="Toggle reference panel">Reference</button>
                    </div>
                    <div class="designer-panel-split active" id="dtab-content">
                        <div class="editor-side">
                            <textarea id="designerContentEditor"></textarea>
                        </div>
                        <div class="ref-side" id="refPanel">
                            <div class="ref-side-header">Reference</div>
                            <div id="refPanelBody"></div>
                        </div>
                    </div>
                    <div class="designer-panel" id="dtab-style">
                        <textarea id="designerStyleEditor"></textarea>
                    </div>
                    <div class="designer-panel" id="dtab-js">
                        <textarea id="designerJsEditor"></textarea>
                    </div>
                    <div class="designer-panel" id="dtab-schema">
                        <div class="schema-builder" id="schemaBuilder">
                            <div class="schema-section">
                                <h4 class="schema-section-title">Section Info</h4>
                                <div class="schema-form-row">
                                    <div class="schema-field"><label>Name</label><input type="text" class="form-control" id="schemaName"></div>
                                    <div class="schema-field"><label>Icon</label><input type="text" class="form-control" id="schemaIcon" placeholder="layout"></div>
                                </div>
                                <div class="schema-field"><label>Description</label><input type="text" class="form-control" id="schemaDescription"></div>
                                <div class="schema-field">
                                    <label>Collection <small style="font-weight:normal;color:var(--text-secondary,#616161);">(auto-loads data into section.collection_data)</small></label>
                                    <select class="form-control" id="schemaCollection">
                                        <option value="">— None —</option>
                                        {% if collections is defined %}
                                        {% for col in collections %}
                                        <option value="{{ col.slug }}">{{ col.name }} ({{ col.slug }})</option>
                                        {% endfor %}
                                        {% endif %}
                                    </select>
                                </div>
                            </div>
                            <div class="schema-section">
                                <div class="schema-section-header"><h4 class="schema-section-title">Settings</h4><button class="btn btn-xs btn-primary" id="addSettingBtn">+ Add</button></div>
                                <div id="settingsList"></div>
                            </div>
                            <div class="schema-section">
                                <div class="schema-section-header"><h4 class="schema-section-title">Block Types</h4><button class="btn btn-xs btn-primary" id="addBlockTypeBtn">+ Add</button></div>
                                <div id="blockTypesList"></div>
                            </div>
                            <div class="schema-section">
                                <div class="schema-section-header"><h4 class="schema-section-title">Presets</h4><button class="btn btn-xs btn-primary" id="addPresetBtn">+ Add</button></div>
                                <div id="presetsList"></div>
                            </div>
                            <div class="schema-section">
                                <div class="schema-section-header schema-json-toggle" id="jsonPreviewToggle"><h4 class="schema-section-title">JSON Preview</h4><span class="chevron">&#9654;</span></div>
                                <div id="jsonPreviewBody" style="display:none;"><pre id="jsonPreviewContent" class="json-preview"></pre></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/codemirror.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/theme/dracula.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.18/addon/hint/show-hint.min.css">
<style nonce="{{ csp_nonce() }}">
#tab-editor { padding: 0; }
.editor-layout {
    display: flex;
    min-height: 500px;
    border-top: 1px solid var(--border-default, #E3E3E3);
}
.editor-sidebar {
    width: 220px;
    border-right: 1px solid var(--border-default, #E3E3E3);
    padding: var(--space-300, 12px);
    overflow-y: auto;
}
.editor-sidebar h4 {
    margin: 0 0 var(--space-200, 8px) 0;
    font-size: var(--font-size-sm, 0.8125rem);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-secondary, #616161);
}
.folder-name {
    font-weight: 600;
    font-size: var(--font-size-sm, 0.8125rem);
    padding: var(--space-100, 4px) 0;
    color: var(--text-primary, #303030);
}
.file-item {
    display: block;
    padding: var(--space-100, 4px) var(--space-200, 8px);
    margin-left: var(--space-200, 8px);
    font-size: var(--font-size-xs, 0.75rem);
    color: var(--text-secondary, #616161);
    text-decoration: none;
    border-radius: var(--radius-100, 4px);
    transition: background 0.15s;
}
.file-item:hover {
    background: var(--bg-surface-hover, #F7F7F7);
    color: var(--text-primary, #303030);
}
.file-item.active {
    background: var(--color-primary, #008060);
    color: #fff;
}
.file-folder {
    margin-bottom: var(--space-300, 12px);
}
.editor-main {
    flex: 1;
    display: flex;
    flex-direction: column;
}
.editor-toolbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-200, 8px) var(--space-300, 12px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
    background: var(--bg-subdued, #FAFAFA);
}
.editor-file-name {
    font-size: var(--font-size-sm, 0.8125rem);
    font-family: monospace;
    color: var(--text-secondary, #616161);
}
.editor-toolbar-right {
    display: flex;
    align-items: center;
    gap: 8px;
}
#sourceEditorPane, #designerPane {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 450px;
}
.CodeMirror {
    flex: 1;
    height: auto;
    min-height: 450px;
    font-size: 13px;
}
.code-editor {
    width: 100%;
    min-height: 450px;
    font-family: monospace;
    font-size: 13px;
    padding: var(--space-300, 12px);
    border: none;
    resize: none;
    background: #282a36;
    color: #f8f8f2;
}
.pages-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-400, 16px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.pages-header .text-muted {
    margin: 0;
}
.data-table {
    width: 100%;
    border-collapse: collapse;
}
.data-table th,
.data-table td {
    padding: var(--space-300, 12px) var(--space-400, 16px);
    text-align: left;
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.data-table th {
    font-size: var(--font-size-sm, 0.8125rem);
    font-weight: 600;
    color: var(--text-secondary, #616161);
    background: var(--bg-subdued, #FAFAFA);
}
.data-table td code {
    background: rgba(0,0,0,0.06);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: var(--font-size-xs, 0.75rem);
}
.btn-xs {
    padding: 4px 8px;
    font-size: var(--font-size-xs, 0.75rem);
}
.btn-danger {
    background: #D72C0D;
    color: #fff;
    border: none;
}
.btn-danger:hover {
    background: #BC2200;
}
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}
.modal-card {
    background: #fff;
    border-radius: var(--radius-200, 8px);
    width: 480px;
    max-width: 90vw;
    box-shadow: 0 20px 60px rgba(0,0,0,0.2);
}
.modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-400, 16px) var(--space-500, 20px);
    border-bottom: 1px solid var(--border-default, #E3E3E3);
}
.modal-header h3 {
    margin: 0;
    font-size: 1rem;
}
.modal-close {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--text-secondary, #616161);
    line-height: 1;
}
.modal-body {
    padding: var(--space-500, 20px);
}
.modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-200, 8px);
    padding: var(--space-400, 16px) var(--space-500, 20px);
    border-top: 1px solid var(--border-default, #E3E3E3);
}
.badge-success {
    background: rgba(4, 123, 93, 0.1);
    color: var(--color-success, #047B5D);
    border: 1px solid rgba(4, 123, 93, 0.2);
}
.badge-draft {
    background: rgba(255, 184, 0, 0.1);
    color: #b8860b;
    border: 1px solid rgba(255, 184, 0, 0.2);
}

/* ── Designer/Source Toggle ── */
.designer-toggle {
    display: inline-flex;
    border: 1px solid var(--border-default, #E3E3E3);
    border-radius: var(--radius-100, 4px);
    overflow: hidden;
}
.toggle-btn {
    padding: 4px 12px;
    font-size: var(--font-size-xs, 0.75rem);
    font-weight: 500;
    font-family: inherit;
    background: var(--bg-surface, #fff);
    border: none;
    cursor: pointer;
    color: var(--text-secondary, #616161);
    transition: all 0.15s;
}
.toggle-btn:not(:last-child) {
    border-right: 1px solid var(--border-default, #E3E3E3);
}
.toggle-btn.active {
