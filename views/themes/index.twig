{% extends "@cms/layouts/cms.twig" %}

{% block title %}Themes{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> / Themes
</div>

<div class="page-header">
    <h1>Themes</h1>
    <div class="page-actions">
        <div class="th-dropdown">
            <button type="button" class="btn btn-primary btn-sm" id="addThemeBtn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:4px"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add theme
            </button>
            <div class="th-dropdown-menu" id="addThemeMenu">
                <button type="button" class="th-dropdown-item" onclick="document.getElementById('install-modal').style.display='flex'">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Upload ZIP
                </button>
                <a href="{{ admin_url('themes/create') }}" class="th-dropdown-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Create blank theme
                </a>
            </div>
        </div>
    </div>
</div>

{# Upload Modal #}
<div id="install-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Upload theme</h3>
            <button type="button" class="modal-close" onclick="document.getElementById('install-modal').style.display='none'">&times;</button>
        </div>
        <form method="POST" action="{{ admin_url('themes/install') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="modal-body">
                <p class="text-secondary text-sm" style="margin-bottom:12px;">Upload a ZIP containing a valid <code>theme.json</code>.</p>
                <div class="form-group">
                    <label for="theme_zip">Theme ZIP File</label>
                    <input type="file" id="theme_zip" name="theme_zip" accept=".zip" required class="form-control">
                    <small class="text-secondary text-sm">Maximum: 50MB</small>
                </div>
                <label style="display:flex;align-items:center;gap:8px;margin-top:12px;font-size:13px;cursor:pointer;">
                    <input type="checkbox" name="overwrite" value="1"> Overwrite if exists
                </label>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').style.display='none'">Cancel</button>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

{% set liveTheme = null %}
{% set draftThemes = [] %}
{% for theme in themes %}
    {% if theme.isLive() %}
        {% set liveTheme = theme %}
    {% else %}
        {% set draftThemes = draftThemes|merge([theme]) %}
    {% endif %}
{% endfor %}

{# ── Active Theme (full width) ── #}
{% if liveTheme %}
<div class="th-card th-card--active th-card--full">
    <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/customize') }}" class="th-card-thumb">
        <div class="th-thumb-inner">
            <iframe src="/?theme_preview={{ liveTheme.getSlug() }}" class="th-thumb-iframe" loading="lazy" scrolling="no" tabindex="-1"></iframe>
        </div>
        <div class="th-thumb-hover">
            <span class="th-thumb-hover-btn">Customize</span>
        </div>
        <span class="th-badge-active">Active</span>
    </a>
    <div class="th-card-body">
        <div class="th-card-info">
            <h3 class="th-card-name">{{ liveTheme.getName() }}</h3>
            {% if themeConfigs[liveTheme.getSlug()] is defined %}
            <span class="th-card-version">v{{ themeConfigs[liveTheme.getSlug()].version }}</span>
            {% endif %}
            {% if themeConfigs[liveTheme.getSlug()] is defined and themeConfigs[liveTheme.getSlug()].layouts|length > 0 %}
            <span class="th-card-meta">{{ themeConfigs[liveTheme.getSlug()].layouts|length }} layout{{ themeConfigs[liveTheme.getSlug()].layouts|length > 1 ? 's' : '' }}</span>
            {% endif %}
        </div>
        <div class="th-card-actions">
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/customize') }}" class="btn btn-primary btn-sm">Customize</a>
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/preview') }}" class="btn btn-outline btn-sm">Preview</a>
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/code') }}" class="btn btn-outline btn-sm">Edit code</a>
        </div>
    </div>
</div>
{% endif %}

{# ── Theme Library Grid ── #}
{% if draftThemes|length > 0 %}
<h2 class="th-section-title">Theme library</h2>
{% endif %}
<div class="th-grid">
    {% for theme in draftThemes %}
    <div class="th-card">
        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/customize') }}" class="th-card-thumb">
            <div class="th-thumb-inner">
                <iframe src="/?theme_preview={{ theme.getSlug() }}" class="th-thumb-iframe" loading="lazy" scrolling="no" tabindex="-1"></iframe>
            </div>
            <div class="th-thumb-hover">
                <span class="th-thumb-hover-btn">Customize</span>
            </div>
        </a>
        <div class="th-card-body">
            <div class="th-card-info">
                <h3 class="th-card-name">{{ theme.getName() }}</h3>
                {% if themeConfigs[theme.getSlug()] is defined %}
                <span class="th-card-version">v{{ themeConfigs[theme.getSlug()].version }}</span>
                {% endif %}
            </div>
            <div class="th-card-actions">
                <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/customize') }}" class="btn btn-outline btn-sm">Customize</a>
                <div class="th-dropdown">
                    <button type="button" class="th-dots-btn" data-theme-menu="{{ theme.getSlug() }}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                    </button>
                    <div class="th-dropdown-menu th-dropdown-menu--right" id="menu-{{ theme.getSlug() }}">
                        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/code') }}" class="th-dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                            Edit code
                        </a>
                        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/preview') }}" class="th-dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            Preview
                        </a>
                        <form method="POST" action="{{ admin_url('themes/' ~ theme.getSlug() ~ '/publish') }}" style="display:contents">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="th-dropdown-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Set as active
                            </button>
                        </form>
                        <div class="th-dropdown-divider"></div>
                        <form method="POST" action="{{ admin_url('themes/' ~ theme.getSlug() ~ '/delete') }}" class="confirm-delete" data-message="Delete theme '{{ theme.getName() }}'? This cannot be undone." style="display:contents">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="th-dropdown-item th-dropdown-item--danger">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% if not liveTheme and draftThemes|length == 0 %}
<div class="card">
    <div class="card-body empty-state">
        <h3>No themes found</h3>
        <p>Create your first theme or upload one from a ZIP package.</p>
        <div style="display:flex;gap:8px;justify-content:center;">
            <a href="{{ admin_url('themes/create') }}" class="btn btn-primary">Create Theme</a>
            <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').style.display='flex'">Upload ZIP</button>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
/* ── Full-width active card ── */
.th-card--full {
    margin-bottom: 28px;
}
.th-card--full .th-card-thumb {
    aspect-ratio: 16 / 6;
}
.th-card--full .th-card-body {
    padding: 16px 20px;
}
.th-card--full .th-card-name {
    font-size: 16px;
}
.th-card-meta {
    font-size: 11px;
    color: var(--text-secondary, #999);
    padding: 2px 8px;
    background: var(--bg-subdued, #f5f5f5);
    border-radius: 4px;
}
.th-section-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text-secondary, #666);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
}

/* ── Grid ── */
.th-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
}

/* ── Card ── */
.th-card {
    background: var(--bg-surface, #fff);
    border: 1px solid var(--border-color, #e1e1e1);
    border-radius: 10px;
    overflow: hidden;
    transition: box-shadow 0.15s;
}
.th-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
}
.th-card--active {
    border-color: var(--color-primary, #047B5D);
    border-width: 2px;
}

/* ── Thumbnail ── */
.th-card-thumb {
    display: block;
    position: relative;
    background: #f4f4f5;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    cursor: pointer;
    text-decoration: none;
}
.th-thumb-inner {
    position: absolute;
    inset: 0;
    overflow: hidden;
}
.th-thumb-iframe {
    position: absolute;
    top: 0; left: 0;
    width: 1440px;
    height: 900px;
    transform-origin: top left;
    border: none;
    pointer-events: none;
}
.th-thumb-hover {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.45);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.2s;
}
.th-card-thumb:hover .th-thumb-hover {
    opacity: 1;
}
.th-thumb-hover-btn {
    padding: 8px 24px;
    background: #fff;
    color: #303030;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
}
.th-badge-active {
    position: absolute;
    top: 10px;
    left: 10px;
    padding: 3px 10px;
    background: var(--color-primary, #047B5D);
    color: #fff;
    font-size: 11px;
    font-weight: 600;
    border-radius: 4px;
    z-index: 2;
    letter-spacing: 0.02em;
}

/* ── Card Body ── */
.th-card-body {
    padding: 14px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
}
.th-card-info {
    display: flex;
    align-items: baseline;
    gap: 6px;
    min-width: 0;
}
.th-card-name {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.th-card-version {
    font-size: 11px;
    color: var(--text-secondary, #999);
    flex-shrink: 0;
}
.th-card-actions {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
}

/* ── Dots Menu ── */
.th-dots-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: 1px solid var(--border-color, #e1e1e1);
    border-radius: 6px;
    background: none;
    cursor: pointer;
    color: var(--text-secondary, #666);
    transition: all 0.1s;
}
.th-dots-btn:hover {
    background: var(--bg-subdued, #f5f5f5);
    color: var(--text-primary, #303030);
}

/* ── Dropdown ── */
.th-dropdown { position: relative; display: inline-block; }
.th-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 4px);
    left: 0;
    z-index: 200;
    min-width: 170px;
    padding: 4px;
    background: var(--bg-surface, #fff);
    border: 1px solid var(--border-color, #e1e1e1);
    border-radius: 8px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
}
.th-dropdown-menu--right { left: auto; right: 0; }
.th-dropdown-menu.is-open { display: block; }
.th-dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 7px 10px;
    font-size: 13px;
    color: var(--text-primary, #303030);
    background: none;
    border: none;
    border-radius: 5px;
    text-decoration: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: background 0.1s;
}
.th-dropdown-item:hover { background: var(--bg-subdued, #f5f5f5); }
.th-dropdown-item--danger { color: var(--color-danger, #dc3545); }
.th-dropdown-item--danger:hover { background: #fef2f2; }
.th-dropdown-divider { height: 1px; background: var(--border-color, #e5e5e5); margin: 4px 0; }

/* ── Modal ── */
.modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); display:flex; align-items:center; justify-content:center; z-index:1000; }
.modal-box { background:var(--bg-surface,#fff); border-radius:10px; box-shadow:0 8px 32px rgba(0,0,0,0.2); width:100%; max-width:440px; overflow:hidden; }
.modal-header { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--border-color,#e5e5e5); }
.modal-header h3 { margin:0; font-size:1rem; }
.modal-close { background:none; border:none; font-size:1.4rem; cursor:pointer; color:var(--text-secondary,#616161); line-height:1; padding:0 4px; }
.modal-close:hover { color:var(--text-primary,#303030); }
.modal-body { padding:20px; }
.modal-footer { padding:12px 20px; border-top:1px solid var(--border-color,#e5e5e5); display:flex; gap:8px; justify-content:flex-end; }

/* ── Responsive ── */
@media (max-width: 700px) {
    .th-grid { grid-template-columns: 1fr; }
}
</style>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Scale iframes to fit their containers
    function scaleIframes() {
        document.querySelectorAll('.th-thumb-iframe').forEach(function(iframe) {
            var container = iframe.closest('.th-card-thumb');
            if (container) {
                var scale = container.offsetWidth / 1440;
                iframe.style.transform = 'scale(' + scale + ')';
            }
        });
    }
    scaleIframes();
    window.addEventListener('resize', scaleIframes);

    // Dropdown toggles
    document.getElementById('addThemeBtn').addEventListener('click', function(e) {
        e.stopPropagation();
        document.getElementById('addThemeMenu').classList.toggle('is-open');
    });
    document.querySelectorAll('[data-theme-menu]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var menu = document.getElementById('menu-' + this.dataset.themeMenu);
            var wasOpen = menu.classList.contains('is-open');
            document.querySelectorAll('.th-dropdown-menu.is-open').forEach(function(m) { m.classList.remove('is-open'); });
            if (!wasOpen) menu.classList.add('is-open');
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('.th-dropdown-menu.is-open').forEach(function(m) { m.classList.remove('is-open'); });
    });

    // Modal
    var modal = document.getElementById('install-modal');
    modal.addEventListener('click', function(e) { if (e.target === modal) modal.style.display = 'none'; });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            modal.style.display = 'none';
            document.querySelectorAll('.th-dropdown-menu.is-open').forEach(function(m) { m.classList.remove('is-open'); });
        }
    });

    // Confirm delete
    document.querySelectorAll('.confirm-delete').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            if (!confirm(form.dataset.message || 'Are you sure?')) e.preventDefault();
        });
    });
})();
</script>
{% endblock %}
