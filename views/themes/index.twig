{% extends "@cms/layouts/cms.twig" %}

{% block title %}Themes{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
    .theme-thumb {
        position: relative;
        display: block;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
        background: var(--zui-gray-100);
    }
    .theme-thumb-inner {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }
    .theme-thumb-iframe {
        width: 1440px;
        height: 900px;
        border: none;
        transform-origin: top left;
        pointer-events: none;
    }
    .theme-thumb-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0);
        transition: background var(--duration) var(--ease);
    }
    .theme-thumb:hover .theme-thumb-overlay {
        background: rgba(0, 0, 0, 0.4);
    }
    .theme-thumb-btn {
        opacity: 0;
        transform: translateY(4px);
        transition: opacity var(--duration) var(--ease), transform var(--duration) var(--ease);
        padding: var(--sp-2) var(--sp-4);
        background: var(--bg-surface);
        color: var(--text-heading);
        border-radius: var(--radius);
        font-size: var(--text-sm);
        font-weight: 600;
        box-shadow: var(--shadow-md);
    }
    .theme-thumb:hover .theme-thumb-btn {
        opacity: 1;
        transform: translateY(0);
    }
    .theme-active-badge {
        position: absolute;
        top: var(--sp-3);
        left: var(--sp-3);
        padding: var(--sp-1) var(--sp-2);
        background: var(--zui-success-600);
        color: #fff;
        font-size: var(--text-xs);
        font-weight: 600;
        border-radius: var(--radius-sm);
        z-index: 2;
    }
    .theme-card-full .theme-thumb {
        aspect-ratio: 21 / 9;
    }
</style>
{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a>
    <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    <span class="breadcrumb-current">Themes</span>
</div>

<div class="page-header">
    <h1>Themes</h1>
    <div class="page-header-actions">
        <div class="dropdown">
            <button type="button" class="btn btn-primary btn-sm" data-dropdown="add-theme-menu">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Add theme
            </button>
            <div class="dropdown-menu" id="add-theme-menu">
                <button type="button" class="dropdown-item" onclick="document.getElementById('install-modal').classList.add('open')">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Upload ZIP
                </button>
                <a href="{{ admin_url('themes/create') }}" class="dropdown-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Create blank theme
                </a>
            </div>
        </div>
    </div>
</div>

{# ── Upload Modal ── #}
<div id="install-modal" class="zui-modal-overlay">
    <div class="zui-modal">
        <div class="zui-modal-header">
            <h2>Upload theme</h2>
            <button type="button" class="btn btn-ghost btn-icon btn-sm" onclick="document.getElementById('install-modal').classList.remove('open')">&times;</button>
        </div>
        <form method="POST" action="{{ admin_url('themes/install') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="zui-modal-body">
                <p class="text-secondary text-sm mb-3">Upload a ZIP containing a valid <code>theme.json</code>.</p>
                <div class="form-group">
                    <label class="form-label" for="theme_zip">Theme ZIP File</label>
                    <input type="file" id="theme_zip" name="theme_zip" accept=".zip" required class="form-control">
                    <span class="form-hint">Maximum: 50MB</span>
                </div>
                <label class="flex items-center gap-2 mt-3 text-sm" style="cursor:pointer">
                    <input type="checkbox" name="overwrite" value="1"> Overwrite if exists
                </label>
            </div>
            <div class="zui-modal-footer">
                <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').classList.remove('open')">Cancel</button>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

{% set liveTheme = null %}
{% set draftThemes = [] %}
{% for theme in themes %}
    {% if theme.isLive() %}
        {% set liveTheme = theme %}
    {% else %}
        {% set draftThemes = draftThemes|merge([theme]) %}
    {% endif %}
{% endfor %}

{# ── Active Theme (full width) ── #}
{% if liveTheme %}
<div class="card theme-card-full mb-5">
    <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/customize') }}" class="theme-thumb">
        <div class="theme-thumb-inner">
            <iframe src="/?theme_preview={{ liveTheme.getSlug() }}" class="theme-thumb-iframe" loading="lazy" scrolling="no" tabindex="-1"></iframe>
        </div>
        <div class="theme-thumb-overlay">
            <span class="theme-thumb-btn">Customize</span>
        </div>
        <span class="theme-active-badge">Active</span>
    </a>
    <div class="card-body flex items-center justify-between">
        <div class="flex items-center gap-2">
            <h3 class="font-semibold">{{ liveTheme.getName() }}</h3>
            {% if themeConfigs[liveTheme.getSlug()] is defined %}
            <span class="badge badge-default">v{{ themeConfigs[liveTheme.getSlug()].version }}</span>
            {% endif %}
            {% if themeConfigs[liveTheme.getSlug()] is defined and themeConfigs[liveTheme.getSlug()].layouts|length > 0 %}
            <span class="text-secondary text-sm">{{ themeConfigs[liveTheme.getSlug()].layouts|length }} layout{{ themeConfigs[liveTheme.getSlug()].layouts|length > 1 ? 's' : '' }}</span>
            {% endif %}
        </div>
        <div class="flex items-center gap-2">
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/customize') }}" class="btn btn-primary btn-sm">Customize</a>
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/preview') }}" class="btn btn-outline btn-sm">Preview</a>
            <a href="{{ admin_url('themes/' ~ liveTheme.getSlug() ~ '/code') }}" class="btn btn-outline btn-sm">Edit code</a>
        </div>
    </div>
</div>
{% endif %}

{# ── Theme Library Grid ── #}
{% if draftThemes|length > 0 %}
<h2 class="font-semibold mb-4">Theme library</h2>
{% endif %}
<div class="grid grid-3 gap-4">
    {% for theme in draftThemes %}
    <div class="card">
        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/customize') }}" class="theme-thumb">
            <div class="theme-thumb-inner">
                <iframe src="/?theme_preview={{ theme.getSlug() }}" class="theme-thumb-iframe" loading="lazy" scrolling="no" tabindex="-1"></iframe>
            </div>
            <div class="theme-thumb-overlay">
                <span class="theme-thumb-btn">Customize</span>
            </div>
        </a>
        <div class="card-body flex items-center justify-between">
            <div class="flex items-center gap-2">
                <h3 class="font-semibold text-sm">{{ theme.getName() }}</h3>
                {% if themeConfigs[theme.getSlug()] is defined %}
                <span class="badge badge-default">v{{ themeConfigs[theme.getSlug()].version }}</span>
                {% endif %}
            </div>
            <div class="flex items-center gap-2">
                <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/customize') }}" class="btn btn-outline btn-sm">Customize</a>
                <div class="dropdown">
                    <button type="button" class="btn btn-ghost btn-icon btn-sm" data-dropdown="menu-{{ theme.getSlug() }}">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                    </button>
                    <div class="dropdown-menu" id="menu-{{ theme.getSlug() }}">
                        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/code') }}" class="dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                            Edit code
                        </a>
                        <a href="{{ admin_url('themes/' ~ theme.getSlug() ~ '/preview') }}" class="dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            Preview
                        </a>
                        <form method="POST" action="{{ admin_url('themes/' ~ theme.getSlug() ~ '/publish') }}" style="display:contents">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="dropdown-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                Set as active
                            </button>
                        </form>
                        <div class="dropdown-divider"></div>
                        <form method="POST" action="{{ admin_url('themes/' ~ theme.getSlug() ~ '/delete') }}" class="confirm-delete" data-message="Delete theme '{{ theme.getName() }}'? This cannot be undone." style="display:contents">
                            {{ csrf_field() | raw }}
                            <button type="submit" class="dropdown-item danger">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% if not liveTheme and draftThemes|length == 0 %}
<div class="card">
    <div class="card-body empty-state">
        <div class="empty-state-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        </div>
        <h2>No themes found</h2>
        <p>Create your first theme or upload one from a ZIP package.</p>
        <div class="flex gap-2 justify-center">
            <a href="{{ admin_url('themes/create') }}" class="btn btn-primary">Create Theme</a>
            <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').classList.add('open')">Upload ZIP</button>
        </div>
    </div>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Scale iframes to fit their containers
    function scaleIframes() {
        document.querySelectorAll('.theme-thumb-iframe').forEach(function(iframe) {
            var container = iframe.closest('.theme-thumb');
            if (container) {
                var scale = container.offsetWidth / 1440;
                iframe.style.transform = 'scale(' + scale + ')';
            }
        });
    }
    scaleIframes();
    window.addEventListener('resize', scaleIframes);

    // Dropdown toggles (data-dropdown pattern)
    document.querySelectorAll('[data-dropdown]').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var menu = document.getElementById(this.dataset.dropdown);
            var wasOpen = menu.classList.contains('open');
            document.querySelectorAll('.dropdown-menu.open').forEach(function(m) { m.classList.remove('open'); });
            if (!wasOpen) menu.classList.add('open');
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('.dropdown-menu.open').forEach(function(m) { m.classList.remove('open'); });
    });

    // Modal
    var modal = document.getElementById('install-modal');
    modal.addEventListener('click', function(e) {
        if (e.target === modal) modal.classList.remove('open');
    });
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            modal.classList.remove('open');
            document.querySelectorAll('.dropdown-menu.open').forEach(function(m) { m.classList.remove('open'); });
        }
    });

    // Confirm delete
    document.querySelectorAll('.confirm-delete').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            if (!confirm(form.dataset.message || 'Are you sure?')) e.preventDefault();
        });
    });
})();
</script>
{% endblock %}
