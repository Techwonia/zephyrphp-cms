{% extends "@cms/layouts/cms.twig" %}

{% block title %}Themes{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / Themes
</div>

<div class="page-header">
    <h1>Themes</h1>
    <div class="page-actions">
        <div class="dropdown">
            <button type="button" class="btn btn-primary btn-sm dropdown-toggle" data-dropdown="import-menu">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                Add theme
            </button>
            <div class="dropdown-menu" id="import-menu">
                <button type="button" class="dropdown-item" onclick="document.getElementById('install-modal').style.display='flex'">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Upload ZIP file
                </button>
                <a href="/cms/themes/create" class="dropdown-item">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Create new theme
                </a>
            </div>
        </div>
    </div>
</div>

{# Install Theme Modal #}
<div id="install-modal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-header">
            <h3>Upload theme</h3>
            <button type="button" class="modal-close" onclick="document.getElementById('install-modal').style.display='none'">&times;</button>
        </div>
        <form method="POST" action="/cms/themes/install" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="modal-body">
                <p class="text-muted" style="margin-bottom:12px;">Upload a theme ZIP package containing a valid <code>theme.json</code> file.</p>
                <div class="form-group">
                    <label for="theme_zip">Theme ZIP File</label>
                    <input type="file" id="theme_zip" name="theme_zip" accept=".zip" required class="form-control">
                    <small class="text-muted">Maximum size: 50MB</small>
                </div>
                <div class="form-group" style="margin-top:12px;">
                    <label class="checkbox-label">
                        <input type="checkbox" name="overwrite" value="1">
                        Overwrite if theme already exists
                    </label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').style.display='none'">Cancel</button>
                <button type="submit" class="btn btn-primary">Upload</button>
            </div>
        </form>
    </div>
</div>

{% set liveTheme = null %}
{% set draftThemes = [] %}
{% for theme in themes %}
    {% if theme.isLive() %}
        {% set liveTheme = theme %}
    {% else %}
        {% set draftThemes = draftThemes|merge([theme]) %}
    {% endif %}
{% endfor %}

<div class="themes-container">
    {# ── Active Theme (full width with live preview) ── #}
    {% if liveTheme %}
    <div class="active-theme-card">
        <div class="active-theme-preview">
            <iframe src="/?theme_preview={{ liveTheme.getSlug() }}" class="preview-iframe" loading="lazy"></iframe>
        </div>
        <div class="active-theme-info">
            <div>
                <div class="theme-card-header">
                    <h3 class="theme-card-name" style="font-size:1.15rem;">{{ liveTheme.getName() }}</h3>
                    <span class="badge badge-live">Active</span>
                </div>
                {% if themeConfigs[liveTheme.getSlug()] is defined %}
                    <span class="theme-version">v{{ themeConfigs[liveTheme.getSlug()].version }}</span>
                {% endif %}
                {% if themeConfigs[liveTheme.getSlug()] is defined and themeConfigs[liveTheme.getSlug()].layouts|length > 0 %}
                    <div style="margin-top:8px;">
                        <span class="theme-meta-item">
                            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
                            {{ themeConfigs[liveTheme.getSlug()].layouts|length }} layout{{ themeConfigs[liveTheme.getSlug()].layouts|length > 1 ? 's' : '' }}
                        </span>
                    </div>
                {% endif %}
            </div>
            <div class="theme-card-actions">
                <a href="/cms/themes/{{ liveTheme.getSlug() }}/customize" class="btn btn-primary btn-sm">Customize</a>
                <div class="dropdown">
                    <button type="button" class="btn-icon" data-dropdown="live-menu">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                    </button>
                    <div class="dropdown-menu dropdown-menu--right" id="live-menu">
                        <a href="/cms/themes/{{ liveTheme.getSlug() }}/preview" class="dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                            Preview
                        </a>
                        <a href="/cms/themes/{{ liveTheme.getSlug() }}/code" class="dropdown-item">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                            Edit code
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}

    {# ── Other Themes Grid ── #}
    {% if draftThemes|length > 0 %}
    <h2 class="section-title">Theme library</h2>
    <div class="theme-grid">

        {% for theme in draftThemes %}
        <div class="theme-card">
            <div class="theme-card-preview">
                <div class="preview-frame">
                    <div class="preview-chrome">
                        <span class="preview-dots"><i></i><i></i><i></i></span>
                        <span class="preview-bar"></span>
                    </div>
                    <div class="preview-body">
                        <div class="preview-nav"></div>
                        <div class="preview-hero">
                            <div class="preview-hero-title"></div>
                            <div class="preview-hero-sub"></div>
                            <div class="preview-hero-btn"></div>
                        </div>
                        <div class="preview-cols">
                            <div class="preview-col"></div>
                            <div class="preview-col"></div>
                            <div class="preview-col"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="theme-card-info">
                <div class="theme-card-header">
                    <h3 class="theme-card-name">{{ theme.getName() }}</h3>
                    {% if themeConfigs[theme.getSlug()] is defined %}
                        <span class="theme-version">v{{ themeConfigs[theme.getSlug()].version }}</span>
                    {% endif %}
                </div>
                <div class="theme-card-actions">
                    <a href="/cms/themes/{{ theme.getSlug() }}/customize" class="btn btn-outline btn-sm">Customize</a>
                    <div class="dropdown">
                        <button type="button" class="btn-icon" data-dropdown="menu-{{ theme.getSlug() }}">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><circle cx="12" cy="5" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="12" cy="19" r="2"/></svg>
                        </button>
                        <div class="dropdown-menu dropdown-menu--right" id="menu-{{ theme.getSlug() }}">
                            <a href="/cms/themes/{{ theme.getSlug() }}/preview" class="dropdown-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                Preview
                            </a>
                            <a href="/cms/themes/{{ theme.getSlug() }}/code" class="dropdown-item">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
                                Edit code
                            </a>
                            <form method="POST" action="/cms/themes/{{ theme.getSlug() }}/publish" style="display:contents">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="dropdown-item">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                    Publish
                                </button>
                            </form>
                            <div class="dropdown-divider"></div>
                            <form method="POST" action="/cms/themes/{{ theme.getSlug() }}/delete" class="confirm-delete" data-message="Delete theme '{{ theme.getName() }}'? This cannot be undone.">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="dropdown-item dropdown-item--danger">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                    Delete
                                </button>
                            </form>
                            <form method="POST" action="/cms/themes/{{ theme.getSlug() }}/uninstall" class="confirm-delete" data-message="Uninstall theme '{{ theme.getName() }}'? This removes all theme files.">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="dropdown-item dropdown-item--danger">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                    Uninstall
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {% if not liveTheme and draftThemes|length == 0 %}
    <div class="card">
        <div class="card-body empty-state">
            <h3>No themes found</h3>
            <p>Create your first theme or upload one from a ZIP package.</p>
            <div style="display:flex;gap:8px;justify-content:center;">
                <a href="/cms/themes/create" class="btn btn-primary">Create Theme</a>
                <button type="button" class="btn btn-outline" onclick="document.getElementById('install-modal').style.display='flex'">Upload ZIP</button>
            </div>
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
/* ── Container ── */
.themes-container {
    max-width: 900px;
    margin: 0 auto;
}

/* ── Active Theme Card ── */
.active-theme-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--bg-surface, #fff);
    border-radius: var(--radius-200, 8px);
    border: 2px solid var(--color-primary, #047B5D);
    overflow: hidden;
    margin-bottom: 24px;
}
.active-theme-preview {
    background: var(--bg-subdued, #f6f6f7);
    position: relative;
    min-height: 280px;
    overflow: hidden;
}
.preview-iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 200%;
    height: 200%;
    transform: scale(0.5);
    transform-origin: top left;
    border: none;
    pointer-events: none;
}
.active-theme-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
}
.section-title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 16px;
    color: var(--text-primary, #303030);
}

/* ── Theme Grid ── */
.theme-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
}

/* ── Theme Card ── */
.theme-card {
    background: var(--bg-surface, #fff);
    border-radius: var(--radius-200, 8px);
    border: 1px solid var(--border-color, #e5e5e5);
    overflow: hidden;
    transition: box-shadow 0.2s, border-color 0.2s;
}
.theme-card:hover {
    box-shadow: 0 4px 16px rgba(0,0,0,0.08);
    border-color: var(--border-color-hover, #ccc);
}
.theme-card--active {
    border-color: var(--color-primary, #047B5D);
    border-width: 2px;
}

/* ── Card Preview ── */
.theme-card-preview {
    background: var(--bg-subdued, #f6f6f7);
    padding: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 180px;
}
.theme-card-preview .badge-live {
    position: absolute;
    top: 10px;
    right: 10px;
}

/* ── Card Info ── */
.theme-card-info {
    padding: 16px;
}
.theme-card-header {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 4px;
}
.theme-card-name {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0;
}
.theme-card-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
}

/* ── Badge ── */
.badge-live {
    display: inline-block;
    background: #e3fcef;
    color: #047B5D;
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 2px 8px;
    border-radius: 999px;
}
.theme-version {
    font-size: 0.75rem;
    color: var(--text-secondary, #999);
}

/* ── Theme Meta ── */
.theme-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.8125rem;
    color: var(--text-secondary, #616161);
}

/* ── Preview Frame ── */
.preview-frame {
    background: #fff;
    border-radius: 6px;
    box-shadow: 0 1px 8px rgba(0,0,0,0.08);
    overflow: hidden;
    width: 100%;
    max-width: 220px;
}
.preview-chrome {
    background: #f1f1f1;
    padding: 5px 8px;
    display: flex;
    align-items: center;
    gap: 5px;
}
.preview-dots i {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: #ccc;
}
.preview-dots i:first-child { background: #ff5f57; }
.preview-dots i:nth-child(2) { background: #febc2e; }
.preview-dots i:last-child { background: #28c840; }
.preview-bar {
    flex: 1;
    height: 8px;
    background: #e5e5e5;
    border-radius: 3px;
    margin-left: 4px;
}
.preview-body {
    padding: 6px;
}
.preview-nav {
    height: 6px;
    background: #f5f5f5;
    border-radius: 2px;
    margin-bottom: 6px;
}
.preview-hero {
    text-align: center;
    padding: 12px 6px;
}
.preview-hero-title {
    width: 60%;
    height: 8px;
    background: #e0e0e0;
    border-radius: 2px;
    margin: 0 auto 5px;
}
.preview-hero-sub {
    width: 80%;
    height: 5px;
    background: #eee;
    border-radius: 2px;
    margin: 0 auto 6px;
}
.preview-hero-btn {
    width: 40%;
    height: 8px;
    background: #333;
    border-radius: 3px;
    margin: 0 auto;
}
.preview-cols {
    display: flex;
    gap: 3px;
    padding: 3px 0;
}
.preview-col {
    flex: 1;
    height: 24px;
    background: #f5f5f5;
    border-radius: 2px;
}

/* ── Dropdowns ── */
.dropdown {
    position: relative;
    display: inline-block;
}
.dropdown-toggle::after {
    content: '';
    display: inline-block;
    width: 0;
    height: 0;
    margin-left: 6px;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 4px solid currentColor;
    vertical-align: middle;
}
.dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 100;
    min-width: 180px;
    padding: 4px 0;
    background: var(--bg-surface, #fff);
    border: 1px solid var(--border-color, #e5e5e5);
    border-radius: var(--radius-200, 8px);
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    margin-top: 4px;
}
.dropdown-menu--right {
    left: auto;
    right: 0;
}
.dropdown-menu.is-open {
    display: block;
}
.dropdown-item {
    display: flex;
    align-items: center;
    gap: 8px;
    width: 100%;
    padding: 8px 14px;
    font-size: var(--font-size-sm, 0.8125rem);
    color: var(--text-primary, #303030);
    background: none;
    border: none;
    text-decoration: none;
    cursor: pointer;
    text-align: left;
    transition: background 0.1s;
}
.dropdown-item:hover {
    background: var(--bg-subdued, #f6f6f7);
}
.dropdown-item--danger {
    color: var(--color-danger, #dc3545);
}
.dropdown-item--danger:hover {
    background: #fef2f2;
}
.dropdown-divider {
    height: 1px;
    background: var(--border-color, #e5e5e5);
    margin: 4px 0;
}

/* ── Icon Button ── */
.btn-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    padding: 0;
    background: none;
    border: 1px solid transparent;
    border-radius: var(--radius-100, 4px);
    cursor: pointer;
    color: var(--text-secondary, #616161);
    transition: all 0.15s;
}
.btn-icon:hover {
    background: var(--bg-subdued, #f6f6f7);
    border-color: var(--border-color, #e5e5e5);
    color: var(--text-primary, #303030);
}

/* ── Modal ── */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}
.modal-box {
    background: var(--bg-surface, #fff);
    border-radius: var(--radius-300, 8px);
    box-shadow: 0 8px 32px rgba(0,0,0,0.2);
    width: 100%;
    max-width: 480px;
    overflow: hidden;
}
.modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid var(--border-color, #e5e5e5);
}
.modal-header h3 { margin: 0; font-size: 1.05rem; }
.modal-close {
    background: none; border: none; font-size: 1.4rem;
    cursor: pointer; color: var(--text-secondary, #616161);
    line-height: 1; padding: 0 4px;
}
.modal-close:hover { color: var(--text-primary, #303030); }
.modal-body { padding: 20px; }
.modal-footer {
    padding: 12px 20px;
    border-top: 1px solid var(--border-color, #e5e5e5);
    display: flex; gap: 8px; justify-content: flex-end;
}
.checkbox-label {
    display: flex; align-items: center; gap: 8px;
    font-size: var(--font-size-sm, 0.8125rem); cursor: pointer;
}

/* ── Responsive ── */
@media (max-width: 768px) {
    .active-theme-card {
        grid-template-columns: 1fr;
    }
    .active-theme-preview {
        min-height: 200px;
    }
    .theme-grid {
        grid-template-columns: 1fr;
    }
}
</style>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
// Dropdown toggles
document.querySelectorAll('[data-dropdown]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var id = this.getAttribute('data-dropdown');
        var menu = document.getElementById(id);
        var wasOpen = menu.classList.contains('is-open');
        document.querySelectorAll('.dropdown-menu.is-open').forEach(function(m) {
            m.classList.remove('is-open');
        });
        if (!wasOpen) menu.classList.add('is-open');
    });
});

document.addEventListener('click', function() {
    document.querySelectorAll('.dropdown-menu.is-open').forEach(function(m) {
        m.classList.remove('is-open');
    });
});

// Modal
document.getElementById('install-modal').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
});
document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        document.getElementById('install-modal').style.display = 'none';
        document.querySelectorAll('.dropdown-menu.is-open').forEach(function(m) {
            m.classList.remove('is-open');
        });
    }
});
</script>
{% endblock %}
