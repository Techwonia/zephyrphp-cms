{# ── Quill Editor Assets ──────────────────────────────────────────
     Include this in templates that need the richtext editor.
     Usage in child templates:
       {% block editor_styles %}{% include '@cms/partials/editor-assets.twig' with {part: 'css'} only %}{% endblock %}
       {% block editor_scripts %}{% include '@cms/partials/editor-assets.twig' with {part: 'js'} only %}{% endblock %}
   ─────────────────────────────────────────────────────────────── #}

{% if part == 'css' %}
<link rel="stylesheet" href="/cms-assets/css/quill.snow.css">
<link rel="stylesheet" href="/cms-assets/css/quill-table-better.css">
<style nonce="{{ csp_nonce() }}">
.ql-source-area{display:none;width:100%;min-height:200px;font-family:var(--font-mono);font-size:var(--text-sm);padding:var(--sp-4);border:none;outline:none;resize:vertical;background:#1e1e1e;color:#d4d4d4;line-height:1.6}
.ql-source-area.active{display:block}
.ql-container-hidden{display:none!important}
.ql-footer{display:flex;justify-content:space-between;align-items:center;padding:var(--sp-2) var(--sp-3);border-top:1px solid var(--border);background:var(--bg-subdued);font-size:var(--text-xs);color:var(--text-secondary)}
.ql-source-btn{background:none;border:1px solid var(--border);border-radius:var(--radius-sm);padding:2px 8px;font-size:11px;cursor:pointer;font-family:var(--font-mono);color:var(--text-secondary);transition:all var(--duration) var(--ease)}
.ql-source-btn:hover,.ql-source-btn.active{background:var(--zui-gray-800);color:#fff;border-color:var(--zui-gray-800)}
.ql-word-count{font-variant-numeric:tabular-nums}
.media-modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,0.5);z-index:600;display:flex;align-items:center;justify-content:center}
.media-modal{background:var(--bg-surface);border-radius:var(--radius-xl);box-shadow:var(--shadow-lg);width:90%;max-width:800px;max-height:85vh;display:flex;flex-direction:column;overflow:hidden;animation:zui-modal-enter var(--duration-slow) var(--ease)}
.media-modal-header{display:flex;align-items:center;justify-content:space-between;padding:var(--sp-4) var(--sp-5);border-bottom:1px solid var(--border)}
.media-modal-header h3{font-size:var(--text-md);font-weight:600;color:var(--text-heading);margin:0}
.media-modal-close{width:32px;height:32px;display:flex;align-items:center;justify-content:center;background:none;border:none;cursor:pointer;font-size:20px;color:var(--text-secondary);border-radius:var(--radius)}
.media-modal-close:hover{background:var(--bg-surface-hover)}
.media-modal-toolbar{display:flex;gap:var(--sp-3);padding:var(--sp-3) var(--sp-5);border-bottom:1px solid var(--border);flex-wrap:wrap;align-items:center}
.media-modal-search{display:flex;align-items:center;gap:var(--sp-2);flex:1;min-width:180px;background:var(--bg-subdued);border-radius:var(--radius);padding:0 var(--sp-3);border:1px solid var(--border)}
.media-modal-search svg{color:var(--text-disabled);flex-shrink:0}
.media-search-input{border:none;background:none;outline:none;padding:var(--sp-2) 0;font-size:var(--text-sm);font-family:var(--font-sans);width:100%;color:var(--text)}
.media-modal-filters{display:flex;gap:var(--sp-1)}
.media-filter-btn{padding:var(--sp-1) var(--sp-3);font-size:var(--text-xs);font-weight:500;border:1px solid var(--border);background:var(--bg-surface);border-radius:var(--radius-full);cursor:pointer;color:var(--text-secondary);font-family:var(--font-sans);transition:all var(--duration) var(--ease)}
.media-filter-btn:hover{border-color:var(--border-hover);color:var(--text)}
.media-filter-btn.active{background:var(--zui-primary-500);color:#fff;border-color:var(--zui-primary-500)}
.media-modal-body{flex:1;overflow-y:auto;padding:var(--sp-4) var(--sp-5)}
.media-modal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(120px,1fr));gap:var(--sp-3)}
.media-modal-item{cursor:pointer;border:2px solid transparent;border-radius:var(--radius);overflow:hidden;transition:border-color var(--duration) var(--ease)}
.media-modal-item:hover{border-color:var(--zui-primary-400)}
.media-modal-thumb{aspect-ratio:1;background:var(--zui-gray-100);overflow:hidden}
.media-modal-thumb img{width:100%;height:100%;object-fit:cover}
.media-modal-name{padding:var(--sp-1) var(--sp-2);font-size:11px;color:var(--text-secondary);overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.media-modal-upload-bar{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-5);border-top:1px solid var(--border);background:var(--bg-subdued)}
.media-upload-label{display:inline-flex;align-items:center;gap:var(--sp-2);padding:var(--sp-2) var(--sp-3);font-size:var(--text-sm);font-weight:500;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;transition:background var(--duration) var(--ease)}
.media-upload-label:hover{background:var(--bg-surface-hover)}
.media-upload-status{font-size:var(--text-xs);color:var(--text-secondary)}
</style>
{% endif %}

{% if part == 'js' %}
<script src="/cms-assets/js/quill.min.js"></script>
<script src="/cms-assets/js/quill-table-better.js"></script>
<script nonce="{{ csp_nonce() }}">
(function() {
    if (typeof Quill === 'undefined') return;
    var textareas = document.querySelectorAll('textarea.richtext-editor');
    if (!textareas.length) return;

    var hasTable = typeof QuillTableBetter !== 'undefined';
    if (hasTable) Quill.register({ 'modules/table-better': QuillTableBetter }, true);

    var toolbarOptions = [
        [{ 'header': [1, 2, 3, false] }],
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        ['blockquote', 'code-block'],
        ['link', 'image', 'video'],
        hasTable ? ['table-better'] : [],
        [{ 'align': [] }],
        ['clean']
    ].filter(function(g) { return g.length > 0; });

    var mediaUrl = '{{ admin_url("media/browse") }}';
    var uploadUrl = '{{ admin_url("media/upload") }}';
    var csrfInput = document.querySelector('input[name="csrf_token"], input[name="_token"]');
    var csrfVal = csrfInput ? csrfInput.value : '';

    function openRichtextMediaBrowser(filter, onSelect) {
        var modal = document.createElement('div');
        modal.className = 'media-modal-overlay';
        modal.innerHTML = '<div class="media-modal">'
            + '<div class="media-modal-header"><h3>Select from Media Library</h3><button type="button" class="media-modal-close">&times;</button></div>'
            + '<div class="media-modal-toolbar">'
            + '<div class="media-modal-search"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input type="text" class="media-search-input" placeholder="Search files..."></div>'
            + '<div class="media-modal-filters">'
            + '<button type="button" class="media-filter-btn' + (filter === 'all' ? ' active' : '') + '" data-filter="all">All</button>'
            + '<button type="button" class="media-filter-btn' + (filter === 'images' ? ' active' : '') + '" data-filter="images">Images</button>'
            + '<button type="button" class="media-filter-btn' + (filter === 'video' ? ' active' : '') + '" data-filter="video">Video</button>'
            + '</div></div>'
            + '<div class="media-modal-body"><p style="text-align:center;padding:40px;color:var(--text-secondary)">Loading...</p></div>'
            + '<div class="media-modal-upload-bar">'
            + '<label class="media-upload-label"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload<input type="file" class="media-upload-input" multiple style="display:none"'
            + (filter === 'images' ? ' accept="image/*"' : filter === 'video' ? ' accept="video/*"' : '')
            + '></label><span class="media-upload-status"></span></div></div>';
        document.body.appendChild(modal);

        var currentFilter = filter || 'all';
        var currentSearch = '';

        modal.querySelector('.media-modal-close').addEventListener('click', function() { modal.remove(); });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
        document.addEventListener('keydown', function onEsc(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onEsc); } });

        function loadItems() {
            var body = modal.querySelector('.media-modal-body');
            body.innerHTML = '<p style="text-align:center;padding:40px;color:var(--text-secondary)">Loading...</p>';
            fetch(mediaUrl + '?filter=' + currentFilter + '&per_page=36' + (currentSearch ? '&search=' + encodeURIComponent(currentSearch) : ''))
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    if (!data.data || !data.data.length) {
                        body.innerHTML = '<div class="empty-state" style="padding:var(--sp-10)"><p>No files found</p><p class="text-secondary text-sm">Upload using the button below</p></div>';
                        return;
                    }
                    var html = '<div class="media-modal-grid">';
                    data.data.forEach(function(item) {
                        var thumb = item.is_image ? '<img src="' + (item.thumbnail || item.url) + '" loading="lazy">' : '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:var(--text-secondary)"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg></div>';
                        html += '<div class="media-modal-item" data-url="' + item.url + '"><div class="media-modal-thumb">' + thumb + '</div><div class="media-modal-name">' + item.name + '</div></div>';
                    });
                    body.innerHTML = html + '</div>';
                    body.querySelectorAll('.media-modal-item').forEach(function(el) {
                        el.addEventListener('click', function() { onSelect(el.dataset.url); modal.remove(); });
                    });
                });
        }

        var searchTimer;
        modal.querySelector('.media-search-input').addEventListener('input', function() {
            clearTimeout(searchTimer); var v = this.value;
            searchTimer = setTimeout(function() { currentSearch = v; loadItems(); }, 300);
        });
        modal.querySelectorAll('.media-filter-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                modal.querySelectorAll('.media-filter-btn').forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active'); currentFilter = btn.dataset.filter; loadItems();
            });
        });
        modal.querySelector('.media-upload-input').addEventListener('change', function() {
            var files = this.files; if (!files.length) return;
            var status = modal.querySelector('.media-upload-status');
            status.textContent = 'Uploading...';
            var lastUrl = '', done = 0;
            Array.from(files).forEach(function(f) {
                var fd = new FormData(); fd.append('file', f); fd.append('csrf_token', csrfVal);
                var xhr = new XMLHttpRequest();
                xhr.open('POST', uploadUrl, true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.onload = function() {
                    done++;
                    try { var r = JSON.parse(xhr.responseText); if (r.path) lastUrl = '/' + r.path; } catch(e) {}
                    if (done >= files.length) {
                        if (lastUrl && files.length === 1) { onSelect(lastUrl); modal.remove(); }
                        else { status.textContent = 'Uploaded!'; loadItems(); }
                    }
                };
                xhr.onerror = function() { done++; status.textContent = 'Error'; };
                xhr.send(fd);
            });
        });
        loadItems();
    }

    textareas.forEach(function(textarea) {
        textarea.style.display = 'none';
        var wrap = document.createElement('div'); wrap.className = 'ql-wrap';
        var toolbarDiv = document.createElement('div'); toolbarDiv.className = 'ql-toolbar-container';
        var editorDiv = document.createElement('div'); editorDiv.innerHTML = textarea.value || '';
        var sourceArea = document.createElement('textarea'); sourceArea.className = 'ql-source-area';
        var footer = document.createElement('div'); footer.className = 'ql-footer';
        footer.innerHTML = '<span class="ql-word-count">0 words</span><button type="button" class="ql-source-btn">&lt;/&gt; HTML</button>';
        wrap.appendChild(toolbarDiv); wrap.appendChild(editorDiv); wrap.appendChild(sourceArea); wrap.appendChild(footer);
        textarea.parentNode.insertBefore(wrap, textarea.nextSibling);

        var quill = new Quill(editorDiv, {
            theme: 'snow',
            modules: {
                toolbar: { container: toolbarOptions, handlers: {
                    image: function() { var q = this.quill; openRichtextMediaBrowser('images', function(url) { var r = q.getSelection(true); q.insertEmbed(r.index, 'image', url); q.setSelection(r.index + 1); }); },
                    video: function() { var q = this.quill; openRichtextMediaBrowser('video', function(url) { var r = q.getSelection(true); q.insertEmbed(r.index, 'video', url); q.setSelection(r.index + 1); }); }
                }},
                'table-better': hasTable ? {} : undefined,
                keyboard: hasTable ? { bindings: QuillTableBetter.keyboardBindings } : {}
            },
            placeholder: textarea.placeholder || 'Write your content...',
        });

        var generatedToolbar = wrap.querySelector('.ql-toolbar');
        if (generatedToolbar && generatedToolbar !== toolbarDiv) toolbarDiv.appendChild(generatedToolbar);

        quill.on('text-change', function() {
            textarea.value = quill.getSemanticHTML();
            var text = quill.getText().trim();
            var words = text ? text.split(/\s+/).length : 0;
            footer.querySelector('.ql-word-count').textContent = words + ' word' + (words !== 1 ? 's' : '');
        });

        var initText = quill.getText().trim();
        var initWords = initText ? initText.split(/\s+/).length : 0;
        footer.querySelector('.ql-word-count').textContent = initWords + ' word' + (initWords !== 1 ? 's' : '');

        var isSource = false, sourceBtn = footer.querySelector('.ql-source-btn'), qlContainer = wrap.querySelector('.ql-container');
        sourceBtn.addEventListener('click', function() {
            isSource = !isSource;
            if (isSource) { sourceArea.value = quill.getSemanticHTML(); sourceArea.classList.add('active'); if (qlContainer) qlContainer.classList.add('ql-container-hidden'); sourceBtn.classList.add('active'); }
            else { quill.clipboard.dangerouslyPasteHTML(sourceArea.value); textarea.value = sourceArea.value; sourceArea.classList.remove('active'); if (qlContainer) qlContainer.classList.remove('ql-container-hidden'); sourceBtn.classList.remove('active'); }
        });
    });
})();
</script>
{% endif %}
