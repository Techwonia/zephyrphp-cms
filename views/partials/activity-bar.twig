{# Activity bar partial. Pass context: 'customizer' or 'code-editor' #}
<style nonce="{{ csp_style_nonce() }}">
.activity-bar {
    width: 48px;
    min-width: 48px;
    background: #1A1A1A;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 0;
    height: 100%;
    z-index: 90;
    border-right: 1px solid rgba(255,255,255,0.08);
}
.activity-bar-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    flex: 1;
}
.activity-bar-bottom {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding-top: 8px;
    border-top: 1px solid rgba(255,255,255,0.08);
}
.ab-item {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: #777;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
    cursor: pointer;
    border: none;
    background: none;
    padding: 0;
}
.ab-item:hover {
    background: rgba(255,255,255,0.08);
    color: #ccc;
    text-decoration: none;
}
.ab-item.active {
    color: #36FBA1;
    background: rgba(54,251,161,0.08);
}
.ab-item svg {
    width: 20px;
    height: 20px;
    stroke: currentColor;
    stroke-width: 1.5;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
}
.ab-item::after {
    content: attr(data-tooltip);
    position: absolute;
    left: calc(100% + 8px);
    top: 50%;
    transform: translateY(-50%);
    background: #303030;
    color: #fff;
    font-size: 12px;
    font-weight: 500;
    padding: 4px 10px;
    border-radius: 6px;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.15s;
    z-index: 200;
}
.ab-item:hover::after {
    opacity: 1;
}
.ab-separator {
    width: 24px;
    height: 1px;
    background: rgba(255,255,255,0.08);
    margin: 4px 0;
}
</style>

{% set theme_slug = theme.getSlug() %}
{% set ab_context = ab_context|default('customizer') %}

<nav class="activity-bar" id="activityBar">
    <div class="activity-bar-top">
        {% if ab_context == 'customizer' %}
        <button class="ab-item active" data-ab-panel="sections" data-tooltip="Sections">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'palette'} only %}
        </button>
        {% else %}
        <a href="/cms/themes/{{ theme_slug }}/customize" class="ab-item" data-tooltip="Customize">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'palette'} only %}
        </a>
        {% endif %}

        {% if ab_context == 'code-editor' %}
        <button class="ab-item active" data-ab-panel="files" data-tooltip="Explorer">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'folder'} only %}
        </button>
        {% else %}
        <a href="/cms/themes/{{ theme_slug }}/code" class="ab-item" data-tooltip="Code Editor">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'code'} only %}
        </a>
        {% endif %}

        <div class="ab-separator"></div>

        <button class="ab-item" data-ab-panel="pages" data-tooltip="Pages">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'layers'} only %}
        </button>
        <button class="ab-item" data-ab-panel="settings" data-tooltip="Settings">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}
        </button>
    </div>
    <div class="activity-bar-bottom">
        <a href="/cms/themes" class="ab-item" data-tooltip="Back to Themes">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'arrow-left'} only %}
        </a>
    </div>
</nav>
