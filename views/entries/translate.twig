{% extends "@cms/layouts/cms.twig" %}

{% block title %}Translate Entry #{{ entry.id }} — {{ language.getName() }}{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url('collections') }}">Collections</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}">{{ collection.getName() }}</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}">Entries</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}">{{ entry.id }}</a> /
    Translate
</div>

<div class="page-header" class="flex items-center justify-between">
    <h1 class="p-0">Translate to {{ language.getName() }} ({{ language.getNativeName() }})</h1>
    <div style="display: flex; gap: var(--sp-2); align-items: center;">
        {# Language selector #}
        <select onchange="if(this.value) window.location.href=this.value;" class="form-control" style="width: auto;">
            {% for lang in languages %}
                {% set defaultLocale = '' %}
                {% if lang.isDefault() %}
                    {% set defaultLocale = lang.getCode() %}
                {% endif %}
                {% if not lang.isDefault() %}
                <option value="/admin/collections/{{ collection.getSlug() }}/entries/{{ entry.id }}/translate/{{ lang.getCode() }}"
                    {% if lang.getCode() == locale %}selected{% endif %}>
                    {{ lang.getName() }} ({{ lang.getCode() }})
                </option>
                {% endif %}
            {% endfor %}
        </select>
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="btn btn-outline btn-sm">Back to Entry</a>
    </div>
</div>

<form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/translate/' ~ locale) }}">
    {{ csrf_field() | raw }}

    {% if translatableFields|length == 0 %}
    <div class="card" style="padding: var(--sp-6); text-align: center;">
        <p style="color: var(--text-secondary); margin: 0;">This collection has no translatable text fields.</p>
    </div>
    {% else %}
    <div class="grid grid-2 gap-4">
        {# Left: source (default locale) #}
        <div>
            <div style="font-weight: 600; margin-bottom: var(--sp-3); padding: var(--sp-2) 0; border-bottom: 2px solid var(--border);">
                Source (Original)
            </div>
            {% for field in translatableFields %}
            <div class="card" class="mb-3">
                <div style="padding: var(--sp-3) var(--sp-4);">
                    <label class="form-label" style="font-weight: 600; color: var(--text-secondary); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em;">
                        {{ field.getLabel() }}
                    </label>
                    {% if field.getType() == 'textarea' or field.getType() == 'richtext' %}
                    <div style="background: var(--bg-subdued); padding: var(--sp-3); border-radius: var(--radius-sm); min-height: 80px; font-size: var(--text-sm); white-space: pre-wrap; word-break: break-word;">{{ entry[field.getSlug()] ?? '' }}</div>
                    {% else %}
                    <div style="background: var(--bg-subdued); padding: var(--sp-2) var(--sp-3); border-radius: var(--radius-sm); font-size: var(--text-sm);">{{ entry[field.getSlug()] ?? '' }}</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>

        {# Right: translation #}
        <div>
            <div style="font-weight: 600; margin-bottom: var(--sp-3); padding: var(--sp-2) 0; border-bottom: 2px solid var(--zui-primary-500);">
                {{ language.getName() }} ({{ locale }})
            </div>
            {% for field in translatableFields %}
            <div class="card" class="mb-3">
                <div style="padding: var(--sp-3) var(--sp-4);">
                    <label class="form-label" style="font-weight: 600; color: var(--text-secondary); font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.05em;">
                        {{ field.getLabel() }}
                        {% if translations[field.getSlug()] is defined and translations[field.getSlug()] %}
                            <span style="color: var(--zui-success-600); font-size: 0.8em; font-weight: 400;">Translated</span>
                        {% else %}
                            <span style="color: var(--zui-warning-600); font-size: 0.8em; font-weight: 400;">Not translated</span>
                        {% endif %}
                    </label>
                    {% if field.getType() == 'textarea' or field.getType() == 'richtext' %}
                    <textarea name="translation_{{ field.getSlug() }}" class="form-control" rows="4" placeholder="Enter {{ language.getName() }} translation...">{{ translations[field.getSlug()] ?? '' }}</textarea>
                    {% else %}
                    <input type="text" name="translation_{{ field.getSlug() }}" class="form-control"
                           value="{{ translations[field.getSlug()] ?? '' }}"
                           placeholder="Enter {{ language.getName() }} translation...">
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <div style="margin-top: var(--sp-4); display: flex; gap: var(--sp-2);">
        <button type="submit" class="btn btn-primary">Save Translations</button>
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="btn btn-outline">Cancel</a>
    </div>
    {% endif %}
</form>
{% endblock %}
