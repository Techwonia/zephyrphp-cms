                </div>
                <div class="ee-sidebar-card-body ee-seo-body">
                    <div class="ee-sidebar-field">
                        <label for="meta_title" class="ee-sidebar-label">Meta Title</label>
                        <input type="text" id="meta_title" name="meta_title" class="form-control"
                               value="{{ entry.meta_title ?? '' }}" maxlength="255"
                               oninput="updateSeoCounter(this, 'meta-title-counter', 60)">
                        <div class="ee-seo-counter">
                            <span>Recommended: 30-60 chars</span>
                            <span id="meta-title-counter">{{ (entry.meta_title ?? '')|length }} / 60</span>
                        </div>
                    </div>

                    <div class="ee-sidebar-field">
                        <label for="meta_description" class="ee-sidebar-label">Meta Description</label>
                        <textarea id="meta_description" name="meta_description" class="form-control"
                                  rows="3" maxlength="500"
                                  oninput="updateSeoCounter(this, 'meta-desc-counter', 160)">{{ entry.meta_description ?? '' }}</textarea>
                        <div class="ee-seo-counter">
                            <span>Recommended: 120-160 chars</span>
                            <span id="meta-desc-counter">{{ (entry.meta_description ?? '')|length }} / 160</span>
                        </div>
                    </div>

                    <div class="ee-sidebar-field">
                        <label for="og_image" class="ee-sidebar-label">OG Image URL</label>
                        <input type="text" id="og_image" name="og_image" class="form-control"
                               value="{{ entry.og_image ?? '' }}" placeholder="https://example.com/image.jpg">
                        <p class="ee-field-hint">Social media preview image. 1200x630px recommended.</p>
                    </div>

                    <div class="ee-sidebar-field">
                        <label for="canonical_url" class="ee-sidebar-label">Canonical URL</label>
                        <input type="url" id="canonical_url" name="canonical_url" class="form-control"
                               value="{{ entry.canonical_url ?? '' }}" placeholder="https://...">
                    </div>

                    <div class="ee-sidebar-field">
                        <label for="robots" class="ee-sidebar-label">Robots</label>
                        <select id="robots" name="robots" class="form-control">
                            <option value="index,follow" {% if (entry.robots ?? 'index,follow') == 'index,follow' %}selected{% endif %}>Index, Follow</option>
                            <option value="index,nofollow" {% if (entry.robots ?? '') == 'index,nofollow' %}selected{% endif %}>Index, No Follow</option>
                            <option value="noindex,follow" {% if (entry.robots ?? '') == 'noindex,follow' %}selected{% endif %}>No Index, Follow</option>
                            <option value="noindex,nofollow" {% if (entry.robots ?? '') == 'noindex,nofollow' %}selected{% endif %}>No Index, No Follow</option>
                        </select>
                    </div>

                    {% if entry.id is defined and entry.id %}
                    <div id="seo-analysis" style="display: none;">
                        <h4 class="ee-sidebar-label" style="margin-top:var(--sp-3);">SEO Analysis</h4>
                        <ul id="seo-issues" class="ee-seo-issues"></ul>
                    </div>
                    {% endif %}
                </div>
            </div>
            {% endif %}

            {# --- Info Card --- #}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/><path d="M8 7v4.5M8 4.5v.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                    <span>Information</span>
                </div>
                <div class="ee-sidebar-card-body">
                    <div class="ee-sidebar-meta-row">
                        <span class="ee-sidebar-meta-label">Entry ID</span>
                        <span class="ee-sidebar-meta-value ee-mono">{{ entry.id }}</span>
                    </div>
                    {% if entry.created_at is defined and entry.created_at %}
                    <div class="ee-sidebar-meta-row">
                        <span class="ee-sidebar-meta-label">Created</span>
                        <span class="ee-sidebar-meta-value">{{ entry.created_at }}</span>
                    </div>
                    {% endif %}
                    {% if entry.updated_at is defined and entry.updated_at %}
                    <div class="ee-sidebar-meta-row">
                        <span class="ee-sidebar-meta-label">Updated</span>
                        <span class="ee-sidebar-meta-value">{{ entry.updated_at }}</span>
                    </div>
                    {% endif %}
                    {% if entry.created_by is defined and entry.created_by %}
                    <div class="ee-sidebar-meta-row">
                        <span class="ee-sidebar-meta-label">Created by</span>
                        <span class="ee-sidebar-meta-value">{{ entry.created_by }}</span>
                    </div>
                    {% endif %}
