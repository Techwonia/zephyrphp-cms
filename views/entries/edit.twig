{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Entry #{{ entry.id }} -- {{ collection.getName() }}{% endblock %}
{% block editor_styles %}{% include '@cms/partials/editor-assets.twig' with {part: 'css'} only %}{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/entries-edit.css">{% endblock %}

{% block content %}
{# --- Lock Warning Banner --- #}
{% if lockInfo %}
<div class="ee-lock-banner">
    <svg width="20" height="20" viewBox="0 0 20 20" fill="none" style="flex-shrink: 0;">
        <path d="M10 2L1 18h18L10 2z" fill="#f59e0b" stroke="#d97706" stroke-width="1"/>
        <text x="10" y="15" text-anchor="middle" font-size="11" font-weight="700" fill="#92400e">!</text>
    </svg>
    <span><strong>{{ lockInfo.user_name }}</strong> is currently editing this entry (since {{ lockInfo.locked_at|date('g:i A') }}). Your changes may be overwritten.</span>
</div>
{% endif %}


{# --- Breadcrumb --- #}
<div class="breadcrumb">
    <a href="{{ admin_url('collections') }}">Collections</a>
    <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}">{{ collection.getName() }}</a>
    <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}">Entries</a>
    <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg>
    {% set _df = collection.getDisplayField() %}
    {% set _entryLabel = (_df and entry[_df] is defined and entry[_df]) ? entry[_df] : (entry.title ?? entry.name ?? entry.slug ?? entry.label ?? ('#' ~ entry.id)) %}
    <span>{{ _entryLabel }}</span>
</div>

{# --- Page Header --- #}
<div class="ee-page-header">
    <div class="ee-page-header-left">
        <h1>{{ _entryLabel }}</h1>
    </div>
    <div class="ee-page-header-right">
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-outline">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="vertical-align: -2px; margin-right: 4px;">
                <path d="M10 12L6 8l4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            Back
        </a>
    </div>
</div>

{# --- Two-Column Layout --- #}
<form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" enctype="multipart/form-data" id="entry-form">
    {{ csrf_field() | raw }}

    <div class="ee-layout">
        {# ==================== MAIN COLUMN ==================== #}
        <div class="ee-main">

            {# Slug field moved to sidebar #}

            {# --- Field Cards --- #}
            {% for field in fields %}
            {% set fieldEditable = (editableFields is iterable) ? (field.getSlug() in editableFields) : true %}
            {% set _fSlug = field.getSlug() %}
            {% set val = entry[_fSlug] ?? field.getDefaultValue() ?? '' %}
            {% set _errs = flash('errors') ?? {} %}
            {% set hasError = _fSlug in (_errs|keys) %}

            <div class="ee-card{% if hasError %} ee-card-error{% endif %}">
                <div class="ee-card-header">
                    <span class="ee-card-title">
                        {{ field.getName() }}
                        {% if field.isRequired() %}<span class="ee-required">*</span>{% endif %}
                        {% if not fieldEditable %}<span class="ee-readonly-badge">Read-only</span>{% endif %}
                    </span>
                    <span class="ee-field-badge ee-badge-{{ field.getType() }}">{{ field.getType() }}</span>
                </div>
                <div class="ee-card-body">

                    {% if not fieldEditable %}
                        {# Read-only display #}
                        {% if field.getType() == 'boolean' %}
                            <div class="ee-readonly-value">
                                <span class="ee-bool-indicator {{ val == '1' or val == 1 or val == true ? 'ee-bool-yes' : 'ee-bool-no' }}">
                                    {{ val == '1' or val == 1 or val == true ? 'Yes' : 'No' }}
                                </span>
                            </div>
                        {% elseif field.getType() == 'image' and val and val is not iterable %}
                            <div class="ee-readonly-value">
                                <img src="{{ media_thumb(val) }}" alt="" class="ee-readonly-image">
                            </div>
                        {% elseif field.getType() == 'richtext' %}
                            <div class="ee-readonly-richtext">{{ val|raw }}</div>
                        {% else %}
                            <div class="ee-readonly-value">{{ val ?: '--' }}</div>
                        {% endif %}

                    {% elseif field.getType() == 'textarea' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control{% if hasError %} is-invalid{% endif %}"
                                  rows="4" {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                    {% elseif field.getType() == 'richtext' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control richtext-editor{% if hasError %} is-invalid{% endif %}"
                                  rows="8" {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                    {% elseif field.getType() == 'boolean' %}
                        <div class="ee-toggle-wrap">
                            <input type="hidden" name="{{ field.getSlug() }}" value="0">
                            <label class="ee-toggle">
                                <input type="checkbox" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" value="1"
                                       {% if val == '1' or val == 1 or val == true %}checked{% endif %}>
                                <span class="ee-toggle-slider"></span>
                                <span class="ee-toggle-label">{{ val == '1' or val == 1 or val == true ? 'Yes' : 'No' }}</span>
                            </label>
                        </div>

                    {% elseif field.getType() == 'number' %}
                        <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}" step="1"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'decimal' %}
                        <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}" step="0.01"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'email' %}
                        <input type="email" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'url' %}
                        <input type="url" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}" placeholder="https://"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'date' %}
                        <input type="date" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'datetime' %}
                        <input type="datetime-local" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val ? val|replace({' ': 'T'}) : '' }}"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'select' %}
                        <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                class="form-control{% if hasError %} is-invalid{% endif %}"
                                {% if field.isRequired() %}required{% endif %}>
                            <option value="">-- Select --</option>
                            {% if field.getOptions() and field.getOptions().choices is defined %}
                                {% for choice in field.getOptions().choices %}
                                    <option value="{{ choice }}" {% if val == choice %}selected{% endif %}>{{ choice }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>

                    {% elseif field.getType() == 'relation' %}
                        {% set relationType = field.getOptions().relation_type ?? 'one_to_one' %}
                        {% set displayField = field.getOptions().display_field ?? null %}
                        {% set isMulti = relationType != 'one_to_one' %}
                        {% set _relData = relationData[_fSlug]|default({}) %}
                        {% set _relHasHierarchy = _relData.hasHierarchy|default(false) %}
                        {% set _relDisplayField = _relData.displayField|default(displayField) %}

                        {% if _relHasHierarchy and not isMulti %}
                            {# Drill-down tree picker for hierarchy relation #}
                            {% set _relTreeJson = [] %}
                            {% for te in _relData.treeEntries|default([]) %}
                                {% set _rl = (_relDisplayField and te[_relDisplayField] is defined) ? te[_relDisplayField] : (te.title ?? te.name ?? te.slug ?? '#' ~ te.id) %}
                                {% set _relTreeJson = _relTreeJson|merge([{'id': te.id, 'label': _rl, 'parent_id': te.parent_id|default(''), 'depth': te._depth}]) %}
                            {% endfor %}
                            {% set _relVal = val is iterable ? '' : (val ?? '') %}
                            {% set _curRelLabel = 'Select...' %}
                            {% if _relVal %}{% for te in _relData.treeEntries|default([]) %}{% if te.id ~ '' == _relVal ~ '' %}{% set _curRelLabel = (_relDisplayField and te[_relDisplayField] is defined) ? te[_relDisplayField] : (te.title ?? te.name ?? '#' ~ te.id) %}{% endif %}{% endfor %}{% endif %}
                            <input type="hidden" name="{{ field.getSlug() }}" id="field_{{ field.getSlug() }}" value="{{ _relVal }}">
                            <div class="tree-picker rel-drill-picker" data-tree="{{ _relTreeJson|json_encode|e('html_attr') }}" data-current="{{ _relVal }}" data-field="{{ _fSlug }}">
                                <button type="button" class="tree-picker-btn">
                                    <span class="tp-label">{{ _curRelLabel }}</span>
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3"/></svg>
                                </button>
                                <div class="tree-picker-dropdown" style="display:none"></div>
                            </div>
                        {% else %}
                            {# Plain select for flat relations #}
                            {% set selectedIds = isMulti and val is iterable ? val : [] %}
                            <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}{% if isMulti %}[]{% endif %}"
                                    class="form-control{% if hasError %} is-invalid{% endif %}"
                                    {% if isMulti %}multiple size="6"{% endif %}
                                    {% if field.isRequired() %}required{% endif %}>
                                {% if not isMulti %}<option value="">Select...</option>{% endif %}
                                {% for relEntry in _relData.entries|default([]) %}
                                    {% set relLabel = (_relDisplayField and relEntry[_relDisplayField] is defined) ? relEntry[_relDisplayField] : (relEntry.title ?? relEntry.name ?? '#' ~ relEntry.id) %}
                                    {% if isMulti %}
                                        <option value="{{ relEntry.id }}" {% if relEntry.id in selectedIds %}selected{% endif %}>{{ relLabel }}</option>
                                    {% else %}
                                        <option value="{{ relEntry.id }}" {% if val == relEntry.id or val == relEntry.id ~ '' %}selected{% endif %}>{{ relLabel }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                        {% endif %}
                        {% if field.getOptions().relation_collection is defined %}
                            <p class="ee-field-hint">{{ relationType|replace({'_': ' '})|title }} -- Related to: {{ field.getOptions().relation_collection }}{% if isMulti %} (hold Ctrl to select multiple){% endif %}</p>
                        {% endif %}

                    {% elseif field.getType() == 'image' or field.getType() == 'file' %}
                        {% set fieldOpts = field.getOptions() ?? {} %}
                        {% set isMultiple = fieldOpts.multiple ?? false %}
                        {% set maxFiles = fieldOpts.max_files ?? 10 %}
                        {% set _resolved = mediaResolved[field.getSlug()]|default(null) %}
                        {% if isMultiple %}
                            {% set _hiddenVal = val is iterable ? val|json_encode : (val ?? '') %}
                            {% set _hasVal = val is iterable ? val|length > 0 : (val ? true : false) %}
                        {% else %}
                            {% set _hiddenVal = val is iterable ? '' : (val ?? '') %}
                            {% set _hasVal = val and val is not iterable %}
                        {% endif %}
                        <div class="media-field{% if isMultiple %} media-field-multiple{% endif %}" data-field="{{ field.getSlug() }}" data-filter="{{ field.getType() == 'image' ? 'images' : 'all' }}" data-multiple="{{ isMultiple ? '1' : '0' }}" data-max-files="{{ maxFiles }}"{% if _hasVal %} style="border-style: solid"{% endif %}{% if isMultiple and _resolved %} data-resolved="{{ _resolved|json_encode|e('html_attr') }}"{% endif %}>
                            <input type="hidden" name="{{ field.getSlug() }}" id="field_{{ field.getSlug() }}" value="{{ _hiddenVal }}">

                            {# Empty state #}
                            <div class="media-field-empty" id="media-empty-{{ field.getSlug() }}" {% if _hasVal %}style="display:none"{% endif %}>
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--text-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    {% if field.getType() == 'image' %}
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                    {% else %}
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                                    {% endif %}
                                </svg>
                                <p class="media-field-text">Click to select from media library</p>
                                <span class="media-field-hint">{% if field.getType() == 'image' %}PNG, JPG, GIF, WEBP{% else %}Any file type{% endif %}{% if isMultiple %} &middot; Up to {{ maxFiles }} files{% endif %}</span>
                            </div>

                            {# Single preview state #}
                            {% if not isMultiple %}
                            <div class="media-field-preview" id="media-preview-{{ field.getSlug() }}" {% if not _resolved %}style="display:none"{% else %}style="display:flex"{% endif %}>
                                {% if _resolved and _resolved.is_image %}
                                    <img src="{{ _resolved.thumb }}" alt="Selected" class="media-field-thumb">
                                {% elseif _resolved %}
                                    <div class="media-field-file-icon">&#128196;</div>
                                {% else %}
                                    <img src="" alt="Selected" class="media-field-thumb">
                                {% endif %}
                                <div class="media-field-info">
                                    <span class="media-field-name">{{ _resolved ? _resolved.name : '' }}</span>
                                    <button type="button" class="media-field-remove" data-field="{{ field.getSlug() }}">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        Remove
                                    </button>
                                </div>
                            </div>
                            {% endif %}

                            {# Multiple preview grid — populated by JS from resolved data #}
                            {% if isMultiple %}
                            <div class="media-field-grid" id="media-grid-{{ field.getSlug() }}" style="display:none"></div>
                            <button type="button" class="btn btn-outline btn-sm media-field-add-more" id="media-add-{{ field.getSlug() }}" style="display:none" data-field="{{ field.getSlug() }}">+ Add more</button>
                            {% endif %}
                        </div>

                    {% elseif field.getType() == 'json' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control ee-json-field{% if hasError %} is-invalid{% endif %}"
                                  rows="5"
                                  placeholder='{"key": "value"}'
                                  {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                    {% else %}
                        {# text, slug, and any other type #}
                        <input type="text" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ val }}"
                               {% if field.isRequired() %}required{% endif %}>
                    {% endif %}

                    {% set _fOpts = field.getOptions() %}
                    {% if _fOpts and _fOpts.max_length is defined and _fOpts.max_length %}
                    <div style="text-align:right;font-size:var(--font-xs,0.75rem);color:var(--text-secondary,#616161);margin-top:4px;">
                        <span class="js-char-count" data-field="{{ _fSlug }}" data-max="{{ _fOpts.max_length }}">0</span> / {{ _fOpts.max_length }}
                    </div>
                    {% endif %}

                    {% if hasError %}
                        <div class="invalid-feedback">{{ _errs[_fSlug] }}</div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}

        </div>

        {# ==================== SIDEBAR ==================== #}
        <div class="ee-sidebar">

            {# --- Publishing Card --- #}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="3" fill="currentColor"/></svg>
                    <span>Publishing</span>
                </div>
                <div class="ee-sidebar-card-body">
                    {% if collection.isPublishable() %}
                    <div class="ee-sidebar-field">
                        <label for="status" class="ee-sidebar-label">Status</label>
                        <select id="status" name="status" class="form-control ee-status-select" onchange="document.getElementById('schedule-group').style.display=this.value==='scheduled'?'':'none'; this.className='form-control ee-status-select ee-status-'+this.value;">
                            <option value="draft" {% if entry.status is defined and entry.status == 'draft' %}selected{% endif %}>Draft</option>
                            <option value="published" {% if entry.status is defined and entry.status == 'published' %}selected{% endif %}>Published</option>
                            <option value="scheduled" {% if entry.status is defined and entry.status == 'scheduled' %}selected{% endif %}>Scheduled</option>
                        </select>
                    </div>
                    {% if entry.published_at is defined and entry.published_at %}
                    <div class="ee-sidebar-meta-row">
                        <span class="ee-sidebar-meta-label">Published at</span>
                        <span class="ee-sidebar-meta-value">{{ entry.published_at }}</span>
                    </div>
                    {% endif %}
                    <div id="schedule-group" class="ee-sidebar-field" style="{% if entry.status is not defined or entry.status != 'scheduled' %}display: none;{% endif %}">
                        <label for="scheduled_at" class="ee-sidebar-label">Publish At</label>
                        <input type="datetime-local" id="scheduled_at" name="scheduled_at" class="form-control"
                               value="{{ entry.scheduled_at is defined and entry.scheduled_at ? entry.scheduled_at|replace({' ': 'T'}) : '' }}">
                        <p class="ee-field-hint">Auto-publishes at this date/time.</p>
                    </div>
                    {% endif %}

                    <div class="ee-sidebar-btn-group">
                        <button type="submit" class="btn btn-primary ee-btn-save">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="vertical-align: -2px; margin-right: 4px;">
                                <path d="M13.3 4.7L6.3 11.7 2.7 8.1" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            Save Changes
                        </button>
                        <button type="button" class="btn btn-outline ee-btn-preview" id="preview-btn">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="vertical-align: -2px; margin-right: 4px;">
                                <path d="M1 8s3-5.5 7-5.5S15 8 15 8s-3 5.5-7 5.5S1 8 1 8z" stroke="currentColor" stroke-width="1.2"/><circle cx="8" cy="8" r="2" stroke="currentColor" stroke-width="1.2"/>
                            </svg>
                            Preview
                        </button>
                    </div>
                </div>
            </div>

            {# --- Parent Selector Card (Hierarchy) --- #}
            {% if collection.hasHierarchy() %}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M11 14v-1.33a2.67 2.67 0 0 0-2.67-2.67H3.33A2.67 2.67 0 0 0 .67 12.67V14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><circle cx="6" cy="4.67" r="2.67" stroke="currentColor" stroke-width="1.2"/><path d="M15.33 14v-1.33a2.67 2.67 0 0 0-2-2.58" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M10.67 2.09a2.67 2.67 0 0 1 0 5.17" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    <span>Parent</span>
                </div>
                <div class="ee-sidebar-card-body">
                    <input type="hidden" name="parent_id" id="parent-id-input" value="{{ entry.parent_id ?? '' }}">
                    {% set _dfKey = collection.getDisplayField() %}
                    {% set _currentParentLabel = 'None (top level)' %}
                    {% if entry.parent_id is defined and entry.parent_id %}
                        {% for item in treeEntries %}
                            {% if item.id == entry.parent_id %}
                                {% set _currentParentLabel = (_dfKey and item[_dfKey] is defined and item[_dfKey]) ? item[_dfKey] : (item.title ?? item.name ?? item.slug ?? ('#' ~ item.id)) %}
                            {% endif %}
                        {% endfor %}
                    {% endif %}
                    {# Build JSON tree data for drill-down picker #}
                    {% set _treeJson = [] %}
                    {% for item in treeEntries %}
                        {% set _lbl = (_dfKey and item[_dfKey] is defined and item[_dfKey]) ? item[_dfKey] : (item.title ?? item.name ?? item.slug ?? ('#' ~ item.id)) %}
                        {% set _treeJson = _treeJson|merge([{'id': item.id, 'label': _lbl, 'parent_id': item.parent_id|default(''), 'depth': item._depth, 'disabled': (entry.id is defined and entry.id == item.id)}]) %}
                    {% endfor %}
                    <div class="tree-picker" id="parent-tree-picker" data-tree="{{ _treeJson|json_encode|e('html_attr') }}" data-current="{{ entry.parent_id ?? '' }}" data-self="{{ entry.id ?? '' }}">
                        <button type="button" class="tree-picker-btn" id="tree-picker-toggle">
                            <span id="tree-picker-label">{{ _currentParentLabel }}</span>
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3"/></svg>
                        </button>
                        <div class="tree-picker-dropdown" id="tree-picker-dropdown" style="display:none"></div>
                    </div>
                </div>
            </div>
            {% endif %}

            {# --- URL Slug Card --- #}
            {% if collection.hasSlug() %}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6.5 11.5L4 14a2.12 2.12 0 01-3-3l2.5-2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M9.5 4.5L12 2a2.12 2.12 0 013 3l-2.5 2.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><line x1="6" y1="10" x2="10" y2="6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                    <span>URL Slug</span>
                </div>
                <div class="ee-sidebar-card-body">
                    {% if collection.getUrlPrefix() %}
                    <div style="font-size:var(--font-xs,0.75rem);color:var(--text-secondary,#616161);margin-bottom:6px;">/{{ collection.getUrlPrefix() }}/</div>
                    {% endif %}
                    <div style="display:flex;align-items:center;gap:6px;">
                        <input type="text" id="entry-slug" name="slug" class="form-control"
                               value="{{ entry.slug ?? '' }}" readonly
                               style="flex:1;font-size:var(--font-sm,0.8125rem);background:var(--bg-subdued,#FAFAFA);cursor:default;">
                        <button type="button" id="slug-edit-btn" style="padding:3px 10px;border:1px solid var(--border,#E3E3E3);border-radius:6px;background:var(--bg-surface,#fff);color:var(--color-primary,#1A7BA8);font-size:var(--font-xs,0.75rem);cursor:pointer;white-space:nowrap;font-family:inherit;">Edit</button>
                    </div>
                    <div id="slug-redirect-row" style="display:none;">
                        {% if entry.slug %}
                        <label style="display:flex;align-items:center;gap:6px;margin-top:8px;font-size:var(--font-xs,0.75rem);color:var(--text-secondary,#616161);cursor:pointer;">
                            <input type="checkbox" name="create_slug_redirect" value="1" checked style="margin:0;">
                            Create redirect from old URL
                        </label>
                        {% endif %}
                    </div>
                </div>
            </div>
            {% endif %}

            {# --- Actions Card --- #}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="3" r="1.5" fill="currentColor"/><circle cx="8" cy="8" r="1.5" fill="currentColor"/><circle cx="8" cy="13" r="1.5" fill="currentColor"/></svg>
                    <span>Actions</span>
                </div>
                <div class="ee-sidebar-card-body ee-actions-body">
                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/duplicate') }}" style="display:contents">
                        {{ csrf_field() | raw }}
                        <button type="submit" class="ee-action-btn" onclick="return confirm('Duplicate this entry?')">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><rect x="5" y="5" width="9" height="9" rx="1.5" stroke="currentColor" stroke-width="1.2"/><path d="M3 11V3a1.5 1.5 0 011.5-1.5H11" stroke="currentColor" stroke-width="1.2"/></svg>
                            Duplicate
                        </button>
                    </form>

                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/history') }}" class="ee-action-btn">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/><path d="M8 4.5V8l2.5 1.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                        History
                    </a>

                    <button type="button" class="ee-action-btn" onclick="document.getElementById('save-template-modal').style.display='flex'">
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 2h8l4 4v8a1 1 0 01-1 1H2a1 1 0 01-1-1V3a1 1 0 011-1z" stroke="currentColor" stroke-width="1.2"/><path d="M5 1v4h5" stroke="currentColor" stroke-width="1.2"/><path d="M5 10h6M5 12.5h3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                        Save as Template
                    </button>

                    {% if collection.isTranslatable() %}
                    {% set activeLangs = available_locales() %}
                    {% if activeLangs|length > 1 %}
                    <div class="ee-action-group">
                        <div class="ee-action-group-label">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2"/><path d="M1.5 8h13M8 1.5c-2 2-2 11 0 13M8 1.5c2 2 2 11 0 13" stroke="currentColor" stroke-width="1.2"/></svg>
                            Translate
                        </div>
                        <div class="ee-lang-links">
                            {% for lang in activeLangs %}
                                {% if not lang.isDefault() %}
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/translate/' ~ lang.getCode()) }}"
                                   class="ee-lang-btn">{{ lang.getCode()|upper }}</a>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}
                    {% endif %}

                    <div class="ee-action-divider"></div>

                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/delete') }}"
                          style="display:contents" class="confirm-delete" data-message="Delete this entry?">
                        {{ csrf_field() | raw }}
                        <button type="submit" class="ee-action-btn ee-action-danger">
                            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M5.3 4V2.7a1 1 0 011-1h3.4a1 1 0 011 1V4M6.5 7v4.5M9.5 7v4.5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/><path d="M3.5 4l.7 9.3a1 1 0 001 .9h5.6a1 1 0 001-.9L12.5 4" stroke="currentColor" stroke-width="1.2"/></svg>
                            Delete Entry
                        </button>
                    </form>
                </div>
            </div>

            {# --- Workflow Card --- #}
            {% if collection.isWorkflowEnabled() %}
            {% set currentStage = entry.status ?? 'draft' %}
            {% set stages = workflow_stages(collection) %}
            <div class="ee-sidebar-card">
                <div class="ee-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M1 8h3l2-5 4 10 2-5h3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    <span>Workflow</span>
                </div>
                <div class="ee-sidebar-card-body">
                    {# Stage progress indicator #}
                    <div class="ee-workflow-stages">
                        {% for stage in stages %}
                        {% set isCurrent = stage == currentStage %}
                        {% set isPast = false %}
                        {% for s in stages %}
                            {% if s == currentStage %}
                                {% set isPast = false %}
                            {% endif %}
                        {% endfor %}
                        <div class="ee-workflow-stage {% if isCurrent %}ee-stage-active{% endif %}">
                            <div class="ee-stage-dot {% if isCurrent %}ee-dot-active{% endif %}"></div>
                            <span class="ee-stage-name">{{ stage|capitalize }}</span>
                        </div>
                        {% if not loop.last %}
                        <div class="ee-stage-connector"></div>
                        {% endif %}
                        {% endfor %}
                    </div>

                    {# Comment input #}
                    <div class="ee-sidebar-field" class="mt-3">
