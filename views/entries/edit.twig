                            {% endfor %}
                            <button type="submit" class="btn btn-primary ee-btn-advance">Advance{% if nextStage is defined and nextStage %} to {{ nextStage|capitalize }}{% endif %}</button>
                        </form>
                        {% endif %}
                    </div>

                    {# Transition History (collapsible) #}
                    {% set history = workflow_history(collection.getTableName(), entry.id) %}
                    {% if history|length > 0 %}
