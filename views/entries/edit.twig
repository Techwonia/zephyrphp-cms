{# --- SEO Counter Function --- #}
<script nonce="{{ csp_nonce() }}">
function updateSeoCounter(el, counterId, recommended) {
    var counter = document.getElementById(counterId);
    if (!counter) return;
    var len = el.value.length;
    counter.textContent = len + ' / ' + recommended;
    if (len > 0 && len <= recommended) {
        counter.style.color = '#28a745';
    } else if (len > recommended) {
        counter.style.color = '#dc3545';
    } else {
        counter.style.color = '';
    }
}
</script>

{# --- SEO Score Fetch --- #}
{% if collection.isSeoEnabled() and entry.id is defined and entry.id %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var slug = '{{ collection.getSlug()|e('js') }}';
    var entryId = '{{ entry.id|e('js') }}';
    fetch('/admin/collections/' + slug + '/entries/' + entryId + '/seo-score')
        .then(function(r) { return r.json(); })
        .then(function(data) {
            var badge = document.getElementById('seo-score-badge');
            if (badge && data.score !== undefined) {
                badge.style.display = '';
                badge.textContent = data.score + '/100';
                if (data.score >= 80) {
                    badge.style.background = '#d4edda'; badge.style.color = '#155724';
                } else if (data.score >= 50) {
                    badge.style.background = '#fff3cd'; badge.style.color = '#856404';
                } else {
                    badge.style.background = '#f8d7da'; badge.style.color = '#721c24';
                }
            }
            var analysis = document.getElementById('seo-analysis');
            var issuesList = document.getElementById('seo-issues');
            if (analysis && issuesList && data.issues && data.issues.length > 0) {
                analysis.style.display = '';
                data.issues.forEach(function(issue) {
                    var li = document.createElement('li');
                    li.textContent = '-- ' + issue;
                    issuesList.appendChild(li);
                });
            }
        }).catch(function() {});
})();
</script>
{% endif %}

{# --- Template Modal, Preview, Content Lock --- #}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Close template modal on overlay click
    var templateModal = document.getElementById('save-template-modal');
    if (templateModal) {
        templateModal.addEventListener('click', function(e) {
            if (e.target === templateModal) templateModal.style.display = 'none';
        });
    }

    // Preview — submit form to preview endpoint in a new tab
    document.getElementById('preview-btn')?.addEventListener('click', function() {
        var form = document.getElementById('entry-form');
        if (!form) return;
        var originalAction = form.action;
        var originalTarget = form.target;
        form.action = originalAction + '/preview';
        form.target = '_blank';
        form.submit();
        form.action = originalAction;
        form.target = originalTarget;
    });

    // Content Lock — heartbeat every 2 minutes, unlock on page leave
    var csrfToken = '{{ csrf_token() }}';
    var heartbeatUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/heartbeat') }}';
    var unlockUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/unlock') }}';

    var heartbeatInterval = setInterval(function() {
        var fd = new FormData();
        fd.append('_token', csrfToken);
        fetch(heartbeatUrl, { method: 'POST', body: fd, credentials: 'same-origin' });
    }, 120000);

    function releaseLock() {
        var fd = new FormData();
        fd.append('_token', csrfToken);
        if (navigator.sendBeacon) {
            navigator.sendBeacon(unlockUrl, fd);
        } else {
            fetch(unlockUrl, { method: 'POST', body: fd, credentials: 'same-origin', keepalive: true });
        }
    }
    window.addEventListener('beforeunload', releaseLock);

    // Character counter for max_length fields
    document.querySelectorAll('.js-char-count').forEach(function(span) {
        var slug = span.dataset.field;
        var max = parseInt(span.dataset.max, 10);
        var input = document.getElementById('field_' + slug);
        if (!input) return;
        function update() {
            var len = (input.value || '').length;
            span.textContent = len;
            span.parentElement.style.color = len > max ? 'var(--color-critical, #D72C0D)' : 'var(--text-secondary, #616161)';
        }
        input.addEventListener('input', update);
        update();
    });

    // Drill-down tree picker for parent selection
    (function() {
        var picker = document.getElementById('parent-tree-picker');
        if (!picker) return;
        var toggle = document.getElementById('tree-picker-toggle');
        var dropdown = document.getElementById('tree-picker-dropdown');
        var hiddenInput = document.getElementById('parent-id-input');
        var labelEl = document.getElementById('tree-picker-label');
        var treeData = JSON.parse(picker.dataset.tree || '[]');
        var currentVal = picker.dataset.current || '';
        var selfId = picker.dataset.self || '';

        // Build parent→children map
        var childrenOf = {};
        var itemMap = {};
        treeData.forEach(function(item) {
            itemMap[item.id] = item;
            var pid = item.parent_id || '__root__';
            if (!childrenOf[pid]) childrenOf[pid] = [];
            childrenOf[pid].push(item);
        });

        function getChildren(parentId) {
            return childrenOf[parentId || '__root__'] || [];
        }

        function renderLevel(parentId, parentLabel) {
            var html = '';
            // Back button (if not root)
            if (parentId) {
                var parent = itemMap[parentId];
                var grandParentId = parent ? (parent.parent_id || '') : '';
                html += '<div class="tp-back" data-go="' + grandParentId + '">'
                    + '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>'
                    + (parentLabel || 'Back')
                    + '</div>';
                // "Select this" option
                html += '<div class="tp-select-current" data-select="' + parentId + '" data-label="' + (parentLabel || '').replace(/"/g, '&quot;') + '">'
                    + '● Select: ' + (parentLabel || '#' + parentId)
                    + '</div>';
            } else {
                // Root level — show "None" option
                html += '<div class="tp-none' + (!currentVal ? ' active' : '') + '" data-select="" data-label="None (top level)">None (top level)</div>';
            }
            // Children
            var children = getChildren(parentId);
            children.forEach(function(child) {
                var hasKids = (childrenOf[child.id] || []).length > 0;
                var isActive = currentVal == child.id;
                var isDisabled = selfId && selfId == child.id;
                html += '<div class="tp-item' + (isActive ? ' active' : '') + (isDisabled ? ' disabled' : '') + '" '
                    + 'data-id="' + child.id + '" data-label="' + child.label.replace(/"/g, '&quot;') + '" '
                    + (hasKids ? 'data-drill="1"' : '') + '>'
                    + '<span>' + child.label + '</span>'
                    + (hasKids ? '<span class="tp-item-arrow">›</span>' : '')
                    + '</div>';
            });
            if (children.length === 0 && parentId) {
                html += '<div style="padding:12px;text-align:center;color:#999;font-size:12px;">No children</div>';
            }
            dropdown.innerHTML = html;
            bindEvents();
        }

        function bindEvents() {
            // Back
            dropdown.querySelectorAll('.tp-back').forEach(function(el) {
                el.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var goTo = el.dataset.go;
                    var parentItem = goTo ? itemMap[goTo] : null;
                    renderLevel(goTo || '', parentItem ? parentItem.label : '');
                });
            });
            // Select
            dropdown.querySelectorAll('[data-select]').forEach(function(el) {
                el.addEventListener('click', function(e) {
                    e.stopPropagation();
                    currentVal = el.dataset.select;
                    hiddenInput.value = currentVal;
                    labelEl.textContent = el.dataset.label;
                    dropdown.style.display = 'none';
                });
            });
            // Drill into children
            dropdown.querySelectorAll('.tp-item[data-drill]').forEach(function(el) {
                el.addEventListener('click', function(e) {
                    e.stopPropagation();
                    renderLevel(el.dataset.id, el.dataset.label);
                });
            });
            // Select leaf items (no drill)
            dropdown.querySelectorAll('.tp-item:not([data-drill]):not(.disabled)').forEach(function(el) {
                el.addEventListener('click', function(e) {
                    e.stopPropagation();
                    currentVal = el.dataset.id;
                    hiddenInput.value = currentVal;
                    labelEl.textContent = el.dataset.label;
                    dropdown.style.display = 'none';
                });
            });
        }

        toggle.addEventListener('click', function(e) {
            e.preventDefault();
            if (dropdown.style.display === 'none') {
                renderLevel('', '');
                dropdown.style.display = 'block';
            } else {
                dropdown.style.display = 'none';
            }
        });
        document.addEventListener('click', function(e) {
            if (!e.target.closest('#parent-tree-picker')) dropdown.style.display = 'none';
        });
    })();

    // Drill-down for relation fields pointing to hierarchy collections
    document.querySelectorAll('.rel-drill-picker').forEach(function(picker) {
        var treeData = JSON.parse(picker.dataset.tree || '[]');
        var fieldSlug = picker.dataset.field;
        var currentVal = picker.dataset.current || '';
        var toggle = picker.querySelector('.tree-picker-btn');
        var dropdown = picker.querySelector('.tree-picker-dropdown');
        var hiddenInput = document.getElementById('field_' + fieldSlug);
        var labelEl = picker.querySelector('.tp-label');
        if (!toggle || !dropdown || !hiddenInput) return;
        var childrenOf = {}, itemMap = {};
        treeData.forEach(function(item) { itemMap[item.id] = item; var pid = item.parent_id || '__root__'; if (!childrenOf[pid]) childrenOf[pid] = []; childrenOf[pid].push(item); });
        function renderLevel(parentId, parentLabel) {
            var html = '';
            if (parentId) {
                var parent = itemMap[parentId]; var gpId = parent ? (parent.parent_id || '') : '';
                html += '<div class="tp-back" data-go="' + gpId + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><polyline points="15 18 9 12 15 6"/></svg>' + (parentLabel || 'Back') + '</div>';
                html += '<div class="tp-select-current" data-select="' + parentId + '" data-label="' + (parentLabel || '').replace(/"/g, '&quot;') + '">● Select: ' + parentLabel + '</div>';
            } else {
                html += '<div class="tp-none' + (!currentVal ? ' active' : '') + '" data-select="" data-label="Select...">None</div>';
            }
            (childrenOf[parentId || '__root__'] || []).forEach(function(child) {
                var hasKids = (childrenOf[child.id] || []).length > 0;
                html += '<div class="tp-item' + (currentVal == child.id ? ' active' : '') + '" data-id="' + child.id + '" data-label="' + child.label.replace(/"/g, '&quot;') + '"' + (hasKids ? ' data-drill="1"' : '') + '><span>' + child.label + '</span>' + (hasKids ? '<span class="tp-item-arrow">›</span>' : '') + '</div>';
            });
            dropdown.innerHTML = html;
            dropdown.querySelectorAll('.tp-back').forEach(function(el) { el.addEventListener('click', function(e) { e.stopPropagation(); var p = itemMap[el.dataset.go]; renderLevel(el.dataset.go || '', p ? p.label : ''); }); });
            dropdown.querySelectorAll('[data-select]').forEach(function(el) { el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.select; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; }); });
            dropdown.querySelectorAll('.tp-item[data-drill]').forEach(function(el) { el.addEventListener('click', function(e) { e.stopPropagation(); renderLevel(el.dataset.id, el.dataset.label); }); });
            dropdown.querySelectorAll('.tp-item:not([data-drill])').forEach(function(el) { el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.id; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; }); });
        }
        toggle.addEventListener('click', function(e) { e.preventDefault(); if (dropdown.style.display === 'none') { renderLevel('', ''); dropdown.style.display = 'block'; } else { dropdown.style.display = 'none'; } });
        document.addEventListener('click', function(e) { if (!e.target.closest('.rel-drill-picker[data-field="' + fieldSlug + '"]')) dropdown.style.display = 'none'; });
    });

    // Slug edit toggle (Shopify pattern: readonly by default, click Edit to unlock)
    {% if collection.hasSlug() %}
    var slugInput = document.getElementById('entry-slug');
    var slugEditBtn = document.getElementById('slug-edit-btn');
    var slugRedirectRow = document.getElementById('slug-redirect-row');
    if (slugInput && slugEditBtn) {
        slugEditBtn.addEventListener('click', function() {
            slugInput.readOnly = false;
            slugInput.style.background = '';
            slugInput.style.cursor = '';
            slugInput.focus();
            slugInput.select();
            slugEditBtn.style.display = 'none';
            if (slugRedirectRow && slugInput.value) slugRedirectRow.style.display = '';
        });
        // Mark as manual edit once user types
        slugInput.addEventListener('input', function() {
            this.dataset.manual = '1';
        });
    }

    // Slug auto-generation (only for new entries without a slug)
    {% if collection.getSlugSourceField() %}
    var sourceField = '{{ collection.getSlugSourceField() }}';
    var sourceInput = document.querySelector('[name="' + sourceField + '"]');
    if (sourceInput && slugInput && !slugInput.value) {
        sourceInput.addEventListener('input', function() {
            if (!slugInput.dataset.manual && !slugInput.readOnly) {
                slugInput.value = this.value.toLowerCase()
                    .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            }
        });
    }
    {% endif %}
    {% endif %}

    // Boolean toggle label update
    document.querySelectorAll('.ee-toggle input[type="checkbox"]').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var label = this.closest('.ee-toggle').querySelector('.ee-toggle-label');
            if (label) label.textContent = this.checked ? 'Yes' : 'No';
        });
    });
})();
</script>

{# --- Media Browser --- #}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Media Field — click to browse
    var mediaUrl = '{{ admin_url("media/browse") }}';

    document.querySelectorAll('.media-field').forEach(function(zone) {
        zone.addEventListener('click', function(e) {
            if (e.target.closest('.media-field-remove') || e.target.closest('.media-field-grid-remove') || e.target.closest('.media-field-add-more')) return;
            var fieldSlug = zone.dataset.field;
            var filter = zone.dataset.filter || 'all';
            var isMultiple = zone.dataset.multiple === '1';
            var maxFiles = parseInt(zone.dataset.maxFiles) || 10;
            openMediaBrowser(fieldSlug, filter, isMultiple, maxFiles);
        });
    });

    // Add more button
    document.querySelectorAll('.media-field-add-more').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var fieldSlug = btn.dataset.field;
            var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
            var filter = zone.dataset.filter || 'all';
            var maxFiles = parseInt(zone.dataset.maxFiles) || 10;
            openMediaBrowser(fieldSlug, filter, true, maxFiles);
        });
    });

    // Remove button (single mode)
    document.addEventListener('click', function(e) {
        var removeBtn = e.target.closest('.media-field-remove');
        if (removeBtn) {
            e.stopPropagation();
            var fieldSlug = removeBtn.dataset.field;
            document.getElementById('field_' + fieldSlug).value = '';
            document.getElementById('media-preview-' + fieldSlug).style.display = 'none';
            document.getElementById('media-empty-' + fieldSlug).style.display = '';
            var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
            if (zone) zone.style.borderStyle = 'dashed';
        }
    });

    // Remove button (multi mode — remove single item from grid)
    document.addEventListener('click', function(e) {
        var gridRemove = e.target.closest('.media-field-grid-remove');
        if (gridRemove) {
            e.stopPropagation();
            var fieldSlug = gridRemove.dataset.field;
            var removeId = parseInt(gridRemove.dataset.id, 10);
            var hiddenInput = document.getElementById('field_' + fieldSlug);
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            current = current.filter(function(id) { return id !== removeId; });
            hiddenInput.value = current.length ? JSON.stringify(current) : '';
            gridRemove.closest('.media-field-grid-item').remove();
            if (current.length === 0) {
                var grid = document.getElementById('media-grid-' + fieldSlug);
                var addBtn = document.getElementById('media-add-' + fieldSlug);
                if (grid) grid.style.display = 'none';
                if (addBtn) addBtn.style.display = 'none';
                document.getElementById('media-empty-' + fieldSlug).style.display = '';
                var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
                if (zone) zone.style.borderStyle = 'dashed';
            }
        }
    });

    // Workflow comment -> hidden fields
    var wfComment = document.getElementById('workflow-comment');
    if (wfComment) {
        var advForm = document.getElementById('workflow-advance-form');
        var rejForm = document.getElementById('workflow-reject-form');
        if (advForm) advForm.addEventListener('submit', function() {
            document.getElementById('advance-comment').value = wfComment.value;
        });
        if (rejForm) rejForm.addEventListener('submit', function() {
            document.getElementById('reject-comment').value = wfComment.value;
        });
    }

    function selectMediaItem(fieldSlug, mediaId, url, name, isImage, isMultiple) {
        var hiddenInput = document.getElementById('field_' + fieldSlug);
        var emptyState = document.getElementById('media-empty-' + fieldSlug);
        var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');

        if (isMultiple) {
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            if (!Array.isArray(current)) current = [];
            var id = parseInt(mediaId, 10);
            if (current.indexOf(id) === -1) current.push(id);
            hiddenInput.value = JSON.stringify(current);

            var grid = document.getElementById('media-grid-' + fieldSlug);
            var addBtn = document.getElementById('media-add-' + fieldSlug);
            emptyState.style.display = 'none';
            grid.style.display = '';
            addBtn.style.display = '';
            if (zone) zone.style.borderStyle = 'solid';

            var item = document.createElement('div');
            item.className = 'media-field-grid-item';
            item.dataset.id = id;
            if (isImage) {
                item.innerHTML = '<img src="' + url + '" alt="' + name + '"><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + id + '">&times;</button><div class="media-field-grid-item-name">' + name + '</div>';
            } else {
                item.innerHTML = '<div class="media-grid-file-icon">&#128196;</div><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + id + '">&times;</button><div class="media-field-grid-item-name">' + name + '</div>';
            }
            grid.appendChild(item);
        } else {
            hiddenInput.value = mediaId;
            emptyState.style.display = 'none';
            if (zone) zone.style.borderStyle = 'solid';

            var preview = document.getElementById('media-preview-' + fieldSlug);
            var thumb = preview.querySelector('.media-field-thumb');
            var fileIcon = preview.querySelector('.media-field-file-icon');
            if (isImage) {
                if (thumb) { thumb.src = url; thumb.style.display = ''; }
                else {
                    var img = document.createElement('img');
                    img.src = url;
                    img.alt = 'Selected';
                    img.className = 'media-field-thumb';
                    preview.insertBefore(img, preview.firstChild);
                }
                if (fileIcon) fileIcon.remove();
            } else {
                if (thumb) thumb.style.display = 'none';
                if (!fileIcon) {
                    var icon = document.createElement('div');
                    icon.className = 'media-field-file-icon';
                    icon.innerHTML = '&#128196;';
                    preview.insertBefore(icon, preview.firstChild);
                }
            }
            preview.querySelector('.media-field-name').textContent = name;
            preview.style.display = 'flex';
        }
    }

    function openMediaBrowser(fieldSlug, filter, isMultiple, maxFiles) {
        if (isMultiple) {
            var hiddenInput = document.getElementById('field_' + fieldSlug);
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            if (Array.isArray(current) && current.length >= maxFiles) {
                alert('Maximum of ' + maxFiles + ' files reached.');
                return;
            }
        }

        var uploadUrl = '{{ admin_url("media/upload") }}';
        var csrfToken = document.querySelector('input[name="_token"], input[name="csrf_token"]');
        var csrfVal = csrfToken ? csrfToken.value : '';

        var selectedIds = [];

        var modal = document.createElement('div');
        modal.className = 'media-modal-overlay';
        modal.innerHTML = '<div class="media-modal">'
            + '<div class="media-modal-header"><h3>Select from Media Library</h3><button type="button" class="media-modal-close">&times;</button></div>'
            + '<div class="media-modal-toolbar">'
            + '<div class="media-modal-search"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input type="text" class="media-search-input" placeholder="Search files..."></div>'
            + '<div class="media-modal-filters">'
            + '<button type="button" class="media-filter-btn' + (filter === 'all' || filter === '' ? ' active' : '') + '" data-filter="all">All</button>'
            + '<button type="button" class="media-filter-btn' + (filter === 'images' ? ' active' : '') + '" data-filter="images">Images</button>'
            + '<button type="button" class="media-filter-btn" data-filter="video">Video</button>'
            + '<button type="button" class="media-filter-btn" data-filter="documents">Docs</button>'
            + '</div></div>'
            + '<div class="media-modal-body"><p style="text-align:center;padding:var(--space-600);color:var(--text-secondary)">Loading...</p></div>'
            + (isMultiple ? '<div class="media-modal-footer" style="display:flex;justify-content:space-between;align-items:center;padding:12px 20px;border-top:1px solid var(--border,#e3e3e3);background:var(--bg-subdued,#fafafa);"><span class="media-selected-count">0 selected</span><button type="button" class="media-done-btn btn btn-primary" disabled>Done</button></div>' : '')
            + '<div class="media-modal-upload-bar">'
            + '<label class="media-upload-label"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload Files<input type="file" class="media-upload-input" multiple accept="image/*,video/*,application/pdf,.doc,.docx,.xls,.xlsx" style="display:none"></label>'
            + '<span class="media-upload-status"></span></div></div>';
        document.body.appendChild(modal);

        var currentFilter = filter || 'all';
        var currentSearch = '';

        modal.querySelector('.media-modal-close').addEventListener('click', function() { modal.remove(); });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });

        function updateSelectedCount() {
            var countEl = modal.querySelector('.media-selected-count');
            var doneBtn = modal.querySelector('.media-done-btn');
            if (countEl) countEl.textContent = selectedIds.length + ' selected';
            if (doneBtn) doneBtn.disabled = selectedIds.length === 0;
        }

        function toggleSelection(id, el) {
            var idx = -1;
            for (var i = 0; i < selectedIds.length; i++) {
                if (selectedIds[i].id === id) { idx = i; break; }
            }
            if (idx >= 0) {
                selectedIds.splice(idx, 1);
                el.classList.remove('media-modal-item-selected');
                var cb = el.querySelector('input[type="checkbox"]');
                if (cb) cb.checked = false;
            } else {
                selectedIds.push({
                    id: parseInt(el.dataset.id, 10),
                    url: el.dataset.url,
                    name: el.dataset.name,
                    isImage: el.dataset.isImage === '1'
                });
                el.classList.add('media-modal-item-selected');
                var cb = el.querySelector('input[type="checkbox"]');
                if (cb) cb.checked = true;
            }
            updateSelectedCount();
        }

        // Multi-select done button
        if (isMultiple) {
            modal.querySelector('.media-done-btn').addEventListener('click', function() {
                selectedIds.forEach(function(item) {
                    selectMediaItem(fieldSlug, item.id, item.url, item.name, item.isImage, true);
                });
                modal.remove();
            });
        }

        function loadMedia() {
            var body = modal.querySelector('.media-modal-body');
            body.innerHTML = '<p style="text-align:center;padding:var(--space-600);color:var(--text-secondary)">Loading...</p>';
            var url = mediaUrl + '?filter=' + currentFilter + '&per_page=36' + (currentSearch ? '&search=' + encodeURIComponent(currentSearch) : '');
            fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                if (!data.data || data.data.length === 0) {
                    body.innerHTML = '<div style="text-align:center;padding:var(--space-800)"><svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg><p style="margin:var(--space-300) 0 var(--space-200);font-weight:600;color:var(--text)">No media files found</p><p style="color:var(--text-secondary);font-size:var(--font-sm)">Upload files using the button below</p></div>';
                    return;
                }
                var html = '<div class="media-modal-grid">';
                data.data.forEach(function(item) {
                    var thumb = item.is_image ? '<img src="' + (item.thumbnail || item.url) + '" alt="" loading="lazy">' : '<div class="media-file-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>';
                    var isSelected = false;
                    for (var s = 0; s < selectedIds.length; s++) { if (selectedIds[s].id === item.id) { isSelected = true; break; } }
                    html += '<div class="media-modal-item' + (isSelected ? ' media-modal-item-selected' : '') + '" data-id="' + item.id + '" data-url="' + item.url + '" data-name="' + item.name + '" data-is-image="' + (item.is_image?'1':'0') + '">'
                        + (isMultiple ? '<div class="media-modal-check"><input type="checkbox"' + (isSelected ? ' checked' : '') + '></div>' : '')
                        + '<div class="media-modal-thumb">' + thumb + '</div>'
                        + '<div class="media-modal-name">' + item.name + '</div></div>';
                });
                body.innerHTML = html + '</div>';
                body.querySelectorAll('.media-modal-item').forEach(function(el) {
                    el.addEventListener('click', function() {
                        if (isMultiple) {
                            toggleSelection(parseInt(el.dataset.id, 10), el);
                        } else {
                            selectMediaItem(fieldSlug, el.dataset.id, el.dataset.url, el.dataset.name, el.dataset.isImage === '1', false);
                            modal.remove();
                        }
                    });
                });
            });
        }

        var searchTimeout;
        modal.querySelector('.media-search-input').addEventListener('input', function() {
            clearTimeout(searchTimeout); var val = this.value;
            searchTimeout = setTimeout(function() { currentSearch = val; loadMedia(); }, 300);
        });
        modal.querySelectorAll('.media-filter-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                modal.querySelectorAll('.media-filter-btn').forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active'); currentFilter = btn.dataset.filter; loadMedia();
            });
        });
        modal.querySelector('.media-upload-input').addEventListener('change', function() {
            var files = this.files; if (!files.length) return;
            var status = modal.querySelector('.media-upload-status');
            var totalFiles = files.length;
            status.textContent = 'Uploading ' + totalFiles + ' file(s)...';
            var uploaded = 0;
            var lastUploadedId = null;
            var lastUploadedUrl = '';
            var lastUploadedName = '';
            var lastIsImage = false;
            Array.from(files).forEach(function(f) {
                var fd = new FormData(); fd.append('file', f); fd.append('csrf_token', csrfVal);
                var xhr = new XMLHttpRequest();
                xhr.open('POST', uploadUrl, true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.onload = function() {
                    uploaded++;
                    try {
                        var resp = JSON.parse(xhr.responseText);
                        if (resp.id) {
                            lastUploadedId = resp.id;
                            lastUploadedUrl = '/' + resp.path;
                            lastUploadedName = f.name;
                            lastIsImage = f.type.startsWith('image/');
                            if (isMultiple) {
                                selectedIds.push({ id: resp.id, url: '/' + resp.path, name: f.name, isImage: lastIsImage });
                                updateSelectedCount();
                            }
                        }
                    } catch(e) {}
                    if (uploaded >= totalFiles) {
                        if (isMultiple) {
                            status.textContent = 'Uploaded! ' + selectedIds.length + ' selected.';
                            loadMedia();
                        } else if (lastUploadedId) {
                            selectMediaItem(fieldSlug, lastUploadedId, lastUploadedUrl, lastUploadedName, lastIsImage, false);
                            modal.remove();
                        } else {
                            status.textContent = 'Uploaded!';
                            loadMedia();
                        }
                    }
                };
                xhr.onerror = function() { uploaded++; status.textContent = 'Upload error'; };
                xhr.send(fd);
            });
        });

        loadMedia();
    }

    // Initialize multi-image grids from resolved media data
    document.querySelectorAll('.media-field[data-multiple="1"]').forEach(function(zone) {
        var fieldSlug = zone.dataset.field;
        var resolvedAttr = zone.dataset.resolved;
        if (!resolvedAttr) return;
        var items = [];
        try { items = JSON.parse(resolvedAttr); } catch(ex) { return; }
        if (!Array.isArray(items) || items.length === 0) return;

        var grid = document.getElementById('media-grid-' + fieldSlug);
        var addBtn = document.getElementById('media-add-' + fieldSlug);
        var emptyState = document.getElementById('media-empty-' + fieldSlug);
        if (!grid) return;

        emptyState.style.display = 'none';
        grid.style.display = '';
        if (addBtn) addBtn.style.display = '';

        items.forEach(function(media) {
            var el = document.createElement('div');
            el.className = 'media-field-grid-item';
            el.dataset.id = media.id;
            if (media.is_image) {
                el.innerHTML = '<img src="' + media.thumb + '" alt="' + media.name + '"><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + media.id + '">&times;</button><div class="media-field-grid-item-name">' + media.name + '</div>';
            } else {
                el.innerHTML = '<div class="media-grid-file-icon">&#128196;</div><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + media.id + '">&times;</button><div class="media-field-grid-item-name">' + media.name + '</div>';
            }
            grid.appendChild(el);
        });
    });
})();
</script>

{# --- Autosave --- #}
<script nonce="{{ csp_nonce() }}">
(function() {
    var collectionSlug = '{{ collection.getSlug()|e('js') }}';
    var entryId = '{{ entry.id|e('js') }}';
    var autosaveBaseUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/autosave') }}';
    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var form = document.getElementById('entry-form');
    var indicator = document.getElementById('autosave-indicator');
    var banner = document.getElementById('autosave-banner');
    var bannerText = document.getElementById('autosave-banner-text');
    var lastSnapshot = '';
    var autosaveData = null;

    function getFormData() {
        var data = {};
        if (!form) return data;
        var elements = form.elements;
        for (var i = 0; i < elements.length; i++) {
            var el = elements[i];
            if (!el.name || el.name === '_token' || el.name === 'csrf_token' || el.type === 'file') continue;
            if (el.type === 'checkbox') {
                data[el.name] = el.checked ? el.value : '0';
            } else if (el.type === 'select-multiple') {
                var selected = [];
                for (var j = 0; j < el.options.length; j++) {
                    if (el.options[j].selected) selected.push(el.options[j].value);
                }
                data[el.name] = selected;
            } else {
                data[el.name] = el.value;
            }
        }
        return data;
    }

    function snapshot() {
        return JSON.stringify(getFormData());
    }

    function doAutosave() {
        var current = snapshot();
        if (current === lastSnapshot) return;
        lastSnapshot = current;
        fetch(autosaveBaseUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrfMeta ? csrfMeta.content : '',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: current,
            credentials: 'same-origin'
        }).then(function(r) { return r.json(); }).then(function(resp) {
            if (resp.success && indicator) {
                indicator.textContent = 'Autosaved at ' + resp.time;
            }
        }).catch(function() {});
    }

    function deleteAutosave() {
        fetch(autosaveBaseUrl + '/delete', {
            method: 'POST',
            headers: {
                'X-CSRF-Token': csrfMeta ? csrfMeta.content : '',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        }).catch(function() {});
    }

    function restoreFormData(data) {
        if (!form || !data) return;
        for (var key in data) {
            if (!data.hasOwnProperty(key)) continue;
            var el = form.elements[key];
            if (!el) continue;
            if (el.type === 'checkbox') {
                el.checked = data[key] === '1' || data[key] === 1;
            } else if (el.type === 'select-multiple' && Array.isArray(data[key])) {
                for (var j = 0; j < el.options.length; j++) {
                    el.options[j].selected = data[key].indexOf(el.options[j].value) !== -1;
                }
            } else if (el.tagName) {
                el.value = data[key];
            }
        }
    }

    // Check for existing autosave on page load
    fetch(autosaveBaseUrl, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
    }).then(function(r) { return r.json(); }).then(function(resp) {
        if (resp.exists && resp.data) {
            autosaveData = resp.data;
            var dt = resp.datetime || 'unknown time';
            bannerText.textContent = 'You have unsaved changes from ' + dt + '.';
            banner.style.display = '';
        }
        lastSnapshot = snapshot();
    }).catch(function() {
        lastSnapshot = snapshot();
    });

    // Banner buttons
    document.getElementById('autosave-restore-btn').addEventListener('click', function() {
        if (autosaveData) restoreFormData(autosaveData);
        banner.style.display = 'none';
        lastSnapshot = snapshot();
    });
    document.getElementById('autosave-dismiss-btn').addEventListener('click', function() {
        banner.style.display = 'none';
        deleteAutosave();
    });

    // Autosave every 30 seconds
    setInterval(doAutosave, 30000);

    // Delete autosave on successful manual save
    if (form) {
        form.addEventListener('submit', function() {
            deleteAutosave();
        });
    }
})();
</script>
{% endblock %}
