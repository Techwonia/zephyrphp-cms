.media-modal-thumb { height: 100px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; overflow: hidden; }
.media-modal-thumb img { width: 100%; height: 100%; object-fit: cover; }
.media-modal-name { padding: 6px 8px; font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* --- Responsive --- */
@media (max-width: 900px) {
    .ee-layout {
        grid-template-columns: 1fr;
    }
    .ee-sidebar {
        position: static;
        order: -1;
    }
}
@media (max-width: 600px) {
    .ee-page-header {
        flex-direction: column;
        align-items: flex-start;
    }
    .ee-page-header-right {
        width: 100%;
    }
    .ee-workflow-stages {
        flex-wrap: wrap;
    }
