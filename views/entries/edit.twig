            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/save-template') }}">
                {{ csrf_field() | raw }}
                <div class="form-group" style="margin-bottom: var(--space-400, 16px);">
