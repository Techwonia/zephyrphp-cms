                        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/workflow/reject') }}" id="workflow-reject-form" style="flex:1">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="workflow_comment" id="reject-comment" value="">
                            <button type="submit" class="btn btn-outline ee-btn-reject">Reject</button>
                        </form>
                        {% endif %}

                        {% set canAdvance = workflow_current(entry) != stages|last %}
                        {% if canAdvance %}
                        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/workflow/advance') }}" id="workflow-advance-form" style="flex:1">
                            <input type="hidden" name="_token" value="{{ csrf_token() }}">
                            <input type="hidden" name="workflow_comment" id="advance-comment" value="">
                            {% set nextStage = null %}
