                                <span class="ee-history-stages">{{ t.getFromStage()|capitalize }} &rarr; {{ t.getToStage()|capitalize }}</span>
                                <span class="ee-history-user">{{ t.getUserName() ?? 'System' }}</span>
                                {% if t.getComment() %}
                                <span class="ee-history-comment">"{{ t.getComment() }}"</span>
