{% extends "@cms/layouts/cms.twig" %}

{% block title %}Edit Entry #{{ entry.id }} — {{ collection.getName() }}{% endblock %}

{% block content %}
{% if lockInfo %}
<div class="alert alert-warning" style="display: flex; align-items: center; gap: var(--space-200); padding: var(--space-300) var(--space-400); margin-bottom: var(--space-400); background: #fff3cd; border: 1px solid #ffecb5; border-radius: var(--radius-200); color: #664d03; font-size: var(--font-sm);">
    <span style="font-size: 1.25rem;">&#9888;</span>
    <span><strong>{{ lockInfo.user_name }}</strong> is currently editing this entry (since {{ lockInfo.locked_at|date('H:i') }}). Your changes may be overwritten.</span>
</div>
{% endif %}
<div class="breadcrumb">
    <a href="{{ admin_url('collections') }}">Collections</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}">{{ collection.getName() }}</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}">Entries</a> / #{{ entry.id }}
</div>

<div class="page-header">
    <h1>Edit Entry #{{ entry.id }}</h1>
    <div class="page-actions">
        {% if collection.isTranslatable() %}
        {% set activeLangs = available_locales() %}
        {% if activeLangs|length > 1 %}
        <div style="display: inline-flex; align-items: center; gap: var(--space-100); margin-right: var(--space-200);">
            <span style="font-size: var(--font-sm); color: var(--text-secondary);">Translate:</span>
            {% for lang in activeLangs %}
                {% if not lang.isDefault() %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/translate/' ~ lang.getCode()) }}"
                   class="btn btn-outline btn-sm" style="padding: 2px 8px; font-size: var(--font-xs);">
                    {{ lang.getCode()|upper }}
                </a>
                {% endif %}
            {% endfor %}
        </div>
        {% endif %}
        {% endif %}
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/history') }}" class="btn btn-outline">History</a>
        <button type="button" class="btn btn-outline" onclick="document.getElementById('save-template-modal').style.display='flex'">Save as Template</button>
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/duplicate') }}"
              style="display:inline">
            {{ csrf_field() | raw }}
            <button type="submit" class="btn btn-outline" onclick="return confirm('Duplicate this entry?')">Duplicate</button>
        </form>
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/delete') }}"
              style="display:inline" class="confirm-delete" data-message="Delete this entry?">
            {{ csrf_field() | raw }}
            <button type="submit" class="btn btn-danger">Delete</button>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}

            {% if collection.hasSlug() %}
            <div class="form-group">
                <label for="entry-slug">Slug</label>
                <input type="text" id="entry-slug" name="slug" class="form-control"
                       value="{{ entry.slug ?? '' }}"
                       placeholder="Auto-generated from {{ collection.getSlugSourceField() ?? 'title' }}">
                <p class="text-muted">Leave blank to keep current slug.</p>
            </div>
            {% endif %}

            {% for field in fields %}
            {% set fieldEditable = editableFields is not defined or field.getSlug() in (editableFields ?? []) %}
            <div class="form-group">
                <label for="field_{{ field.getSlug() }}">
                    {{ field.getName() }}
                    {% if field.isRequired() %} *{% endif %}
                    {% if not fieldEditable %}<span style="font-size: var(--font-xs); color: var(--text-secondary); font-weight: normal;">(read-only)</span>{% endif %}
                </label>

                {% set val = entry[field.getSlug()] ?? field.getDefaultValue() ?? '' %}
                {% set hasError = flash('errors')[field.getSlug()] is defined %}

                {% if not fieldEditable %}
                    {# Show as read-only display #}
                    {% if field.getType() == 'boolean' %}
                        <div class="form-control-plaintext">{{ val == '1' or val == 1 or val == true ? 'Yes' : 'No' }}</div>
                    {% elseif field.getType() == 'image' and val %}
                        <div><img src="/{{ val }}" alt="" style="max-height: 100px; border-radius: 4px; border: 1px solid var(--border);"></div>
                    {% elseif field.getType() == 'richtext' %}
                        <div class="form-control-plaintext" style="border: 1px solid var(--border); padding: var(--space-200); border-radius: var(--radius-200); background: var(--bg-subdued); max-height: 200px; overflow-y: auto;">{{ val|raw }}</div>
                    {% else %}
                        <div class="form-control-plaintext" style="padding: var(--space-200) 0; color: var(--text-secondary);">{{ val ?: '—' }}</div>
                    {% endif %}
                {% elseif field.getType() == 'textarea' %}
                    <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                              class="form-control{% if hasError %} is-invalid{% endif %}"
                              rows="4" {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                {% elseif field.getType() == 'richtext' %}
                    <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                              class="form-control richtext-editor{% if hasError %} is-invalid{% endif %}"
                              rows="8" {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                {% elseif field.getType() == 'boolean' %}
                    <div>
                        <label style="display: inline-flex; align-items: center; gap: 0.5rem; cursor: pointer;">
                            <input type="hidden" name="{{ field.getSlug() }}" value="0">
                            <input type="checkbox" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" value="1"
                                   {% if val == '1' or val == 1 or val == true %}checked{% endif %}>
                            Yes
                        </label>
                    </div>

                {% elseif field.getType() == 'number' %}
                    <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}" step="1"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'decimal' %}
                    <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}" step="0.01"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'email' %}
                    <input type="email" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'url' %}
                    <input type="url" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}" placeholder="https://"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'date' %}
                    <input type="date" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'datetime' %}
                    <input type="datetime-local" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val ? val|replace({' ': 'T'}) : '' }}"
                           {% if field.isRequired() %}required{% endif %}>

                {% elseif field.getType() == 'select' %}
                    <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                            class="form-control{% if hasError %} is-invalid{% endif %}"
                            {% if field.isRequired() %}required{% endif %}>
                        <option value="">— Select —</option>
                        {% if field.getOptions() and field.getOptions().choices is defined %}
                            {% for choice in field.getOptions().choices %}
                                <option value="{{ choice }}" {% if val == choice %}selected{% endif %}>{{ choice }}</option>
                            {% endfor %}
                        {% endif %}
                    </select>

                {% elseif field.getType() == 'relation' %}
                    {% set relationType = field.getOptions().relation_type ?? 'one_to_one' %}
                    {% set displayField = field.getOptions().display_field ?? null %}
                    {% set isMulti = relationType != 'one_to_one' %}
                    {% set selectedIds = isMulti and val is iterable ? val : [] %}
                    <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}{% if isMulti %}[]{% endif %}"
                            class="form-control{% if hasError %} is-invalid{% endif %}"
                            {% if isMulti %}multiple size="6"{% endif %}
                            {% if field.isRequired() %}required{% endif %}>
                        {% if not isMulti %}<option value="">— Select —</option>{% endif %}
                        {% if relationData[field.getSlug()] is defined %}
                            {% for relEntry in relationData[field.getSlug()].entries %}
                                {% if displayField and relEntry[displayField] is defined %}
                                    {% set relLabel = relEntry[displayField] %}
                                {% else %}
                                    {% set relLabel = '' %}
                                    {% for rk, rv in relEntry %}
                                        {% if rk not in ['id', 'slug', 'status', 'published_at', 'created_by', 'created_at', 'updated_at'] and rv is not null and relLabel == '' %}
                                            {% set relLabel = rv %}
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}
                                {% if isMulti %}
                                    <option value="{{ relEntry.id }}" {% if relEntry.id in selectedIds %}selected{% endif %}>
                                        {{ relLabel ? relLabel : '#' ~ relEntry.id }}
                                    </option>
                                {% else %}
                                    <option value="{{ relEntry.id }}" {% if val == relEntry.id or val == relEntry.id ~ '' %}selected{% endif %}>
                                        {{ relLabel ? relLabel : '#' ~ relEntry.id }}
                                    </option>
                                {% endif %}
                            {% endfor %}
                        {% endif %}
                    </select>
                    {% if field.getOptions().relation_collection is defined %}
                        <p class="text-muted">{{ relationType|replace({'_': ' '})|title }} — Related to: {{ field.getOptions().relation_collection }}{% if isMulti %} (hold Ctrl to select multiple){% endif %}</p>
                    {% endif %}

                {% elseif field.getType() == 'image' or field.getType() == 'file' %}
                    {% if val %}
                        <div style="margin-bottom: 0.5rem;">
                            {% if field.getType() == 'image' %}
                                <img src="/{{ val }}" alt="" style="max-height: 100px; border-radius: 4px; border: 1px solid var(--border);">
                            {% else %}
                                <a href="/{{ val }}" target="_blank">{{ val }}</a>
                            {% endif %}
                        </div>
                    {% endif %}
                    <input type="hidden" id="field_{{ field.getSlug() }}_path" name="{{ field.getSlug() }}_from_media" value="">
                    <div style="display: flex; gap: 8px; align-items: flex-start;">
                        <input type="file" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               {% if field.getType() == 'image' %}accept="image/*"{% endif %}
                               style="flex: 1;">
                        <button type="button" class="btn btn-outline media-browse-btn"
                                data-field="{{ field.getSlug() }}"
                                data-filter="{{ field.getType() == 'image' ? 'images' : 'all' }}">
                            Browse Media
                        </button>
                    </div>
                    <div id="media-preview-{{ field.getSlug() }}" style="margin-top: 8px; display: none;">
                        <img src="" alt="Selected" style="max-height: 80px; border-radius: 4px; border: 1px solid var(--border);">
                        <span class="media-selected-name" style="margin-left: 8px;"></span>
                        <button type="button" class="btn btn-sm btn-outline media-clear-btn" data-field="{{ field.getSlug() }}" style="margin-left: 4px;">Clear</button>
                    </div>
                    {% if val %}
                        <p class="text-muted">Leave empty to keep current file.</p>
                    {% endif %}

                {% elseif field.getType() == 'json' %}
                    <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                              class="form-control{% if hasError %} is-invalid{% endif %}"
                              rows="5" style="font-family: monospace; font-size: 0.85rem;"
                              {% if field.isRequired() %}required{% endif %}>{{ val }}</textarea>

                {% else %}
                    {# text, slug, and any other type #}
                    <input type="text" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                           class="form-control{% if hasError %} is-invalid{% endif %}"
                           value="{{ val }}"
                           {% if field.isRequired() %}required{% endif %}>
                {% endif %}

                {% if hasError %}
                    <div class="invalid-feedback">{{ flash('errors')[field.getSlug()] }}</div>
                {% endif %}
            </div>
            {% endfor %}

            {% if collection.isPublishable() %}
            <div class="form-group">
                <label for="status">Status</label>
                <select id="status" name="status" class="form-control" onchange="document.getElementById('schedule-group').style.display=this.value==='scheduled'?'':'none'">
                    <option value="draft" {% if entry.status is defined and entry.status == 'draft' %}selected{% endif %}>Draft</option>
                    <option value="published" {% if entry.status is defined and entry.status == 'published' %}selected{% endif %}>Published</option>
                    <option value="scheduled" {% if entry.status is defined and entry.status == 'scheduled' %}selected{% endif %}>Scheduled</option>
                </select>
                {% if entry.published_at is defined and entry.published_at %}
                    <p class="text-muted">Published at: {{ entry.published_at }}</p>
                {% endif %}
            </div>
            <div class="form-group" id="schedule-group" style="{% if entry.status is not defined or entry.status != 'scheduled' %}display: none;{% endif %}">
                <label for="scheduled_at">Publish At</label>
                <input type="datetime-local" id="scheduled_at" name="scheduled_at" class="form-control"
                       value="{{ entry.scheduled_at is defined and entry.scheduled_at ? entry.scheduled_at|replace({' ': 'T'}) : '' }}">
                <p class="text-muted">Entry will be auto-published at this date and time.</p>
            </div>
            {% endif %}

            {% if collection.isSeoEnabled() %}
                {% include "@cms/partials/seo-panel.twig" with {entry: entry, collection_slug: collection.getSlug()} %}
            {% endif %}

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <button type="button" class="btn btn-outline" id="preview-btn">Preview</button>
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-outline">Cancel</a>
                <span id="autosave-indicator" style="margin-left: var(--space-300); font-size: var(--font-sm); color: var(--text-secondary);"></span>
            </div>
        </form>

        {# Autosave Recovery Banner #}
        <div id="autosave-banner" style="display: none; margin-top: var(--space-300); padding: var(--space-300) var(--space-400); background: var(--bg-warning, #fff8e1); border: 1px solid var(--border-warning, #ffe082); border-radius: var(--radius-200, 6px); font-size: var(--font-sm);">
            <span id="autosave-banner-text"></span>
            <button type="button" id="autosave-restore-btn" class="btn btn-sm btn-primary" style="margin-left: var(--space-200);">Restore</button>
            <button type="button" id="autosave-dismiss-btn" class="btn btn-sm btn-outline" style="margin-left: var(--space-100);">Dismiss</button>
        </div>

        {# Workflow Panel #}
        {% if collection.isWorkflowEnabled() %}
        {% set currentStage = entry.status ?? 'draft' %}
        {% set stages = workflow_stages(collection) %}
        <div style="margin-top: var(--space-600); border-top: 2px solid var(--border); padding-top: var(--space-500);">
            <h3 style="margin: 0 0 var(--space-300);">Workflow</h3>

            {# Stage indicator #}
            <div style="display: flex; gap: var(--space-100); margin-bottom: var(--space-400);">
                {% for stage in stages %}
                <div style="flex: 1; text-align: center; padding: var(--space-200) var(--space-100); border-radius: var(--radius-100);
                    {% if stage == currentStage %}
                        background: var(--color-primary); color: var(--color-primary-text); font-weight: 600;
                    {% elseif loop.index < stages|length %}
                        {% set stageIdx = 0 %}{% set currentIdx = 0 %}
                        background: var(--bg-subdued); color: var(--text-secondary);
                    {% else %}
                        background: var(--bg-subdued); color: var(--text-disabled);
                    {% endif %}
                    font-size: var(--font-sm); text-transform: capitalize;">
                    {{ stage }}
                </div>
                {% endfor %}
            </div>

            {# Advance/Reject buttons #}
            <div style="display: flex; gap: var(--space-300); align-items: flex-start;">
                <div style="flex: 1;">
                    <label class="form-label" style="font-size: var(--font-sm);">Comment (optional)</label>
                    <input type="text" id="workflow-comment" class="form-control" placeholder="Add a comment...">
                </div>
                <div style="display: flex; gap: var(--space-200); padding-top: 22px;">
                    {% set canReject = workflow_current(entry) != stages|first %}
                    {% if canReject %}
                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/workflow/reject') }}" id="workflow-reject-form">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <input type="hidden" name="workflow_comment" id="reject-comment" value="">
                        <button type="submit" class="btn btn-outline" style="border-color: var(--color-critical); color: var(--color-critical);">Reject</button>
                    </form>
                    {% endif %}

                    {% set canAdvance = workflow_current(entry) != stages|last %}
                    {% if canAdvance %}
                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/workflow/advance') }}" id="workflow-advance-form">
                        <input type="hidden" name="_token" value="{{ csrf_token() }}">
                        <input type="hidden" name="workflow_comment" id="advance-comment" value="">
                        {% set nextStage = null %}
                        {% for stage in stages %}
                            {% if stage == currentStage and not loop.last %}
                                {% set nextStage = stages[loop.index] %}
                            {% endif %}
                        {% endfor %}
                        <button type="submit" class="btn btn-primary">Advance{% if nextStage is defined and nextStage %} to {{ nextStage|capitalize }}{% endif %}</button>
                    </form>
                    {% endif %}
                </div>
            </div>

            {# Transition History #}
            {% set history = workflow_history(collection.getTableName(), entry.id) %}
            {% if history|length > 0 %}
            <div style="margin-top: var(--space-400);">
                <h4 style="margin: 0 0 var(--space-200); font-size: var(--font-sm); color: var(--text-secondary);">Transition History</h4>
                {% for t in history %}
                <div style="display: flex; gap: var(--space-300); padding: var(--space-200) 0; border-bottom: 1px solid var(--bg-subdued); font-size: var(--font-sm);">
                    <span style="color: {% if t.getAction() == 'advance' %}var(--color-success){% else %}var(--color-critical){% endif %}; font-weight: 500; min-width: 60px;">
                        {{ t.getAction()|capitalize }}
                    </span>
                    <span>{{ t.getFromStage()|capitalize }} &rarr; {{ t.getToStage()|capitalize }}</span>
                    <span style="color: var(--text-secondary);">by {{ t.getUserName() ?? 'System' }}</span>
                    {% if t.getComment() %}
                    <span style="color: var(--text-secondary); font-style: italic;">"{{ t.getComment() }}"</span>
                    {% endif %}
                    <span style="color: var(--text-disabled); margin-left: auto;">{{ t.getCreatedAt()|date('M j, g:i A') }}</span>
                </div>
                {% endfor %}
            </div>
            {% endif %}
        </div>
        {% endif %}

        {% if entry.created_at is defined or entry.updated_at is defined %}
        <div class="text-muted" style="margin-top: var(--space-400);">
            {% if entry.created_at is defined and entry.created_at %}Created: {{ entry.created_at }}{% endif %}
            {% if entry.updated_at is defined and entry.updated_at %} &middot; Updated: {{ entry.updated_at }}{% endif %}
        </div>
        {% endif %}
    </div>
</div>

{# Save as Template Modal #}
<div id="save-template-modal" style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; align-items: center; justify-content: center;">
    <div style="background: var(--bg-surface, #fff); border-radius: var(--radius-300, 12px); padding: var(--space-500, 24px); width: 90%; max-width: 420px; box-shadow: 0 8px 30px rgba(0,0,0,0.12);">
        <h3 style="margin: 0 0 var(--space-300, 12px);">Save as Template</h3>
        <p style="font-size: var(--font-sm, 0.875rem); color: var(--text-secondary, #666); margin: 0 0 var(--space-400, 16px);">
            Save this entry's field values as a reusable template for new entries.
        </p>
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/save-template') }}">
            {{ csrf_field() | raw }}
            <div class="form-group" style="margin-bottom: var(--space-400, 16px);">
                <label for="template_name">Template Name</label>
                <input type="text" id="template_name" name="template_name" class="form-control"
                       placeholder="e.g. Blog Post Default" required>
            </div>
            <div style="display: flex; gap: var(--space-200, 8px); justify-content: flex-end;">
                <button type="button" class="btn btn-outline" onclick="document.getElementById('save-template-modal').style.display='none'">Cancel</button>
                <button type="submit" class="btn btn-primary">Save Template</button>
            </div>
        </form>
    </div>
</div>

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    // Close template modal on overlay click
    var templateModal = document.getElementById('save-template-modal');
    if (templateModal) {
        templateModal.addEventListener('click', function(e) {
            if (e.target === templateModal) templateModal.style.display = 'none';
        });
    }

    // Preview — submit form to preview endpoint in a new tab
    document.getElementById('preview-btn')?.addEventListener('click', function() {
        var form = document.querySelector('form[enctype]');
        if (!form) return;
        var originalAction = form.action;
        var originalTarget = form.target;
        form.action = originalAction + '/preview';
        form.target = '_blank';
        form.submit();
        form.action = originalAction;
        form.target = originalTarget;
    });

    // Content Lock — heartbeat every 2 minutes, unlock on page leave
    var lockSlug = '{{ collection.getSlug()|e('js') }}';
    var lockId = '{{ entry.id|e('js') }}';
    var csrfToken = '{{ csrf_token() }}';
    var heartbeatUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/heartbeat') }}';
    var unlockUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/unlock') }}';

    // Heartbeat — renew lock every 2 minutes
    var heartbeatInterval = setInterval(function() {
        var fd = new FormData();
        fd.append('_token', csrfToken);
        fetch(heartbeatUrl, { method: 'POST', body: fd, credentials: 'same-origin' });
    }, 120000);

    // Release lock on page leave
    function releaseLock() {
        var fd = new FormData();
        fd.append('_token', csrfToken);
        if (navigator.sendBeacon) {
            navigator.sendBeacon(unlockUrl, fd);
        } else {
            fetch(unlockUrl, { method: 'POST', body: fd, credentials: 'same-origin', keepalive: true });
        }
    }
    window.addEventListener('beforeunload', releaseLock);
})();
</script>
<script nonce="{{ csp_nonce() }}">
(function() {
    // Media Browser
    document.querySelectorAll('.media-browse-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            openMediaBrowser(btn.dataset.field, btn.dataset.filter || 'all');
        });
    });
    document.querySelectorAll('.media-clear-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById('field_' + btn.dataset.field + '_path').value = '';
            document.getElementById('media-preview-' + btn.dataset.field).style.display = 'none';
        });
    });
    // Workflow comment → hidden fields
    var wfComment = document.getElementById('workflow-comment');
    if (wfComment) {
        var advForm = document.getElementById('workflow-advance-form');
        var rejForm = document.getElementById('workflow-reject-form');
        if (advForm) advForm.addEventListener('submit', function() {
            document.getElementById('advance-comment').value = wfComment.value;
        });
        if (rejForm) rejForm.addEventListener('submit', function() {
            document.getElementById('reject-comment').value = wfComment.value;
        });
    }

    function openMediaBrowser(fieldSlug, filter) {
        var modal = document.createElement('div');
        modal.className = 'media-modal-overlay';
        modal.innerHTML = '<div class="media-modal"><div class="media-modal-header"><h3>Select from Media Library</h3><button type="button" class="media-modal-close">&times;</button></div><div class="media-modal-body"><p>Loading...</p></div></div>';
        document.body.appendChild(modal);
        modal.querySelector('.media-modal-close').addEventListener('click', function() { modal.remove(); });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
        fetch('/admin/media/browse?filter=' + filter + '&per_page=24')
            .then(function(r) { return r.json(); })
            .then(function(data) {
                var body = modal.querySelector('.media-modal-body');
                if (!data.data || data.data.length === 0) { body.innerHTML = '<p>No media files found.</p>'; return; }
                var html = '<div class="media-modal-grid">';
                data.data.forEach(function(item) {
                    var thumb = item.is_image ? '<img src="' + item.thumbnail + '" alt="">' : '<div class="media-file-icon">&#128196;</div>';
                    html += '<div class="media-modal-item" data-url="' + item.url + '" data-name="' + item.name + '" data-is-image="' + (item.is_image?'1':'0') + '"><div class="media-modal-thumb">' + thumb + '</div><div class="media-modal-name">' + item.name + '</div></div>';
                });
                body.innerHTML = html + '</div>';
                body.querySelectorAll('.media-modal-item').forEach(function(item) {
                    item.addEventListener('click', function() {
                        var url = item.dataset.url;
                        document.getElementById('field_' + fieldSlug + '_path').value = url.replace(/^\//, '');
                        var preview = document.getElementById('media-preview-' + fieldSlug);
                        if (item.dataset.isImage === '1') { preview.querySelector('img').src = url; preview.querySelector('img').style.display = ''; } else { preview.querySelector('img').style.display = 'none'; }
                        preview.querySelector('.media-selected-name').textContent = item.dataset.name;
                        preview.style.display = 'flex';
                        document.getElementById('field_' + fieldSlug).value = '';
                        modal.remove();
                    });
                });
            });
    }
})();
</script>
<style nonce="{{ csp_nonce() }}">
.media-modal-overlay { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.5); z-index: 9999; display: flex; align-items: center; justify-content: center; }
.media-modal { background: #fff; border-radius: 12px; width: 90%; max-width: 800px; max-height: 80vh; display: flex; flex-direction: column; }
.media-modal-header { display: flex; justify-content: space-between; align-items: center; padding: 16px 20px; border-bottom: 1px solid #e8e8e8; }
.media-modal-header h3 { margin: 0; font-size: 1.1rem; }
.media-modal-close { background: none; border: none; font-size: 1.5rem; cursor: pointer; padding: 0 4px; }
.media-modal-body { padding: 20px; overflow-y: auto; flex: 1; }
.media-modal-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 12px; }
.media-modal-item { border: 2px solid #e8e8e8; border-radius: 8px; cursor: pointer; overflow: hidden; transition: border-color 0.2s; }
.media-modal-item:hover { border-color: #008060; }
.media-modal-thumb { height: 100px; display: flex; align-items: center; justify-content: center; background: #f8f9fa; overflow: hidden; }
.media-modal-thumb img { width: 100%; height: 100%; object-fit: cover; }
.media-modal-name { padding: 6px 8px; font-size: 0.75rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
</style>
<script nonce="{{ csp_nonce() }}">
(function() {
    var collectionSlug = '{{ collection.getSlug()|e('js') }}';
    var entryId = '{{ entry.id|e('js') }}';
    var autosaveBaseUrl = '{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/autosave') }}';
    var csrfMeta = document.querySelector('meta[name="csrf-token"]');
    var form = document.querySelector('form[method="POST"][enctype]');
    var indicator = document.getElementById('autosave-indicator');
    var banner = document.getElementById('autosave-banner');
    var bannerText = document.getElementById('autosave-banner-text');
    var lastSnapshot = '';
    var autosaveData = null;

    function getFormData() {
        var data = {};
        if (!form) return data;
        var elements = form.elements;
        for (var i = 0; i < elements.length; i++) {
            var el = elements[i];
            if (!el.name || el.name === '_token' || el.name === 'csrf_token' || el.type === 'file') continue;
            if (el.type === 'checkbox') {
                data[el.name] = el.checked ? el.value : '0';
            } else if (el.type === 'select-multiple') {
                var selected = [];
                for (var j = 0; j < el.options.length; j++) {
                    if (el.options[j].selected) selected.push(el.options[j].value);
                }
                data[el.name] = selected;
            } else {
                data[el.name] = el.value;
            }
        }
        return data;
    }

    function snapshot() {
        return JSON.stringify(getFormData());
    }

    function doAutosave() {
        var current = snapshot();
        if (current === lastSnapshot) return;
        lastSnapshot = current;
        fetch(autosaveBaseUrl, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'X-CSRF-Token': csrfMeta ? csrfMeta.content : '',
                'X-Requested-With': 'XMLHttpRequest'
            },
            body: current,
            credentials: 'same-origin'
        }).then(function(r) { return r.json(); }).then(function(resp) {
            if (resp.success && indicator) {
                indicator.textContent = 'Autosaved at ' + resp.time;
            }
        }).catch(function() {});
    }

    function deleteAutosave() {
        fetch(autosaveBaseUrl + '/delete', {
            method: 'POST',
            headers: {
                'X-CSRF-Token': csrfMeta ? csrfMeta.content : '',
                'X-Requested-With': 'XMLHttpRequest'
            },
            credentials: 'same-origin'
        }).catch(function() {});
    }

    function restoreFormData(data) {
        if (!form || !data) return;
        for (var key in data) {
            if (!data.hasOwnProperty(key)) continue;
            var el = form.elements[key];
            if (!el) continue;
            if (el.type === 'checkbox') {
                el.checked = data[key] === '1' || data[key] === 1;
            } else if (el.type === 'select-multiple' && Array.isArray(data[key])) {
                for (var j = 0; j < el.options.length; j++) {
                    el.options[j].selected = data[key].indexOf(el.options[j].value) !== -1;
                }
            } else if (el.tagName) {
                el.value = data[key];
            }
        }
    }

    // Check for existing autosave on page load
    fetch(autosaveBaseUrl, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
    }).then(function(r) { return r.json(); }).then(function(resp) {
        if (resp.exists && resp.data) {
            autosaveData = resp.data;
            var dt = resp.datetime || 'unknown time';
            bannerText.textContent = 'You have unsaved changes from ' + dt + '.';
            banner.style.display = '';
        }
        // Initialize snapshot after check
        lastSnapshot = snapshot();
    }).catch(function() {
        lastSnapshot = snapshot();
    });

    // Banner buttons
    document.getElementById('autosave-restore-btn').addEventListener('click', function() {
        if (autosaveData) restoreFormData(autosaveData);
        banner.style.display = 'none';
        lastSnapshot = snapshot();
    });
    document.getElementById('autosave-dismiss-btn').addEventListener('click', function() {
        banner.style.display = 'none';
        deleteAutosave();
    });

    // Autosave every 30 seconds
    setInterval(doAutosave, 30000);

    // Delete autosave on successful manual save
    if (form) {
        form.addEventListener('submit', function() {
            deleteAutosave();
        });
    }
})();
</script>
{% endblock %}
{% endblock %}
