{% extends "@cms/layouts/cms.twig" %}

{% block title %}New Entry — {{ collection.getName() }}{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/entries-create.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url('collections') }}">Collections</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}">{{ collection.getName() }}</a> /
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}">Entries</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> New
</div>

<div class="page-header" class="mb-5">
    <h1>New {{ collection.getName() }} Entry</h1>
</div>

<form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" enctype="multipart/form-data" id="entry-form">
    {{ csrf_field() | raw }}

    <div class="ec-layout">
        {# ============================================
           LEFT COLUMN — Main Form Fields
           ============================================ #}
        <div class="ec-main">
            {% for field in fields %}
            {% set fieldEditable = (editableFields is iterable) ? (field.getSlug() in editableFields) : true %}
            {% set _fSlug = field.getSlug() %}
            {% set _oldInput = flash('_old_input') ?? {} %}
            {% set _tplData = templateData ?? {} %}
            {% set oldVal = _oldInput[_fSlug] ?? _tplData[_fSlug] ?? field.getDefaultValue() ?? '' %}
            {% set _errs = flash('errors') ?? {} %}
            {% set hasError = _fSlug in (_errs|keys) %}

            <div class="ec-field-card{% if hasError %} ec-field-card--error{% endif %}">
                <div class="ec-field-header">
                    <label class="ec-field-label" for="field_{{ field.getSlug() }}">
                        {{ field.getName() }}
                        {% if field.isRequired() %}<span class="ec-required">*</span>{% endif %}
                        {% if not fieldEditable %}<span class="ec-readonly-badge">Read-only</span>{% endif %}
                    </label>
                    <span class="ec-field-type">{{ field.getType() }}</span>
                </div>

                <div class="ec-field-body">
                    {% if not fieldEditable %}
                        {# Read-only display #}
                        {% if field.getType() == 'boolean' %}
                            <div class="ec-readonly-value">{{ oldVal == '1' or oldVal == 1 ? 'Yes' : 'No' }}</div>
                        {% elseif field.getType() == 'richtext' %}
                            <div class="ec-readonly-value ec-readonly-richtext">{{ oldVal|raw }}</div>
                        {% else %}
                            <div class="ec-readonly-value">{{ oldVal ?: '---' }}</div>
                        {% endif %}

                    {% elseif field.getType() == 'textarea' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control{% if hasError %} is-invalid{% endif %}"
                                  rows="4" {% if field.isRequired() %}required{% endif %}
                                  placeholder="Enter {{ field.getName()|lower }}...">{{ oldVal }}</textarea>

                    {% elseif field.getType() == 'richtext' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control richtext-editor{% if hasError %} is-invalid{% endif %}"
                                  rows="10" {% if field.isRequired() %}required{% endif %}
                                  placeholder="Write your content here...">{{ oldVal }}</textarea>

                    {% elseif field.getType() == 'boolean' %}
                        <div class="ec-toggle-wrap">
                            <input type="hidden" name="{{ field.getSlug() }}" value="0">
                            <label class="ec-toggle">
                                <input type="checkbox" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}" value="1"
                                       {% if oldVal == '1' or oldVal == 1 %}checked{% endif %}>
                                <span class="ec-toggle-slider"></span>
                            </label>
                            <span class="ec-toggle-label">{{ oldVal == '1' or oldVal == 1 ? 'Enabled' : 'Disabled' }}</span>
                        </div>

                    {% elseif field.getType() == 'number' %}
                        <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}" step="1"
                               placeholder="0"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'decimal' %}
                        <input type="number" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}" step="0.01"
                               placeholder="0.00"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'email' %}
                        <input type="email" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}"
                               placeholder="email@example.com"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'url' %}
                        <input type="url" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}" placeholder="https://"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'date' %}
                        <input type="date" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'datetime' %}
                        <input type="datetime-local" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}"
                               {% if field.isRequired() %}required{% endif %}>

                    {% elseif field.getType() == 'select' %}
                        <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                class="form-control{% if hasError %} is-invalid{% endif %}"
                                {% if field.isRequired() %}required{% endif %}>
                            <option value="">-- Select --</option>
                            {% if field.getOptions() and field.getOptions().choices is defined %}
                                {% for choice in field.getOptions().choices %}
                                    <option value="{{ choice }}" {% if oldVal == choice %}selected{% endif %}>{{ choice }}</option>
                                {% endfor %}
                            {% endif %}
                        </select>

                    {% elseif field.getType() == 'relation' %}
                        {% set relationType = field.getOptions().relation_type ?? 'one_to_one' %}
                        {% set displayField = field.getOptions().display_field ?? null %}
                        {% set isMulti = relationType != 'one_to_one' %}
                        {% set _relData = relationData[field.getSlug()]|default({}) %}
                        {% set _relHasHierarchy = _relData.hasHierarchy|default(false) %}
                        {% set _relDisplayField = _relData.displayField|default(displayField) %}

                        {% if _relHasHierarchy and not isMulti %}
                            {# Drill-down tree picker for hierarchy relation #}
                            {% set _relTreeJson = [] %}
                            {% for te in _relData.treeEntries|default([]) %}
                                {% set _rl = (_relDisplayField and te[_relDisplayField] is defined) ? te[_relDisplayField] : (te.title ?? te.name ?? te.slug ?? '#' ~ te.id) %}
                                {% set _relTreeJson = _relTreeJson|merge([{'id': te.id, 'label': _rl, 'parent_id': te.parent_id|default(''), 'depth': te._depth}]) %}
                            {% endfor %}
                            {% set _currentRelLabel = 'Select...' %}
                            {% if oldVal %}{% for te in _relData.treeEntries|default([]) %}{% if te.id == oldVal %}{% set _currentRelLabel = (_relDisplayField and te[_relDisplayField] is defined) ? te[_relDisplayField] : (te.title ?? te.name ?? '#' ~ te.id) %}{% endif %}{% endfor %}{% endif %}
                            <input type="hidden" name="{{ field.getSlug() }}" id="field_{{ field.getSlug() }}" value="{{ oldVal }}">
                            <div class="tree-picker rel-drill-picker" data-tree="{{ _relTreeJson|json_encode|e('html_attr') }}" data-current="{{ oldVal }}" data-field="{{ _fSlug }}">
                                <button type="button" class="tree-picker-btn">
                                    <span class="tp-label">{{ _currentRelLabel }}</span>
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3"/></svg>
                                </button>
                                <div class="tree-picker-dropdown" style="display:none"></div>
                            </div>
                        {% else %}
                            {# Plain select for flat relations #}
                            <select id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}{% if isMulti %}[]{% endif %}"
                                    class="form-control{% if hasError %} is-invalid{% endif %}"
                                    {% if isMulti %}multiple size="6"{% endif %}
                                    {% if field.isRequired() %}required{% endif %}>
                                {% if not isMulti %}<option value="">-- Select --</option>{% endif %}
                                {% for relEntry in _relData.entries|default([]) %}
                                    {% set relLabel = (_relDisplayField and relEntry[_relDisplayField] is defined) ? relEntry[_relDisplayField] : (relEntry.title ?? relEntry.name ?? '#' ~ relEntry.id) %}
                                    <option value="{{ relEntry.id }}" {% if oldVal == relEntry.id ~ '' %}selected{% endif %}>
                                        {{ relLabel }}
                                    </option>
                                {% endfor %}
                            </select>
                        {% endif %}
                        {% if field.getOptions().relation_collection is defined %}
                            <p class="ec-field-hint">{{ relationType|replace({'_': ' '})|title }} → {{ field.getOptions().relation_collection }}</p>
                        {% endif %}

                    {% elseif field.getType() == 'image' or field.getType() == 'file' %}
                        {% set fieldOpts = field.getOptions() ?? {} %}
                        {% set isMultiple = fieldOpts.multiple ?? false %}
                        {% set maxFiles = fieldOpts.max_files ?? 10 %}
                        <div class="media-field{% if isMultiple %} media-field-multiple{% endif %}" data-field="{{ field.getSlug() }}" data-filter="{{ field.getType() == 'image' ? 'images' : 'all' }}" data-multiple="{{ isMultiple ? '1' : '0' }}" data-max-files="{{ maxFiles }}">
                            <input type="hidden" name="{{ field.getSlug() }}" id="field_{{ field.getSlug() }}" value="">

                            {# Empty state #}
                            <div class="media-field-empty" id="media-empty-{{ field.getSlug() }}">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="var(--text-secondary)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    {% if field.getType() == 'image' %}
                                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/>
                                    {% else %}
                                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                                    {% endif %}
                                </svg>
                                <p class="media-field-text">Click to select from media library</p>
                                <span class="media-field-hint">{% if field.getType() == 'image' %}PNG, JPG, GIF, WEBP{% else %}Any file type{% endif %}{% if isMultiple %} &middot; Up to {{ maxFiles }} files{% endif %}</span>
                            </div>

                            {# Single preview state #}
                            <div class="media-field-preview" id="media-preview-{{ field.getSlug() }}" style="display:none">
                                <img src="" alt="Selected" class="media-field-thumb">
                                <div class="media-field-info">
                                    <span class="media-field-name"></span>
                                    <button type="button" class="media-field-remove" data-field="{{ field.getSlug() }}">
                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                        Remove
                                    </button>
                                </div>
                            </div>

                            {# Multiple preview grid #}
                            {% if isMultiple %}
                            <div class="media-field-grid" id="media-grid-{{ field.getSlug() }}" style="display:none"></div>
                            <button type="button" class="btn btn-outline btn-sm media-field-add-more" id="media-add-{{ field.getSlug() }}" style="display:none" data-field="{{ field.getSlug() }}">+ Add more</button>
                            {% endif %}
                        </div>

                    {% elseif field.getType() == 'json' %}
                        <textarea id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                                  class="form-control ec-json-editor{% if hasError %} is-invalid{% endif %}"
                                  rows="5"
                                  placeholder='{"key": "value"}'
                                  {% if field.isRequired() %}required{% endif %}>{{ oldVal }}</textarea>

                    {% else %}
                        {# text, slug, and any other type #}
                        <input type="text" id="field_{{ field.getSlug() }}" name="{{ field.getSlug() }}"
                               class="form-control{% if hasError %} is-invalid{% endif %}"
                               value="{{ oldVal }}"
                               placeholder="Enter {{ field.getName()|lower }}..."
                               {% if field.isRequired() %}required{% endif %}>
                    {% endif %}

                    {% set _fOpts = field.getOptions() %}
                    {% if _fOpts and _fOpts.max_length is defined and _fOpts.max_length %}
                    <div style="text-align:right;font-size:var(--font-xs,0.75rem);color:var(--text-secondary,#616161);margin-top:4px;">
                        <span class="js-char-count" data-field="{{ _fSlug }}" data-max="{{ _fOpts.max_length }}">0</span> / {{ _fOpts.max_length }}
                    </div>
                    {% endif %}

                    {% if hasError %}
                        <div class="ec-field-error">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                            {{ _errs[_fSlug] }}
                        </div>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>

        {# ============================================
           RIGHT COLUMN — Sidebar
           ============================================ #}
        <div class="ec-sidebar">
            {# Publishing Card #}
            <div class="ec-sidebar-card">
                <div class="ec-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                    Publishing
                </div>
                <div class="ec-sidebar-card-body">
                    {% if collection.isPublishable() %}
                    <div class="ec-status-group">
                        <label class="ec-status-option">
                            <input type="radio" name="status" value="draft" checked onchange="document.getElementById('schedule-group').style.display='none'">
                            <span class="ec-status-pill ec-status-draft">
                                <span class="ec-status-dot"></span>
                                Draft
                            </span>
                        </label>
                        <label class="ec-status-option">
                            <input type="radio" name="status" value="published" onchange="document.getElementById('schedule-group').style.display='none'">
                            <span class="ec-status-pill ec-status-published">
                                <span class="ec-status-dot"></span>
                                Published
                            </span>
                        </label>
                        <label class="ec-status-option">
                            <input type="radio" name="status" value="scheduled" onchange="document.getElementById('schedule-group').style.display=''">
                            <span class="ec-status-pill ec-status-scheduled">
                                <span class="ec-status-dot"></span>
                                Scheduled
                            </span>
                        </label>
                    </div>
                    <div id="schedule-group" style="display: none; margin-top: var(--sp-3);">
                        <label class="ec-sidebar-label" for="scheduled_at">Publish At</label>
                        <input type="datetime-local" id="scheduled_at" name="scheduled_at" class="form-control">
                        <p class="ec-field-hint">Auto-published at this date/time.</p>
                    </div>
                    {% endif %}

                    <div class="ec-publish-actions">
                        <button type="submit" class="btn btn-primary" style="width: 100%;">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            Create Entry
                        </button>
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-outline" style="width: 100%; text-align: center;">Cancel</a>
                    </div>
                </div>
            </div>

            {# Template Card #}
            {% if templates is defined and templates|length > 0 %}
            <div class="ec-sidebar-card">
                <div class="ec-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                    Template
                </div>
                <div class="ec-sidebar-card-body">
                    <select id="template-selector" class="form-control"
                            onchange="if(this.value){window.location='{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}?template='+this.value}else{window.location='{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}'}">
                        <option value="">Blank (no template)</option>
                        {% for tpl in templates %}
                            <option value="{{ tpl.getId() }}" {% if selectedTemplateId is defined and selectedTemplateId == tpl.getId() ~ '' %}selected{% endif %}>{{ tpl.getName() }}</option>
                        {% endfor %}
                    </select>
                    <button type="button" class="ec-manage-link" onclick="document.getElementById('template-manage-panel').style.display=document.getElementById('template-manage-panel').style.display==='none'?'':'none'">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1 0 2.83 2 2 0 0 1-2.83 0l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-2 2 2 2 0 0 1-2-2v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83 0 2 2 0 0 1 0-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1-2-2 2 2 0 0 1 2-2h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 0-2.83 2 2 0 0 1 2.83 0l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 2-2 2 2 0 0 1 2 2v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 0 2 2 0 0 1 0 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 2 2 2 2 0 0 1-2 2h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
                        Manage Templates
                    </button>
                    <div id="template-manage-panel" style="display: none;" class="ec-template-manage">
                        {% for tpl in templates %}
                        <div class="ec-template-item">
                            <span>{{ tpl.getName() }}</span>
                            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/templates/' ~ tpl.getId() ~ '/delete') }}" style="display: inline;" class="confirm-delete" data-message="Delete template '{{ tpl.getName()|e('html_attr') }}'?">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn btn-sm btn-danger" style="padding: 2px 8px; font-size: var(--text-xs);">Delete</button>
                            </form>
                        </div>
                        {% endfor %}
                    </div>
                </div>
            </div>
            {% endif %}

            {# Parent Selector Card (Hierarchy) #}
            {% if collection.hasHierarchy() %}
            <div class="ec-sidebar-card">
                <div class="ec-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    Parent
                </div>
                <div class="ec-sidebar-card-body">
                    <input type="hidden" name="parent_id" id="parent-id-input" value="">
                    {% set _dfKey = collection.getDisplayField() %}
                    {% set _treeJson = [] %}
                    {% for item in treeEntries %}
                        {% set _lbl = (_dfKey and item[_dfKey] is defined and item[_dfKey]) ? item[_dfKey] : (item.title ?? item.name ?? item.slug ?? ('#' ~ item.id)) %}
                        {% set _treeJson = _treeJson|merge([{'id': item.id, 'label': _lbl, 'parent_id': item.parent_id|default(''), 'depth': item._depth}]) %}
                    {% endfor %}
                    <div class="tree-picker" id="parent-tree-picker" data-tree="{{ _treeJson|json_encode|e('html_attr') }}" data-current="" data-self="">
                        <button type="button" class="tree-picker-btn" id="tree-picker-toggle">
                            <span id="tree-picker-label">None (top level)</span>
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 4.5l3 3 3-3"/></svg>
                        </button>
                        <div class="tree-picker-dropdown" id="tree-picker-dropdown" style="display:none"></div>
                    </div>
                </div>
            </div>
            {% endif %}

            {# Slug Card #}
            {% if collection.hasSlug() %}
            <div class="ec-sidebar-card">
                <div class="ec-sidebar-card-header">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                    URL Slug
                </div>
                <div class="ec-sidebar-card-body">
                    <input type="text" id="entry-slug" name="slug" class="form-control"
                           value="{{ flash('_old_input').slug ?? '' }}"
                           placeholder="Auto-generated from {{ collection.getSlugSourceField() ?? 'title' }}">
                    <p class="ec-field-hint">Leave blank to auto-generate from the {{ collection.getSlugSourceField() ?? 'title' }} field.</p>
                </div>
            </div>
            {% endif %}

            {# SEO Card #}
            {% if collection.isSeoEnabled() %}
            <div class="ec-sidebar-card">
                <div class="ec-sidebar-card-header ec-sidebar-card-header--collapsible" onclick="this.parentElement.querySelector('.ec-sidebar-card-body').classList.toggle('ec-collapsed'); this.classList.toggle('ec-header-collapsed');">
                    <div class="flex items-center gap-2">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        SEO
                        <span class="seo-score-badge" id="seo-score-badge" style="display: none; padding: 2px 8px; border-radius: var(--radius-full); font-size: var(--text-xs);"></span>
                    </div>
                    <svg class="ec-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </div>
                <div class="ec-sidebar-card-body">
                    <div class="ec-sidebar-field">
                        <label class="ec-sidebar-label" for="meta_title">Meta Title</label>
                        <input type="text" id="meta_title" name="meta_title" class="form-control"
                               value="" maxlength="255"
                               placeholder="Page title for search engines"
                               oninput="updateSeoCounter(this, 'meta-title-counter', 60)">
                        <div class="ec-counter-row">
                            <span>30-60 chars recommended</span>
                            <span id="meta-title-counter">0 / 60</span>
                        </div>
                    </div>
                    <div class="ec-sidebar-field">
                        <label class="ec-sidebar-label" for="meta_description">Meta Description</label>
                        <textarea id="meta_description" name="meta_description" class="form-control"
                                  rows="3" maxlength="500"
                                  placeholder="Brief description for search results"
                                  oninput="updateSeoCounter(this, 'meta-desc-counter', 160)"></textarea>
                        <div class="ec-counter-row">
                            <span>120-160 chars recommended</span>
                            <span id="meta-desc-counter">0 / 160</span>
                        </div>
                    </div>
                    <div class="ec-sidebar-field">
                        <label class="ec-sidebar-label" for="og_image">OG Image URL</label>
                        <input type="text" id="og_image" name="og_image" class="form-control"
                               value="" placeholder="https://example.com/image.jpg">
                        <p class="ec-field-hint">1200x630px recommended.</p>
                    </div>
                    <div class="ec-sidebar-field">
                        <label class="ec-sidebar-label" for="canonical_url">Canonical URL</label>
                        <input type="url" id="canonical_url" name="canonical_url" class="form-control"
                               value="" placeholder="https://...">
                    </div>
                    <div class="ec-sidebar-field">
                        <label class="ec-sidebar-label" for="robots">Robots</label>
                        <select id="robots" name="robots" class="form-control">
                            <option value="index,follow" selected>Index, Follow</option>
                            <option value="index,nofollow">Index, No Follow</option>
                            <option value="noindex,follow">No Index, Follow</option>
                            <option value="noindex,nofollow">No Index, No Follow</option>
                        </select>
                    </div>
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</form>
{% endblock %}

{% block scripts %}

<script nonce="{{ csp_nonce() }}">
(function() {
    {% if collection.hasSlug() and collection.getSlugSourceField() %}
    var sourceField = '{{ collection.getSlugSourceField() }}';
    var sourceInput = document.querySelector('[name="' + sourceField + '"]');
    var slugInput = document.getElementById('entry-slug');
    if (sourceInput && slugInput) {
        sourceInput.addEventListener('input', function() {
            if (!slugInput.dataset.manual) {
                slugInput.value = this.value.toLowerCase()
                    .replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
            }
        });
        slugInput.addEventListener('input', function() {
            this.dataset.manual = this.value ? '1' : '';
        });
    }
    {% endif %}

    // Toggle switch label update
    document.querySelectorAll('.ec-toggle input[type="checkbox"]').forEach(function(cb) {
        cb.addEventListener('change', function() {
            var label = this.closest('.ec-toggle-wrap').querySelector('.ec-toggle-label');
            if (label) label.textContent = this.checked ? 'Enabled' : 'Disabled';
        });
    });

    // Media Field — click to browse
    var mediaUrl = '{{ admin_url("media/browse") }}';

    document.querySelectorAll('.media-field').forEach(function(zone) {
        zone.addEventListener('click', function(e) {
            if (e.target.closest('.media-field-remove') || e.target.closest('.media-field-grid-remove') || e.target.closest('.media-field-add-more')) return;
            var fieldSlug = zone.dataset.field;
            var filter = zone.dataset.filter || 'all';
            var isMultiple = zone.dataset.multiple === '1';
            var maxFiles = parseInt(zone.dataset.maxFiles) || 10;
            openMediaBrowser(fieldSlug, filter, isMultiple, maxFiles);
        });
    });

    // Add more button
    document.querySelectorAll('.media-field-add-more').forEach(function(btn) {
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            var fieldSlug = btn.dataset.field;
            var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
            var filter = zone.dataset.filter || 'all';
            var maxFiles = parseInt(zone.dataset.maxFiles) || 10;
            openMediaBrowser(fieldSlug, filter, true, maxFiles);
        });
    });

    // Remove button (single mode)
    document.addEventListener('click', function(e) {
        var removeBtn = e.target.closest('.media-field-remove');
        if (removeBtn) {
            e.stopPropagation();
            var fieldSlug = removeBtn.dataset.field;
            document.getElementById('field_' + fieldSlug).value = '';
            document.getElementById('media-preview-' + fieldSlug).style.display = 'none';
            document.getElementById('media-empty-' + fieldSlug).style.display = '';
            var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
            if (zone) zone.style.borderStyle = 'dashed';
        }
    });

    // Remove button (multi mode — remove single item from grid)
    document.addEventListener('click', function(e) {
        var gridRemove = e.target.closest('.media-field-grid-remove');
        if (gridRemove) {
            e.stopPropagation();
            var fieldSlug = gridRemove.dataset.field;
            var removeId = parseInt(gridRemove.dataset.id, 10);
            var hiddenInput = document.getElementById('field_' + fieldSlug);
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            current = current.filter(function(id) { return id !== removeId; });
            hiddenInput.value = current.length ? JSON.stringify(current) : '';
            gridRemove.closest('.media-field-grid-item').remove();
            if (current.length === 0) {
                var grid = document.getElementById('media-grid-' + fieldSlug);
                var addBtn = document.getElementById('media-add-' + fieldSlug);
                if (grid) grid.style.display = 'none';
                if (addBtn) addBtn.style.display = 'none';
                document.getElementById('media-empty-' + fieldSlug).style.display = '';
                var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');
                if (zone) zone.style.borderStyle = 'dashed';
            }
        }
    });

    function selectMediaItem(fieldSlug, mediaId, url, name, isImage, isMultiple) {
        var hiddenInput = document.getElementById('field_' + fieldSlug);
        var emptyState = document.getElementById('media-empty-' + fieldSlug);
        var zone = document.querySelector('.media-field[data-field="' + fieldSlug + '"]');

        if (isMultiple) {
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            if (!Array.isArray(current)) current = [];
            var id = parseInt(mediaId, 10);
            if (current.indexOf(id) === -1) current.push(id);
            hiddenInput.value = JSON.stringify(current);

            var grid = document.getElementById('media-grid-' + fieldSlug);
            var addBtn = document.getElementById('media-add-' + fieldSlug);
            emptyState.style.display = 'none';
            grid.style.display = '';
            addBtn.style.display = '';
            if (zone) zone.style.borderStyle = 'solid';

            var item = document.createElement('div');
            item.className = 'media-field-grid-item';
            item.dataset.id = id;
            if (isImage) {
                item.innerHTML = '<img src="' + url + '" alt="' + name + '"><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + id + '">&times;</button><div class="media-field-grid-item-name">' + name + '</div>';
            } else {
                item.innerHTML = '<div class="media-grid-file-icon">&#128196;</div><button type="button" class="media-field-grid-remove" data-field="' + fieldSlug + '" data-id="' + id + '">&times;</button><div class="media-field-grid-item-name">' + name + '</div>';
            }
            grid.appendChild(item);
        } else {
            hiddenInput.value = mediaId;
            emptyState.style.display = 'none';
            if (zone) zone.style.borderStyle = 'solid';

            var preview = document.getElementById('media-preview-' + fieldSlug);
            var thumb = preview.querySelector('.media-field-thumb');
            if (isImage) {
                thumb.src = url;
                thumb.style.display = '';
                var fileIcon = preview.querySelector('.media-field-file-icon');
                if (fileIcon) fileIcon.remove();
            } else {
                thumb.style.display = 'none';
                if (!preview.querySelector('.media-field-file-icon')) {
                    var icon = document.createElement('div');
                    icon.className = 'media-field-file-icon';
                    icon.innerHTML = '&#128196;';
                    preview.insertBefore(icon, preview.firstChild);
                }
            }
            preview.querySelector('.media-field-name').textContent = name;
            preview.style.display = 'flex';
        }
    }

    function openMediaBrowser(fieldSlug, filter, isMultiple, maxFiles) {
        if (isMultiple) {
            var hiddenInput = document.getElementById('field_' + fieldSlug);
            var current = [];
            try { current = JSON.parse(hiddenInput.value); } catch(ex) { current = []; }
            if (Array.isArray(current) && current.length >= maxFiles) {
                alert('Maximum of ' + maxFiles + ' files reached.');
                return;
            }
        }

        var uploadUrl = '{{ admin_url("media/upload") }}';
        var csrfToken = document.querySelector('input[name="_token"], input[name="csrf_token"]');
        var csrfVal = csrfToken ? csrfToken.value : '';

        var selectedIds = [];

        var modal = document.createElement('div');
        modal.className = 'media-modal-overlay';
        modal.innerHTML = '<div class="media-modal">'
            + '<div class="media-modal-header">'
            + '<h3>Select from Media Library</h3>'
            + '<button type="button" class="media-modal-close">&times;</button>'
            + '</div>'
            + '<div class="media-modal-toolbar">'
            + '<div class="media-modal-search"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg><input type="text" class="media-search-input" placeholder="Search files..."></div>'
            + '<div class="media-modal-filters">'
            + '<button type="button" class="media-filter-btn' + (filter === 'all' || filter === '' ? ' active' : '') + '" data-filter="all">All</button>'
            + '<button type="button" class="media-filter-btn' + (filter === 'images' ? ' active' : '') + '" data-filter="images">Images</button>'
            + '<button type="button" class="media-filter-btn" data-filter="video">Video</button>'
            + '<button type="button" class="media-filter-btn" data-filter="documents">Docs</button>'
            + '</div>'
            + '</div>'
            + '<div class="media-modal-body"><p style="text-align:center;padding:var(--sp-6);color:var(--text-secondary)">Loading...</p></div>'
            + (isMultiple ? '<div class="media-modal-footer" style="display:flex;justify-content:space-between;align-items:center;padding:12px 20px;border-top:1px solid var(--border,#e3e3e3);background:var(--bg-subdued,#fafafa);"><span class="media-selected-count">0 selected</span><button type="button" class="media-done-btn btn btn-primary" disabled>Done</button></div>' : '')
            + '<div class="media-modal-upload-bar">'
            + '<label class="media-upload-label"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg> Upload Files<input type="file" class="media-upload-input" multiple accept="image/*,video/*,application/pdf,.doc,.docx,.xls,.xlsx" style="display:none"></label>'
            + '<span class="media-upload-status"></span>'
            + '</div>'
            + '</div>';
        document.body.appendChild(modal);

        var currentFilter = filter || 'all';
        var currentSearch = '';

        modal.querySelector('.media-modal-close').addEventListener('click', function() { modal.remove(); });
        modal.addEventListener('click', function(e) { if (e.target === modal) modal.remove(); });
        document.addEventListener('keydown', function onEsc(e) { if (e.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onEsc); } });

        function updateSelectedCount() {
            var countEl = modal.querySelector('.media-selected-count');
            var doneBtn = modal.querySelector('.media-done-btn');
            if (countEl) countEl.textContent = selectedIds.length + ' selected';
            if (doneBtn) doneBtn.disabled = selectedIds.length === 0;
        }

        function toggleSelection(id, el) {
            var idx = -1;
            for (var i = 0; i < selectedIds.length; i++) {
                if (selectedIds[i].id === id) { idx = i; break; }
            }
            if (idx >= 0) {
                selectedIds.splice(idx, 1);
                el.classList.remove('media-modal-item-selected');
                var cb = el.querySelector('input[type="checkbox"]');
                if (cb) cb.checked = false;
            } else {
                selectedIds.push({
                    id: parseInt(el.dataset.id, 10),
                    url: el.dataset.url,
                    name: el.dataset.name,
                    isImage: el.dataset.isImage === '1'
                });
                el.classList.add('media-modal-item-selected');
                var cb = el.querySelector('input[type="checkbox"]');
                if (cb) cb.checked = true;
            }
            updateSelectedCount();
        }

        // Multi-select done button
        if (isMultiple) {
            modal.querySelector('.media-done-btn').addEventListener('click', function() {
                selectedIds.forEach(function(item) {
                    selectMediaItem(fieldSlug, item.id, item.url, item.name, item.isImage, true);
                });
                modal.remove();
            });
        }

        function loadMedia() {
            var body = modal.querySelector('.media-modal-body');
            body.innerHTML = '<p style="text-align:center;padding:var(--sp-6);color:var(--text-secondary)">Loading...</p>';
            var url = mediaUrl + '?filter=' + currentFilter + '&per_page=36' + (currentSearch ? '&search=' + encodeURIComponent(currentSearch) : '');
            fetch(url).then(function(r) { return r.json(); }).then(function(data) {
                if (!data.data || data.data.length === 0) {
                    body.innerHTML = '<div style="text-align:center;padding:var(--sp-8)">'
                        + '<svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled)" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>'
                        + '<p style="margin:var(--sp-3) 0 var(--sp-2);font-weight:600;color:var(--text)">No media files found</p>'
                        + '<p style="color:var(--text-secondary);font-size:var(--text-sm);margin-bottom:var(--sp-4)">Upload files using the button below or go to the <a href=\'' + mediaUrl.replace('/browse', '') + '\' style="color:var(--zui-primary-500)">Media Library</a></p>'
                        + '</div>';
                    return;
                }
                var html = '<div class="media-modal-grid">';
                data.data.forEach(function(item) {
                    var thumb = item.is_image ? '<img src="' + (item.thumbnail || item.url) + '" alt="' + item.name + '" loading="lazy">' : '<div class="media-file-icon"><svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>';
                    var isSelected = false;
                    for (var s = 0; s < selectedIds.length; s++) { if (selectedIds[s].id === item.id) { isSelected = true; break; } }
                    html += '<div class="media-modal-item' + (isSelected ? ' media-modal-item-selected' : '') + '" data-id="' + item.id + '" data-url="' + item.url + '" data-name="' + item.name + '" data-is-image="' + (item.is_image ? '1' : '0') + '">'
                        + (isMultiple ? '<div class="media-modal-check"><input type="checkbox"' + (isSelected ? ' checked' : '') + '></div>' : '')
                        + '<div class="media-modal-thumb">' + thumb + '</div>'
                        + '<div class="media-modal-name">' + item.name + '</div>'
                        + '</div>';
                });
                body.innerHTML = html + '</div>';
                body.querySelectorAll('.media-modal-item').forEach(function(el) {
                    el.addEventListener('click', function() {
                        if (isMultiple) {
                            toggleSelection(parseInt(el.dataset.id, 10), el);
                        } else {
                            selectMediaItem(fieldSlug, el.dataset.id, el.dataset.url, el.dataset.name, el.dataset.isImage === '1', false);
                            modal.remove();
                        }
                    });
                });
            });
        }

        // Search
        var searchTimeout;
        modal.querySelector('.media-search-input').addEventListener('input', function() {
            clearTimeout(searchTimeout);
            var val = this.value;
            searchTimeout = setTimeout(function() { currentSearch = val; loadMedia(); }, 300);
        });

        // Filter tabs
        modal.querySelectorAll('.media-filter-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                modal.querySelectorAll('.media-filter-btn').forEach(function(b) { b.classList.remove('active'); });
                btn.classList.add('active');
                currentFilter = btn.dataset.filter;
                loadMedia();
            });
        });

        // Upload — auto-select uploaded file
        modal.querySelector('.media-upload-input').addEventListener('change', function() {
            var files = this.files;
            if (!files.length) return;
            var status = modal.querySelector('.media-upload-status');
            var totalFiles = files.length;
            status.textContent = 'Uploading ' + totalFiles + ' file(s)...';
            var uploaded = 0;
            var lastUploadedId = null;
            var lastUploadedUrl = '';
            var lastUploadedName = '';
            var lastIsImage = false;
            Array.from(files).forEach(function(f) {
                var fd = new FormData();
                fd.append('file', f);
                fd.append('csrf_token', csrfVal);
                var xhr = new XMLHttpRequest();
                xhr.open('POST', uploadUrl, true);
                xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
                xhr.onload = function() {
                    uploaded++;
                    try {
                        var resp = JSON.parse(xhr.responseText);
                        if (resp.id) {
                            lastUploadedId = resp.id;
                            lastUploadedUrl = '/' + resp.path;
                            lastUploadedName = f.name;
                            lastIsImage = f.type.startsWith('image/');
                            if (isMultiple) {
                                // Auto-check uploaded items in multi mode
                                selectedIds.push({ id: resp.id, url: '/' + resp.path, name: f.name, isImage: lastIsImage });
                                updateSelectedCount();
                            }
                        }
                    } catch(e) {}
                    if (uploaded >= totalFiles) {
                        if (isMultiple) {
                            status.textContent = 'Uploaded! ' + selectedIds.length + ' selected.';
                            loadMedia();
                        } else if (lastUploadedId) {
                            selectMediaItem(fieldSlug, lastUploadedId, lastUploadedUrl, lastUploadedName, lastIsImage, false);
                            modal.remove();
                        } else {
                            status.textContent = 'Uploaded!';
                            loadMedia();
                        }
                    }
                };
                xhr.onerror = function() { uploaded++; status.textContent = 'Upload error'; };
                xhr.send(fd);
            });
        });

        loadMedia();
    }
})();
</script>

{# SEO counter script #}
{% if collection.isSeoEnabled() %}
<script nonce="{{ csp_nonce() }}">
function updateSeoCounter(el, counterId, recommended) {
    var counter = document.getElementById(counterId);
    if (!counter) return;
    var len = el.value.length;
    counter.textContent = len + ' / ' + recommended;
    if (len > 0 && len <= recommended) {
        counter.style.color = '#047B5D';
    } else if (len > recommended) {
        counter.style.color = '#D72C0D';
    } else {
        counter.style.color = '';
    }
}
</script>
{% endif %}

{# Drill-down tree picker for parent selection #}
<script nonce="{{ csp_nonce() }}">
(function() {
    var picker = document.getElementById('parent-tree-picker');
    if (!picker) return;
    var toggle = document.getElementById('tree-picker-toggle');
    var dropdown = document.getElementById('tree-picker-dropdown');
    var hiddenInput = document.getElementById('parent-id-input');
    var labelEl = document.getElementById('tree-picker-label');
    var treeData = JSON.parse(picker.dataset.tree || '[]');
    var currentVal = picker.dataset.current || '';
    var selfId = picker.dataset.self || '';
    var childrenOf = {};
    var itemMap = {};
    treeData.forEach(function(item) {
        itemMap[item.id] = item;
        var pid = item.parent_id || '__root__';
        if (!childrenOf[pid]) childrenOf[pid] = [];
        childrenOf[pid].push(item);
    });
    function renderLevel(parentId, parentLabel) {
        var html = '';
        if (parentId) {
            var parent = itemMap[parentId];
            var gpId = parent ? (parent.parent_id || '') : '';
            html += '<div class="tp-back" data-go="' + gpId + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><polyline points="15 18 9 12 15 6"/></svg>' + (parentLabel || 'Back') + '</div>';
            html += '<div class="tp-select-current" data-select="' + parentId + '" data-label="' + (parentLabel || '').replace(/"/g, '&quot;') + '">● Select: ' + (parentLabel || '#' + parentId) + '</div>';
        } else {
            html += '<div class="tp-none' + (!currentVal ? ' active' : '') + '" data-select="" data-label="None (top level)">None (top level)</div>';
        }
        var children = childrenOf[parentId || '__root__'] || [];
        children.forEach(function(child) {
            var hasKids = (childrenOf[child.id] || []).length > 0;
            var isActive = currentVal == child.id;
            var isDisabled = selfId && selfId == child.id;
            html += '<div class="tp-item' + (isActive ? ' active' : '') + (isDisabled ? ' disabled' : '') + '" data-id="' + child.id + '" data-label="' + child.label.replace(/"/g, '&quot;') + '"' + (hasKids ? ' data-drill="1"' : '') + '><span>' + child.label + '</span>' + (hasKids ? '<span class="tp-item-arrow">›</span>' : '') + '</div>';
        });
        if (!children.length && parentId) html += '<div style="padding:12px;text-align:center;color:#999;font-size:12px;">No children</div>';
        dropdown.innerHTML = html;
        bindEvents();
    }
    function bindEvents() {
        dropdown.querySelectorAll('.tp-back').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); var p = itemMap[el.dataset.go]; renderLevel(el.dataset.go || '', p ? p.label : ''); });
        });
        dropdown.querySelectorAll('[data-select]').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.select; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; });
        });
        dropdown.querySelectorAll('.tp-item[data-drill]').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); renderLevel(el.dataset.id, el.dataset.label); });
        });
        dropdown.querySelectorAll('.tp-item:not([data-drill]):not(.disabled)').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.id; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; });
        });
    }
    toggle.addEventListener('click', function(e) {
        e.preventDefault();
        if (dropdown.style.display === 'none') { renderLevel('', ''); dropdown.style.display = 'block'; } else { dropdown.style.display = 'none'; }
    });
    document.addEventListener('click', function(e) { if (!e.target.closest('#parent-tree-picker')) dropdown.style.display = 'none'; });
})();
</script>

{# Drill-down for relation fields pointing to hierarchy collections #}
<script nonce="{{ csp_nonce() }}">
document.querySelectorAll('.rel-drill-picker').forEach(function(picker) {
    var treeData = JSON.parse(picker.dataset.tree || '[]');
    var fieldSlug = picker.dataset.field;
    var currentVal = picker.dataset.current || '';
    var toggle = picker.querySelector('.tree-picker-btn');
    var dropdown = picker.querySelector('.tree-picker-dropdown');
    var hiddenInput = document.getElementById('field_' + fieldSlug);
    var labelEl = picker.querySelector('.tp-label');
    if (!toggle || !dropdown || !hiddenInput) return;

    var childrenOf = {}, itemMap = {};
    treeData.forEach(function(item) {
        itemMap[item.id] = item;
        var pid = item.parent_id || '__root__';
        if (!childrenOf[pid]) childrenOf[pid] = [];
        childrenOf[pid].push(item);
    });

    function renderLevel(parentId, parentLabel) {
        var html = '';
        if (parentId) {
            var parent = itemMap[parentId];
            var gpId = parent ? (parent.parent_id || '') : '';
            html += '<div class="tp-back" data-go="' + gpId + '"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="width:14px;height:14px"><polyline points="15 18 9 12 15 6"/></svg>' + (parentLabel || 'Back') + '</div>';
            html += '<div class="tp-select-current" data-select="' + parentId + '" data-label="' + (parentLabel || '').replace(/"/g, '&quot;') + '">● Select: ' + parentLabel + '</div>';
        } else {
            html += '<div class="tp-none' + (!currentVal ? ' active' : '') + '" data-select="" data-label="Select...">None</div>';
        }
        (childrenOf[parentId || '__root__'] || []).forEach(function(child) {
            var hasKids = (childrenOf[child.id] || []).length > 0;
            html += '<div class="tp-item' + (currentVal == child.id ? ' active' : '') + '" data-id="' + child.id + '" data-label="' + child.label.replace(/"/g, '&quot;') + '"' + (hasKids ? ' data-drill="1"' : '') + '><span>' + child.label + '</span>' + (hasKids ? '<span class="tp-item-arrow">›</span>' : '') + '</div>';
        });
        dropdown.innerHTML = html;
        dropdown.querySelectorAll('.tp-back').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); var p = itemMap[el.dataset.go]; renderLevel(el.dataset.go || '', p ? p.label : ''); });
        });
        dropdown.querySelectorAll('[data-select]').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.select; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; });
        });
        dropdown.querySelectorAll('.tp-item[data-drill]').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); renderLevel(el.dataset.id, el.dataset.label); });
        });
        dropdown.querySelectorAll('.tp-item:not([data-drill])').forEach(function(el) {
            el.addEventListener('click', function(e) { e.stopPropagation(); currentVal = el.dataset.id; hiddenInput.value = currentVal; labelEl.textContent = el.dataset.label; dropdown.style.display = 'none'; });
        });
    }
    toggle.addEventListener('click', function(e) { e.preventDefault(); if (dropdown.style.display === 'none') { renderLevel('', ''); dropdown.style.display = 'block'; } else { dropdown.style.display = 'none'; } });
    document.addEventListener('click', function(e) { if (!e.target.closest('.rel-drill-picker[data-field="' + fieldSlug + '"]')) dropdown.style.display = 'none'; });
});
</script>

{# Character counter for max_length fields #}
<script nonce="{{ csp_nonce() }}">
document.querySelectorAll('.js-char-count').forEach(function(span) {
    var slug = span.dataset.field;
    var max = parseInt(span.dataset.max, 10);
    var input = document.getElementById('field_' + slug);
    if (!input) return;
    function update() {
        var len = (input.value || '').length;
        span.textContent = len;
        span.parentElement.style.color = len > max ? 'var(--color-critical, #D72C0D)' : 'var(--text-secondary, #616161)';
    }
    input.addEventListener('input', update);
    update();
});
</script>

{% endblock %}
