{% extends "@cms/layouts/cms.twig" %}

{% block title %}{{ collection.getName() }} Entries{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
/* ── Page ───────────────────────────────────────── */
.ep { max-width: 1320px; margin: 0 auto; padding-bottom: 80px; }

/* ── Breadcrumb (light) ─────────────────────────── */
.ep-crumb { margin-bottom: var(--sp-4); }

/* ── Title row ──────────────────────────────────── */
.ep-title-row { display: flex; align-items: center; gap: var(--sp-3); margin-bottom: var(--sp-4); }
.ep-title-icon {
    width: 36px; height: 36px; border-radius: var(--radius-lg);
    background: var(--zui-primary-50); color: var(--zui-primary-600);
    display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ep-title-icon svg { width: 18px; height: 18px; }
.ep-title { font-size: 1.25rem; font-weight: 700; color: var(--text-heading); margin: 0; }
.ep-title-actions { margin-left: auto; display: flex; align-items: center; gap: var(--sp-2); }

/* ── Toolbar: View selector + Column/Filter/Sort ── */
.ep-bar {
    display: flex; align-items: center; gap: var(--sp-1);
    padding: var(--sp-2) 0; margin-bottom: var(--sp-2);
    border-bottom: 1px solid var(--zui-gray-100);
}
.ep-bar-item {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 5px 12px; font-size: 13px; font-weight: 500; color: var(--text-secondary);
    background: none; border: 1px solid transparent; border-radius: var(--radius-md);
    cursor: pointer; text-decoration: none; transition: all 100ms; white-space: nowrap;
}
.ep-bar-item:hover { color: var(--text-heading); background: var(--zui-gray-50); }
.ep-bar-item.is-active { color: var(--zui-primary-600); background: var(--zui-primary-50); border-color: var(--zui-primary-200); }
.ep-bar-item svg { width: 14px; height: 14px; }
.ep-bar-count {
    font-size: 10px; font-weight: 700; min-width: 18px; height: 18px; line-height: 18px;
    text-align: center; background: var(--zui-gray-200); color: var(--text-secondary);
    border-radius: 50%; display: inline-block;
}
.ep-bar-item.is-active .ep-bar-count { background: var(--zui-primary-100); color: var(--zui-primary-700); }
.ep-bar-sep { width: 1px; height: 20px; background: var(--zui-gray-200); margin: 0 var(--sp-2); flex-shrink: 0; }
.ep-bar-right { margin-left: auto; display: flex; align-items: center; gap: var(--sp-1); }

/* ── Active filter chips ────────────────────────── */
.ep-chips { display: flex; align-items: center; gap: var(--sp-2); flex-wrap: wrap; padding: var(--sp-2) 0; }
.ep-chip {
    display: inline-flex; align-items: center; gap: 4px; padding: 2px 6px 2px 10px;
    background: var(--zui-gray-100); color: var(--text); font-size: 12px; font-weight: 500;
    border-radius: var(--radius-full);
}
.ep-chip b { font-weight: 600; color: var(--text-heading); }
.ep-chip-x { display: inline-flex; padding: 2px; color: var(--text-secondary); cursor: pointer; text-decoration: none; border-radius: 50%; }
.ep-chip-x:hover { color: var(--text-heading); background: var(--zui-gray-200); }

/* ── Filter panel ───────────────────────────────── */
.ep-filter-panel {
    position: absolute; top: calc(100% + 4px); right: 0; z-index: 60;
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md); padding: var(--sp-3); min-width: 340px; display: none;
}
.ep-filter-panel.open { display: block; }
.ep-filter-row { display: flex; gap: var(--sp-2); margin-bottom: var(--sp-2); align-items: center; }
.ep-filter-row select, .ep-filter-row input { font-size: 13px; height: 32px; }

/* ── Sort panel ─────────────────────────────────── */
.ep-sort-panel {
    position: absolute; top: calc(100% + 4px); right: 0; z-index: 60;
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md); padding: var(--sp-2); min-width: 200px; display: none;
}
.ep-sort-panel.open { display: block; }

/* ── Table ──────────────────────────────────────── */
.ep-table-wrap {
    background: var(--bg-surface); border: 1px solid var(--zui-gray-200);
    border-radius: var(--radius-lg);
}
.ep-table { width: 100%; border-collapse: collapse; table-layout: fixed; }
.ep-table th {
    padding: 10px 14px; font-size: 13px; font-weight: 600; color: var(--text-heading);
    text-align: left; border-bottom: 1px solid var(--zui-gray-200);
    background: var(--bg-surface); position: relative; cursor: pointer;
    user-select: none; white-space: nowrap;
}
.ep-table th:hover { background: var(--zui-gray-50); }
.ep-table th:first-child { width: 44px; cursor: default; }
.ep-table th:first-child:hover { background: var(--bg-surface); }
.ep-table th:last-child { width: 50px; cursor: default; }
.ep-table th:last-child:hover { background: var(--bg-surface); }
.ep-th-sort {
    display: inline-flex; align-items: center; gap: 4px;
    color: inherit; text-decoration: none; font: inherit;
}
.ep-th-sort svg { width: 12px; height: 12px; color: var(--text-secondary); }
.ep-th-sort.is-active svg { color: var(--zui-primary-600); }
.ep-sort-icon--desc { transform: rotate(180deg); }

/* Column header context menu */
.ep-col-menu {
    position: absolute; top: 100%; left: 0; z-index: 70;
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-md);
    padding: var(--sp-1) 0; min-width: 180px; display: none;
}
.ep-col-menu.open { display: block; }
.ep-col-menu-item {
    display: flex; align-items: center; gap: var(--sp-2); padding: 7px 14px;
    font-size: 13px; color: var(--text); text-decoration: none;
    cursor: pointer; border: none; background: none; width: 100%; text-align: left;
    transition: background 80ms;
}
.ep-col-menu-item:hover { background: var(--zui-gray-50); }
.ep-col-menu-item svg { width: 14px; height: 14px; color: var(--text-secondary); flex-shrink: 0; }
.ep-col-menu-item.danger { color: var(--zui-error-600); }
.ep-col-menu-item.danger svg { color: var(--zui-error-400); }
.ep-col-menu-divider { height: 1px; background: var(--zui-gray-100); margin: 4px 0; }

/* ── Table rows ─────────────────────────────────── */
.ep-table td {
    padding: 0 14px; height: 48px; font-size: 13px; color: var(--text);
    border-bottom: 1px solid var(--zui-gray-100); vertical-align: middle;
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    position: relative;
}
.ep-table tr:last-child td { border-bottom: none; }
.ep-table tbody tr { transition: background 60ms; }
.ep-table tbody tr:hover { background: var(--zui-gray-50); }
.ep-table tbody tr.is-selected { background: var(--zui-primary-50); }

/* Checkbox column */
.ep-table td:first-child, .ep-table th:first-child { text-align: center; padding: 0 8px; }
.ep-cb { width: 16px; height: 16px; accent-color: var(--zui-primary-500); cursor: pointer; }

/* Entry name */
.ep-name {
    font-weight: 500; color: var(--text-heading); text-decoration: none;
    display: inline-flex; align-items: center; gap: 8px;
}
.ep-name:hover { color: var(--zui-primary-600); }

/* Open button (hover reveal) */
.ep-open-btn {
    display: none; align-items: center; gap: 4px; padding: 2px 10px;
    font-size: 12px; font-weight: 500; color: var(--zui-primary-600);
    background: var(--zui-primary-50); border: 1px solid var(--zui-primary-200);
    border-radius: var(--radius-md); text-decoration: none; white-space: nowrap;
}
.ep-open-btn svg { width: 12px; height: 12px; }
.ep-table tbody tr:hover .ep-open-btn { display: inline-flex; }

/* Image thumbnails */
.ep-thumb { width: 28px; height: 28px; border-radius: 6px; object-fit: cover; border: 1px solid var(--zui-gray-200); }

/* Richtext preview */
.ep-rt-preview { cursor: pointer; }
.ep-rt-preview:hover { color: var(--zui-primary-600); }

/* Boolean badges */
.ep-bool-yes { background: var(--zui-success-50); color: var(--zui-success-700); font-size: 11px; font-weight: 600; padding: 2px 10px; border-radius: var(--radius-full); }
.ep-bool-no { background: var(--zui-gray-100); color: var(--text-secondary); font-size: 11px; font-weight: 600; padding: 2px 10px; border-radius: var(--radius-full); }

/* Date cell — hidden until JS renders */
.ep-date { font-size: 13px; color: var(--text-secondary); visibility: hidden; }
.ep-date.is-ready { visibility: visible; }

/* Actions column */
.ep-actions-cell { text-align: right !important; }
.ep-action {
    display: inline-flex; align-items: center; justify-content: center;
    width: 28px; height: 28px; color: var(--text-secondary); background: none;
    border: none; border-radius: var(--radius-md); cursor: pointer;
    text-decoration: none; opacity: 0; transition: opacity 80ms, color 80ms, background 80ms;
}
.ep-table tbody tr:hover .ep-action { opacity: 1; }
.ep-action:hover { color: var(--text-heading); background: var(--zui-gray-100); }
.ep-action svg { width: 14px; height: 14px; }

/* Row dropdown fix */
.ep-actions-cell .dropdown { position: static; }
.ep-actions-cell .dropdown-menu { position: absolute; z-index: 60; right: 14px; left: auto; }

/* ── Column toggle panel ────────────────────────── */
.ep-col-panel {
    position: absolute; top: calc(100% + 4px); right: 0; z-index: 60;
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md); padding: var(--sp-2); min-width: 200px; display: none;
}
.ep-col-panel.open { display: block; }
.ep-col-panel-title { font-size: 10px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-secondary); padding: var(--sp-1) var(--sp-2); }
.ep-col-panel label { display: flex; align-items: center; gap: var(--sp-2); padding: 4px var(--sp-2); font-size: 13px; cursor: pointer; border-radius: var(--radius-sm); }
.ep-col-panel label:hover { background: var(--bg-surface-hover); }

/* ── Import Card ────────────────────────────────── */
.ep-import-card { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: var(--sp-3); margin-bottom: var(--sp-3); }

/* ── Empty State ────────────────────────────────── */
.ep-empty { text-align: center; padding: var(--sp-10) var(--sp-4); background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); }
.ep-empty-icon { width: 48px; height: 48px; background: var(--zui-gray-100); border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; margin: 0 auto var(--sp-3); color: var(--text-secondary); }
.ep-empty-icon svg { width: 22px; height: 22px; }

/* ── Pagination ─────────────────────────────────── */
.ep-pagination { display: flex; align-items: center; justify-content: space-between; padding: var(--sp-2) var(--sp-3); border-top: 1px solid var(--zui-gray-200); font-size: 12px; color: var(--text-secondary); }
.ep-pagination-ctrls { display: flex; align-items: center; gap: 3px; }
.ep-pg {
    display: inline-flex; align-items: center; justify-content: center; min-width: 28px; height: 28px;
    padding: 0 6px; font-size: 12px; font-weight: 500; color: var(--text);
    background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-md);
    text-decoration: none; cursor: pointer; transition: all 100ms; gap: 3px;
}
.ep-pg:hover { border-color: var(--zui-primary-400); color: var(--zui-primary-600); }
.ep-pg.is-current { background: var(--zui-primary-500); color: #fff; border-color: var(--zui-primary-500); }
.ep-pg.is-disabled { opacity: 0.35; pointer-events: none; }

/* ── Bulk Bar ───────────────────────────────────── */
.ep-bulk {
    position: fixed; bottom: var(--sp-4); left: 50%; transform: translateX(-50%);
    display: none; align-items: center; gap: var(--sp-3); padding: 10px 20px;
    background: var(--zui-gray-900); color: #fff; font-size: 13px;
    border-radius: var(--radius-xl); box-shadow: 0 8px 32px rgba(0,0,0,0.24); z-index: 100;
}
.ep-bulk.is-visible { display: flex; }
.ep-bulk .btn { height: 28px; font-size: 12px; color: #fff; border-color: rgba(255,255,255,0.3); }
.ep-bulk .btn:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.5); }
.ep-bulk .btn-danger { background: var(--zui-error-600); border-color: var(--zui-error-600); }

/* ── Column hidden ──────────────────────────────── */
.col-hidden { display: none !important; }

/* ── Hierarchy ──────────────────────────────────── */
.ep-hier-arrow { display: inline-flex; align-items: center; justify-content: center; width: 20px; height: 20px; border-radius: 4px; color: var(--zui-primary-600); font-weight: 700; font-size: 14px; flex-shrink: 0; text-decoration: none; }
.ep-hier-arrow:hover { background: rgba(14,165,233,0.1); }
.tree-indent { display: inline-flex; align-items: center; flex-shrink: 0; }
.tree-toggle-btn { background: none; border: none; cursor: pointer; padding: 2px; margin-right: 3px; color: var(--text-secondary); font-size: 11px; width: 16px; text-align: center; border-radius: 3px; }
.tree-toggle-btn:hover { background: var(--bg-surface-hover); }

/* ── View chip ──────────────────────────────────── */
.ep-view-chip {
    display: inline-flex; align-items: center; gap: 5px; padding: 3px 8px 3px 6px;
    background: var(--zui-primary-50); color: var(--zui-primary-700); font-size: 12px;
    font-weight: 500; border-radius: var(--radius-full);
}
.ep-view-chip a { color: var(--zui-primary-400); text-decoration: none; line-height: 1; }
.ep-view-chip a:hover { color: var(--zui-primary-700); }

/* ── Bulk field form ────────────────────────────── */
.ep-bulk-field-form { padding: var(--sp-3); }

/* ── Responsive ─────────────────────────────────── */
@media (max-width: 768px) {
    .ep-title-row { flex-wrap: wrap; }
    .ep-bar { overflow-x: auto; }
}
</style>
{% endblock %}

{% block content %}

{% set _totalCount = entries.total|default(entries.data|length) %}

{# ── Breadcrumb ─────────────────────────────────── #}
<div class="breadcrumb ep-crumb">
    <a href="{{ admin_url() }}">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'home'} only %} Dashboard</a>
    <span class="breadcrumb-sep">/</span>
    <a href="{{ admin_url('collections') }}">Collections</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">{{ collection.getName() }}</span>
</div>

<div class="ep">

    {# ── Title Row ──────────────────────────────────── #}
    <div class="ep-title-row">
        <div class="ep-title-icon">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'layers'} only %}
        </div>
        <h1 class="ep-title">{{ collection.getName() }}</h1>

        <div class="ep-title-actions">
            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash') }}" class="btn btn-outline btn-sm">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %} Trash
                {% if trashCount is defined and trashCount > 0 %}
                    <span class="badge badge-error" style="margin-left:2px">{{ trashCount }}</span>
                {% endif %}
            </a>
            <div class="dropdown" data-dropdown>
                <button class="btn btn-outline btn-sm" data-dropdown-trigger>
                    Export <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
                </button>
                <div class="dropdown-menu" data-dropdown-menu>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=csv') }}" class="dropdown-item">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} CSV</a>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=json') }}" class="dropdown-item">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'code'} only %} JSON</a>
                </div>
            </div>
            <button class="btn btn-outline btn-sm" id="toggle-import-btn">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Import</button>
            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="btn btn-primary btn-sm">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %} New Entry
            </a>
            <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}" class="btn btn-ghost btn-icon btn-sm" title="Settings">
                {% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}
            </a>
        </div>
    </div>

    {# ── Import Form (hidden) ───────────────────────── #}
    <div id="import-form" class="ep-import-card hidden">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/import/preview') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="flex items-center gap-3">
                <div class="form-group" style="flex:1;margin-bottom:0;">
                    <label for="import_file" class="form-label">Import File (CSV or JSON)</label>
                    <input type="file" id="import_file" name="import_file" class="form-control" accept=".csv,.json" required>
                </div>
                <button type="submit" class="btn btn-primary btn-sm" style="align-self:flex-end;">Preview &amp; Map</button>
            </div>
        </form>
    </div>

    {# ── Toolbar Bar ────────────────────────────────── #}
    <div class="ep-bar">
        {# View tabs #}
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}"
           class="ep-bar-item {% if activeViewSlug is not defined or not activeViewSlug %}is-active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
            Default
        </a>
        {% if savedViews is defined and savedViews|length > 0 %}
            {% for sv in savedViews %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?view=' ~ sv.getSlug()) }}"
                   class="ep-bar-item {% if activeViewSlug is defined and activeViewSlug == sv.getSlug() %}is-active{% endif %}">
                    {{ sv.getName() }}
                </a>
            {% endfor %}
        {% endif %}

        <div class="ep-bar-sep"></div>

        {# Column toggle #}
        <div style="position:relative;" class="ep-bar-right">
            <button type="button" class="ep-bar-item" id="col-toggle-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 3v18M15 3v18"/></svg>
                Column
                <span class="ep-bar-count" id="col-count">{{ listableFields|length }}</span>
            </button>
            <div class="ep-col-panel" id="col-toggle-dropdown">
                <div class="ep-col-panel-title">Toggle Columns</div>
                <div id="col-toggle-list"></div>
            </div>
        </div>

        {# Filter #}
        <div style="position:relative;">
            <button type="button" class="ep-bar-item {% if activeFilters is defined and activeFilters|length > 0 %}is-active{% endif %}" id="filter-toggle-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 3H2l8 9.46V19l4 2v-8.54L22 3z"/></svg>
                Filter
                {% if activeFilters is defined and activeFilters|length > 0 %}
                    <span class="ep-bar-count">{{ activeFilters|length }}</span>
                {% endif %}
            </button>
            <div class="ep-filter-panel" id="filter-panel">
                <div style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--text-secondary);margin-bottom:var(--sp-2);">Filter entries</div>
                <form method="GET" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" id="filter-form">
                    {% if sortBy %}<input type="hidden" name="sort_by" value="{{ sortBy }}">{% endif %}
                    {% if sortDir %}<input type="hidden" name="sort_dir" value="{{ sortDir }}">{% endif %}
                    {% if activeViewSlug %}<input type="hidden" name="view" value="{{ activeViewSlug }}">{% endif %}
                    <div id="filter-rows">
                        {% if activeFilters is defined and activeFilters|length > 0 %}
                            {% for fField, fValue in activeFilters %}
                            <div class="ep-filter-row">
                                <select name="filter_field[]" class="form-control" style="flex:1;">
                                    <option value="">-- Field --</option>
                                    {% for field in listableFields %}<option value="{{ field.getSlug() }}" {% if fField == field.getSlug() %}selected{% endif %}>{{ field.getName() }}</option>{% endfor %}
                                    {% if collection.isPublishable() %}<option value="status" {% if fField == 'status' %}selected{% endif %}>Status</option>{% endif %}
                                </select>
                                <input type="text" name="filter_value[]" class="form-control" placeholder="Value" value="{{ fValue }}" style="flex:1;">
                                <button type="button" class="btn btn-ghost btn-icon btn-sm ep-remove-filter" style="width:28px;height:28px;" title="Remove">
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                                </button>
                            </div>
                            {% endfor %}
                        {% else %}
                        <div class="ep-filter-row">
                            <select name="filter_field[]" class="form-control" style="flex:1;">
                                <option value="">-- Field --</option>
                                {% for field in listableFields %}<option value="{{ field.getSlug() }}">{{ field.getName() }}</option>{% endfor %}
                                {% if collection.isPublishable() %}<option value="status">Status</option>{% endif %}
                            </select>
                            <input type="text" name="filter_value[]" class="form-control" placeholder="Value" style="flex:1;">
                            <button type="button" class="btn btn-ghost btn-icon btn-sm ep-remove-filter" style="width:28px;height:28px;" title="Remove">
                                <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                            </button>
                        </div>
                        {% endif %}
                    </div>
                    <div class="flex items-center gap-2" style="margin-top:var(--sp-2);">
                        <button type="button" class="btn btn-ghost btn-sm" id="add-filter-row">+ Add</button>
                        <div style="margin-left:auto;display:flex;gap:var(--sp-2);">
                            {% if activeFilters is defined and activeFilters|length > 0 %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-ghost btn-sm" style="color:var(--zui-error-600);">Clear all</a>
                            {% endif %}
                            <button type="submit" class="btn btn-primary btn-sm">Apply</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>

        {# Sort #}
        <div style="position:relative;">
            <button type="button" class="ep-bar-item {% if sortBy and sortBy != 'id' %}is-active{% endif %}" id="sort-toggle-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M11 5h10M11 9h7M11 13h4M3 17l4 4 4-4M7 3v18"/></svg>
                Sort
            </button>
            <div class="ep-sort-panel" id="sort-panel">
                {% for field in listableFields %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=' ~ field.getSlug() ~ '&sort_dir=ASC' ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                   class="ep-col-menu-item {% if sortBy == field.getSlug() %}is-active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                    {{ field.getName() }} {{ sortBy == field.getSlug() ? (sortDir == 'ASC' ? '↑' : '↓') : '' }}
                </a>
                {% endfor %}
                {% if collection.isPublishable() %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=status&sort_dir=ASC' ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                   class="ep-col-menu-item {% if sortBy == 'status' %}is-active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                    Status {{ sortBy == 'status' ? (sortDir == 'ASC' ? '↑' : '↓') : '' }}
                </a>
                {% endif %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=created_at&sort_dir=DESC' ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                   class="ep-col-menu-item {% if sortBy == 'created_at' %}is-active{% endif %}">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
                    Updated {{ sortBy == 'created_at' ? (sortDir == 'ASC' ? '↑' : '↓') : '' }}
                </a>
                <div class="ep-col-menu-divider"></div>
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries' ~ (activeViewSlug ? '?view=' ~ activeViewSlug : '')) }}" class="ep-col-menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
                    Reset sort
                </a>
            </div>
        </div>

        {% if collection.hasHierarchy() %}
        <button type="button" class="ep-bar-item" id="tree-toggle">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2v6m0 4v6m-6-8h12M6 8V4h12v4M6 16v4h12v-4"/></svg>
            Tree
        </button>
        {% endif %}
    </div>

    {# ── Active View Chip ───────────────────────────── #}
    {% if activeViewSlug is defined and activeViewSlug %}
        {% for sv in savedViews %}
            {% if sv.getSlug() == activeViewSlug %}
            <div class="flex items-center gap-2 mb-3">
                <div class="ep-view-chip">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'grid'} only %}
                    <span>{{ sv.getName() }}</span>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" title="Clear">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </a>
                </div>
                <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/views/' ~ sv.getId() ~ '/delete') }}" style="display:inline;">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--zui-error-600);" onclick="return confirm('Delete this saved view?')">Delete</button>
                </form>
            </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {# ── Active filter chips ────────────────────────── #}
    {% if activeFilters is defined and activeFilters|length > 0 %}
    <div class="ep-chips">
        {% for fField, fValue in activeFilters %}
            <span class="ep-chip">
                <b>{{ fField }}</b> = {{ fValue }}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="ep-chip-x" title="Clear filters">
                    <svg width="10" height="10" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                </a>
            </span>
        {% endfor %}
    </div>
    {% endif %}

    {# ── Hierarchy breadcrumb ───────────────────────── #}
    {% if collection.hasHierarchy() and (parentBreadcrumbs is defined and parentBreadcrumbs|length > 0) %}
    <div class="flex items-center gap-2 mb-3" style="font-size:13px;">
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=') }}" style="color:var(--zui-primary-600);text-decoration:none;font-weight:600;">{{ collection.getName() }}</a>
        {% for bc in parentBreadcrumbs %}
            <span class="text-secondary">›</span>
            {% if not loop.last %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=' ~ bc.id) }}" style="color:var(--zui-primary-600);text-decoration:none;font-weight:600;">{{ bc.label }}</a>
            {% else %}
                <span class="font-semibold text-heading">{{ bc.label }}</span>
            {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    {# ── Data Table ─────────────────────────────────── #}
    {% if entries.data|length > 0 %}
    <div class="ep-table-wrap" id="entries-list">
        <table class="ep-table">
            <thead>
                <tr>
                    <th><input type="checkbox" id="select-all" class="ep-cb"></th>
                    {% for field in listableFields %}
                    <th data-col="field-{{ field.getSlug() }}" data-col-name="{{ field.getName() }}" data-col-type="{{ field.getType() }}" data-col-slug="{{ field.getSlug() }}">
                        <span class="ep-th-sort {% if sortBy == field.getSlug() %}is-active{% endif %}">
                            {{ field.getName() }}
                            {% if sortBy == field.getSlug() %}
                                <svg viewBox="0 0 12 12" fill="none" class="{% if sortDir == 'DESC' %}ep-sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            {% endif %}
                        </span>
                    </th>
                    {% endfor %}
                    {% if collection.isPublishable() %}
                    <th data-col="col-status" data-col-name="Status" data-col-slug="status">
                        <span class="ep-th-sort {% if sortBy == 'status' %}is-active{% endif %}">
                            Status
                            {% if sortBy == 'status' %}
                                <svg viewBox="0 0 12 12" fill="none" class="{% if sortDir == 'DESC' %}ep-sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            {% endif %}
                        </span>
                    </th>
                    {% endif %}
                    <th data-col="col-updated" data-col-name="Updated" data-col-slug="created_at">
                        <span class="ep-th-sort {% if sortBy == 'created_at' %}is-active{% endif %}">
                            Updated
                            {% if sortBy == 'created_at' %}
                                <svg viewBox="0 0 12 12" fill="none" class="{% if sortDir == 'DESC' %}ep-sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            {% endif %}
                        </span>
                    </th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries.data %}
                {% set _eId = entry.id %}
                {% set _eDepth = depthMap[_eId]|default(0) %}
                {% set _eChildren = childCountMap[_eId]|default(0) %}
                {% set _eParent = entry.parent_id|default('') %}
                <tr data-entry-id="{{ _eId }}" data-parent-id="{{ _eParent }}" data-depth="{{ _eDepth }}" data-children="{{ _eChildren }}">
                    <td><input type="checkbox" class="entry-checkbox ep-cb" value="{{ entry.id }}"></td>

                    {% for field in listableFields %}
                    <td data-col="field-{{ field.getSlug() }}">
                        {% if loop.first %}
                            {% if collection.hasHierarchy() and _eChildren > 0 %}
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=' ~ entry.id) }}" class="ep-hier-arrow" title="View {{ _eChildren }} children">›</a>
                            {% endif %}
                            {% set _nameVal = entry[field.getSlug()]|default('')|striptags %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="ep-name">
                                {{ _nameVal|slice(0, 80) }}{% if _nameVal|length > 80 %}…{% endif %}
                            </a>
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="ep-open-btn">
                                <svg viewBox="0 0 16 16" fill="none"><path d="M6 3h7v7M13 3L6.5 9.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                Open
                            </a>
                        {% elseif field.getType() == 'boolean' %}
                            <span class="ep-bool-{{ entry[field.getSlug()] ? 'yes' : 'no' }}">{{ entry[field.getSlug()] ? 'Yes' : 'No' }}</span>
                        {% elseif (field.getType() == 'image' or field.getType() == 'file') and entry[field.getSlug()] %}
                            {% set _imgVal = entry[field.getSlug()] %}
                            {% set _thumbs = media_thumbs(_imgVal, 3) %}
                            {% set _totalImgCount = media_thumbs_count(_imgVal) %}
                            {% if _thumbs|length > 0 %}
                                <span class="flex items-center gap-1">
                                {% for _t in _thumbs %}<img src="{{ _t }}" alt="" class="ep-thumb">{% endfor %}
                                {% if _totalImgCount > 3 %}<span class="text-secondary text-xs">+{{ _totalImgCount - 3 }}</span>{% endif %}
                                </span>
                            {% endif %}
                        {% elseif field.getType() == 'richtext' and entry[field.getSlug()] %}
                            {% set _rtVal = entry[field.getSlug()]|striptags %}
                            <span class="ep-rt-preview" data-content="{{ entry[field.getSlug()]|e('html_attr') }}">{{ _rtVal|slice(0, 60) }}{% if _rtVal|length > 60 %}…{% endif %}</span>
                        {% elseif field.getType() == 'relation' and entry[field.getSlug()] %}
                            {% set _fKey = field.getSlug() %}
                            {% set _relLabels = relationLabels[_fKey]|default({}) %}
                            {% set _entryVal = entry[_fKey] %}
                            {% if _entryVal in (_relLabels|keys) %}<span>{{ _relLabels[_entryVal] }}</span>{% else %}<span class="text-secondary">#{{ _entryVal }}</span>{% endif %}
                        {% else %}
                            {% set _cellVal = entry[field.getSlug()]|default('')|striptags %}
                            {{ _cellVal|slice(0, 80) }}{% if _cellVal|length > 80 %}…{% endif %}
                        {% endif %}
                    </td>
                    {% endfor %}

                    {% if collection.isPublishable() %}
                    <td data-col="col-status">
                        {% set _st = entry.status|default('draft') %}
                        <span class="badge badge-{{ _st == 'published' ? 'success' : (_st == 'scheduled' ? 'info' : (_st == 'review' ? 'default' : 'warning')) }}">
                            <span class="badge-dot"></span> {{ _st|capitalize }}
                        </span>
                    </td>
                    {% endif %}

                    <td data-col="col-updated">
                        <span class="ep-date entries-relative-time" data-time="{{ entry.updated_at|default(entry.created_at|default('')) }}"></span>
                    </td>

                    <td class="ep-actions-cell">
                        <div class="dropdown" data-dropdown>
                            <button class="ep-action" data-dropdown-trigger title="Actions">
                                <svg viewBox="0 0 16 16" fill="none"><circle cx="8" cy="3" r="1" fill="currentColor"/><circle cx="8" cy="8" r="1" fill="currentColor"/><circle cx="8" cy="13" r="1" fill="currentColor"/></svg>
                            </button>
                            <div class="dropdown-menu" data-dropdown-menu>
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="dropdown-item">
                                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'edit'} only %} Edit
                                </a>
                                <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/duplicate') }}">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="dropdown-item" onclick="return confirm('Duplicate this entry?')">
                                        {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %} Duplicate
                                    </button>
                                </form>
                                <div class="dropdown-divider"></div>
                                <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/delete') }}" class="confirm-delete" data-message="Delete this entry?">
                                    {{ csrf_field() | raw }}
                                    <button type="submit" class="dropdown-item danger">
                                        {% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %} Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>

        {# ── Pagination ─────────────────────────────── #}
        {% if entries.last_page > 1 %}
        <div class="ep-pagination">
            <span>
                {% set _showTo = entries.current_page * entries.per_page %}
                {% if _showTo > entries.total %}{% set _showTo = entries.total %}{% endif %}
                {{ ((entries.current_page - 1) * entries.per_page) + 1 }}–{{ _showTo }} of {{ entries.total }}
            </span>
            <div class="ep-pagination-ctrls">
                {% if entries.current_page > 1 %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page - 1) ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="ep-pg">‹ Prev</a>
                {% else %}
                    <span class="ep-pg is-disabled">‹ Prev</span>
                {% endif %}
                {% for p in 1..entries.last_page %}
                    {% if p == entries.current_page %}
                        <span class="ep-pg is-current">{{ p }}</span>
                    {% elseif p == 1 or p == entries.last_page or (p >= entries.current_page - 2 and p <= entries.current_page + 2) %}
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ p ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="ep-pg">{{ p }}</a>
                    {% elseif p == 2 or p == entries.last_page - 1 %}
                        <span class="text-secondary">…</span>
                    {% endif %}
                {% endfor %}
                {% if entries.current_page < entries.last_page %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page + 1) ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="ep-pg">Next ›</a>
                {% else %}
                    <span class="ep-pg is-disabled">Next ›</span>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Bulk Bar ───────────────────────────────────── #}
    <div class="ep-bulk" id="bulk-bar">
        <span><strong id="bulk-count">0</strong> selected</span>
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/bulk') }}" class="flex items-center gap-2">
            {{ csrf_field() | raw }}
            <input type="hidden" name="selected_ids" id="bulk-ids" value="">
            <input type="hidden" name="bulk_action" id="bulk-action-value" value="">
            {% if collection.isPublishable() %}
            <button type="submit" class="btn btn-outline btn-sm" onclick="document.getElementById('bulk-action-value').value='publish'; return confirm('Publish selected?')">Publish</button>
            <button type="submit" class="btn btn-outline btn-sm" onclick="document.getElementById('bulk-action-value').value='unpublish'; return confirm('Unpublish selected?')">Unpublish</button>
            {% endif %}
            <div class="dropdown" data-dropdown>
                <button type="button" class="btn btn-outline btn-sm" data-dropdown-trigger>Update Field <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 6l2.5-2.5L7.5 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></button>
                <div class="dropdown-menu" data-dropdown-menu style="bottom:calc(100% + 4px);top:auto;">
                    <div class="ep-bulk-field-form">
                        <label class="form-label">Field</label>
                        <select name="bulk_field" id="bulk-field-select" class="form-control" style="margin-bottom:8px;">
                            <option value="">-- Select --</option>
                            {% for field in fields %}{% if field.getType() in ['text','number','select','boolean','email','url'] %}<option value="{{ field.getSlug() }}" data-type="{{ field.getType() }}" {% if field.getType() == 'select' and field.getOptions() %}data-options="{{ field.getOptions()|json_encode }}"{% endif %}>{{ field.getName() }}</option>{% endif %}{% endfor %}
                        </select>
                        <label class="form-label">Value</label>
                        <span id="bulk-value-wrapper"><input type="text" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value"></span>
                        <button type="submit" class="btn btn-primary btn-sm" style="margin-top:8px;width:100%;" onclick="document.getElementById('bulk-action-value').value='update_field'; return confirm('Update field?')">Apply</button>
                    </div>
                </div>
            </div>
            <button type="submit" class="btn btn-danger btn-sm" onclick="document.getElementById('bulk-action-value').value='delete'; return confirm('Delete selected?')">Delete</button>
        </form>
    </div>

    {% else %}
    <div class="ep-empty">
        <div class="ep-empty-icon">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'file-text'} only %}</div>
        <h3 class="text-heading font-semibold mb-2">No entries yet</h3>
        <p class="text-secondary text-sm mb-3">Create the first entry for this collection.</p>
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="btn btn-primary btn-sm">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %} Create Entry</a>
    </div>
    {% endif %}

</div>

{# ── JavaScript ─────────────────────────────────── #}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    var collSlug = '{{ collection.getSlug()|e("js") }}';
    var baseUrl = '{{ admin_url("collections/" ~ collection.getSlug() ~ "/entries")|e("js") }}';

    /* ── Dropdown system ───────────────────────── */
    document.querySelectorAll('[data-dropdown]').forEach(function(dd) {
        var trigger = dd.querySelector('[data-dropdown-trigger]');
        var menu = dd.querySelector('[data-dropdown-menu]');
        if (!trigger || !menu) return;
        trigger.addEventListener('click', function(e) {
            e.stopPropagation();
            document.querySelectorAll('[data-dropdown-menu].open').forEach(function(m) { if (m !== menu) m.classList.remove('open'); });
            menu.classList.toggle('open');
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('[data-dropdown-menu].open').forEach(function(m) { m.classList.remove('open'); });
        document.querySelectorAll('.ep-col-panel.open, .ep-filter-panel.open, .ep-sort-panel.open').forEach(function(p) { p.classList.remove('open'); });
    });

    /* ── Panel toggles ─────────────────────────── */
    function panelToggle(btnId, panelId) {
        var btn = document.getElementById(btnId);
        var panel = document.getElementById(panelId);
        if (!btn || !panel) return;
        btn.addEventListener('click', function(e) {
            e.stopPropagation();
            // Close other panels
            document.querySelectorAll('.ep-col-panel.open, .ep-filter-panel.open, .ep-sort-panel.open').forEach(function(p) { if (p !== panel) p.classList.remove('open'); });
            panel.classList.toggle('open');
        });
        panel.addEventListener('click', function(e) { e.stopPropagation(); });
    }
    panelToggle('col-toggle-btn', 'col-toggle-dropdown');
    panelToggle('filter-toggle-btn', 'filter-panel');
    panelToggle('sort-toggle-btn', 'sort-panel');

    /* ── Import toggle ─────────────────────────── */
    var importBtn = document.getElementById('toggle-import-btn');
    var importForm = document.getElementById('import-form');
    if (importBtn && importForm) importBtn.addEventListener('click', function() { importForm.classList.toggle('hidden'); });

    /* ── Column header click → sort ────────────── */
    document.querySelectorAll('.ep-table th[data-col-slug]').forEach(function(th) {
        th.addEventListener('click', function(e) {
            if (e.target.closest('.ep-col-menu') || e.target.closest('input')) return;
            var slug = th.dataset.colSlug;
            var currentSort = '{{ sortBy|e("js") }}';
            var currentDir = '{{ sortDir|e("js") }}';
            var newDir = (slug === currentSort && currentDir === 'ASC') ? 'DESC' : 'ASC';
            var url = baseUrl + '?sort_by=' + slug + '&sort_dir=' + newDir;
            {% if activeViewSlug %}url += '&view={{ activeViewSlug|e("js") }}';{% endif %}
            window.location.href = url;
        });
    });

    /* ── Filter rows ───────────────────────────── */
    var addFilterRow = document.getElementById('add-filter-row');
    var filterRows = document.getElementById('filter-rows');
    if (addFilterRow && filterRows) {
        addFilterRow.addEventListener('click', function() {
            var first = filterRows.querySelector('.ep-filter-row');
            if (first) { var clone = first.cloneNode(true); clone.querySelectorAll('input,select').forEach(function(el){el.value='';}); filterRows.appendChild(clone); bindRemoveFilter(clone); }
        });
    }
    function bindRemoveFilter(row) {
        var btn = row.querySelector('.ep-remove-filter');
        if (btn) btn.addEventListener('click', function() {
            var rows = filterRows.querySelectorAll('.ep-filter-row');
            if (rows.length > 1) row.remove(); else row.querySelectorAll('input,select').forEach(function(el){el.value='';});
        });
    }
    document.querySelectorAll('.ep-filter-row').forEach(bindRemoveFilter);

    /* ── Bulk selection ────────────────────────── */
    var selectAll = document.getElementById('select-all');
    var checkboxes = document.querySelectorAll('.entry-checkbox');
    var bulkBar = document.getElementById('bulk-bar');
    var bulkCount = document.getElementById('bulk-count');
    var bulkIds = document.getElementById('bulk-ids');
    function updateBulk() {
        var selected = document.querySelectorAll('.entry-checkbox:checked');
        var ids = Array.from(selected).map(function(cb){return cb.value;});
        if (bulkBar) bulkBar.classList.toggle('is-visible', ids.length > 0);
        if (bulkCount) bulkCount.textContent = ids.length;
        if (bulkIds) bulkIds.value = ids.join(',');
        document.querySelectorAll('.ep-table tbody tr').forEach(function(row) {
            var cb = row.querySelector('.entry-checkbox');
            row.classList.toggle('is-selected', cb && cb.checked);
        });
    }
    if (selectAll) selectAll.addEventListener('change', function() { checkboxes.forEach(function(cb){cb.checked=selectAll.checked;}); updateBulk(); });
    checkboxes.forEach(function(cb) { cb.addEventListener('change', updateBulk); });

    /* ── Bulk field update ─────────────────────── */
    var bulkFieldSelect = document.getElementById('bulk-field-select');
    var bulkValueWrapper = document.getElementById('bulk-value-wrapper');
    function renderValueInput(type, options) {
        if (!bulkValueWrapper) return; var html = '';
        if (type==='boolean') html='<select name="bulk_value" class="form-control"><option value="0">No</option><option value="1">Yes</option></select>';
        else if (type==='select'&&options){var opts;try{opts=typeof options==='string'?JSON.parse(options):options;}catch(e){opts=[];}html='<select name="bulk_value" class="form-control"><option value="">--</option>';if(Array.isArray(opts))opts.forEach(function(o){var v=typeof o==='object'?(o.value||''):o;var l=typeof o==='object'?(o.label||o.value||''):o;html+='<option value="'+v+'">'+l+'</option>';});html+='</select>';}
        else html='<input type="'+(type==='number'?'number':type==='email'?'email':type==='url'?'url':'text')+'" name="bulk_value" class="form-control" placeholder="Value"'+(type==='number'?' step="any"':'')+'>';
        bulkValueWrapper.innerHTML = html;
    }
    if (bulkFieldSelect) bulkFieldSelect.addEventListener('change', function() { var s=this.options[this.selectedIndex]; renderValueInput(s.getAttribute('data-type')||'text',s.getAttribute('data-options')); });

    /* ── Richtext preview modal ────────────────── */
    document.querySelectorAll('.ep-rt-preview').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.stopPropagation(); var c=el.dataset.content; if(!c) return;
            var o=document.createElement('div'); o.className='zui-modal-overlay';
            o.innerHTML='<div class="zui-modal"><div class="zui-modal-header"><h3>Preview</h3><button class="btn btn-ghost btn-icon btn-sm" data-close>×</button></div><div class="zui-modal-body">'+c+'</div><div class="zui-modal-footer"><button class="btn btn-outline btn-sm" data-close>Close</button></div></div>';
            document.body.appendChild(o);
            o.querySelectorAll('[data-close]').forEach(function(b){b.addEventListener('click',function(){o.remove();});});
            o.addEventListener('click',function(ev){if(ev.target===o)o.remove();});
        });
    });

    /* ── Confirm delete ────────────────────────── */
    document.querySelectorAll('.confirm-delete').forEach(function(f) { f.addEventListener('submit', function(e) { if(!confirm(f.dataset.message||'Are you sure?')) e.preventDefault(); }); });

    /* ── Relative time ─────────────────────────── */
    function timeAgo(d) {
        if(!d) return ''; var dt=new Date(d); if(isNaN(dt.getTime())) return d;
        var s=Math.max(0,Math.floor((Date.now()-dt.getTime())/1000));
        var i=[{l:'y',s:31536000},{l:'mo',s:2592000},{l:'w',s:604800},{l:'d',s:86400,dy:1},{l:'h',s:3600},{l:'m',s:60}];
        for(var j=0;j<i.length;j++){var c=Math.floor(s/i[j].s);if(c>=1){if(i[j].dy&&c===1)return'Yesterday';return c+i[j].l+' ago';}}
        return 'Just now';
    }
    document.querySelectorAll('.entries-relative-time').forEach(function(el) {
        var raw=el.getAttribute('data-time'); if(raw){var r=timeAgo(raw);if(r){el.textContent=r;el.title=raw;}} el.classList.add('is-ready');
    });

    /* ── Column Toggle ─────────────────────────── */
    var colToggleList = document.getElementById('col-toggle-list');
    var storageKey = 'entries-cols-' + collSlug;
    var toggleableCols = [];
    var listEl = document.getElementById('entries-list');
    if (listEl) {
        listEl.querySelectorAll('thead th[data-col]').forEach(function(th) {
            var id=th.getAttribute('data-col'), name=th.getAttribute('data-col-name');
            if(id&&name) toggleableCols.push({id:id,name:name});
        });
    }
    function loadColState(){try{return JSON.parse(localStorage.getItem(storageKey));}catch(e){return null;}}
    function saveColState(s){try{localStorage.setItem(storageKey,JSON.stringify(s));}catch(e){}}
    function applyColVis(s) {
        if(!listEl||!s) return;
        var visCount = 0;
        toggleableCols.forEach(function(c){
            var vis=!(c.id in s)||s[c.id];
            if(vis) visCount++;
            listEl.querySelectorAll('[data-col="'+c.id+'"]').forEach(function(cell){cell.classList.toggle('col-hidden',!vis);});
        });
        var countEl = document.getElementById('col-count');
        if (countEl) countEl.textContent = visCount;
    }
    function buildColList(s) {
        if(!colToggleList) return; colToggleList.innerHTML='';
        toggleableCols.forEach(function(c){
            var vis=!s||!(c.id in s)||s[c.id];
            var l=document.createElement('label'); var cb=document.createElement('input');
            cb.type='checkbox'; cb.checked=vis;
            cb.addEventListener('change',function(){var st=loadColState()||{};st[c.id]=cb.checked;saveColState(st);applyColVis(st);});
            l.appendChild(cb); l.appendChild(document.createTextNode(' '+c.name)); colToggleList.appendChild(l);
        });
    }
    if (toggleableCols.length > 0) {
        var saved = loadColState();
        if (saved) applyColVis(saved);
        buildColList(saved);
    }
});

{% if collection.hasHierarchy() %}
(function() {
    var treeBtn = document.getElementById('tree-toggle'); if (!treeBtn) return;
    var rows = document.querySelectorAll('.ep-table tbody tr');
    var isTreeMode = true, collapsed = {};
    function applyTree() {
        rows.forEach(function(row) {
            var depth=parseInt(row.dataset.depth||'0',10), pid=row.dataset.parentId, eid=row.dataset.entryId, cc=parseInt(row.dataset.children||'0',10);
            var fc=row.querySelector('[data-col^="field-"]'); if(!fc) return;
            var old=fc.querySelector('.tree-indent'); if(old) old.remove();
            if(!isTreeMode){row.style.display='';return;}
            var hidden=false;
            if(pid){var cid=pid,seen={};while(cid&&!seen[cid]){seen[cid]=true;if(collapsed[cid]){hidden=true;break;}var pr=document.querySelector('[data-entry-id="'+cid+'"]');cid=pr?pr.dataset.parentId:'';}}
            row.style.display=hidden?'none':'';
            if(depth>0||cc>0){
                var indent=document.createElement('span');indent.className='tree-indent';
                if(depth>0){var sp=document.createElement('span');sp.style.cssText='display:inline-block;width:'+(depth*20)+'px;';indent.appendChild(sp);}
                if(cc>0){var tog=document.createElement('button');tog.type='button';tog.className='tree-toggle-btn';tog.textContent=collapsed[eid]?'▶':'▼';tog.addEventListener('click',function(e){e.stopPropagation();collapsed[eid]=!collapsed[eid];this.textContent=collapsed[eid]?'▶':'▼';applyTree();});indent.appendChild(tog);}
                else if(depth>0){var lf=document.createElement('span');lf.style.cssText='color:var(--border);margin-right:3px;font-size:11px;width:16px;text-align:center;display:inline-block;';lf.textContent='└';indent.appendChild(lf);}
                fc.insertBefore(indent,fc.firstChild);
            }
        });
    }
    treeBtn.addEventListener('click', function() {
        isTreeMode=!isTreeMode;collapsed={};
        this.style.background=isTreeMode?'var(--zui-primary-500)':'';
        this.style.color=isTreeMode?'#fff':'';
        this.style.borderColor=isTreeMode?'var(--zui-primary-500)':'';
        applyTree();
    });
    treeBtn.style.background='var(--zui-primary-500)';treeBtn.style.color='#fff';treeBtn.style.borderColor='var(--zui-primary-500)';
    applyTree();
})();
{% endif %}
</script>

