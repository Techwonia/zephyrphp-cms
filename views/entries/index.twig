{% extends "@cms/layouts/cms.twig" %}

{% block title %}{{ collection.getName() }} Entries{% endblock %}

{% block content %}

{# ── Header ────────────────────────────────────────── #}
<div class="entries-page">

    <div class="entries-header">
        <div class="entries-header__left">
            <a href="{{ admin_url('collections') }}" class="entries-back-link">
                <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>{{ collection.getName() }}</span>
            </a>
            <span class="entries-count">{{ entries.total is defined ? entries.total : entries.data|length }} {{ entries.total is defined and entries.total == 1 ? 'entry' : 'entries' }}</span>
        </div>
        <div class="entries-header__actions">
            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash') }}" class="entries-btn entries-btn--outline">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M5.333 4V2.667a1.333 1.333 0 011.334-1.334h2.666a1.333 1.333 0 011.334 1.334V4m2 0v9.333a1.333 1.333 0 01-1.334 1.334H4.667a1.333 1.333 0 01-1.334-1.334V4h9.334z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Trash
                {% if trashCount is defined and trashCount > 0 %}
                    <span class="entries-badge entries-badge--danger">{{ trashCount }}</span>
                {% endif %}
            </a>

            <div class="entries-dropdown" data-dropdown>
                <button class="entries-btn entries-btn--outline" data-dropdown-trigger>
                    Export
                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M3 5l3 3 3-3" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="entries-dropdown__menu" data-dropdown-menu>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=csv') }}" class="entries-dropdown__item">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.167 1.167H3.5A1.167 1.167 0 002.333 2.333v9.334A1.167 1.167 0 003.5 12.833h7a1.167 1.167 0 001.167-1.166V4.667L8.167 1.167z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Export as CSV
                    </a>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=json') }}" class="entries-dropdown__item">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.167 1.167H3.5A1.167 1.167 0 002.333 2.333v9.334A1.167 1.167 0 003.5 12.833h7a1.167 1.167 0 001.167-1.166V4.667L8.167 1.167z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Export as JSON
                    </a>
                </div>
            </div>

            <button class="entries-btn entries-btn--outline" id="toggle-import-btn">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M14 10v2.667A1.334 1.334 0 0112.667 14H3.333A1.334 1.334 0 012 12.667V10M4.667 6.667L8 10l3.333-3.333M8 10V2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Import
            </button>

            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="entries-btn entries-btn--primary">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3.333v9.334M3.333 8h9.334" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                New Entry
            </a>
        </div>
    </div>

    {# ── Import Form (hidden) ──────────────────────── #}
    <div id="import-form" class="entries-panel" style="display: none;">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/import/preview') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="entries-panel__row">
                <div class="entries-panel__field">
                    <label for="import_file" class="entries-label">Import File (CSV or JSON)</label>
                    <input type="file" id="import_file" name="import_file" class="form-control" accept=".csv,.json" required>
                </div>
                <button type="submit" class="entries-btn entries-btn--primary">Preview &amp; Map</button>
            </div>
            <p class="entries-panel__hint">Upload your file to preview data and map columns before importing.</p>
        </form>
    </div>

    {# ── Toolbar ───────────────────────────────────── #}
    <div class="entries-toolbar">
        {% if listableFields|length > 0 %}
        <form method="GET" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search">
            <svg class="entries-search__icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"/><path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            <input type="text" name="search" class="entries-search__input" placeholder="Search entries..." value="{{ search }}" autocomplete="off">
            {% if search %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search__clear" title="Clear search">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M10.5 3.5L3.5 10.5M3.5 3.5l7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                </a>
            {% endif %}
        </form>
        {% endif %}

        <div class="entries-toolbar__right">
            {# Saved Views Dropdown #}
            <div class="entries-dropdown" data-dropdown>
                <button class="entries-btn entries-btn--outline entries-btn--sm" data-dropdown-trigger>
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.167 5.25h11.666M1.167 8.75h11.666M5.25 1.167v11.666M8.75 1.167v11.666" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                    Views
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 4l2.5 2.5L7.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </button>
                <div class="entries-dropdown__menu entries-dropdown__menu--right" data-dropdown-menu>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}"
                       class="entries-dropdown__item {% if activeViewSlug is empty %}entries-dropdown__item--active{% endif %}">
                        All Entries
                    </a>
                    {% if savedViews is defined and savedViews|length > 0 %}
                        <div class="entries-dropdown__divider"></div>
                        {% for sv in savedViews %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?view=' ~ sv.getSlug()) }}"
                               class="entries-dropdown__item {% if activeViewSlug == sv.getSlug() %}entries-dropdown__item--active{% endif %}">
                                {{ sv.getName() }}{% if sv.isDefault() %} <span class="entries-text-muted">(default)</span>{% endif %}
                                <span class="entries-text-muted" style="margin-left:auto; font-size: 0.75rem;">{{ sv.getFilters()|length }} filter{{ sv.getFilters()|length != 1 ? 's' : '' }}</span>
                            </a>
                        {% endfor %}
                    {% endif %}
                    <div class="entries-dropdown__divider"></div>
                    <button class="entries-dropdown__item" id="toggle-save-view-btn" type="button">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2.333v9.334M2.333 7h9.334" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                        Save Current View
                    </button>
                </div>
            </div>
        </div>
    </div>

    {# ── Active View Chip ──────────────────────────── #}
    {% if activeViewSlug is defined and activeViewSlug %}
        {% for sv in savedViews %}
            {% if sv.getSlug() == activeViewSlug %}
            <div class="entries-active-view">
                <div class="entries-chip">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.167 5.25h11.666M1.167 8.75h11.666M5.25 1.167v11.666M8.75 1.167v11.666" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                    <span>{{ sv.getName() }}</span>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-chip__close" title="Clear view">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </a>
                </div>
                <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/views/' ~ sv.getId() ~ '/delete') }}" style="display:inline;">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="entries-btn entries-btn--ghost entries-btn--sm entries-btn--danger-text" onclick="return confirm('Delete this saved view?')">Delete View</button>
                </form>
            </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {# ── Save View Form (hidden) ───────────────────── #}
    <div id="save-view-form" class="entries-panel" style="display: none;">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/views') }}">
            {{ csrf_field() | raw }}
            <h4 class="entries-panel__title">Save Current View</h4>
            <div class="entries-panel__grid">
                <div class="entries-panel__field entries-panel__field--grow">
                    <label for="view_name" class="entries-label">View Name <span class="entries-text-required">*</span></label>
                    <input type="text" id="view_name" name="view_name" class="form-control" placeholder="e.g. Published Posts" required>
                </div>
                <div class="entries-panel__field">
                    <label for="view_sort_by" class="entries-label">Sort By</label>
                    <select name="view_sort_by" id="view_sort_by" class="form-control">
                        <option value="">Default (ID)</option>
                        {% for field in listableFields %}
                            <option value="{{ field.getSlug() }}">{{ field.getName() }}</option>
                        {% endfor %}
                        <option value="created_at">Created At</option>
                        {% if collection.isPublishable() %}
                            <option value="status">Status</option>
                        {% endif %}
                    </select>
                </div>
                <div class="entries-panel__field">
                    <label for="view_sort_dir" class="entries-label">Direction</label>
                    <select name="view_sort_dir" id="view_sort_dir" class="form-control">
                        <option value="DESC">Descending</option>
                        <option value="ASC">Ascending</option>
                    </select>
                </div>
            </div>
            <div id="view-filters" class="entries-panel__filters">
                <label class="entries-label">Filters</label>
                <div class="view-filter-row">
                    <select name="filter_field[]" class="form-control">
                        <option value="">-- Field --</option>
                        {% for field in listableFields %}
                            <option value="{{ field.getSlug() }}">{{ field.getName() }}</option>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                            <option value="status">Status</option>
                        {% endif %}
                    </select>
                    <input type="text" name="filter_value[]" class="form-control" placeholder="Value (exact match)">
                </div>
            </div>
            <button type="button" class="entries-btn entries-btn--outline entries-btn--sm" id="add-filter-btn">+ Add Filter</button>
            <div class="entries-panel__footer">
                <label class="entries-checkbox-label"><input type="checkbox" name="view_is_default" value="1"> Set as default view</label>
                <button type="submit" class="entries-btn entries-btn--primary entries-btn--sm">Save View</button>
            </div>
        </form>
    </div>

    {# ── Data Table ────────────────────────────────── #}
    {% if entries.data|length > 0 %}
    <div class="entries-card">
        <div class="entries-table-wrap">
            <table class="entries-table">
                <thead>
                    <tr>
                        <th class="entries-table__check-col"><input type="checkbox" id="select-all" class="entries-checkbox"></th>
                        {% for field in listableFields %}
                        <th>
                            {% set nextDir = (sortBy == field.getSlug() and sortDir == 'ASC') ? 'DESC' : 'ASC' %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=' ~ field.getSlug() ~ '&sort_dir=' ~ nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == field.getSlug() %}entries-table__sort--active{% endif %}">
                                {{ field.getName() }}
                                {% if sortBy == field.getSlug() %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                        <th>
                            {% set nextDir = (sortBy == 'status' and sortDir == 'ASC') ? 'DESC' : 'ASC' %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=status&sort_dir=' ~ nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == 'status' %}entries-table__sort--active{% endif %}">
                                Status
                                {% if sortBy == 'status' %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        {% endif %}
                        <th>
                            {% set nextDir = (sortBy == 'created_at' and sortDir == 'ASC') ? 'DESC' : 'ASC' %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=created_at&sort_dir=' ~ nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == 'created_at' %}entries-table__sort--active{% endif %}">
                                Updated
                                {% if sortBy == 'created_at' %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        <th class="entries-table__actions-col">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in entries.data %}
                    <tr class="entries-table__row">
                        <td class="entries-table__check-col"><input type="checkbox" class="entry-checkbox entries-checkbox" value="{{ entry.id }}"></td>
                        {% for field in listableFields %}
                        <td class="entries-table__cell">
                            {% if field.getType() == 'boolean' %}
                                <span class="entries-bool entries-bool--{{ entry[field.getSlug()] ? 'yes' : 'no' }}">{{ entry[field.getSlug()] ? 'Yes' : 'No' }}</span>
                            {% elseif field.getType() == 'image' and entry[field.getSlug()] %}
                                <img src="/{{ entry[field.getSlug()] }}" alt="" class="entries-thumb">
                            {% elseif field.getType() == 'relation' and entry[field.getSlug()] %}
                                {% if relationLabels[field.getSlug()] is defined and relationLabels[field.getSlug()][entry[field.getSlug()]] is defined %}
                                    <span class="entries-truncate">{{ relationLabels[field.getSlug()][entry[field.getSlug()]] }}</span>
                                {% else %}
                                    <span class="entries-truncate entries-text-muted">#{{ entry[field.getSlug()] }}</span>
                                {% endif %}
                            {% else %}
                                <span class="entries-truncate">{{ entry[field.getSlug()] ?? '' }}</span>
                            {% endif %}
                        </td>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                        <td>
                            {% set st = entry.status ?? 'draft' %}
                            <span class="entries-status entries-status--{{ st }}">
                                <span class="entries-status__dot"></span>
                                {{ st|capitalize }}
                            </span>
                        </td>
                        {% endif %}
                        <td>
                            <span class="entries-relative-time" data-time="{{ entry.updated_at ?? entry.created_at ?? '' }}">{{ entry.updated_at ?? entry.created_at ?? '' }}</span>
                        </td>
                        <td class="entries-table__actions-col">
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="entries-icon-btn" title="Edit">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M11.333 2a1.886 1.886 0 012.667 2.667L5.333 13.333 2 14l.667-3.333L11.333 2z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </a>
                            <div class="entries-dropdown entries-dropdown--right" data-dropdown>
                                <button class="entries-icon-btn" data-dropdown-trigger title="More actions">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="3" r="1" fill="currentColor"/><circle cx="8" cy="8" r="1" fill="currentColor"/><circle cx="8" cy="13" r="1" fill="currentColor"/></svg>
                                </button>
                                <div class="entries-dropdown__menu entries-dropdown__menu--right entries-dropdown__menu--compact" data-dropdown-menu>
                                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/duplicate') }}">
                                        {{ csrf_field() | raw }}
                                        <button type="submit" class="entries-dropdown__item" onclick="return confirm('Duplicate this entry?')">
                                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="4.667" y="4.667" width="8.167" height="8.167" rx="1" stroke="currentColor" stroke-width="1"/><path d="M9.333 4.667V2.333A1.167 1.167 0 008.167 1.167H2.333A1.167 1.167 0 001.167 2.333v5.834A1.167 1.167 0 002.333 9.333h2.334" stroke="currentColor" stroke-width="1"/></svg>
                                            Duplicate
                                        </button>
                                    </form>
                                    <div class="entries-dropdown__divider"></div>
                                    <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/delete') }}" class="confirm-delete" data-message="Delete this entry?">
                                        {{ csrf_field() | raw }}
                                        <button type="submit" class="entries-dropdown__item entries-dropdown__item--danger">
                                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.75 3.5h10.5M4.667 3.5V2.333a1.167 1.167 0 011.166-1.166h2.334a1.167 1.167 0 011.166 1.166V3.5m1.75 0v8.167a1.167 1.167 0 01-1.166 1.166H4.083a1.167 1.167 0 01-1.166-1.166V3.5h8.166z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# ── Pagination ────────────────────────────── #}
        {% if entries.last_page > 1 %}
        <div class="entries-pagination">
            <span class="entries-pagination__info">
                {% set showTo = entries.current_page * entries.per_page %}
                Showing {{ ((entries.current_page - 1) * entries.per_page) + 1 }}–{{ showTo > entries.total ? entries.total : showTo }} of {{ entries.total }}
            </span>
            <div class="entries-pagination__controls">
                {% if entries.current_page > 1 %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page - 1) ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__btn">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.75 10.5L5.25 7l3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Prev
                    </a>
                {% else %}
                    <span class="entries-pagination__btn entries-pagination__btn--disabled">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.75 10.5L5.25 7l3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Prev
                    </span>
                {% endif %}

                {% for p in 1..entries.last_page %}
                    {% if p == entries.current_page %}
                        <span class="entries-pagination__page entries-pagination__page--active">{{ p }}</span>
                    {% elseif p == 1 or p == entries.last_page or (p >= entries.current_page - 2 and p <= entries.current_page + 2) %}
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ p ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__page">{{ p }}</a>
                    {% elseif p == 2 or p == entries.last_page - 1 %}
                        <span class="entries-pagination__ellipsis">...</span>
                    {% endif %}
                {% endfor %}

                {% if entries.current_page < entries.last_page %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page + 1) ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__btn">
                        Next
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5.25 3.5L8.75 7l-3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                {% else %}
                    <span class="entries-pagination__btn entries-pagination__btn--disabled">
                        Next
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5.25 3.5L8.75 7l-3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Bulk Actions (floating bar) ───────────────── #}
    <div id="bulk-bar" class="entries-bulk-bar">
        <div class="entries-bulk-bar__inner">
            <span class="entries-bulk-bar__count"><strong id="bulk-count">0</strong> selected</span>
            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/bulk') }}" class="entries-bulk-bar__form">
                {{ csrf_field() | raw }}
                <input type="hidden" name="selected_ids" id="bulk-ids" value="">
                <input type="hidden" name="bulk_action" id="bulk-action-value" value="">

                {% if collection.isPublishable() %}
                <button type="submit" class="entries-btn entries-btn--sm entries-btn--outline" onclick="document.getElementById('bulk-action-value').value='publish'; return confirm('Publish selected entries?')">Publish</button>
                <button type="submit" class="entries-btn entries-btn--sm entries-btn--outline" onclick="document.getElementById('bulk-action-value').value='unpublish'; return confirm('Unpublish selected entries?')">Unpublish</button>
                {% endif %}

                <div class="entries-dropdown entries-dropdown--up" data-dropdown>
                    <button type="button" class="entries-btn entries-btn--sm entries-btn--outline" data-dropdown-trigger>
                        Update Field
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 6l2.5-2.5L7.5 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="entries-dropdown__menu entries-dropdown__menu--up" data-dropdown-menu>
                        <div class="entries-bulk-field-form" style="padding: var(--space-300);">
                            <label class="entries-label">Field</label>
                            <select name="bulk_field" id="bulk-field-select" class="form-control" style="margin-bottom: 8px;">
                                <option value="">-- Select Field --</option>
                                {% for field in fields %}
                                    {% if field.getType() in ['text', 'number', 'select', 'boolean', 'email', 'url'] %}
                                    <option value="{{ field.getSlug() }}" data-type="{{ field.getType() }}" {% if field.getType() == 'select' and field.getOptions() %}data-options="{{ field.getOptions()|json_encode }}"{% endif %}>{{ field.getName() }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <label class="entries-label">Value</label>
                            <span id="bulk-value-wrapper">
                                <input type="text" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">
                            </span>
                            <button type="submit" class="entries-btn entries-btn--primary entries-btn--sm" style="margin-top: 8px; width: 100%;" onclick="document.getElementById('bulk-action-value').value='update_field'; return confirm('Update field for selected entries?')">Apply</button>
                        </div>
                    </div>
                </div>

                <button type="submit" class="entries-btn entries-btn--sm entries-btn--danger" onclick="document.getElementById('bulk-action-value').value='delete'; return confirm('Delete selected entries? This cannot be undone.')">Delete</button>
            </form>
        </div>
    </div>

    {% else %}
    {# ── Empty State ───────────────────────────────── #}
    <div class="entries-empty">
        <div class="entries-empty__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="8" y="6" width="32" height="36" rx="4" stroke="currentColor" stroke-width="2"/><path d="M16 18h16M16 24h16M16 30h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3 class="entries-empty__title">No entries yet</h3>
        <p class="entries-empty__text">Get started by creating the first entry for this collection.</p>
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="entries-btn entries-btn--primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3.333v9.334M3.333 8h9.334" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Create Entry
        </a>
    </div>
    {% endif %}

</div>

