{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {

    /* ── Dropdown system ───────────────────────── */
    document.querySelectorAll('[data-dropdown]').forEach(function(dd) {
        var trigger = dd.querySelector('[data-dropdown-trigger]');
        var menu = dd.querySelector('[data-dropdown-menu]');
        if (!trigger || !menu) return;

        trigger.addEventListener('click', function(e) {
            e.stopPropagation();
            // Close all other dropdowns first
            document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
                if (m !== menu) m.classList.remove('is-open');
            });
            menu.classList.toggle('is-open');
        });
    });
    document.addEventListener('click', function() {
        document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
            m.classList.remove('is-open');
        });
    });
    // Prevent dropdown menus from closing when clicking inside them (for forms)
    document.querySelectorAll('[data-dropdown-menu]').forEach(function(m) {
        m.addEventListener('click', function(e) {
            // Only stop propagation for non-link, non-submit elements
            if (!e.target.closest('a') && e.target.type !== 'submit') {
                e.stopPropagation();
            }
        });
    });

    /* ── Import toggle ─────────────────────────── */
    var importBtn = document.getElementById('toggle-import-btn');
    var importForm = document.getElementById('import-form');
    if (importBtn && importForm) {
        importBtn.addEventListener('click', function() {
            importForm.style.display = importForm.style.display === 'none' ? 'block' : 'none';
        });
    }

    /* ── Save View toggle ──────────────────────── */
    var saveViewBtn = document.getElementById('toggle-save-view-btn');
    var saveViewForm = document.getElementById('save-view-form');
    if (saveViewBtn && saveViewForm) {
        saveViewBtn.addEventListener('click', function() {
            saveViewForm.style.display = saveViewForm.style.display === 'none' ? 'block' : 'none';
            // Close the Views dropdown
            document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
                m.classList.remove('is-open');
            });
        });
    }

    /* ── Add filter row ────────────────────────── */
    var addFilterBtn = document.getElementById('add-filter-btn');
    var viewFilters = document.getElementById('view-filters');
    if (addFilterBtn && viewFilters) {
        addFilterBtn.addEventListener('click', function() {
            var firstRow = viewFilters.querySelector('.view-filter-row');
            if (firstRow) {
                var clone = firstRow.cloneNode(true);
                clone.querySelectorAll('input, select').forEach(function(el) { el.value = ''; });
                viewFilters.appendChild(clone);
            }
        });
    }

    /* ── Bulk selection ────────────────────────── */
    var selectAll = document.getElementById('select-all');
    var checkboxes = document.querySelectorAll('.entry-checkbox');
    var bulkBar = document.getElementById('bulk-bar');
    var bulkCount = document.getElementById('bulk-count');
    var bulkIds = document.getElementById('bulk-ids');

    function updateBulk() {
        var selected = document.querySelectorAll('.entry-checkbox:checked');
        var ids = Array.from(selected).map(function(cb) { return cb.value; });
        if (bulkBar) {
            if (ids.length > 0) {
                bulkBar.classList.add('is-visible');
            } else {
                bulkBar.classList.remove('is-visible');
            }
        }
        if (bulkCount) bulkCount.textContent = ids.length;
        if (bulkIds) bulkIds.value = ids.join(',');
    }

    if (selectAll) {
        selectAll.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
            updateBulk();
        });
    }
    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateBulk);
    });

    /* ── Bulk field update (value rendering) ───── */
    var bulkFieldSelect = document.getElementById('bulk-field-select');
    var bulkValueWrapper = document.getElementById('bulk-value-wrapper');

    function renderValueInput(type, options) {
        if (!bulkValueWrapper) return;
        var html = '';
        if (type === 'boolean') {
            html = '<select name="bulk_value" id="bulk-value-input" class="form-control">' +
                   '<option value="0">No</option><option value="1">Yes</option></select>';
        } else if (type === 'select' && options) {
            var opts;
            try { opts = typeof options === 'string' ? JSON.parse(options) : options; } catch(e) { opts = []; }
            html = '<select name="bulk_value" id="bulk-value-input" class="form-control">';
            html += '<option value="">-- Select --</option>';
            if (Array.isArray(opts)) {
                opts.forEach(function(o) {
                    var val = typeof o === 'object' ? (o.value || '') : o;
                    var label = typeof o === 'object' ? (o.label || o.value || '') : o;
                    html += '<option value="' + val + '">' + label + '</option>';
                });
            }
            html += '</select>';
        } else if (type === 'number') {
            html = '<input type="number" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value" step="any">';
        } else if (type === 'email') {
            html = '<input type="email" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        } else if (type === 'url') {
            html = '<input type="url" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        } else {
            html = '<input type="text" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        }
        bulkValueWrapper.innerHTML = html;
    }

    if (bulkFieldSelect) {
        bulkFieldSelect.addEventListener('change', function() {
            var selected = this.options[this.selectedIndex];
            var type = selected.getAttribute('data-type') || 'text';
            var options = selected.getAttribute('data-options') || null;
            renderValueInput(type, options);
        });
    }

    /* ── Confirm delete forms ──────────────────── */
    document.querySelectorAll('.confirm-delete').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            if (!confirm(form.dataset.message || 'Are you sure?')) {
                e.preventDefault();
            }
        });
    });

    /* ── Relative time conversion ──────────────── */
    function timeAgo(dateStr) {
        if (!dateStr) return '';
        var date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        var now = new Date();
        var seconds = Math.floor((now - date) / 1000);
        if (seconds < 0) seconds = 0;

        var intervals = [
            { label: 'year', seconds: 31536000 },
            { label: 'month', seconds: 2592000 },
            { label: 'week', seconds: 604800 },
            { label: 'day', seconds: 86400 },
            { label: 'hour', seconds: 3600 },
            { label: 'minute', seconds: 60 }
        ];

        for (var i = 0; i < intervals.length; i++) {
            var count = Math.floor(seconds / intervals[i].seconds);
            if (count >= 1) {
                if (intervals[i].label === 'day' && count === 1) return 'Yesterday';
                return count + ' ' + intervals[i].label + (count > 1 ? 's' : '') + ' ago';
            }
        }
        return 'Just now';
    }

    document.querySelectorAll('.entries-relative-time').forEach(function(el) {
        var raw = el.getAttribute('data-time');
        if (raw) {
            var relative = timeAgo(raw);
            if (relative) {
                el.textContent = relative;
                el.title = raw;
            }
        }
    });

    /* ── Search submit on Enter ────────────────── */
    var searchInput = document.querySelector('.entries-search__input');
    if (searchInput) {
        searchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                this.closest('form').submit();
            }
        });
    }
});
</script>
{% endblock %}
