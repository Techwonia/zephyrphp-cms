{% extends "@cms/layouts/cms.twig" %}

{% block title %}{{ collection.getName() }} Entries{% endblock %}
{% block styles %}
<style nonce="{{ csp_nonce() }}">
.entries-page{padding-bottom:80px}
.entries-toolbar{display:flex;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-4);border-bottom:1px solid var(--zui-gray-100)}
.entries-search{flex:1;position:relative}
.entries-search input{width:100%;height:34px;padding:0 var(--sp-3) 0 36px;font-size:var(--text-sm);border:1px solid var(--border);border-radius:var(--radius);background:var(--bg-surface);outline:none;font-family:var(--font-sans);transition:border-color 120ms ease}
.entries-search input:focus{border-color:var(--border-focus);box-shadow:0 0 0 2px var(--ring-focus)}
.entries-search svg{position:absolute;left:var(--sp-3);top:50%;transform:translateY(-50%);color:var(--text-disabled);pointer-events:none;width:16px;height:16px}
.entries-search-clear{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--text-secondary);padding:2px;border-radius:50%}
.entries-search-clear:hover{color:var(--text)}
.entries-views-btn{display:inline-flex;align-items:center;gap:6px;padding:6px 12px;font-size:var(--text-sm);color:var(--text-secondary);background:none;border:1px solid var(--border);border-radius:var(--radius);cursor:pointer;font-family:var(--font-sans);transition:border-color 120ms ease}
.entries-views-btn:hover{border-color:var(--border-hover);color:var(--text)}
.entries-chip{display:inline-flex;align-items:center;gap:4px;padding:2px 8px 2px 10px;background:var(--zui-primary-50);color:var(--zui-primary-700);font-size:var(--text-xs);font-weight:500;border-radius:var(--radius-full);margin:var(--sp-2) 0 var(--sp-2) var(--sp-4)}
.entries-chip button{background:none;border:none;cursor:pointer;color:var(--zui-primary-400);padding:0;line-height:1}
.entries-chip button:hover{color:var(--zui-primary-700)}
.entries-panel{margin:0 var(--sp-4);padding:var(--sp-4);background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);margin-bottom:var(--sp-3)}
.entries-panel__row{display:flex;align-items:flex-end;gap:var(--sp-3)}
.entries-panel__field{flex:1}
.entries-panel__hint{font-size:var(--text-xs);color:var(--text-secondary);margin-top:var(--sp-2)}
.entries-label{display:block;font-size:var(--text-sm);font-weight:500;color:var(--text-heading);margin-bottom:var(--sp-1)}
.entries-save-view{margin:0 var(--sp-4) var(--sp-3);padding:var(--sp-3);background:var(--zui-gray-50);border:1px solid var(--border);border-radius:var(--radius)}
.entries-save-view__row{display:flex;gap:var(--sp-2);align-items:center}
.hierarchy-breadcrumb{display:flex;align-items:center;gap:var(--sp-2);padding:var(--sp-2) var(--sp-4);font-size:var(--text-sm)}
.hierarchy-breadcrumb a{color:var(--text-secondary);text-decoration:none}
.hierarchy-breadcrumb a:hover{color:var(--zui-primary-600)}
.entries-dropdown{position:relative;display:inline-flex}
.entries-dropdown__menu{display:none;position:absolute;top:calc(100% + 4px);right:0;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-md);min-width:160px;padding:var(--sp-1) 0;z-index:50}
.entries-dropdown__menu.open{display:block}
.entries-dropdown__item{display:flex;align-items:center;gap:var(--sp-2);padding:var(--sp-2) var(--sp-3);font-size:var(--text-sm);color:var(--text);text-decoration:none;transition:background 120ms ease}
.entries-dropdown__item:hover{background:var(--bg-surface-hover)}
.entries-views-dropdown{position:absolute;top:calc(100% + 4px);right:0;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-md);min-width:200px;padding:var(--sp-1) 0;z-index:50;display:none}
.entries-views-dropdown.open{display:block}
.entries-views-dropdown a{display:block;padding:var(--sp-2) var(--sp-3);font-size:var(--text-sm);color:var(--text);text-decoration:none}
.entries-views-dropdown a:hover{background:var(--bg-surface-hover)}
.entries-views-dropdown a.active{color:var(--zui-primary-600);font-weight:500}
.entries-views-dropdown button{display:block;width:100%;text-align:left;padding:var(--sp-2) var(--sp-3);font-size:var(--text-sm);color:var(--zui-primary-600);background:none;border:none;border-top:1px solid var(--border);cursor:pointer;font-family:var(--font-sans)}
.entries-views-dropdown button:hover{background:var(--bg-surface-hover)}
.entries-bulk-bar{position:fixed;bottom:var(--sp-4);left:50%;transform:translateX(-50%);display:none;align-items:center;gap:var(--sp-3);padding:var(--sp-3) var(--sp-5);background:var(--zui-gray-900);color:#FFF;font-size:var(--text-sm);border-radius:var(--radius-lg);box-shadow:var(--shadow-lg);z-index:100}
.entries-bulk-bar.visible{display:flex}
.entries-bulk-bar .btn{height:28px;font-size:var(--text-xs)}
.col-toggle{position:relative}
.col-toggle-menu{display:none;position:absolute;top:calc(100% + 4px);right:0;background:var(--bg-surface);border:1px solid var(--border);border-radius:var(--radius);box-shadow:var(--shadow-md);min-width:180px;padding:var(--sp-2);z-index:50}
.col-toggle-menu.open{display:block}
.col-toggle-menu label{display:flex;align-items:center;gap:var(--sp-2);padding:var(--sp-1) var(--sp-2);font-size:var(--text-sm);cursor:pointer;border-radius:var(--radius-sm)}
.col-toggle-menu label:hover{background:var(--bg-surface-hover)}
.entries-empty{text-align:center;padding:var(--sp-16) var(--sp-6)}
.entries-empty svg{width:48px;height:48px;color:var(--text-disabled);margin:0 auto var(--sp-4)}
.entries-empty h3{font-size:var(--text-lg);font-weight:600;color:var(--text-heading);margin-bottom:var(--sp-2)}
.entries-empty p{color:var(--text-secondary);font-size:var(--text-sm);margin-bottom:var(--sp-5)}
</style>
{% endblock %}

{% block content %}

<div class="breadcrumb">
    <a href="{{ admin_url() }}">{% include '@cms/partials/sidebar-icon.twig' with {icon: 'home'} only %} Dashboard</a>
    <span class="breadcrumb-sep">/</span>
    <a href="{{ admin_url('collections') }}">Collections</a>
    <span class="breadcrumb-sep">/</span>
    <span class="breadcrumb-current">{{ collection.getName() }}</span>
</div>

{% set _totalCount = entries.total|default(entries.data|length) %}

<div class="page-header">
    <div>
        <h1>{{ collection.getName() }}</h1>
        <p class="page-header-sub">{{ _totalCount }} {{ _totalCount == 1 ? 'entry' : 'entries' }}</p>
    </div>
    <div class="page-header-actions">
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash') }}" class="btn btn-outline btn-sm">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'archive'} only %}
            Trash
            {% if trashCount is defined and trashCount > 0 %}
                <span class="badge badge-error" style="margin-left:2px">{{ trashCount }}</span>
            {% endif %}
        </a>

        <div class="dropdown">
            <button class="btn btn-outline btn-sm" data-dropdown-trigger>
                Export
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m6 9 6 6 6-6"/></svg>
            </button>
            <div class="dropdown-menu" data-dropdown-menu>
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=csv') }}" class="dropdown-item">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %}
                    Export as CSV
                </a>
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/export?format=json') }}" class="dropdown-item">
                    {% include '@cms/partials/sidebar-icon.twig' with {icon: 'code'} only %}
                    Export as JSON
                </a>
            </div>
        </div>

        <button class="btn btn-outline btn-sm" id="toggle-import-btn">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'file'} only %}
            Import
        </button>

        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="btn btn-primary btn-sm">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'plus'} only %}
            New Entry
        </a>

        <a href="{{ admin_url('collections/' ~ collection.getSlug()) }}" class="btn btn-ghost btn-icon btn-sm" title="Collection Settings">
            {% include '@cms/partials/sidebar-icon.twig' with {icon: 'settings'} only %}
        </a>
    </div>
</div>

{# ── Entries page wrapper ── #}
<div class="entries-page">

    {# ── Import Form (hidden) ──────────────────────── #}
    <div id="import-form" class="entries-panel" style="display: none;">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/import/preview') }}" enctype="multipart/form-data">
            {{ csrf_field() | raw }}
            <div class="entries-panel__row">
                <div class="entries-panel__field">
                    <label for="import_file" class="entries-label">Import File (CSV or JSON)</label>
                    <input type="file" id="import_file" name="import_file" class="form-control" accept=".csv,.json" required>
                </div>
                <button type="submit" class="entries-btn entries-btn--primary">Preview &amp; Map</button>
            </div>
            <p class="entries-panel__hint">Upload your file to preview data and map columns before importing.</p>
        </form>
    </div>

    {# ── Active View Chip ──────────────────────────── #}
    {% if activeViewSlug is defined and activeViewSlug %}
        {% for sv in savedViews %}
            {% if sv.getSlug() == activeViewSlug %}
            <div class="entries-active-view">
                <div class="entries-chip">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.167 5.25h11.666M1.167 8.75h11.666M5.25 1.167v11.666M8.75 1.167v11.666" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                    <span>{{ sv.getName() }}</span>
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-chip__close" title="Clear view">
                        <svg width="12" height="12" viewBox="0 0 12 12" fill="none"><path d="M9 3L3 9M3 3l6 6" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </a>
                </div>
                <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/views/' ~ sv.getId() ~ '/delete') }}" style="display:inline;">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="entries-btn entries-btn--ghost entries-btn--sm entries-btn--danger-text" onclick="return confirm('Delete this saved view?')">Delete View</button>
                </form>
            </div>
            {% endif %}
        {% endfor %}
    {% endif %}

    {# ── Save View Form (hidden) ───────────────────── #}
    <div id="save-view-form" class="entries-panel" style="display: none;">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/views') }}">
            {{ csrf_field() | raw }}
            <h4 class="entries-panel__title">Save Current View</h4>
            <div class="entries-panel__grid">
                <div class="entries-panel__field entries-panel__field--grow">
                    <label for="view_name" class="entries-label">View Name <span class="entries-text-required">*</span></label>
                    <input type="text" id="view_name" name="view_name" class="form-control" placeholder="e.g. Published Posts" required>
                </div>
                <div class="entries-panel__field">
                    <label for="view_sort_by" class="entries-label">Sort By</label>
                    <select name="view_sort_by" id="view_sort_by" class="form-control">
                        <option value="">Default (ID)</option>
                        {% for field in listableFields %}
                            <option value="{{ field.getSlug() }}">{{ field.getName() }}</option>
                        {% endfor %}
                        <option value="created_at">Created At</option>
                        {% if collection.isPublishable() %}
                            <option value="status">Status</option>
                        {% endif %}
                    </select>
                </div>
                <div class="entries-panel__field">
                    <label for="view_sort_dir" class="entries-label">Direction</label>
                    <select name="view_sort_dir" id="view_sort_dir" class="form-control">
                        <option value="DESC">Descending</option>
                        <option value="ASC">Ascending</option>
                    </select>
                </div>
            </div>
            <div id="view-filters" class="entries-panel__filters">
                <label class="entries-label">Filters</label>
                <div class="view-filter-row">
                    <select name="filter_field[]" class="form-control">
                        <option value="">-- Field --</option>
                        {% for field in listableFields %}
                            <option value="{{ field.getSlug() }}">{{ field.getName() }}</option>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                            <option value="status">Status</option>
                        {% endif %}
                    </select>
                    <input type="text" name="filter_value[]" class="form-control" placeholder="Value (exact match)">
                </div>
            </div>
            <button type="button" class="entries-btn entries-btn--outline entries-btn--sm" id="add-filter-btn">+ Add Filter</button>
            <div class="entries-panel__footer">
                <label class="entries-checkbox-label"><input type="checkbox" name="view_is_default" value="1"> Set as default view</label>
                <button type="submit" class="entries-btn entries-btn--primary entries-btn--sm">Save View</button>
            </div>
        </form>
    </div>

    {# ── Data Table ────────────────────────────────── #}
    {% if entries.data|length > 0 %}
    <div class="entries-card">
        {# ── Toolbar (inside card, seamless) ───────── #}
        <div class="entries-toolbar">
            {% if listableFields|length > 0 %}
            <form method="GET" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search">
                <svg class="entries-search__icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"/><path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                <input type="text" name="search" class="entries-search__input" placeholder="Search entries..." value="{{ search }}" autocomplete="off">
                {% if search %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search__clear" title="Clear search">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M10.5 3.5L3.5 10.5M3.5 3.5l7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                    </a>
                {% endif %}
            </form>
            {% endif %}

            {% if collection.hasHierarchy() and (parentBreadcrumbs is defined and parentBreadcrumbs|length > 0) %}
            <div class="entries-hierarchy-path" style="display:flex;align-items:center;gap:6px;padding:8px 0;font-size:0.8125rem;">
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=') }}" style="color:var(--color-primary,#1A7BA8);text-decoration:none;font-weight:600;">{{ collection.getName() }}</a>
                {% for bc in parentBreadcrumbs %}
                    <span style="color:var(--text-disabled,#ccc);">›</span>
                    {% if not loop.last %}
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=' ~ bc.id) }}" style="color:var(--color-primary,#1A7BA8);text-decoration:none;">{{ bc.label }}</a>
                    {% else %}
                        <span style="font-weight:600;color:var(--text,#303030);">{{ bc.label }}</span>
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}

            <div class="entries-toolbar__right">
                {# Saved Views Dropdown #}
                <div class="entries-dropdown" data-dropdown>
                    <button class="entries-btn entries-btn--outline entries-btn--sm" data-dropdown-trigger>
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.167 5.25h11.666M1.167 8.75h11.666M5.25 1.167v11.666M8.75 1.167v11.666" stroke="currentColor" stroke-width="1" stroke-linecap="round"/></svg>
                        Views
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 4l2.5 2.5L7.5 4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="entries-dropdown__menu entries-dropdown__menu--right" data-dropdown-menu>
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}"
                           class="entries-dropdown__item {% if activeViewSlug is empty %}entries-dropdown__item--active{% endif %}">
                            All Entries
                        </a>
                        {% if savedViews is defined and savedViews|length > 0 %}
                            <div class="entries-dropdown__divider"></div>
                            {% for sv in savedViews %}
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?view=' ~ sv.getSlug()) }}"
                                   class="entries-dropdown__item {% if activeViewSlug == sv.getSlug() %}entries-dropdown__item--active{% endif %}">
                                    {{ sv.getName() }}{% if sv.isDefault() %} <span class="entries-text-muted">(default)</span>{% endif %}
                                    <span class="entries-text-muted" style="margin-left:auto; font-size: 0.75rem;">{{ sv.getFilters()|length }} filter{{ sv.getFilters()|length != 1 ? 's' : '' }}</span>
                                </a>
                            {% endfor %}
                        {% endif %}
                        <div class="entries-dropdown__divider"></div>
                        <button class="entries-dropdown__item" id="toggle-save-view-btn" type="button">
                            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M7 2.333v9.334M2.333 7h9.334" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                            Save Current View
                        </button>
                    </div>
                </div>
            </div>
        </div>

        {# ── Table ─────────────────────────────────── #}
        <div class="entries-table-wrap">
            <table class="entries-table" id="entries-table">
                <thead>
                    <tr>
                        <th class="entries-col-checkbox"><input type="checkbox" id="select-all" class="entries-checkbox"></th>
                        {% for field in listableFields %}
                        <th class="entries-col-field" data-col="field-{{ field.getSlug() }}" data-col-name="{{ field.getName() }}" data-col-type="{{ field.getType() }}">
                            {% set _nextDir = 'ASC' %}
                            {% if sortBy == field.getSlug() and sortDir == 'ASC' %}
                                {% set _nextDir = 'DESC' %}
                            {% endif %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=' ~ field.getSlug() ~ '&sort_dir=' ~ _nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == field.getSlug() %}entries-table__sort--active{% endif %}">
                                {{ field.getName() }}
                                {% if sortBy == field.getSlug() %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                        <th class="entries-col-status" data-col="col-status" data-col-name="Status">
                            {% set _nextDir = 'ASC' %}
                            {% if sortBy == 'status' and sortDir == 'ASC' %}
                                {% set _nextDir = 'DESC' %}
                            {% endif %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=status&sort_dir=' ~ _nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == 'status' %}entries-table__sort--active{% endif %}">
                                Status
                                {% if sortBy == 'status' %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        {% endif %}
                        <th class="entries-col-updated" data-col="col-updated" data-col-name="Updated">
                            {% set _nextDir = 'ASC' %}
                            {% if sortBy == 'created_at' and sortDir == 'ASC' %}
                                {% set _nextDir = 'DESC' %}
                            {% endif %}
                            <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?sort_by=created_at&sort_dir=' ~ _nextDir ~ '&search=' ~ search ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}"
                               class="entries-table__sort {% if sortBy == 'created_at' %}entries-table__sort--active{% endif %}">
                                Updated
                                {% if sortBy == 'created_at' %}
                                    <svg width="12" height="12" viewBox="0 0 12 12" fill="none" class="entries-table__sort-icon {% if sortDir == 'DESC' %}entries-table__sort-icon--desc{% endif %}"><path d="M3 5l3-3 3 3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                {% endif %}
                            </a>
                        </th>
                        <th class="entries-col-actions">
                            <button type="button" class="entries-col-toggle-btn" id="col-toggle-btn" title="Toggle columns">
                                <svg width="15" height="15" viewBox="0 0 15 15" fill="none"><path d="M7.5 9.625a2.125 2.125 0 100-4.25 2.125 2.125 0 000 4.25z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/><path d="M12.135 9.625a1.05 1.05 0 00.21 1.158l.038.038a1.274 1.274 0 11-1.802 1.8l-.038-.037a1.05 1.05 0 00-1.158-.21 1.05 1.05 0 00-.637.961v.108a1.274 1.274 0 01-2.548 0v-.057a1.05 1.05 0 00-.688-.962 1.05 1.05 0 00-1.158.21l-.038.039a1.274 1.274 0 11-1.8-1.802l.037-.038a1.05 1.05 0 00.21-1.158 1.05 1.05 0 00-.961-.637h-.108a1.274 1.274 0 010-2.548h.057a1.05 1.05 0 00.962-.688 1.05 1.05 0 00-.21-1.158l-.039-.038a1.274 1.274 0 111.802-1.8l.038.037a1.05 1.05 0 001.158.21h.05a1.05 1.05 0 00.638-.961V1.83a1.274 1.274 0 012.548 0v.057a1.05 1.05 0 00.637.962 1.05 1.05 0 001.158-.21l.038-.039a1.274 1.274 0 111.8 1.802l-.037.038a1.05 1.05 0 00-.21 1.158v.05a1.05 1.05 0 00.961.638h.108a1.274 1.274 0 010 2.548h-.057a1.05 1.05 0 00-.962.637z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                            </button>
                            <div class="entries-col-toggle-dropdown" id="col-toggle-dropdown">
                                <div class="entries-col-toggle-title">Toggle Columns</div>
                                <div id="col-toggle-list"></div>
                            </div>
                        </th>
                    </tr>
                </thead>
                <tbody>
                    {% for entry in entries.data %}
                    {% set _eId = entry.id %}
                    {% set _eDepth = depthMap[_eId]|default(0) %}
                    {% set _eChildren = childCountMap[_eId]|default(0) %}
                    {% set _eParent = entry.parent_id|default('') %}
                    <tr class="entries-table__row" data-entry-id="{{ _eId }}" data-parent-id="{{ _eParent }}" data-depth="{{ _eDepth }}" data-children="{{ _eChildren }}">
                        <td class="entries-col-checkbox"><input type="checkbox" class="entry-checkbox entries-checkbox" value="{{ entry.id }}"></td>
                        {% for field in listableFields %}
                        <td class="entries-col-field" data-col="field-{{ field.getSlug() }}"{% if loop.first and collection.hasHierarchy() %} style="display:flex;align-items:center;gap:6px;"{% endif %}>
                            {% if loop.first and collection.hasHierarchy() and _eChildren > 0 %}
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?parent=' ~ entry.id) }}" style="display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:4px;color:var(--color-primary,#1A7BA8);font-weight:700;font-size:16px;flex-shrink:0;transition:background 0.1s;" title="View {{ _eChildren }} children" onmouseover="this.style.background='rgba(26,123,168,0.1)'" onmouseout="this.style.background=''">›</a>
                            {% endif %}
                            {% if field.getType() == 'boolean' %}
                                <span class="entries-bool entries-bool--{{ entry[field.getSlug()] ? 'yes' : 'no' }}">{{ entry[field.getSlug()] ? 'Yes' : 'No' }}</span>
                            {% elseif (field.getType() == 'image' or field.getType() == 'file') and entry[field.getSlug()] %}
                                {% set _imgVal = entry[field.getSlug()] %}
                                {% set _thumbs = media_thumbs(_imgVal, 3) %}
                                {% set _totalCount = media_thumbs_count(_imgVal) %}
                                {% if _thumbs|length > 0 %}
                                    <span class="entries-thumb-group">
                                    {% for _t in _thumbs %}
                                        <img src="{{ _t }}" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:6px;border:1px solid #e3e3e3;display:inline-block;vertical-align:middle;">
                                    {% endfor %}
                                    {% if _totalCount > 3 %}<span class="entries-text-muted" style="font-size:11px;margin-left:4px;">+{{ _totalCount - 3 }}</span>{% endif %}
                                    </span>
                                {% endif %}
                            {% elseif field.getType() == 'richtext' and entry[field.getSlug()] %}
                                {% set _rtVal = entry[field.getSlug()]|striptags %}
                                <span class="entries-richtext-preview" data-content="{{ entry[field.getSlug()]|e('html_attr') }}" title="Click to preview">{{ _rtVal|slice(0, 60) }}{% if _rtVal|length > 60 %}...{% endif %}</span>
                            {% elseif field.getType() == 'relation' and entry[field.getSlug()] %}
                                {% set _fKey = field.getSlug() %}
                                {% set _relLabels = relationLabels[_fKey]|default({}) %}
                                {% set _entryVal = entry[_fKey] %}
                                {% if _entryVal in (_relLabels|keys) %}
                                    <span class="entries-truncate">{{ _relLabels[_entryVal] }}</span>
                                {% else %}
                                    <span class="entries-truncate entries-text-muted">#{{ _entryVal }}</span>
                                {% endif %}
                            {% else %}
                                {% set _cellVal = entry[field.getSlug()]|default('')|striptags %}
                                <span class="entries-truncate">{{ _cellVal|slice(0, 80) }}{% if _cellVal|length > 80 %}...{% endif %}</span>
                            {% endif %}
                        </td>
                        {% endfor %}
                        {% if collection.isPublishable() %}
                        <td class="entries-col-status" data-col="col-status">
                            {% set _st = entry.status|default('draft') %}
                            <span class="entries-status entries-status--{{ _st }}">
                                <span class="entries-status__dot"></span>
                                {{ _st|capitalize }}
                            </span>
                        </td>
                        {% endif %}
                        <td class="entries-col-updated" data-col="col-updated">
                            <span class="entries-relative-time" data-time="{{ entry.updated_at|default(entry.created_at|default('')) }}">{{ entry.updated_at|default(entry.created_at|default('')) }}</span>
                        </td>
                        <td class="entries-col-actions">
                            <div class="entries-actions-inner">
                                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id) }}" class="entries-icon-btn" title="Edit">
                                    <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M11.333 2a1.886 1.886 0 012.667 2.667L5.333 13.333 2 14l.667-3.333L11.333 2z" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                </a>
                                <div class="entries-dropdown entries-dropdown--right" data-dropdown>
                                    <button class="entries-icon-btn" data-dropdown-trigger title="More actions">
                                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="3" r="1" fill="currentColor"/><circle cx="8" cy="8" r="1" fill="currentColor"/><circle cx="8" cy="13" r="1" fill="currentColor"/></svg>
                                    </button>
                                    <div class="entries-dropdown__menu entries-dropdown__menu--right entries-dropdown__menu--compact" data-dropdown-menu>
                                        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/duplicate') }}">
                                            {{ csrf_field() | raw }}
                                            <button type="submit" class="entries-dropdown__item" onclick="return confirm('Duplicate this entry?')">
                                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><rect x="4.667" y="4.667" width="8.167" height="8.167" rx="1" stroke="currentColor" stroke-width="1"/><path d="M9.333 4.667V2.333A1.167 1.167 0 008.167 1.167H2.333A1.167 1.167 0 001.167 2.333v5.834A1.167 1.167 0 002.333 9.333h2.334" stroke="currentColor" stroke-width="1"/></svg>
                                                Duplicate
                                            </button>
                                        </form>
                                        <div class="entries-dropdown__divider"></div>
                                        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/delete') }}" class="confirm-delete" data-message="Delete this entry?">
                                            {{ csrf_field() | raw }}
                                            <button type="submit" class="entries-dropdown__item entries-dropdown__item--danger">
                                                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1.75 3.5h10.5M4.667 3.5V2.333a1.167 1.167 0 011.166-1.166h2.334a1.167 1.167 0 011.166 1.166V3.5m1.75 0v8.167a1.167 1.167 0 01-1.166 1.166H4.083a1.167 1.167 0 01-1.166-1.166V3.5h8.166z" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/></svg>
                                                Delete
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>

        {# ── Pagination ────────────────────────────── #}
        {% if entries.last_page > 1 %}
        <div class="entries-pagination">
            <span class="entries-pagination__info">
                {% set _showTo = entries.current_page * entries.per_page %}
                {% set _showToFinal = _showTo %}
                {% if _showTo > entries.total %}
                    {% set _showToFinal = entries.total %}
                {% endif %}
                Showing {{ ((entries.current_page - 1) * entries.per_page) + 1 }}&ndash;{{ _showToFinal }} of {{ entries.total }}
            </span>
            <div class="entries-pagination__controls">
                {% if entries.current_page > 1 %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page - 1) ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__btn">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.75 10.5L5.25 7l3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Prev
                    </a>
                {% else %}
                    <span class="entries-pagination__btn entries-pagination__btn--disabled">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M8.75 10.5L5.25 7l3.5-3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Prev
                    </span>
                {% endif %}

                {% for p in 1..entries.last_page %}
                    {% if p == entries.current_page %}
                        <span class="entries-pagination__page entries-pagination__page--active">{{ p }}</span>
                    {% elseif p == 1 or p == entries.last_page or (p >= entries.current_page - 2 and p <= entries.current_page + 2) %}
                        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ p ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__page">{{ p }}</a>
                    {% elseif p == 2 or p == entries.last_page - 1 %}
                        <span class="entries-pagination__ellipsis">...</span>
                    {% endif %}
                {% endfor %}

                {% if entries.current_page < entries.last_page %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries?page=' ~ (entries.current_page + 1) ~ '&search=' ~ search ~ '&sort_by=' ~ sortBy ~ '&sort_dir=' ~ sortDir ~ (activeViewSlug ? '&view=' ~ activeViewSlug : '')) }}" class="entries-pagination__btn">
                        Next
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5.25 3.5L8.75 7l-3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                {% else %}
                    <span class="entries-pagination__btn entries-pagination__btn--disabled">
                        Next
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M5.25 3.5L8.75 7l-3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </div>

    {# ── Bulk Actions (floating bar) ───────────────── #}
    <div id="bulk-bar" class="entries-bulk-bar">
        <div class="entries-bulk-bar__inner">
            <span class="entries-bulk-bar__count"><strong id="bulk-count">0</strong> selected</span>
            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/bulk') }}" class="entries-bulk-bar__form">
                {{ csrf_field() | raw }}
                <input type="hidden" name="selected_ids" id="bulk-ids" value="">
                <input type="hidden" name="bulk_action" id="bulk-action-value" value="">

                {% if collection.isPublishable() %}
                <button type="submit" class="entries-btn entries-btn--sm entries-btn--outline" onclick="document.getElementById('bulk-action-value').value='publish'; return confirm('Publish selected entries?')">Publish</button>
                <button type="submit" class="entries-btn entries-btn--sm entries-btn--outline" onclick="document.getElementById('bulk-action-value').value='unpublish'; return confirm('Unpublish selected entries?')">Unpublish</button>
                {% endif %}

                <div class="entries-dropdown entries-dropdown--up" data-dropdown>
                    <button type="button" class="entries-btn entries-btn--sm entries-btn--outline" data-dropdown-trigger>
                        Update Field
                        <svg width="10" height="10" viewBox="0 0 10 10" fill="none"><path d="M2.5 6l2.5-2.5L7.5 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="entries-dropdown__menu entries-dropdown__menu--up" data-dropdown-menu>
                        <div class="entries-bulk-field-form" style="padding: var(--sp-3);">
                            <label class="entries-label">Field</label>
                            <select name="bulk_field" id="bulk-field-select" class="form-control" style="margin-bottom: 8px;">
                                <option value="">-- Select Field --</option>
                                {% for field in fields %}
                                    {% if field.getType() in ['text', 'number', 'select', 'boolean', 'email', 'url'] %}
                                    <option value="{{ field.getSlug() }}" data-type="{{ field.getType() }}" {% if field.getType() == 'select' and field.getOptions() %}data-options="{{ field.getOptions()|json_encode }}"{% endif %}>{{ field.getName() }}</option>
                                    {% endif %}
                                {% endfor %}
                            </select>
                            <label class="entries-label">Value</label>
                            <span id="bulk-value-wrapper">
                                <input type="text" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">
                            </span>
                            <button type="submit" class="entries-btn entries-btn--primary entries-btn--sm" style="margin-top: 8px; width: 100%;" onclick="document.getElementById('bulk-action-value').value='update_field'; return confirm('Update field for selected entries?')">Apply</button>
                        </div>
                    </div>
                </div>

                <button type="submit" class="entries-btn entries-btn--sm entries-btn--danger" onclick="document.getElementById('bulk-action-value').value='delete'; return confirm('Delete selected entries? This cannot be undone.')">Delete</button>
            </form>
        </div>
    </div>

    {% else %}
    {# ── Toolbar (shown even when empty, for search) ── #}
    {% if listableFields|length > 0 %}
    <div class="entries-toolbar entries-toolbar--standalone">
        <form method="GET" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search">
            <svg class="entries-search__icon" width="16" height="16" viewBox="0 0 16 16" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.3"/><path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
            <input type="text" name="search" class="entries-search__input" placeholder="Search entries..." value="{{ search }}" autocomplete="off">
            {% if search %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="entries-search__clear" title="Clear search">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M10.5 3.5L3.5 10.5M3.5 3.5l7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
                </a>
            {% endif %}
        </form>
    </div>
    {% endif %}

    {# ── Empty State ───────────────────────────────── #}
    <div class="entries-empty">
        <div class="entries-empty__icon">
            <svg width="48" height="48" viewBox="0 0 48 48" fill="none"><rect x="8" y="6" width="32" height="36" rx="4" stroke="currentColor" stroke-width="2"/><path d="M16 18h16M16 24h16M16 30h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
        </div>
        <h3 class="entries-empty__title">No entries yet</h3>
        <p class="entries-empty__text">Get started by creating the first entry for this collection.</p>
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/create') }}" class="entries-btn entries-btn--primary">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M8 3.333v9.334M3.333 8h9.334" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Create Entry
        </a>
    </div>
    {% endif %}

</div>

{# ── Richtext Preview Modal (reusable container) ── #}

{# ══════════════════════════════════════════════════════ #}
{#  Styles                                                #}
{# ══════════════════════════════════════════════════════ #}

{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {

    /* ── Dropdown system ───────────────────────── */
    document.querySelectorAll('[data-dropdown]').forEach(function(dd) {
        var trigger = dd.querySelector('[data-dropdown-trigger]');
        var menu = dd.querySelector('[data-dropdown-menu]');
        if (!trigger || !menu) return;

        trigger.addEventListener('click', function(e) {
            e.stopPropagation();
            document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
                if (m !== menu) m.classList.remove('is-open');
            });
            menu.classList.toggle('is-open');
        });
    });
    document.addEventListener('click', function(e) {
        /* Close dropdowns and column toggle */
        if (!e.target.closest('#col-toggle-btn') && !e.target.closest('#col-toggle-dropdown')) {
            var colDd = document.getElementById('col-toggle-dropdown');
            if (colDd) colDd.classList.remove('is-open');
        }
        document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
            m.classList.remove('is-open');
        });
    });
    document.querySelectorAll('[data-dropdown-menu]').forEach(function(m) {
        m.addEventListener('click', function(e) {
            if (!e.target.closest('a') && e.target.type !== 'submit') {
                e.stopPropagation();
            }
        });
    });

    /* ── Import toggle ─────────────────────────── */
    var importBtn = document.getElementById('toggle-import-btn');
    var importForm = document.getElementById('import-form');
    if (importBtn && importForm) {
        importBtn.addEventListener('click', function() {
            importForm.style.display = importForm.style.display === 'none' ? 'block' : 'none';
        });
    }

    /* ── Save View toggle ──────────────────────── */
    var saveViewBtn = document.getElementById('toggle-save-view-btn');
    var saveViewForm = document.getElementById('save-view-form');
    if (saveViewBtn && saveViewForm) {
        saveViewBtn.addEventListener('click', function() {
            saveViewForm.style.display = saveViewForm.style.display === 'none' ? 'block' : 'none';
            document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
                m.classList.remove('is-open');
            });
        });
    }

    /* ── Add filter row ────────────────────────── */
    var addFilterBtn = document.getElementById('add-filter-btn');
    var viewFilters = document.getElementById('view-filters');
    if (addFilterBtn && viewFilters) {
        addFilterBtn.addEventListener('click', function() {
            var firstRow = viewFilters.querySelector('.view-filter-row');
            if (firstRow) {
                var clone = firstRow.cloneNode(true);
                clone.querySelectorAll('input, select').forEach(function(el) { el.value = ''; });
                viewFilters.appendChild(clone);
            }
        });
    }

    /* ── Bulk selection ────────────────────────── */
    var selectAll = document.getElementById('select-all');
    var checkboxes = document.querySelectorAll('.entry-checkbox');
    var bulkBar = document.getElementById('bulk-bar');
    var bulkCount = document.getElementById('bulk-count');
    var bulkIds = document.getElementById('bulk-ids');

    function updateBulk() {
        var selected = document.querySelectorAll('.entry-checkbox:checked');
        var ids = Array.from(selected).map(function(cb) { return cb.value; });
        if (bulkBar) {
            if (ids.length > 0) {
                bulkBar.classList.add('is-visible');
            } else {
                bulkBar.classList.remove('is-visible');
            }
        }
        if (bulkCount) bulkCount.textContent = ids.length;
        if (bulkIds) bulkIds.value = ids.join(',');
    }

    if (selectAll) {
        selectAll.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
            updateBulk();
        });
    }
    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateBulk);
    });

    /* ── Bulk field update (value rendering) ───── */
    var bulkFieldSelect = document.getElementById('bulk-field-select');
    var bulkValueWrapper = document.getElementById('bulk-value-wrapper');

    function renderValueInput(type, options) {
        if (!bulkValueWrapper) return;
        var html = '';
        if (type === 'boolean') {
            html = '<select name="bulk_value" id="bulk-value-input" class="form-control">' +
                   '<option value="0">No</option><option value="1">Yes</option></select>';
        } else if (type === 'select' && options) {
            var opts;
            try { opts = typeof options === 'string' ? JSON.parse(options) : options; } catch(e) { opts = []; }
            html = '<select name="bulk_value" id="bulk-value-input" class="form-control">';
            html += '<option value="">-- Select --</option>';
            if (Array.isArray(opts)) {
                opts.forEach(function(o) {
                    var val = typeof o === 'object' ? (o.value || '') : o;
                    var label = typeof o === 'object' ? (o.label || o.value || '') : o;
                    html += '<option value="' + val + '">' + label + '</option>';
                });
            }
            html += '</select>';
        } else if (type === 'number') {
            html = '<input type="number" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value" step="any">';
        } else if (type === 'email') {
            html = '<input type="email" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        } else if (type === 'url') {
            html = '<input type="url" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        } else {
            html = '<input type="text" name="bulk_value" id="bulk-value-input" class="form-control" placeholder="New value">';
        }
        bulkValueWrapper.innerHTML = html;
    }

    if (bulkFieldSelect) {
        bulkFieldSelect.addEventListener('change', function() {
            var selected = this.options[this.selectedIndex];
            var type = selected.getAttribute('data-type') || 'text';
            var options = selected.getAttribute('data-options') || null;
            renderValueInput(type, options);
        });
    }

    /* ── Richtext content preview modal ────────── */
    document.querySelectorAll('.entries-richtext-preview').forEach(function(el) {
        el.addEventListener('click', function(e) {
            e.stopPropagation();
            var content = el.dataset.content;
            if (!content) return;
            var modal = document.createElement('div');
            modal.className = 'entries-content-modal';
            modal.innerHTML = '<div class="entries-content-modal-box">'
                + '<div class="entries-content-modal-header"><h3>Content Preview</h3><button class="entries-content-modal-close">&times;</button></div>'
                + '<div class="entries-content-modal-body">' + content + '</div></div>';
            document.body.appendChild(modal);
            modal.querySelector('.entries-content-modal-close').addEventListener('click', function() { modal.remove(); });
            modal.addEventListener('click', function(ev) { if (ev.target === modal) modal.remove(); });
            document.addEventListener('keydown', function onEsc(ev) { if (ev.key === 'Escape') { modal.remove(); document.removeEventListener('keydown', onEsc); } });
        });
    });

    /* ── Confirm delete forms ──────────────────── */
    document.querySelectorAll('.confirm-delete').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            if (!confirm(form.dataset.message || 'Are you sure?')) {
                e.preventDefault();
            }
        });
    });

    /* ── Relative time conversion ──────────────── */
    function timeAgo(dateStr) {
        if (!dateStr) return '';
        var date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        var now = new Date();
        var seconds = Math.floor((now - date) / 1000);
        if (seconds < 0) seconds = 0;

        var intervals = [
            { label: 'y', full: 'year', seconds: 31536000 },
            { label: 'mo', full: 'month', seconds: 2592000 },
            { label: 'w', full: 'week', seconds: 604800 },
            { label: 'd', full: 'day', seconds: 86400 },
            { label: 'h', full: 'hour', seconds: 3600 },
            { label: 'm', full: 'minute', seconds: 60 }
        ];

        for (var i = 0; i < intervals.length; i++) {
            var count = Math.floor(seconds / intervals[i].seconds);
            if (count >= 1) {
                if (intervals[i].full === 'day' && count === 1) return 'Yesterday';
                return count + intervals[i].label + ' ago';
            }
        }
        return 'Just now';
    }

    document.querySelectorAll('.entries-relative-time').forEach(function(el) {
        var raw = el.getAttribute('data-time');
        if (raw) {
            var relative = timeAgo(raw);
            if (relative) {
                el.textContent = relative;
                el.title = raw;
            }
        }
    });

    /* ── Search submit on Enter ────────────────── */
    var searchInput = document.querySelector('.entries-search__input');
    if (searchInput) {
        searchInput.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') {
                this.closest('form').submit();
            }
        });
    }

    /* ── Column Toggle System ──────────────────── */
    var colToggleBtn = document.getElementById('col-toggle-btn');
    var colToggleDropdown = document.getElementById('col-toggle-dropdown');
    var colToggleList = document.getElementById('col-toggle-list');
    var collectionSlug = '{{ collection.getSlug()|e("js") }}';
    var storageKey = 'entries-cols-' + collectionSlug;

    /* Gather all toggleable columns */
    var toggleableCols = [];
    var table = document.getElementById('entries-table');
    if (table) {
        var headerCells = table.querySelectorAll('thead th[data-col]');
        headerCells.forEach(function(th) {
            var colId = th.getAttribute('data-col');
            var colName = th.getAttribute('data-col-name');
            if (colId && colName) {
                toggleableCols.push({ id: colId, name: colName });
            }
        });
    }

    /* Load saved state from localStorage */
    function loadColState() {
        var saved = null;
        try { saved = JSON.parse(localStorage.getItem(storageKey)); } catch(e) {}
        return saved;
    }

    function saveColState(state) {
        try { localStorage.setItem(storageKey, JSON.stringify(state)); } catch(e) {}
    }

    /* Apply column visibility */
    function applyColVisibility(state) {
        if (!table || !state) return;
        toggleableCols.forEach(function(col) {
            var isVisible = true;
            if (col.id in state) {
                isVisible = state[col.id];
            }
            var cells = table.querySelectorAll('[data-col="' + col.id + '"]');
            cells.forEach(function(cell) {
                if (isVisible) {
                    cell.classList.remove('entries-col-hidden');
                } else {
                    cell.classList.add('entries-col-hidden');
                }
            });
        });
    }

    /* Build the toggle dropdown */
    function buildColToggleList(state) {
        if (!colToggleList) return;
        colToggleList.innerHTML = '';
        toggleableCols.forEach(function(col) {
            var isVisible = true;
            if (state && (col.id in state)) {
                isVisible = state[col.id];
            }
            var label = document.createElement('label');
            label.className = 'entries-col-toggle-item';
            var cb = document.createElement('input');
            cb.type = 'checkbox';
            cb.checked = isVisible;
            cb.setAttribute('data-col-id', col.id);
            cb.addEventListener('change', function() {
                var currentState = loadColState() || {};
                currentState[col.id] = cb.checked;
                saveColState(currentState);
                applyColVisibility(currentState);
            });
            var text = document.createTextNode(col.name);
            label.appendChild(cb);
            label.appendChild(text);
            colToggleList.appendChild(label);
        });
    }

    /* Init column toggle */
    if (colToggleBtn && colToggleDropdown && toggleableCols.length > 0) {
        var savedState = loadColState();
        if (savedState) {
            applyColVisibility(savedState);
        }
        buildColToggleList(savedState);

        colToggleBtn.addEventListener('click', function(e) {
            e.stopPropagation();
            /* Close other dropdowns */
            document.querySelectorAll('[data-dropdown-menu].is-open').forEach(function(m) {
                m.classList.remove('is-open');
            });
            colToggleDropdown.classList.toggle('is-open');
        });

        colToggleDropdown.addEventListener('click', function(e) {
            e.stopPropagation();
        });
    }

});

{% if collection.hasHierarchy() %}
// ── Tree View Toggle ──
(function() {
    var treeBtn = document.getElementById('tree-toggle');
    if (!treeBtn) return;

    var rows = document.querySelectorAll('.entries-table__row');
    var isTreeMode = true; // Start in tree mode for hierarchy collections
    var collapsed = {}; // Track collapsed parent IDs

    function applyTreeView() {
        rows.forEach(function(row) {
            var depth = parseInt(row.dataset.depth || '0', 10);
            var parentId = row.dataset.parentId;
            var entryId = row.dataset.entryId;
            var childCount = parseInt(row.dataset.children || '0', 10);
            var firstFieldCell = row.querySelector('.entries-col-field');
            if (!firstFieldCell) return;

            // Remove existing tree elements
            var old = firstFieldCell.querySelector('.tree-indent');
            if (old) old.remove();

            if (!isTreeMode) {
                row.style.display = '';
                return;
            }

            // Check if this row should be hidden (any ancestor is collapsed)
            var hidden = false;
            if (parentId) {
                var checkId = parentId;
                var seen = {};
                while (checkId && !seen[checkId]) {
                    seen[checkId] = true;
                    if (collapsed[checkId]) { hidden = true; break; }
                    // Find parent's parent
                    var parentRow = document.querySelector('[data-entry-id="' + checkId + '"]');
                    checkId = parentRow ? parentRow.dataset.parentId : '';
                }
            }
            row.style.display = hidden ? 'none' : '';

            // Add indent + toggle
            if (depth > 0 || childCount > 0) {
                var indent = document.createElement('span');
                indent.className = 'tree-indent';
                indent.style.cssText = 'display:inline-flex;align-items:center;flex-shrink:0;';

                // Spacing
                if (depth > 0) {
                    var spacer = document.createElement('span');
                    spacer.style.cssText = 'display:inline-block;width:' + (depth * 24) + 'px;';
                    indent.appendChild(spacer);
                }

                // Expand/collapse toggle or leaf connector
                if (childCount > 0) {
                    var toggle = document.createElement('button');
                    toggle.type = 'button';
                    toggle.className = 'tree-toggle-btn';
                    toggle.style.cssText = 'background:none;border:none;cursor:pointer;padding:2px;margin-right:4px;color:var(--text-secondary,#616161);font-size:11px;line-height:1;width:18px;text-align:center;border-radius:3px;';
                    toggle.textContent = collapsed[entryId] ? '▶' : '▼';
                    toggle.dataset.entryId = entryId;
                    toggle.addEventListener('click', function(e) {
                        e.stopPropagation();
                        collapsed[entryId] = !collapsed[entryId];
                        this.textContent = collapsed[entryId] ? '▶' : '▼';
                        applyTreeView();
                    });
                    toggle.addEventListener('mouseenter', function() { this.style.background = 'var(--bg-surface-hover,#f5f5f5)'; });
                    toggle.addEventListener('mouseleave', function() { this.style.background = 'none'; });
                    indent.appendChild(toggle);
                } else if (depth > 0) {
                    var leaf = document.createElement('span');
                    leaf.style.cssText = 'color:var(--border,#ddd);margin-right:4px;font-size:12px;width:18px;text-align:center;display:inline-block;';
                    leaf.textContent = '└';
                    indent.appendChild(leaf);
                }

                firstFieldCell.insertBefore(indent, firstFieldCell.firstChild);
            }
        });
    }

    treeBtn.addEventListener('click', function() {
        isTreeMode = !isTreeMode;
        collapsed = {};
        treeBtn.innerHTML = isTreeMode
            ? '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1h12v2H1zM1 5h12v2H1zM1 9h12v2H1z" fill="currentColor" opacity="0.6"/></svg> Flat View'
            : '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M2 2h3v3H2zM7 2h3v3H7zM7 7h3v3H7z" fill="currentColor" opacity="0.6"/><path d="M5 3.5h2M5 8.5h2M10 5.5v2" stroke="currentColor" stroke-width="1"/></svg> Tree View';
        treeBtn.style.background = isTreeMode ? 'var(--color-primary,#1A7BA8)' : '';
        treeBtn.style.color = isTreeMode ? '#fff' : '';
        applyTreeView();
    });

    // Auto-apply tree mode on load
    treeBtn.innerHTML = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M1 1h12v2H1zM1 5h12v2H1zM1 9h12v2H1z" fill="currentColor" opacity="0.6"/></svg> Flat View';
    treeBtn.style.background = 'var(--color-primary,#1A7BA8)';
    treeBtn.style.color = '#fff';
    applyTreeView();
})();
{% endif %}
</script>
{% endblock %}
