{% extends "@cms/layouts/cms.twig" %}

{% block title %}Trash — {{ collection.getName() }}{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/entries-trash.css">{% endblock %}

{% block content %}

<div class="trash-header">
    <div class="trash-header-left">
        <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="trash-back">
            <svg viewBox="0 0 24 24"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
            Entries
        </a>
        <h1 class="trash-title">Trash &mdash; {{ collection.getName() }}</h1>
        <p class="trash-subtitle">{{ entries.total }} deleted {{ entries.total == 1 ? 'entry' : 'entries' }}</p>
    </div>
    {% if entries.total > 0 %}
    <div class="trash-actions">
        <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash/empty') }}" class="confirm-delete" data-message="Permanently delete ALL {{ entries.total }} trashed entries? This cannot be undone.">
            {{ csrf_field() | raw }}
            <button type="submit" class="btn btn-danger">
                <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none;vertical-align:-2px;margin-right:4px;"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                Empty Trash
            </button>
        </form>
    </div>
    {% endif %}
</div>

{% if entries.data|length > 0 %}
<div class="trash-table-card">
    <div style="overflow-x: auto;">
        <table class="trash-table">
            <thead>
                <tr>
                    <th class="col-check"><input type="checkbox" id="select-all"></th>
                    <th class="col-id">ID</th>
                    {% for field in listableFields %}
                    <th>{{ field.getName() }}</th>
                    {% endfor %}
                    <th class="col-deleted">Deleted</th>
                    <th class="col-actions">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for entry in entries.data %}
                <tr>
                    <td class="col-check"><input type="checkbox" class="entry-checkbox" value="{{ entry.id }}"></td>
                    <td class="col-id"><strong>{{ entry.id }}</strong></td>
                    {% for field in listableFields %}
                    <td>
                        {% if field.getType() == 'boolean' %}
                            <span class="badge {{ entry[field.getSlug()] ? 'badge-success' : 'badge-default' }}">{{ entry[field.getSlug()] ? 'Yes' : 'No' }}</span>
                        {% elseif field.getType() == 'image' and entry[field.getSlug()] %}
                            <img src="/{{ entry[field.getSlug()] }}" alt="" style="max-height: 30px; border-radius: var(--radius-sm);">
                        {% elseif field.getType() == 'relation' and entry[field.getSlug()] %}
                            {% set _fKey = field.getSlug() %}
                            {% set _relLabels = relationLabels[_fKey] ?? {} %}
                            {% set _entryVal = entry[_fKey] %}
                            {% if _entryVal in (_relLabels|keys) %}
                                <span class="truncate">{{ _relLabels[_entryVal] }}</span>
                            {% else %}
                                <span class="truncate" class="text-secondary">#{{ _entryVal }}</span>
                            {% endif %}
                        {% else %}
                            {% set _cellVal = entry[field.getSlug()]|default('') %}
                            <span class="truncate">{{ _cellVal ? _cellVal : '&mdash;' }}</span>
                        {% endif %}
                    </td>
                    {% endfor %}
                    <td class="col-deleted">
                        <span class="deleted-time" data-datetime="{{ entry.deleted_at }}">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                            <span class="relative-time">{{ entry.deleted_at ?? '&mdash;' }}</span>
                        </span>
                    </td>
                    <td class="col-actions">
                        <div class="action-group">
                            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/restore') }}">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn-restore" title="Restore entry">
                                    <svg viewBox="0 0 24 24"><path d="M3 12a9 9 0 109-9M3 3v6h6"/></svg>
                                    Restore
                                </button>
                            </form>
                            <form method="POST" action="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries/' ~ entry.id ~ '/force-delete') }}" class="confirm-delete" data-message="Permanently delete this entry? This cannot be undone.">
                                {{ csrf_field() | raw }}
                                <button type="submit" class="btn-destroy" title="Delete forever">
                                    <svg viewBox="0 0 24 24"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
                                    Delete
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    {% if entries.last_page > 1 or entries.total > 0 %}
    <div class="trash-footer">
        <span class="trash-footer-info">
            {% set showTo = entries.current_page * entries.per_page %}
            Showing {{ ((entries.current_page - 1) * entries.per_page) + 1 }}&ndash;{{ showTo > entries.total ? entries.total : showTo }} of {{ entries.total }}
        </span>
        {% if entries.last_page > 1 %}
        <div class="pagination" style="margin: 0; padding: 0; border: none;">
            {% if entries.current_page > 1 %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash?page=' ~ (entries.current_page - 1)) }}">&laquo; Prev</a>
            {% endif %}
            {% for p in 1..entries.last_page %}
                {% if p == entries.current_page %}
                    <span class="active">{{ p }}</span>
                {% else %}
                    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash?page=' ~ p) }}">{{ p }}</a>
                {% endif %}
            {% endfor %}
            {% if entries.current_page < entries.last_page %}
                <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/trash?page=' ~ (entries.current_page + 1)) }}">Next &raquo;</a>
            {% endif %}
        </div>
        {% endif %}
    </div>
    {% endif %}
</div>
{% else %}
<div class="trash-empty-state">
    <div class="trash-empty-icon">
        <svg viewBox="0 0 24 24"><path d="M3 6h18M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
    </div>
    <h3>Trash is empty</h3>
    <p>No deleted entries found for this collection.</p>
    <a href="{{ admin_url('collections/' ~ collection.getSlug() ~ '/entries') }}" class="btn btn-outline">
        <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;stroke-width:2;fill:none;vertical-align:-2px;margin-right:4px;"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Back to Entries
    </a>
</div>
{% endif %}
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    // Confirm delete
    document.querySelectorAll('.confirm-delete').forEach(function(form) {
        form.addEventListener('submit', function(e) {
            if (!confirm(form.dataset.message || 'Are you sure?')) {
                e.preventDefault();
            }
        });
    });

    // Relative dates
    function timeAgo(dateStr) {
        if (!dateStr) return '';
        var date = new Date(dateStr);
        if (isNaN(date.getTime())) return dateStr;
        var now = new Date();
        var seconds = Math.floor((now - date) / 1000);
        if (seconds < 60) return 'Just now';
        var minutes = Math.floor(seconds / 60);
        if (minutes < 60) return minutes + 'm ago';
        var hours = Math.floor(minutes / 60);
        if (hours < 24) return hours + 'h ago';
        var days = Math.floor(hours / 24);
        if (days < 7) return days + 'd ago';
        var weeks = Math.floor(days / 7);
        if (weeks < 4) return weeks + 'w ago';
        var months = Math.floor(days / 30);
        if (months < 12) return months + 'mo ago';
        return Math.floor(days / 365) + 'y ago';
    }

    document.querySelectorAll('.deleted-time[data-datetime]').forEach(function(el) {
        var dt = el.getAttribute('data-datetime');
        if (dt) {
            var span = el.querySelector('.relative-time');
            if (span) span.textContent = timeAgo(dt);
        }
    });

    // Select all checkboxes
    var selectAll = document.getElementById('select-all');
    var checkboxes = document.querySelectorAll('.entry-checkbox');
    if (selectAll) {
        selectAll.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAll.checked; });
        });
    }
});
</script>
{% endblock %}
