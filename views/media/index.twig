{% extends "@cms/layouts/cms.twig" %}

{% block title %}Media Library{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/media-index.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Media
</div>

<div class="page-header">
    <div>
        <h1>Media Library</h1>
        <span class="ml-header-count">{{ total }} file{{ total != 1 ? 's' : '' }}</span>
    </div>
    <div class="page-actions" style="display:flex; gap:8px;">
        <button class="btn btn-outline" id="newFolderBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/><line x1="12" y1="10" x2="12" y2="16"/><line x1="9" y1="13" x2="15" y2="13"/></svg>
            New Folder
        </button>
        <button class="btn btn-primary" id="uploadBtn">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            Upload Files
        </button>
    </div>
</div>

<div class="ml-layout">
    {# ── Sidebar ── #}
    <aside class="ml-sidebar" id="mlSidebar">
        <div class="ml-sidebar-section">
            <div class="ml-sidebar-heading">Library</div>
            <div class="ml-folder-item {{ currentFolder == '' and currentFilter != 'recent' and currentFilter != 'images' and currentFilter != 'video' and currentFilter != 'documents' and currentFilter != 'audio' ? 'active' : '' }}" data-folder="" data-special="all">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                <span>All Files</span>
                <span class="ml-folder-count">{{ total }}</span>
            </div>
            <div class="ml-folder-item {{ currentFilter == 'recent' ? 'active' : '' }}" data-folder="" data-special="recent">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                <span>Recent</span>
            </div>
            <div class="ml-folder-item {{ currentFilter == 'images' and currentFolder == '' ? 'active' : '' }}" data-folder="" data-special="images">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                <span>Images</span>
            </div>
            <div class="ml-folder-item {{ currentFilter == 'video' and currentFolder == '' ? 'active' : '' }}" data-folder="" data-special="video">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                <span>Video</span>
            </div>
            <div class="ml-folder-item {{ currentFilter == 'documents' and currentFolder == '' ? 'active' : '' }}" data-folder="" data-special="documents">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                <span>Documents</span>
            </div>
        </div>

        {% if folders|length > 0 %}
        <div class="ml-sidebar-section">
            <div class="ml-sidebar-heading">Folders</div>
            {% for folder in folders %}
                {% set folderName = folder|split('/')|last %}
                {% set depth = folder|split('/')|length - 1 %}
                <div class="ml-folder-item {{ currentFolder == folder ? 'active' : '' }}" data-folder="{{ folder }}" style="padding-left:{{ 12 + depth * 16 }}px;">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    <span>{{ folderName }}</span>
                </div>
            {% endfor %}
        </div>
        {% endif %}

        {% if allTags|length > 0 %}
        <div class="ml-sidebar-section">
            <div class="ml-sidebar-heading">Tags</div>
            <div class="ml-sidebar-tags">
                {% for tag in allTags %}
                    <a href="{{ admin_url('media?tag=' ~ tag ~ (currentFolder ? '&folder=' ~ currentFolder : '') ~ (currentFilter != 'all' ? '&filter=' ~ currentFilter : '')) }}"
                       class="ml-sidebar-tag {{ activeTag == tag ? 'active' : '' }}">{{ tag }}</a>
                {% endfor %}
                {% if activeTag %}
                    <a href="{{ admin_url('media' ~ (currentFolder ? '?folder=' ~ currentFolder : '') ~ (currentFilter != 'all' ? (currentFolder ? '&' : '?') ~ 'filter=' ~ currentFilter : '')) }}"
                       class="ml-sidebar-tag ml-tag-clear">Clear filter</a>
                {% endif %}
            </div>
        </div>
        {% endif %}
    </aside>

    {# ── Main Content ── #}
    <div class="ml-main">
        {# Toolbar #}
        <div class="ml-toolbar">
            <div class="ml-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="mlSearch" placeholder="Search files..." value="{{ search }}">
            </div>
            <div class="ml-toolbar-actions">
                <select id="mlFilterSelect" class="ml-filter-select">
                    <option value="all" {{ currentFilter == 'all' ? 'selected' : '' }}>All Types</option>
                    <option value="images" {{ currentFilter == 'images' ? 'selected' : '' }}>Images</option>
                    <option value="documents" {{ currentFilter == 'documents' ? 'selected' : '' }}>Documents</option>
                    <option value="video" {{ currentFilter == 'video' ? 'selected' : '' }}>Video</option>
                    <option value="audio" {{ currentFilter == 'audio' ? 'selected' : '' }}>Audio</option>
                </select>
                <div class="ml-view-toggle">
                    <button class="ml-view-btn active" data-view="grid" title="Grid view">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                    </button>
                    <button class="ml-view-btn" data-view="list" title="List view">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/><line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/><line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/></svg>
                    </button>
                </div>
            </div>
        </div>

        {# Active filters indicator #}
        {% if activeTag or currentFolder or search %}
        <div class="ml-active-filters">
            {% if currentFolder %}
                <span class="ml-active-filter">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    {{ currentFolder }}
                </span>
            {% endif %}
            {% if activeTag %}
                <span class="ml-active-filter">
                    Tag: {{ activeTag }}
                    <a href="{{ admin_url('media' ~ (currentFolder ? '?folder=' ~ currentFolder : '')) }}" class="ml-filter-remove">&times;</a>
                </span>
            {% endif %}
            {% if search %}
                <span class="ml-active-filter">
                    Search: "{{ search }}"
                </span>
            {% endif %}
        </div>
        {% endif %}

        <div class="ml-content-scroll">
            {# Drop Zone #}
            <div class="ml-dropzone" id="mlDropzone">
                <div class="ml-dropzone-inner">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                    <p>Drop files here to upload</p>
                    <span id="dropFolderHint">Uploading to: <strong>{{ currentFolder ? currentFolder : 'Root' }}</strong></span>
                </div>
            </div>

            {# Bulk Action Bar #}
            <div class="ml-bulk-bar" id="mlBulkBar" style="display:none;">
                <label class="ml-bulk-check"><input type="checkbox" id="mlSelectAll"> Select all</label>
                <span id="mlSelectedCount">0 selected</span>
                <div class="ml-bulk-actions">
                    <select id="mlBulkMoveFolder" class="ml-bulk-move-select">
                        <option value="">Move to...</option>
                        <option value="__root__">Root (uploads/)</option>
                        {% for folder in folders %}
                        <option value="{{ folder }}">{{ folder }}</option>
                        {% endfor %}
                    </select>
                    <button class="btn btn-sm btn-outline" id="mlBulkMove" disabled>Move</button>
                    <button class="btn btn-sm btn-danger" id="mlBulkDelete">Delete</button>
                </div>
            </div>

            {# File Grid #}
            {% if media|length > 0 %}
            <div class="ml-grid" id="mlGrid">
                {% for item in media %}
                <div class="ml-file-card" data-id="{{ item.getId() }}">
                    <div class="ml-file-select" onclick="event.stopPropagation();">
                        <input type="checkbox" class="ml-file-checkbox" data-id="{{ item.getId() }}">
                    </div>
                    <a href="javascript:void(0)" class="ml-file-link" data-detail-id="{{ item.getId() }}">
                        <div class="ml-file-thumb">
                            {% if item.isImage() %}
                                <img src="{{ item.getThumbnailUrl() ?: item.getUrl() }}" alt="{{ item.getOriginalName() }}" loading="lazy">
                            {% else %}
                                <div class="ml-file-icon">
                                    {% set ext = item.getOriginalName()|split('.')|last|lower %}
                                    {% if ext in ['pdf'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <span class="ml-file-ext" style="color:#dc3545">PDF</span>
                                    {% elseif ext in ['doc','docx'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2b579a" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <span class="ml-file-ext" style="color:#2b579a">DOC</span>
                                    {% elseif ext in ['xls','xlsx'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#217346" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <span class="ml-file-ext" style="color:#217346">XLS</span>
                                    {% elseif ext in ['mp4','webm','mov','avi'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6f42c1" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                        <span class="ml-file-ext" style="color:#6f42c1">{{ ext|upper }}</span>
                                    {% elseif ext in ['mp3','wav','ogg','flac'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#e83e8c" stroke-width="1.5"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
                                        <span class="ml-file-ext" style="color:#e83e8c">{{ ext|upper }}</span>
                                    {% elseif ext in ['zip','rar','7z','tar','gz'] %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#fd7e14" stroke-width="1.5"><path d="M21 8v13H3V8"/><path d="M1 3h22v5H1z"/><path d="M10 12h4"/></svg>
                                        <span class="ml-file-ext" style="color:#fd7e14">{{ ext|upper }}</span>
                                    {% else %}
                                        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#6c757d" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <span class="ml-file-ext">{{ ext|upper }}</span>
                                    {% endif %}
                                </div>
                            {% endif %}
                        </div>
                        <div class="ml-file-info">
                            <span class="ml-file-name" title="{{ item.getOriginalName() }}">{{ item.getOriginalName() }}</span>
                            <span class="ml-file-meta">{{ item.getHumanSize() }}</span>
                            {% if item.getTags()|length > 0 %}
                            <div class="ml-file-tags">
                                {% for tag in item.getTags()|slice(0, 2) %}
                                <span class="ml-file-tag">{{ tag }}</span>
                                {% endfor %}
                                {% if item.getTags()|length > 2 %}
                                <span class="ml-file-tag">+{{ item.getTags()|length - 2 }}</span>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                    </a>
                    <div class="ml-file-hover-actions">
                        <button class="ml-hover-btn" data-detail-id="{{ item.getId() }}" title="View details">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                </div>
                {% endfor %}
            </div>

            {# Pagination #}
            {% if lastPage > 1 %}
            {% set _pq = '' %}
            {% if currentFolder %}{% set _pq = _pq ~ '&folder=' ~ currentFolder %}{% endif %}
            {% if currentFilter != 'all' %}{% set _pq = _pq ~ '&filter=' ~ currentFilter %}{% endif %}
            {% if search %}{% set _pq = _pq ~ '&search=' ~ search %}{% endif %}
            {% if activeTag %}{% set _pq = _pq ~ '&tag=' ~ activeTag %}{% endif %}
            <div class="ml-pagination">
                {% if currentPage > 1 %}
                    <a href="{{ admin_url('media?page=' ~ (currentPage - 1) ~ _pq) }}" class="ml-page-btn">&laquo; Prev</a>
                {% endif %}

                {% for p in range(max(1, currentPage - 2), min(lastPage, currentPage + 2)) %}
                    {% if p == currentPage %}
                        <span class="ml-page-btn ml-page-current">{{ p }}</span>
                    {% else %}
                        <a href="{{ admin_url('media?page=' ~ p ~ _pq) }}" class="ml-page-btn">{{ p }}</a>
                    {% endif %}
                {% endfor %}

                {% if currentPage < lastPage %}
                    <a href="{{ admin_url('media?page=' ~ (currentPage + 1) ~ _pq) }}" class="ml-page-btn">Next &raquo;</a>
                {% endif %}
                <span class="ml-page-info">{{ currentPage }} of {{ lastPage }}</span>
            </div>
            {% endif %}

            {% else %}
            <div class="ml-empty" id="mlEmpty">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--border-color,#ddd)" stroke-width="1"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <h3>No media files{% if currentFolder %} in "{{ currentFolder }}"{% endif %}</h3>
                <p>Drag and drop files here or click the Upload button to get started.</p>
            </div>
            {% endif %}
        </div>{# /ml-content-scroll #}
    </div>
</div>

{# ── Upload Modal ── #}
<div class="ml-modal-overlay" id="uploadModal" style="display:none">
    <div class="ml-modal ml-modal-md">
        <div class="ml-modal-header">
            <h3>Upload Files</h3>
            <button class="ml-modal-close" data-close="uploadModal">&times;</button>
        </div>
        <div class="ml-modal-body">
            <div class="ml-upload-folder-row">
                <label>Upload to:</label>
                <select id="uploadFolderSelect" class="ml-upload-folder-select">
                    <option value="">Root (uploads/)</option>
                    {% for folder in folders %}
                    <option value="{{ folder }}" {{ currentFolder == folder ? 'selected' : '' }}>{{ folder }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="ml-upload-zone" id="uploadZone">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <p>Drop files here or click to browse</p>
                <span>Images, documents, video, audio (max 10MB)</span>
            </div>
        </div>
    </div>
</div>

{# ── Media Detail Modal ── #}
<div class="ml-modal-overlay" id="mediaDetailModal" style="display:none">
    <div class="ml-modal ml-modal-lg ml-detail-modal">
        <div class="ml-modal-header">
            <h3 id="mdModalTitle">File Details</h3>
            <button class="ml-modal-close" data-close="mediaDetailModal">&times;</button>
        </div>
        <div class="ml-modal-body" id="mdModalBody" style="padding:0;">
            <div class="ml-detail-loading">Loading...</div>
        </div>
    </div>
</div>

{# ── New Folder Modal ── #}
<div class="ml-modal-overlay" id="folderModal" style="display:none">
    <div class="ml-modal">
        <div class="ml-modal-header">
            <h3>New Folder</h3>
            <button class="ml-modal-close" data-close="folderModal">&times;</button>
        </div>
        <div class="ml-modal-body">
            <form method="POST" action="{{ admin_url('media/folders/create') }}" id="newFolderForm">
                {{ csrf_field() | raw }}
                <input type="hidden" name="parent_folder" value="{{ currentFolder }}">
                <div class="form-group">
                    <label class="ml-form-label">Folder Name</label>
                    <input type="text" name="folder_name" class="form-control" placeholder="e.g. products, banners" pattern="[a-zA-Z0-9_\-]+" required>
                    <small class="ml-form-hint">Letters, numbers, hyphens, underscores only.</small>
                </div>
                {% if currentFolder %}
                <p class="ml-form-hint" style="margin-top:8px;">Will be created inside: <strong>{{ currentFolder }}</strong></p>
                {% endif %}
                <div class="ml-modal-actions">
                    <button type="button" class="btn btn-outline" data-close="folderModal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Folder</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Upload Progress Float ── #}
<div class="ml-upload-float" id="uploadFloat" style="display:none">
    <div class="ml-upload-float-header">
        <span id="uploadFloatTitle">Uploading...</span>
        <button class="ml-upload-float-close" id="uploadFloatClose">&times;</button>
    </div>
    <div class="ml-upload-float-body" id="uploadFloatBody"></div>
</div>
{% endblock %}

{% block styles %}
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var csrf = document.querySelector('meta[name="csrf-token"]')?.content || '{{ csrf_token() }}';
    var currentFolder = '{{ currentFolder }}';
    var activeTag = '{{ activeTag }}';

    // ── Sidebar Navigation ──
    document.querySelectorAll('.ml-folder-item').forEach(function(el) {
        el.addEventListener('click', function() {
            var folder = this.dataset.folder;
            var special = this.dataset.special || '';
            var url = '{{ admin_url("media") }}';
            if (special === 'recent') url += '?filter=recent';
            else if (special === 'images') url += '?filter=images';
            else if (special === 'video') url += '?filter=video';
            else if (special === 'documents') url += '?filter=documents';
            else if (folder) url += '?folder=' + encodeURIComponent(folder);
            window.location.href = url;
        });
    });

    // ── Filter Dropdown ──
    document.getElementById('mlFilterSelect').addEventListener('change', function() {
        var filter = this.value;
        var url = '{{ admin_url("media") }}?filter=' + filter;
        if (currentFolder) url += '&folder=' + encodeURIComponent(currentFolder);
        window.location.href = url;
    });

    // ── View Toggle ──
    var gridEl = document.getElementById('mlGrid');
    document.querySelectorAll('.ml-view-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.ml-view-btn').forEach(function(b) { b.classList.remove('active'); });
            this.classList.add('active');
            if (gridEl) {
                if (this.dataset.view === 'list') {
                    gridEl.classList.add('list-view');
                } else {
                    gridEl.classList.remove('list-view');
                }
            }
            try { localStorage.setItem('ml-view', this.dataset.view); } catch(e) {}
        });
    });
    // Restore saved view preference
    try {
        var savedView = localStorage.getItem('ml-view');
        if (savedView === 'list' && gridEl) {
            gridEl.classList.add('list-view');
            document.querySelectorAll('.ml-view-btn').forEach(function(b) {
                b.classList.toggle('active', b.dataset.view === 'list');
            });
        }
    } catch(e) {}

    // ── Search with Debounce ──
    var searchTimer;
    document.getElementById('mlSearch').addEventListener('input', function() {
        var val = this.value;
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function() {
            var url = '{{ admin_url("media") }}?search=' + encodeURIComponent(val);
            if (currentFolder) url += '&folder=' + encodeURIComponent(currentFolder);
            window.location.href = url;
        }, 500);
    });

    // ── Modal Helpers ──
    function openModal(id) { document.getElementById(id).style.display = 'flex'; }
    function closeModal(id) { document.getElementById(id).style.display = 'none'; }

    document.querySelectorAll('[data-close]').forEach(function(btn) {
        btn.addEventListener('click', function() { closeModal(this.dataset.close); });
    });
    document.querySelectorAll('.ml-modal-overlay').forEach(function(overlay) {
        overlay.addEventListener('click', function(e) {
            if (e.target === overlay) overlay.style.display = 'none';
        });
    });

    // ── New Folder Modal ──
    document.getElementById('newFolderBtn').addEventListener('click', function() {
        openModal('folderModal');
    });

    // ── Upload Modal ──
    var fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.multiple = true;
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);

    document.getElementById('uploadBtn').addEventListener('click', function() {
        openModal('uploadModal');
    });

    var uploadZone = document.getElementById('uploadZone');
    uploadZone.addEventListener('click', function() { fileInput.click(); });
    uploadZone.addEventListener('dragover', function(e) { e.preventDefault(); this.classList.add('drag-over'); });
    uploadZone.addEventListener('dragleave', function(e) { e.preventDefault(); this.classList.remove('drag-over'); });
    uploadZone.addEventListener('drop', function(e) {
        e.preventDefault();
        this.classList.remove('drag-over');
        if (e.dataTransfer.files.length > 0) {
            uploadFiles(e.dataTransfer.files);
        }
    });

    fileInput.addEventListener('change', function() {
        if (this.files.length > 0) uploadFiles(this.files);
        this.value = '';
    });

    // ── Drag & Drop on main content area ──
    var mlMain = document.querySelector('.ml-main');
    var mlScroll = document.querySelector('.ml-content-scroll');
    var dragCounter = 0;
    mlScroll.addEventListener('dragenter', function(e) {
        e.preventDefault();
        dragCounter++;
        mlMain.classList.add('drag-over');
    });
    mlScroll.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dragCounter--;
        if (dragCounter <= 0) { mlMain.classList.remove('drag-over'); dragCounter = 0; }
    });
    mlScroll.addEventListener('dragover', function(e) { e.preventDefault(); });
    mlScroll.addEventListener('drop', function(e) {
        e.preventDefault();
        mlMain.classList.remove('drag-over');
        dragCounter = 0;
        if (e.dataTransfer.files.length > 0) uploadFiles(e.dataTransfer.files);
    });

    // ── Upload Files with Progress ──
    function uploadFiles(files) {
        var uploadFolder = document.getElementById('uploadFolderSelect')?.value || currentFolder;
        var floatEl = document.getElementById('uploadFloat');
        var body = document.getElementById('uploadFloatBody');
        var title = document.getElementById('uploadFloatTitle');
        floatEl.style.display = '';
        title.textContent = 'Uploading ' + files.length + ' file' + (files.length > 1 ? 's' : '') + '...';
        body.innerHTML = '';

        // Close upload modal if open
        closeModal('uploadModal');

        var completed = 0;
        var total = files.length;

        Array.from(files).forEach(function(file, idx) {
            var itemEl = document.createElement('div');
            itemEl.className = 'ml-upload-item';
            itemEl.innerHTML = '<span class="ml-upload-item-name">' + file.name + '</span>' +
                '<span class="ml-upload-item-status uploading" id="upload-status-' + idx + '">0%</span>';
            var progressWrap = document.createElement('div');
            progressWrap.className = 'ml-upload-progress';
            progressWrap.innerHTML = '<div class="ml-upload-progress-bar" id="upload-bar-' + idx + '" style="width:0%"></div>';

            var wrapper = document.createElement('div');
            wrapper.style.padding = '0 14px 8px';
            wrapper.appendChild(progressWrap);

            body.appendChild(itemEl);
            body.appendChild(wrapper);

            var formData = new FormData();
            formData.append('file', file);
            formData.append('folder', uploadFolder);

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '{{ admin_url("media/upload") }}');
            xhr.setRequestHeader('X-CSRF-TOKEN', csrf);
            xhr.setRequestHeader('X-Requested-With', 'XMLHttpRequest');

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    var pct = Math.round((e.loaded / e.total) * 100);
                    document.getElementById('upload-bar-' + idx).style.width = pct + '%';
                    document.getElementById('upload-status-' + idx).textContent = pct + '%';
                }
            });

            xhr.addEventListener('load', function() {
                completed++;
                var statusEl = document.getElementById('upload-status-' + idx);
                if (xhr.status >= 200 && xhr.status < 300) {
                    statusEl.textContent = 'Done';
                    statusEl.className = 'ml-upload-item-status done';
                } else {
                    var err = 'Error';
                    try { err = JSON.parse(xhr.responseText).error || 'Error'; } catch(e) {}
                    statusEl.textContent = err;
                    statusEl.className = 'ml-upload-item-status error';
                }
                if (completed === total) {
                    title.textContent = completed + ' file' + (completed > 1 ? 's' : '') + ' uploaded';
                    setTimeout(function() { window.location.reload(); }, 1000);
                }
            });

            xhr.addEventListener('error', function() {
                completed++;
                var statusEl = document.getElementById('upload-status-' + idx);
                statusEl.textContent = 'Failed';
                statusEl.className = 'ml-upload-item-status error';
                if (completed === total) title.textContent = 'Upload complete';
            });

            xhr.send(formData);
        });
    }

    // ── Detail Modal ──
    function openDetail(id) {
        var modal = document.getElementById('mediaDetailModal');
        var body = document.getElementById('mdModalBody');
        body.innerHTML = '<div class="ml-detail-loading">Loading...</div>';
        openModal('mediaDetailModal');

        fetch('{{ admin_url("media") }}/' + id, {
            headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-TOKEN': csrf }
        })
        .then(function(r) { return r.json(); })
        .then(function(d) {
            document.getElementById('mdModalTitle').textContent = d.original_name;

            var preview = '';
            if (d.is_image) {
                preview = '<img src="' + d.url + '" alt="' + (d.alt_text || d.original_name).replace(/"/g, '&quot;') + '">';
            } else {
                preview = '<div style="font-size:56px;color:#bbb;">&#128196;</div><p style="color:#888;margin-top:8px;font-size:13px;">' + d.mime_type + '</p>';
            }

            var dims = '';
            if (d.dimensions) {
                dims = '<div class="md-meta-item"><strong>Dimensions</strong>' + d.dimensions.width + ' &times; ' + d.dimensions.height + 'px</div>';
            }

            var fullUrl = window.location.origin + d.url;
            var tagChips = '';
            if (d.tags && d.tags.length > 0) {
                tagChips = '<div class="md-tag-chips">' + d.tags.map(function(t) {
                    return '<span class="md-tag-chip">' + t + '</span>';
                }).join('') + '</div>';
            }

            body.innerHTML =
                '<div class="md-layout">' +
                    '<div class="md-preview">' + preview + '</div>' +
                    '<div class="md-sidebar">' +
                        '<div class="md-sidebar-body">' +
                            '<div class="md-info-row">' +
                                '<div class="md-info-label">Display Name</div>' +
                                '<input type="text" id="mdDisplayName" class="md-form-input" value="' + (d.original_name || '').replace(/"/g, '&quot;') + '">' +
                            '</div>' +
                            '<div class="md-info-row">' +
                                '<div class="md-info-label">Alt Text</div>' +
                                '<input type="text" id="mdAltText" class="md-form-input" value="' + (d.alt_text || '').replace(/"/g, '&quot;') + '" placeholder="Describe this image for accessibility">' +
                            '</div>' +
                            '<div class="md-info-row">' +
                                '<div class="md-info-label">Tags</div>' +
                                '<input type="text" id="mdTags" class="md-form-input" value="' + (d.tags_string || '').replace(/"/g, '&quot;') + '" placeholder="e.g. hero, banner, product">' +
                                tagChips +
                            '</div>' +
                            '<div class="md-info-meta">' +
                                '<div class="md-meta-item"><strong>Size</strong>' + d.human_size + '</div>' +
                                '<div class="md-meta-item"><strong>Type</strong>' + d.mime_type + '</div>' +
                                dims +
                                '<div class="md-meta-item"><strong>Filename</strong><span style="font-size:11px;word-break:break-all;">' + d.filename + '</span></div>' +
                            '</div>' +
                            '<div class="md-info-row">' +
                                '<div class="md-info-label">URL</div>' +
                                '<div class="md-url-row">' +
                                    '<input type="text" class="md-url-input" value="' + fullUrl + '" readonly id="mdUrlInput">' +
                                    '<button class="md-copy-btn" id="mdCopyUrl">Copy</button>' +
                                '</div>' +
                            '</div>' +
                        '</div>' +
                        '<div class="md-actions">' +
                            '<button class="btn btn-primary btn-sm" id="mdSaveBtn" data-id="' + d.id + '">Save Changes</button>' +
                            '<button class="btn btn-danger btn-sm" id="mdDeleteBtn" data-id="' + d.id + '">Delete</button>' +
                        '</div>' +
                    '</div>' +
                '</div>';

            // Copy URL
            document.getElementById('mdCopyUrl').addEventListener('click', function() {
                var input = document.getElementById('mdUrlInput');
                input.select();
                navigator.clipboard.writeText(input.value).then(function() {
                    document.getElementById('mdCopyUrl').textContent = 'Copied!';
                    setTimeout(function() { document.getElementById('mdCopyUrl').textContent = 'Copy'; }, 1500);
                }).catch(function() {
                    document.execCommand('copy');
                    document.getElementById('mdCopyUrl').textContent = 'Copied!';
                    setTimeout(function() { document.getElementById('mdCopyUrl').textContent = 'Copy'; }, 1500);
                });
            });

            // Save
            document.getElementById('mdSaveBtn').addEventListener('click', function() {
                var btn = this;
                btn.disabled = true;
                btn.textContent = 'Saving...';
                var formData = new FormData();
                formData.append('original_name', document.getElementById('mdDisplayName').value);
                formData.append('alt_text', document.getElementById('mdAltText').value);
                formData.append('tags', document.getElementById('mdTags').value);
                fetch('{{ admin_url("media") }}/' + this.dataset.id + '/update', {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': csrf },
                    body: formData
                }).then(function() {
                    closeModal('mediaDetailModal');
                    window.location.reload();
                }).catch(function() {
                    btn.disabled = false;
                    btn.textContent = 'Save Changes';
                });
            });

            // Delete
            document.getElementById('mdDeleteBtn').addEventListener('click', function() {
                if (!confirm('Permanently delete this file?')) return;
                var formData = new FormData();
                fetch('{{ admin_url("media") }}/' + this.dataset.id + '/delete', {
                    method: 'POST',
                    headers: { 'X-CSRF-TOKEN': csrf },
                    body: formData
                }).then(function() {
                    closeModal('mediaDetailModal');
                    window.location.reload();
                });
            });
        })
        .catch(function() {
            body.innerHTML = '<div style="text-align:center;padding:50px;color:var(--danger,#dc3545);font-size:14px;">Failed to load file details.</div>';
        });
    }

    document.querySelectorAll('[data-detail-id]').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            openDetail(this.dataset.detailId);
        });
    });

    // ── Bulk Selection ──
    var bulkBar = document.getElementById('mlBulkBar');
    var selectAllCb = document.getElementById('mlSelectAll');
    var checkboxes = document.querySelectorAll('.ml-file-checkbox');

    function updateBulkBar() {
        var checked = document.querySelectorAll('.ml-file-checkbox:checked');
        var count = checked.length;
        bulkBar.style.display = count > 0 ? '' : 'none';
        document.getElementById('mlSelectedCount').textContent = count + ' selected';
        checkboxes.forEach(function(cb) {
            cb.closest('.ml-file-card').classList.toggle('selected', cb.checked);
        });
        var moveBtn = document.getElementById('mlBulkMove');
        if (moveBtn) moveBtn.disabled = !document.getElementById('mlBulkMoveFolder').value;
    }

    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateBulkBar);
    });

    if (selectAllCb) {
        selectAllCb.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAllCb.checked; });
            updateBulkBar();
        });
    }

    // Bulk move folder select
    var bulkMoveFolder = document.getElementById('mlBulkMoveFolder');
    var bulkMoveBtn = document.getElementById('mlBulkMove');
    if (bulkMoveFolder) {
        bulkMoveFolder.addEventListener('change', function() {
            bulkMoveBtn.disabled = !this.value;
        });
    }

    // Bulk move
    if (bulkMoveBtn) {
        bulkMoveBtn.addEventListener('click', function() {
            var ids = [];
            document.querySelectorAll('.ml-file-checkbox:checked').forEach(function(cb) {
                ids.push(cb.dataset.id);
            });
            if (ids.length === 0) return;
            var targetFolder = bulkMoveFolder.value;
            if (targetFolder === '__root__') targetFolder = '';
            if (!confirm('Move ' + ids.length + ' file(s) to ' + (targetFolder || 'root') + '?')) return;

            fetch('{{ admin_url("media/bulk") }}', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
                body: JSON.stringify({ action: 'move', ids: ids, target_folder: targetFolder })
            }).then(function(r) { return r.json(); }).then(function(data) {
                if (data.success) window.location.reload();
                else alert(data.error || 'Failed to move files.');
            });
        });
    }

    // Bulk delete
    document.getElementById('mlBulkDelete')?.addEventListener('click', function() {
        var ids = [];
        document.querySelectorAll('.ml-file-checkbox:checked').forEach(function(cb) {
            ids.push(cb.dataset.id);
        });
        if (ids.length === 0) return;
        if (!confirm('Delete ' + ids.length + ' file(s)? This cannot be undone.')) return;

        fetch('{{ admin_url("media/bulk") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
            body: JSON.stringify({ action: 'delete', ids: ids })
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) window.location.reload();
            else alert(data.error || 'Failed to delete.');
        });
    });

    // ── Close Upload Float ──
    document.getElementById('uploadFloatClose').addEventListener('click', function() {
        document.getElementById('uploadFloat').style.display = 'none';
    });

    // ── Escape closes modals ──
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeModal('folderModal');
            closeModal('uploadModal');
            closeModal('mediaDetailModal');
        }
    });
})();
</script>
{% endblock %}
