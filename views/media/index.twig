{% extends "@cms/layouts/cms.twig" %}

{% block title %}Media Library{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> / Media
</div>

<div class="page-header">
    <h1>Media Library</h1>
    <div class="page-actions" style="display:flex; gap:8px;">
        <button class="btn btn-outline" id="newFolderBtn">+ Folder</button>
        <button class="btn btn-primary" id="uploadBtn">+ Upload Files</button>
    </div>
</div>

<div class="ml-layout">
    {# ── Sidebar: Folder Tree ── #}
    <aside class="ml-sidebar" id="mlSidebar">
        <div class="ml-sidebar-header">
            <span class="ml-sidebar-title">Folders</span>
        </div>
        <div class="ml-sidebar-body">
            <div class="ml-folder-item {{ currentFolder == '' and currentFilter != 'recent' ? 'active' : '' }}" data-folder="" data-special="all">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                All Files
            </div>
            <div class="ml-folder-item {{ currentFilter == 'recent' ? 'active' : '' }}" data-folder="" data-special="recent">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                Recent
            </div>
            <div class="ml-folder-item {{ currentFilter == 'images' and currentFolder == '' ? 'active' : '' }}" data-folder="" data-special="images">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                Images
            </div>
            <div class="ml-sidebar-sep"></div>
            {% for folder in folders %}
                {% set folderName = folder|split('/')|last %}
                {% set depth = folder|split('/')|length - 1 %}
                <div class="ml-folder-item {{ currentFolder == folder ? 'active' : '' }}" data-folder="{{ folder }}" style="padding-left:{{ 12 + depth * 16 }}px;">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
                    {{ folderName }}
                </div>
            {% endfor %}
        </div>
    </aside>

    {# ── Main Content ── #}
    <div class="ml-main">
        {# Toolbar #}
        <div class="ml-toolbar">
            <div class="ml-search">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                <input type="text" id="mlSearch" placeholder="Search files..." value="{{ search }}">
            </div>
            <div class="ml-filters">
                <button class="ml-filter-btn {{ currentFilter == 'all' ? 'active' : '' }}" data-filter="all">All</button>
                <button class="ml-filter-btn {{ currentFilter == 'images' ? 'active' : '' }}" data-filter="images">Images</button>
                <button class="ml-filter-btn {{ currentFilter == 'documents' ? 'active' : '' }}" data-filter="documents">Docs</button>
                <button class="ml-filter-btn {{ currentFilter == 'video' ? 'active' : '' }}" data-filter="video">Video</button>
            </div>
            <span class="ml-count">{{ total }} file{{ total != 1 ? 's' : '' }}</span>
        </div>

        <div class="ml-content-scroll">
        {# Drop Zone #}
        <div class="ml-dropzone" id="mlDropzone">
            <div class="ml-dropzone-inner">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                <p>Drop files here to upload</p>
                <span id="dropFolderHint">Uploading to: <strong>{{ currentFolder ? currentFolder : 'Root' }}</strong></span>
            </div>
        </div>

        {# Bulk Action Bar (hidden until selection) #}
        <div class="ml-bulk-bar" id="mlBulkBar" style="display:none;">
            <label class="ml-bulk-check"><input type="checkbox" id="mlSelectAll"> Select all</label>
            <span id="mlSelectedCount">0 selected</span>
            <button class="btn btn-danger btn-sm" id="mlBulkDelete">Delete Selected</button>
        </div>

        {# File Grid #}
        {% if media|length > 0 %}
        <div class="ml-grid" id="mlGrid">
            {% for item in media %}
            <div class="ml-file-card" data-id="{{ item.getId() }}">
                <div class="ml-file-select" onclick="event.stopPropagation();">
                    <input type="checkbox" class="ml-file-checkbox" data-id="{{ item.getId() }}">
                </div>
                <a href="javascript:void(0)" class="ml-file-link" data-detail-id="{{ item.getId() }}">
                <div class="ml-file-thumb">
                    {% if item.isImage() %}
                        <img src="{{ item.getThumbnailUrl() ?: item.getUrl() }}" alt="{{ item.getOriginalName() }}" loading="lazy">
                    {% else %}
                        <div class="ml-file-icon">
                            {% set ext = item.getOriginalName()|split('.')|last|lower %}
                            {% if ext in ['pdf'] %}
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#dc3545" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span style="color:#dc3545">PDF</span>
                            {% elseif ext in ['doc','docx'] %}
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#2b579a" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span style="color:#2b579a">DOC</span>
                            {% elseif ext in ['mp4','webm','mov'] %}
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6f42c1" stroke-width="1.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                                <span style="color:#6f42c1">{{ ext|upper }}</span>
                            {% else %}
                                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#666" stroke-width="1.5"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                                <span>{{ ext|upper }}</span>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
                <div class="ml-file-info">
                    <span class="ml-file-name" title="{{ item.getOriginalName() }}">{{ item.getOriginalName() }}</span>
                    <span class="ml-file-meta">{{ item.getHumanSize() }}</span>
                </div>
                </a>
            </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if lastPage > 1 %}
        {% set _pq = '' %}
        {% if currentFolder %}{% set _pq = _pq ~ '&folder=' ~ currentFolder %}{% endif %}
        {% if currentFilter != 'all' %}{% set _pq = _pq ~ '&filter=' ~ currentFilter %}{% endif %}
        {% if search %}{% set _pq = _pq ~ '&search=' ~ search %}{% endif %}
        <div class="ml-pagination">
            {% if currentPage > 1 %}
                <a href="{{ admin_url('media?page=' ~ (currentPage - 1) ~ _pq) }}" class="ml-page-btn">&laquo; Prev</a>
            {% endif %}
            <span class="ml-page-info">Page {{ currentPage }} of {{ lastPage }}</span>
            {% if currentPage < lastPage %}
                <a href="{{ admin_url('media?page=' ~ (currentPage + 1) ~ _pq) }}" class="ml-page-btn">Next &raquo;</a>
            {% endif %}
        </div>
        {% endif %}

        {% else %}
        <div class="ml-empty" id="mlEmpty">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1.5"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
            <h3>No media files{% if currentFolder %} in this folder{% endif %}</h3>
            <p>Drag & drop files here or click upload.</p>
        </div>
        {% endif %}
        </div>{# /ml-content-scroll #}
    </div>
</div>

{# ── Media Detail Modal ── #}
<div class="ml-modal-overlay" id="mediaDetailModal" style="display:none">
    <div class="ml-modal" style="max-width:700px;">
        <div class="ml-modal-header">
            <h3 id="mdModalTitle">File Details</h3>
            <button class="ml-modal-close" data-close="mediaDetailModal">&times;</button>
        </div>
        <div class="ml-modal-body" id="mdModalBody" style="padding:0;">
            <div style="text-align:center;padding:40px;color:var(--text-secondary);">Loading...</div>
        </div>
    </div>
</div>

{# ── New Folder Modal ── #}
<div class="ml-modal-overlay" id="folderModal" style="display:none">
    <div class="ml-modal">
        <div class="ml-modal-header">
            <h3>New Folder</h3>
            <button class="ml-modal-close" data-close="folderModal">&times;</button>
        </div>
        <div class="ml-modal-body">
            <form method="POST" action="{{ admin_url('media/folders/create') }}" id="newFolderForm">
                {{ csrf_field() | raw }}
                <input type="hidden" name="parent_folder" value="{{ currentFolder }}">
                <div style="margin-bottom:12px;">
                    <label style="font-size:12px;font-weight:600;display:block;margin-bottom:4px;">Folder Name</label>
                    <input type="text" name="folder_name" class="form-control" placeholder="e.g. products, banners" pattern="[a-zA-Z0-9_\-]+" required>
                    <small style="color:var(--text-secondary)">Letters, numbers, hyphens, underscores only.</small>
                </div>
                {% if currentFolder %}
                <p style="font-size:12px;color:var(--text-secondary)">Will be created inside: <strong>{{ currentFolder }}</strong></p>
                {% endif %}
                <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:16px;">
                    <button type="button" class="btn btn-outline" data-close="folderModal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create</button>
                </div>
            </form>
        </div>
    </div>
</div>

{# ── Upload Progress Float (bottom-right) ── #}
<div class="ml-upload-float" id="uploadFloat" style="display:none">
    <div class="ml-upload-float-header">
        <span id="uploadFloatTitle">Uploading...</span>
        <button class="ml-upload-float-close" id="uploadFloatClose">&times;</button>
    </div>
    <div class="ml-upload-float-body" id="uploadFloatBody"></div>
</div>
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
/* ── Layout ── */
.ml-layout { display:flex; gap:0; height:calc(100vh - 180px); min-height:400px; }
.ml-sidebar { width:220px; flex-shrink:0; background:var(--bg-surface,#fff); border:1px solid var(--border-color,#e5e5e5); border-radius:8px; overflow:hidden; display:flex; flex-direction:column; }
.ml-sidebar-header { padding:10px 14px; font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.04em; color:var(--text-secondary); border-bottom:1px solid var(--border-color); flex-shrink:0; }
.ml-sidebar-body { flex:1; overflow-y:auto; padding:4px 0; }
.ml-sidebar-sep { height:1px; background:var(--border-color,#e5e5e5); margin:4px 0; }
.ml-folder-item { display:flex; align-items:center; gap:8px; padding:7px 14px; font-size:13px; cursor:pointer; color:var(--text-primary); transition:background 0.1s; border-radius:0; }
.ml-folder-item:hover { background:var(--bg-subdued,#f7f7f7); }
.ml-folder-item.active { background:var(--color-primary,#047B5D); color:#fff; }
.ml-folder-item.active svg { stroke:#fff; }
.ml-main { flex:1; min-width:0; margin-left:16px; display:flex; flex-direction:column; background:var(--bg-surface,#fff); border:1px solid var(--border-color,#e5e5e5); border-radius:8px; overflow:hidden; }

/* ── Toolbar ── */
.ml-toolbar { display:flex; align-items:center; gap:12px; padding:12px 16px; border-bottom:1px solid var(--border-color); flex-wrap:wrap; flex-shrink:0; }
.ml-search { display:flex; align-items:center; gap:6px; padding:5px 10px; border:1px solid var(--border-color); border-radius:6px; background:var(--bg-subdued,#fafafa); flex:1; min-width:160px; max-width:280px; }
.ml-search input { border:none; outline:none; font-size:13px; width:100%; background:transparent; }
.ml-filters { display:flex; gap:4px; }
.ml-filter-btn { padding:4px 10px; border:1px solid var(--border-color); border-radius:5px; background:var(--bg-surface); font-size:12px; cursor:pointer; color:var(--text-primary); transition:all 0.1s; }
.ml-filter-btn:hover { border-color:var(--color-primary); }
.ml-filter-btn.active { background:var(--color-primary); color:#fff; border-color:var(--color-primary); }
.ml-count { font-size:12px; color:var(--text-secondary); margin-left:auto; }
.ml-content-scroll { flex:1; overflow-y:auto; padding:16px; }

/* ── Bulk Bar ── */
.ml-bulk-bar { display:flex; align-items:center; gap:12px; padding:8px 14px; background:var(--bg-surface); border:1px solid var(--color-primary); border-radius:6px; margin-bottom:12px; }
.ml-bulk-check { display:flex; align-items:center; gap:6px; font-size:13px; cursor:pointer; }
#mlSelectedCount { font-size:12px; color:var(--text-secondary); }

/* ── File Selection ── */
.ml-file-select { position:absolute; top:6px; left:6px; z-index:3; opacity:0; transition:opacity 0.15s; }
.ml-file-card:hover .ml-file-select, .ml-file-card.selected .ml-file-select { opacity:1; }
.ml-file-card.selected { border-color:var(--color-primary); box-shadow:0 0 0 2px rgba(4,123,93,0.2); }
.ml-file-checkbox { width:16px; height:16px; cursor:pointer; }
.ml-file-link { display:block; text-decoration:none; color:inherit; }

/* ── Grid ── */
.ml-grid { display:grid; grid-template-columns:repeat(auto-fill, minmax(160px, 1fr)); gap:12px; }
.ml-file-card { position:relative; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:8px; overflow:hidden; transition:box-shadow 0.15s, border-color 0.15s; }
.ml-file-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.08); border-color:var(--color-primary,#047B5D); }
.ml-file-thumb { aspect-ratio:1; background:#f4f4f5; display:flex; align-items:center; justify-content:center; overflow:hidden; }
.ml-file-thumb img { width:100%; height:100%; object-fit:cover; }
.ml-file-icon { display:flex; flex-direction:column; align-items:center; gap:4px; }
.ml-file-icon span { font-size:10px; font-weight:700; text-transform:uppercase; }
.ml-file-info { padding:8px 10px; }
.ml-file-name { display:block; font-size:12px; font-weight:500; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; color:var(--text-primary); }
.ml-file-meta { font-size:11px; color:var(--text-secondary); }

/* ── Pagination ── */
.ml-pagination { display:flex; align-items:center; justify-content:center; gap:12px; margin-top:20px; }
.ml-page-btn { padding:6px 14px; border:1px solid var(--border-color); border-radius:6px; text-decoration:none; font-size:13px; color:var(--text-primary); background:var(--bg-surface); }
.ml-page-btn:hover { border-color:var(--color-primary); }
.ml-page-info { font-size:13px; color:var(--text-secondary); }

/* ── Empty ── */
.ml-empty { text-align:center; padding:60px 20px; color:var(--text-secondary); }
.ml-empty h3 { margin:12px 0 4px; font-size:16px; color:var(--text-primary); }
.ml-empty p { font-size:13px; }

/* ── Drop Zone ── */
.ml-content-scroll { position:relative; }
.ml-dropzone { display:none; position:absolute; inset:0; z-index:50; background:rgba(4,123,93,0.06); border:3px dashed var(--color-primary,#047B5D); border-radius:0; }
.ml-dropzone-inner { position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:8px; color:var(--color-primary); }
.ml-dropzone-inner p { font-size:16px; font-weight:600; margin:0; }
.ml-dropzone-inner span { font-size:12px; color:var(--text-secondary); }
.ml-main.drag-over .ml-dropzone { display:block; }

/* ── Modal ── */
.ml-modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.5); z-index:1000; display:flex; align-items:center; justify-content:center; }
.ml-modal { background:var(--bg-surface); border-radius:10px; width:100%; max-width:400px; box-shadow:0 8px 30px rgba(0,0,0,0.2); }
.ml-modal-header { display:flex; align-items:center; justify-content:space-between; padding:16px 20px; border-bottom:1px solid var(--border-color); }
.ml-modal-header h3 { margin:0; font-size:15px; }
.ml-modal-close { background:none; border:none; font-size:20px; cursor:pointer; color:var(--text-secondary); }
.ml-modal-body { padding:20px; }

/* ── Upload Float ── */
.ml-upload-float { position:fixed; bottom:20px; right:20px; width:360px; max-height:50vh; background:var(--bg-surface); border:1px solid var(--border-color); border-radius:10px; box-shadow:0 8px 30px rgba(0,0,0,0.15); z-index:999; overflow:hidden; display:flex; flex-direction:column; }
.ml-upload-float-header { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:#f8f8f8; border-bottom:1px solid var(--border-color); font-size:13px; font-weight:600; flex-shrink:0; }
.ml-upload-float-close { background:none; border:none; font-size:18px; cursor:pointer; color:var(--text-secondary); }
.ml-upload-float-body { flex:1; overflow-y:auto; }
.ml-upload-item { display:flex; align-items:center; gap:10px; padding:8px 14px; border-bottom:1px solid #f0f0f0; font-size:12px; }
.ml-upload-item-name { flex:1; min-width:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.ml-upload-item-status { flex-shrink:0; font-weight:600; }
.ml-upload-item-status.done { color:#047B5D; }
.ml-upload-item-status.error { color:#dc3545; }
.ml-upload-item-status.uploading { color:#f0883e; }
.ml-upload-progress { width:100%; height:3px; background:#e5e5e5; border-radius:2px; margin-top:4px; overflow:hidden; }
.ml-upload-progress-bar { height:100%; background:var(--color-primary,#047B5D); transition:width 0.2s; border-radius:2px; }

/* ── Detail Modal Content ── */
.md-layout { display:flex; gap:0; }
.md-preview { flex:1; background:#f4f4f5; display:flex; align-items:center; justify-content:center; min-height:280px; padding:20px; }
.md-preview img { max-width:100%; max-height:320px; border-radius:4px; }
.md-info { width:260px; flex-shrink:0; border-left:1px solid var(--border-color); padding:16px; overflow-y:auto; max-height:400px; }
.md-info-row { margin-bottom:10px; }
.md-info-label { font-size:11px; font-weight:600; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.03em; margin-bottom:2px; }
.md-info-value { font-size:13px; word-break:break-all; }
.md-actions { display:flex; gap:8px; padding:12px 16px; border-top:1px solid var(--border-color); }
.md-copy-btn { padding:6px 14px; border:1px solid var(--border-color); border-radius:6px; background:var(--bg-surface); font-size:12px; cursor:pointer; }
.md-copy-btn:hover { border-color:var(--color-primary); }

/* ── Responsive ── */
@media (max-width: 768px) {
    .ml-layout { flex-direction:column; }
    .ml-sidebar { width:100%; position:static; }
    .ml-main { margin-left:0; margin-top:12px; }
    .ml-grid { grid-template-columns:repeat(auto-fill, minmax(120px, 1fr)); }
}
</style>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    var csrf = document.querySelector('meta[name="csrf-token"]')?.content || '{{ csrf_token() }}';
    var currentFolder = '{{ currentFolder }}';

    // ── Sidebar Navigation ──
    document.querySelectorAll('.ml-folder-item').forEach(function(el) {
        el.addEventListener('click', function() {
            var folder = this.dataset.folder;
            var special = this.dataset.special || '';
            var url = '{{ admin_url("media") }}';
            if (special === 'recent') url += '?filter=recent';
            else if (special === 'images') url += '?filter=images';
            else if (folder) url += '?folder=' + encodeURIComponent(folder);
            window.location.href = url;
        });
    });

    // ── Filter Buttons ──
    document.querySelectorAll('.ml-filter-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            var filter = this.dataset.filter;
            var url = '{{ admin_url("media") }}?filter=' + filter;
            if (currentFolder) url += '&folder=' + encodeURIComponent(currentFolder);
            window.location.href = url;
        });
    });

    // ── Search ──
    var searchTimer;
    document.getElementById('mlSearch').addEventListener('input', function() {
        var val = this.value;
        clearTimeout(searchTimer);
        searchTimer = setTimeout(function() {
            var url = '{{ admin_url("media") }}?search=' + encodeURIComponent(val);
            if (currentFolder) url += '&folder=' + encodeURIComponent(currentFolder);
            window.location.href = url;
        }, 500);
    });

    // ── New Folder Modal ──
    document.getElementById('newFolderBtn').addEventListener('click', function() {
        document.getElementById('folderModal').style.display = 'flex';
    });
    document.querySelectorAll('[data-close]').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById(this.dataset.close).style.display = 'none';
        });
    });

    // ── Upload Button (click to select files) ──
    var fileInput = document.createElement('input');
    fileInput.type = 'file';
    fileInput.multiple = true;
    fileInput.style.display = 'none';
    document.body.appendChild(fileInput);

    document.getElementById('uploadBtn').addEventListener('click', function() {
        fileInput.click();
    });
    fileInput.addEventListener('change', function() {
        if (this.files.length > 0) uploadFiles(this.files);
        this.value = '';
    });

    // ── Drag & Drop ──
    var mlMain = document.querySelector('.ml-main');
    var mlScroll = document.querySelector('.ml-content-scroll');
    var dragCounter = 0;
    mlScroll.addEventListener('dragenter', function(e) {
        e.preventDefault();
        dragCounter++;
        mlMain.classList.add('drag-over');
    });
    mlScroll.addEventListener('dragleave', function(e) {
        e.preventDefault();
        dragCounter--;
        if (dragCounter <= 0) { mlMain.classList.remove('drag-over'); dragCounter = 0; }
    });
    mlScroll.addEventListener('dragover', function(e) { e.preventDefault(); });
    mlScroll.addEventListener('drop', function(e) {
        e.preventDefault();
        mlMain.classList.remove('drag-over');
        dragCounter = 0;
        if (e.dataTransfer.files.length > 0) uploadFiles(e.dataTransfer.files);
    });

    // ── Upload Files with Progress Float ──
    function uploadFiles(files) {
        var floatEl = document.getElementById('uploadFloat');
        var body = document.getElementById('uploadFloatBody');
        var title = document.getElementById('uploadFloatTitle');
        floatEl.style.display = '';
        title.textContent = 'Uploading ' + files.length + ' file' + (files.length > 1 ? 's' : '') + '...';
        body.innerHTML = '';

        var completed = 0;
        var total = files.length;

        Array.from(files).forEach(function(file, idx) {
            var itemEl = document.createElement('div');
            itemEl.className = 'ml-upload-item';
            itemEl.innerHTML = '<span class="ml-upload-item-name">' + file.name + '</span>' +
                '<span class="ml-upload-item-status uploading" id="upload-status-' + idx + '">0%</span>';
            var progressWrap = document.createElement('div');
            progressWrap.className = 'ml-upload-progress';
            progressWrap.innerHTML = '<div class="ml-upload-progress-bar" id="upload-bar-' + idx + '" style="width:0%"></div>';

            var wrapper = document.createElement('div');
            wrapper.style.padding = '0 14px 8px';
            wrapper.appendChild(progressWrap);

            body.appendChild(itemEl);
            body.appendChild(wrapper);

            var formData = new FormData();
            formData.append('file', file);
            formData.append('folder', currentFolder);

            var xhr = new XMLHttpRequest();
            xhr.open('POST', '{{ admin_url("media/upload") }}');
            xhr.setRequestHeader('X-CSRF-TOKEN', csrf);

            xhr.upload.addEventListener('progress', function(e) {
                if (e.lengthComputable) {
                    var pct = Math.round((e.loaded / e.total) * 100);
                    document.getElementById('upload-bar-' + idx).style.width = pct + '%';
                    document.getElementById('upload-status-' + idx).textContent = pct + '%';
                }
            });

            xhr.addEventListener('load', function() {
                completed++;
                var statusEl = document.getElementById('upload-status-' + idx);
                if (xhr.status >= 200 && xhr.status < 300) {
                    statusEl.textContent = 'Done';
                    statusEl.className = 'ml-upload-item-status done';
                } else {
                    var err = 'Error';
                    try { err = JSON.parse(xhr.responseText).error || 'Error'; } catch(e) {}
                    statusEl.textContent = err;
                    statusEl.className = 'ml-upload-item-status error';
                }
                if (completed === total) {
                    title.textContent = completed + ' file' + (completed > 1 ? 's' : '') + ' uploaded';
                    setTimeout(function() { window.location.reload(); }, 1000);
                }
            });

            xhr.addEventListener('error', function() {
                completed++;
                var statusEl = document.getElementById('upload-status-' + idx);
                statusEl.textContent = 'Failed';
                statusEl.className = 'ml-upload-item-status error';
                if (completed === total) title.textContent = 'Upload complete';
            });

            xhr.send(formData);
        });
    }

    // ── Detail Modal ──
    document.querySelectorAll('[data-detail-id]').forEach(function(link) {
        link.addEventListener('click', function(e) {
            e.preventDefault();
            var id = this.dataset.detailId;
            var modal = document.getElementById('mediaDetailModal');
            var body = document.getElementById('mdModalBody');
            body.innerHTML = '<div style="text-align:center;padding:40px;color:var(--text-secondary);">Loading...</div>';
            modal.style.display = 'flex';

            fetch('{{ admin_url("media") }}/' + id, {
                headers: { 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-TOKEN': csrf }
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                document.getElementById('mdModalTitle').textContent = d.original_name;
                var preview = '';
                if (d.is_image) {
                    preview = '<img src="' + d.url + '" alt="' + (d.alt_text || d.original_name) + '">';
                } else {
                    preview = '<div style="font-size:48px;color:#999;">&#128196;</div><p style="color:#666;margin-top:8px;">' + d.mime_type + '</p>';
                }
                var dims = d.dimensions ? '<div class="md-info-row"><div class="md-info-label">Dimensions</div><div class="md-info-value">' + d.dimensions.width + ' x ' + d.dimensions.height + 'px</div></div>' : '';
                var fullUrl = window.location.origin + d.url;
                body.innerHTML =
                    '<div class="md-layout">' +
                        '<div class="md-preview">' + preview + '</div>' +
                        '<div class="md-info">' +
                            '<div class="md-info-row"><div class="md-info-label">Filename</div><div class="md-info-value">' + d.filename + '</div></div>' +
                            '<div class="md-info-row"><div class="md-info-label">Type</div><div class="md-info-value">' + d.mime_type + '</div></div>' +
                            '<div class="md-info-row"><div class="md-info-label">Size</div><div class="md-info-value">' + d.human_size + '</div></div>' +
                            dims +
                            '<div class="md-info-row"><div class="md-info-label">URL</div><div class="md-info-value" style="font-size:11px;font-family:monospace;">' + d.url + '</div></div>' +
                            '<div class="md-info-row" style="margin-top:16px;">' +
                                '<label style="font-size:11px;font-weight:600;display:block;margin-bottom:4px;">Alt Text</label>' +
                                '<input type="text" id="mdAltText" value="' + (d.alt_text || '').replace(/"/g, '&quot;') + '" style="width:100%;padding:5px 8px;border:1px solid var(--border-color);border-radius:4px;font-size:12px;" placeholder="Describe this image">' +
                            '</div>' +
                            '<div class="md-info-row">' +
                                '<label style="font-size:11px;font-weight:600;display:block;margin-bottom:4px;">Display Name</label>' +
                                '<input type="text" id="mdDisplayName" value="' + (d.original_name || '').replace(/"/g, '&quot;') + '" style="width:100%;padding:5px 8px;border:1px solid var(--border-color);border-radius:4px;font-size:12px;">' +
                            '</div>' +
                        '</div>' +
                    '</div>' +
                    '<div class="md-actions">' +
                        '<button class="md-copy-btn" id="mdCopyUrl" data-url="' + fullUrl + '">Copy URL</button>' +
                        '<button class="btn btn-primary btn-sm" id="mdSaveBtn" data-id="' + d.id + '">Save</button>' +
                        '<button class="btn btn-danger btn-sm" id="mdDeleteBtn" data-id="' + d.id + '" style="margin-left:auto;">Delete</button>' +
                    '</div>';

                // Bind copy
                document.getElementById('mdCopyUrl').addEventListener('click', function() {
                    navigator.clipboard.writeText(this.dataset.url).then(function() {
                        document.getElementById('mdCopyUrl').textContent = 'Copied!';
                        setTimeout(function() { document.getElementById('mdCopyUrl').textContent = 'Copy URL'; }, 1500);
                    });
                });

                // Bind save
                document.getElementById('mdSaveBtn').addEventListener('click', function() {
                    var formData = new FormData();
                    formData.append('original_name', document.getElementById('mdDisplayName').value);
                    formData.append('alt_text', document.getElementById('mdAltText').value);
                    fetch('{{ admin_url("media") }}/' + this.dataset.id + '/update', {
                        method: 'POST',
                        headers: { 'X-CSRF-TOKEN': csrf },
                        body: formData
                    }).then(function() {
                        modal.style.display = 'none';
                        window.location.reload();
                    });
                });

                // Bind delete
                document.getElementById('mdDeleteBtn').addEventListener('click', function() {
                    if (!confirm('Permanently delete this file?')) return;
                    var formData = new FormData();
                    fetch('{{ admin_url("media") }}/' + this.dataset.id + '/delete', {
                        method: 'POST',
                        headers: { 'X-CSRF-TOKEN': csrf },
                        body: formData
                    }).then(function() {
                        modal.style.display = 'none';
                        window.location.reload();
                    });
                });
            })
            .catch(function() {
                body.innerHTML = '<div style="text-align:center;padding:40px;color:#dc3545;">Failed to load file details.</div>';
            });
        });
    });

    // ── Bulk Selection ──
    var bulkBar = document.getElementById('mlBulkBar');
    var selectAllCb = document.getElementById('mlSelectAll');
    var checkboxes = document.querySelectorAll('.ml-file-checkbox');

    function updateBulkBar() {
        var checked = document.querySelectorAll('.ml-file-checkbox:checked');
        var count = checked.length;
        bulkBar.style.display = count > 0 ? '' : 'none';
        document.getElementById('mlSelectedCount').textContent = count + ' selected';
        checkboxes.forEach(function(cb) {
            cb.closest('.ml-file-card').classList.toggle('selected', cb.checked);
        });
    }

    checkboxes.forEach(function(cb) {
        cb.addEventListener('change', updateBulkBar);
    });

    if (selectAllCb) {
        selectAllCb.addEventListener('change', function() {
            checkboxes.forEach(function(cb) { cb.checked = selectAllCb.checked; });
            updateBulkBar();
        });
    }

    document.getElementById('mlBulkDelete')?.addEventListener('click', function() {
        var ids = [];
        document.querySelectorAll('.ml-file-checkbox:checked').forEach(function(cb) {
            ids.push(cb.dataset.id);
        });
        if (ids.length === 0) return;
        if (!confirm('Delete ' + ids.length + ' file(s)? This cannot be undone.')) return;

        fetch('{{ admin_url("media/bulk") }}', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrf },
            body: JSON.stringify({ action: 'delete', ids: ids })
        }).then(function(r) { return r.json(); }).then(function(data) {
            if (data.success) window.location.reload();
            else alert(data.error || 'Failed to delete');
        });
    });

    // ── Close Upload Float ──
    document.getElementById('uploadFloatClose').addEventListener('click', function() {
        document.getElementById('uploadFloat').style.display = 'none';
    });

    // ── Escape closes modals ──
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            document.getElementById('folderModal').style.display = 'none';
        }
    });
})();
</script>
{% endblock %}
