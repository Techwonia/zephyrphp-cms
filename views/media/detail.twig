{% extends "@cms/layouts/cms.twig" %}

{% block title %}{{ item.getOriginalName() }} — Media{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/media-detail.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> <a href="{{ admin_url('media') }}">Media</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> {{ item.getOriginalName() }}
</div>

<div class="page-header">
    <h1>{{ item.getOriginalName() }}</h1>
    <div class="page-actions">
        <a href="{{ admin_url('media') }}" class="btn btn-outline">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Back to Library
        </a>
    </div>
</div>

<div class="md-page-layout">
    {# Preview #}
    <div class="md-page-preview card">
        <div class="md-page-preview-inner">
            {% if item.isImage() %}
                <img src="{{ item.getUrl() }}" alt="{{ item.getAltText() ?? item.getOriginalName() }}">
            {% else %}
                <div class="md-page-file-icon">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="#ccc" stroke-width="1"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    <span>{{ item.getMimeType() }}</span>
                </div>
            {% endif %}
        </div>
    </div>

    {# Info Panel #}
    <div class="md-page-info">
        {# File Information #}
        <div class="card">
            <div class="card-header"><h3 class="md-card-title">File Information</h3></div>
            <div class="card-body">
                <div class="md-page-meta-grid">
                    <div class="md-page-meta-item">
                        <span class="md-page-meta-label">Filename</span>
                        <span class="md-page-meta-value">{{ item.getFilename() }}</span>
                    </div>
                    <div class="md-page-meta-item">
                        <span class="md-page-meta-label">Original Name</span>
                        <span class="md-page-meta-value">{{ item.getOriginalName() }}</span>
                    </div>
                    <div class="md-page-meta-item">
                        <span class="md-page-meta-label">MIME Type</span>
                        <span class="md-page-meta-value">{{ item.getMimeType() }}</span>
                    </div>
                    <div class="md-page-meta-item">
                        <span class="md-page-meta-label">Size</span>
                        <span class="md-page-meta-value">{{ item.getHumanSize() }}</span>
                    </div>
                    {% if dimensions %}
                    <div class="md-page-meta-item">
                        <span class="md-page-meta-label">Dimensions</span>
                        <span class="md-page-meta-value">{{ dimensions.width }} &times; {{ dimensions.height }}px</span>
                    </div>
                    {% endif %}
                </div>

                <div class="md-page-url-section">
                    <span class="md-page-meta-label">URL</span>
                    <div class="md-page-url-row">
                        <input type="text" class="md-page-url-input" value="{{ item.getUrl() }}" readonly id="detailUrlInput">
                        <button class="btn btn-sm btn-outline copy-url-btn" id="detailCopyUrl">Copy URL</button>
                    </div>
                </div>

                <div class="md-page-meta-item" style="margin-top: 8px;">
                    <span class="md-page-meta-label">Path</span>
                    <span class="md-page-meta-value" style="font-size: 11px; font-family: monospace; word-break: break-all;">{{ item.getPath() }}</span>
                </div>
            </div>
        </div>

        {# Edit Metadata #}
        <div class="card">
            <div class="card-header"><h3 class="md-card-title">Edit Metadata</h3></div>
            <div class="card-body">
                <form method="POST" action="{{ admin_url('media/' ~ item.getId() ~ '/update') }}">
                    {{ csrf_field() | raw }}
                    <div class="form-group">
                        <label class="md-form-label" for="original_name">Display Name</label>
                        <input type="text" id="original_name" name="original_name" class="form-control" value="{{ item.getOriginalName() }}">
                    </div>
                    <div class="form-group">
                        <label class="md-form-label" for="alt_text">Alt Text</label>
                        <input type="text" id="alt_text" name="alt_text" class="form-control" value="{{ item.getAltText() ?? '' }}" placeholder="Describe this image for accessibility">
                        <small class="md-form-hint">Used as alt attribute for images. Important for SEO and accessibility.</small>
                    </div>
                    <div class="form-group">
                        <label class="md-form-label" for="tags">Tags</label>
                        <input type="text" id="tags" name="tags" class="form-control" value="{{ item.getTagsString() ?? '' }}" placeholder="e.g. hero, banner, product">
                        <small class="md-form-hint">Comma-separated tags for organizing media.</small>
                        {% if item.getTags()|length > 0 %}
                        <div class="md-page-tag-chips">
                            {% for tag in item.getTags() %}
                            <a href="{{ admin_url('media?tag=' ~ tag) }}" class="md-page-tag-chip">{{ tag }}</a>
                            {% endfor %}
                        </div>
                        {% endif %}
                    </div>
                    <button type="submit" class="btn btn-primary">Save Changes</button>
                </form>
            </div>
        </div>

        {# Usage #}
        <div class="card">
            <div class="card-header"><h3 class="md-card-title">Usage</h3></div>
            <div class="card-body">
                {% if usage|length > 0 %}
                    <p class="md-usage-hint">This file is referenced in {{ usage|length }} entr{{ usage|length == 1 ? 'y' : 'ies' }}:</p>
                    <ul class="md-usage-list">
                        {% for ref in usage %}
                        <li>
                            <a href="{{ admin_url('collections/' ~ ref.collection_slug ~ '/entries/' ~ ref.entry_id ~ '/edit') }}">
                                {{ ref.collection }} #{{ ref.entry_id }}
                            </a>
                        </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="md-usage-hint">No entries reference this file.</p>
                {% endif %}
            </div>
        </div>

        {# Danger Zone #}
        <div class="card md-danger-card">
            <div class="card-body">
                <form method="POST" action="{{ admin_url('media/' ~ item.getId() ~ '/delete') }}" onsubmit="return confirm('Permanently delete this file?')">
                    {{ csrf_field() | raw }}
                    <button type="submit" class="btn btn-danger">Delete File</button>
                    {% if usage|length > 0 %}
                        <small class="md-danger-warning">Warning: This file is used in {{ usage|length }} entr{{ usage|length == 1 ? 'y' : 'ies' }}.</small>
                    {% endif %}
                </form>
            </div>
        </div>
    </div>
</div>

{% block styles %}
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('detailCopyUrl')?.addEventListener('click', function(e) {
        e.preventDefault();
        var input = document.getElementById('detailUrlInput');
        var fullUrl = window.location.origin + input.value;
        navigator.clipboard.writeText(fullUrl).then(function() {
            document.getElementById('detailCopyUrl').textContent = 'Copied!';
            setTimeout(function() { document.getElementById('detailCopyUrl').textContent = 'Copy URL'; }, 1500);
        }).catch(function() {
            input.select();
            document.execCommand('copy');
            document.getElementById('detailCopyUrl').textContent = 'Copied!';
            setTimeout(function() { document.getElementById('detailCopyUrl').textContent = 'Copy URL'; }, 1500);
        });
    });
});
</script>
{% endblock %}
{% endblock %}
