{% extends "@cms/layouts/cms.twig" %}

{% block title %}AI Builder{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / AI Builder
</div>

<div class="page-header">
    <h1>AI Builder</h1>
    <div class="page-actions">
        <a href="/cms/ai-builder/settings" class="btn btn-outline btn-sm">AI Settings</a>
    </div>
</div>

<div class="ai-layout">
    {# Left: Prompt Panel #}
    <div class="ai-prompt-panel">
        <div class="card">
            <div class="card-header">
                <h3>Generate with AI</h3>
            </div>
            <div class="card-body">
                {# Mode selector #}
                <div class="ai-modes">
                    <button type="button" class="ai-mode active" data-mode="page" title="Generate a full page">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="9" x2="21" y2="9"/></svg>
                        Page
                    </button>
                    <button type="button" class="ai-mode" data-mode="section" title="Generate a reusable section">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><line x1="3" y1="12" x2="21" y2="12"/></svg>
                        Section
                    </button>
                    <button type="button" class="ai-mode" data-mode="content" title="Generate page content/copy">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        Content
                    </button>
                    <button type="button" class="ai-mode" data-mode="explain" title="Explain template code">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                        Explain
                    </button>
                    <button type="button" class="ai-mode" data-mode="fix" title="Fix broken template">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/></svg>
                        Fix
                    </button>
                </div>

                {# Provider selector #}
                <div class="form-group" style="margin-top:12px;">
                    <label>AI Model</label>
                    <select id="ai-provider" class="form-control">
                        {% for p in providers %}
                            {% if p.available %}
                            <option value="{{ p.key }}" {{ p.is_default ? 'selected' : '' }}>
                                {{ p.name }} ({{ p.model }}){% if p.tier == 'free' %} — Free{% endif %}
                            </option>
                            {% endif %}
                        {% endfor %}
                    </select>
                    {% if availableProviders|length == 0 %}
                        <small class="text-danger">No AI providers configured. <a href="/cms/ai-builder/settings">Add API keys</a></small>
                    {% endif %}
                </div>

                {# Prompt input #}
                <div class="form-group" style="margin-top:12px;">
                    <label id="prompt-label">Describe the page you want to create</label>
                    <textarea id="ai-prompt" class="form-control ai-textarea" rows="6" maxlength="5000"
                        placeholder="Create a landing page for a SaaS product with a hero section, features grid, pricing table, and contact form..."></textarea>
                    <small class="text-muted"><span id="char-count">0</span> / 5000</small>
                </div>

                <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:12px;">
                    <button type="button" id="ai-generate" class="btn btn-primary" {{ availableProviders|length == 0 ? 'disabled' : '' }}>
                        Generate
                    </button>
                </div>

                {# Loading state #}
                <div id="ai-loading" style="display:none;margin-top:16px;text-align:center;">
                    <div class="ai-spinner"></div>
                    <p class="text-muted" style="margin-top:8px;">Generating with <strong id="loading-provider"></strong>...</p>
                </div>

                {# Error display #}
                <div id="ai-error" class="alert alert-danger" style="display:none;margin-top:12px;"></div>
            </div>
        </div>

        {# History #}
        {% if history|length > 0 %}
        <div class="card" style="margin-top:var(--space-400);">
            <div class="card-header"><h3>Recent Generations</h3></div>
            <div class="card-body" style="max-height:300px;overflow-y:auto;">
                {% for item in history %}
                <div class="ai-history-item" data-prompt="{{ item.prompt|e('html_attr') }}">
                    <div class="ai-history-meta">
                        <span class="badge badge-{{ item.mode }}">{{ item.mode|capitalize }}</span>
                        <span class="text-muted">{{ item.provider }}</span>
                        <span class="text-muted">{{ item.tokens_used }} tokens</span>
                    </div>
                    <p class="ai-history-prompt">{{ item.result_summary }}</p>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}
    </div>

    {# Right: Result Panel #}
    <div class="ai-result-panel">
        <div class="card" id="result-card" style="display:none;">
            <div class="card-header" style="display:flex;align-items:center;justify-content:space-between;">
                <h3 id="result-title">Generated Page</h3>
                <div style="display:flex;gap:8px;">
                    <button type="button" class="btn btn-sm btn-outline" id="btn-copy" title="Copy to clipboard">Copy</button>
                    <button type="button" class="btn btn-sm btn-outline" id="btn-preview" title="Preview in new tab">Preview</button>
                    <button type="button" class="btn btn-sm btn-primary" id="btn-save" title="Save to theme">Save</button>
                </div>
            </div>
            <div class="card-body">
                {# Code output #}
                <div id="result-code" class="ai-code-block">
                    <pre><code id="result-content"></code></pre>
                </div>

                {# Usage stats #}
                <div id="result-usage" class="ai-usage" style="margin-top:12px;display:none;">
                    <span>Model: <strong id="usage-model"></strong></span>
                    <span>Tokens: <strong id="usage-tokens"></strong></span>
                    <span>Time: <strong id="usage-time"></strong></span>
                </div>
            </div>
        </div>

        {# Save modal #}
        <div id="save-modal" class="modal-overlay" style="display:none;">
            <div class="modal-content" style="max-width:480px;">
                <div class="modal-header">
                    <h3 id="save-modal-title">Save Page</h3>
                    <button type="button" class="modal-close" onclick="document.getElementById('save-modal').style.display='none'">&times;</button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="save-title">Title</label>
                        <input type="text" id="save-title" class="form-control" placeholder="Page Title">
                    </div>
                    <div class="form-group" style="margin-top:12px;">
                        <label for="save-slug">Slug</label>
                        <input type="text" id="save-slug" class="form-control" placeholder="page-slug">
                        <small class="text-muted">Will be saved as templates/[slug].twig</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-outline" onclick="document.getElementById('save-modal').style.display='none'">Cancel</button>
                    <button type="button" class="btn btn-primary" id="btn-save-confirm">Save to Theme</button>
                </div>
            </div>
        </div>

        {# Empty state #}
        <div id="result-empty" class="card">
            <div class="card-body empty-state" style="min-height:400px;display:flex;flex-direction:column;align-items:center;justify-content:center;">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="var(--text-disabled, #ccc)" stroke-width="1">
                    <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
                </svg>
                <h3 style="margin-top:16px;">Ready to build</h3>
                <p class="text-muted">Describe what you want and AI will generate it for you.</p>
                <div class="ai-suggestions" style="margin-top:16px;">
                    <button class="ai-suggestion" data-prompt="Create a modern landing page with a hero section, features grid, testimonials, and a call-to-action">Landing Page</button>
                    <button class="ai-suggestion" data-prompt="Create a blog listing page with cards showing post title, excerpt, date, and featured image">Blog Page</button>
                    <button class="ai-suggestion" data-prompt="Create a pricing table with three tiers: Free, Pro, and Enterprise with feature comparison">Pricing Table</button>
                    <button class="ai-suggestion" data-prompt="Create a contact page with a form (name, email, subject, message) and company info sidebar">Contact Page</button>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
.ai-layout {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: var(--space-400);
    align-items: start;
}
@media (max-width: 1024px) {
    .ai-layout { grid-template-columns: 1fr; }
}
.ai-modes {
    display: flex; gap: 4px; flex-wrap: wrap;
}
.ai-mode {
    display: flex; align-items: center; gap: 6px;
    padding: 6px 12px; border-radius: var(--radius-200);
    border: 1px solid var(--border-color, #e5e5e5);
    background: var(--bg-surface); color: var(--text-secondary);
    cursor: pointer; font-size: 0.8125rem; transition: all 0.15s;
}
.ai-mode:hover { border-color: var(--color-primary, #3B82F6); color: var(--color-primary, #3B82F6); }
.ai-mode.active {
    background: var(--color-primary, #3B82F6); color: #fff;
    border-color: var(--color-primary, #3B82F6);
}
.ai-mode.active svg { stroke: #fff; }
.ai-textarea {
    font-family: inherit; resize: vertical; min-height: 120px;
}
.ai-spinner {
    width: 32px; height: 32px; border: 3px solid var(--border-color, #e5e5e5);
    border-top-color: var(--color-primary, #3B82F6);
    border-radius: 50%; animation: spin 0.8s linear infinite;
    margin: 0 auto;
}
@keyframes spin { to { transform: rotate(360deg); } }
.ai-code-block {
    background: var(--bg-subdued, #f5f5f5); border-radius: var(--radius-200);
    padding: 16px; overflow-x: auto; max-height: 600px; overflow-y: auto;
}
.ai-code-block pre { margin: 0; white-space: pre-wrap; word-break: break-word; }
.ai-code-block code { font-size: 0.8125rem; line-height: 1.6; }
.ai-usage {
    display: flex; gap: 16px; font-size: 0.75rem; color: var(--text-disabled, #999);
    padding-top: 8px; border-top: 1px solid var(--border-color, #e5e5e5);
}
.ai-suggestions {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center;
}
.ai-suggestion {
    padding: 6px 14px; border-radius: 20px;
    border: 1px solid var(--border-color, #e5e5e5);
    background: var(--bg-surface); color: var(--text-secondary);
    cursor: pointer; font-size: 0.8125rem; transition: all 0.15s;
}
.ai-suggestion:hover {
    border-color: var(--color-primary, #3B82F6);
    color: var(--color-primary, #3B82F6);
    background: rgba(59,130,246,0.05);
}
.ai-history-item {
    padding: 8px 0; border-bottom: 1px solid var(--border-color, #e5e5e5);
    cursor: pointer;
}
.ai-history-item:hover { background: var(--bg-subdued, #f9f9f9); }
.ai-history-item:last-child { border-bottom: none; }
.ai-history-meta { display: flex; gap: 8px; font-size: 0.75rem; margin-bottom: 4px; }
.ai-history-prompt { font-size: 0.8125rem; margin: 0; color: var(--text-primary); }
.badge-page { background: rgba(59,130,246,0.1); color: #3B82F6; }
.badge-section { background: rgba(255,140,0,0.1); color: #c77800; }
.badge-content { background: rgba(16,185,129,0.1); color: #047B5D; }
.badge-explain { background: rgba(128,0,255,0.1); color: #7c3aed; }
.badge-fix { background: rgba(220,53,69,0.1); color: #dc3545; }
.alert-danger {
    background: rgba(220,53,69,0.1); border: 1px solid rgba(220,53,69,0.3);
    border-radius: var(--radius-200); padding: 12px 16px; color: #721c24;
}
</style>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
(function() {
    const promptEl = document.getElementById('ai-prompt');
    const providerEl = document.getElementById('ai-provider');
    const generateBtn = document.getElementById('ai-generate');
    const loadingEl = document.getElementById('ai-loading');
    const errorEl = document.getElementById('ai-error');
    const resultCard = document.getElementById('result-card');
    const resultEmpty = document.getElementById('result-empty');
    const resultContent = document.getElementById('result-content');
    const resultTitle = document.getElementById('result-title');
    const charCount = document.getElementById('char-count');
    const promptLabel = document.getElementById('prompt-label');

    let currentMode = 'page';
    let lastResult = null;

    // Mode labels
    const modeLabels = {
        page: 'Describe the page you want to create',
        section: 'Describe the section you want to create',
        content: 'Describe the content you want to write',
        explain: 'Paste the template code to explain',
        fix: 'Paste the broken template (optionally add ---ERROR--- followed by the error message)'
    };
    const modePlaceholders = {
        page: 'Create a landing page for a SaaS product with a hero section, features grid, pricing table, and contact form...',
        section: 'Create a testimonials carousel section with star ratings, customer photos, and quote text...',
        content: 'Write a compelling hero section headline and subtext for a project management tool...',
        explain: 'Paste your Twig template code here to get an explanation of what it does...',
        fix: 'Paste the broken template code here. Optionally add ---ERROR--- followed by the error message.'
    };

    // Mode switching
    document.querySelectorAll('.ai-mode').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.ai-mode').forEach(function(b) { b.classList.remove('active'); });
            btn.classList.add('active');
            currentMode = btn.dataset.mode;
            promptLabel.textContent = modeLabels[currentMode] || modeLabels.page;
            promptEl.placeholder = modePlaceholders[currentMode] || modePlaceholders.page;
        });
    });

    // Char counter
    promptEl.addEventListener('input', function() {
        charCount.textContent = promptEl.value.length;
    });

    // Quick suggestions
    document.querySelectorAll('.ai-suggestion').forEach(function(btn) {
        btn.addEventListener('click', function() {
            promptEl.value = btn.dataset.prompt;
            charCount.textContent = promptEl.value.length;
            promptEl.focus();
        });
    });

    // History click to re-use prompt
    document.querySelectorAll('.ai-history-item').forEach(function(item) {
        item.addEventListener('click', function() {
            promptEl.value = item.dataset.prompt;
            charCount.textContent = promptEl.value.length;
            promptEl.focus();
        });
    });

    // Generate
    generateBtn.addEventListener('click', function() {
        var prompt = promptEl.value.trim();
        if (!prompt) { promptEl.focus(); return; }

        generateBtn.disabled = true;
        loadingEl.style.display = 'block';
        errorEl.style.display = 'none';
        document.getElementById('loading-provider').textContent = providerEl.options[providerEl.selectedIndex].text;

        var formData = new FormData();
        formData.append('prompt', prompt);
        formData.append('provider', providerEl.value);
        formData.append('mode', currentMode);
        formData.append('_token', document.querySelector('meta[name="csrf-token"]')?.content || '');

        fetch('/cms/ai-builder/generate', {
            method: 'POST',
            body: formData,
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            generateBtn.disabled = false;
            loadingEl.style.display = 'none';

            if (!data.success) {
                errorEl.textContent = data.error || 'Generation failed.';
                errorEl.style.display = 'block';
                return;
            }

            lastResult = data.result;
            showResult(data.mode, data.result);
        })
        .catch(function(err) {
            generateBtn.disabled = false;
            loadingEl.style.display = 'none';
            errorEl.textContent = 'Request failed: ' + err.message;
            errorEl.style.display = 'block';
        });
    });

    function showResult(mode, result) {
        resultEmpty.style.display = 'none';
        resultCard.style.display = 'block';

        var content = '';
        var title = 'Generated Result';

        if (mode === 'page') {
            title = result.title || 'Generated Page';
            content = result.template || JSON.stringify(result, null, 2);
        } else if (mode === 'section') {
            title = result.name || 'Generated Section';
            content = result.template || JSON.stringify(result, null, 2);
        } else if (mode === 'content') {
            title = 'Generated Content';
            content = result.content || '';
        } else if (mode === 'explain') {
            title = 'Code Explanation';
            content = result.explanation || '';
        } else if (mode === 'fix') {
            title = 'Fixed Template';
            content = result.fixed_template || '';
        }

        resultTitle.textContent = title;
        resultContent.textContent = content;

        // Usage stats
        var usage = result.usage;
        if (usage) {
            document.getElementById('result-usage').style.display = 'flex';
            document.getElementById('usage-model').textContent = usage.model || '';
            document.getElementById('usage-tokens').textContent = (usage.total_tokens || 0).toLocaleString();
            document.getElementById('usage-time').textContent = (usage.duration || 0).toFixed(1) + 's';
        }

        // Show/hide save button based on mode
        document.getElementById('btn-save').style.display = (mode === 'page' || mode === 'section') ? '' : 'none';
    }

    // Copy
    document.getElementById('btn-copy').addEventListener('click', function() {
        var text = resultContent.textContent;
        navigator.clipboard.writeText(text).then(function() {
            document.getElementById('btn-copy').textContent = 'Copied!';
            setTimeout(function() { document.getElementById('btn-copy').textContent = 'Copy'; }, 2000);
        });
    });

    // Preview (open in new tab)
    document.getElementById('btn-preview').addEventListener('click', function() {
        var content = resultContent.textContent;
        var w = window.open('', '_blank');
        w.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>Preview</title></head><body>');
        w.document.write('<pre style="white-space:pre-wrap;font-family:monospace;padding:20px;">' + content.replace(/</g, '&lt;') + '</pre>');
        w.document.write('</body></html>');
        w.document.close();
    });

    // Save
    document.getElementById('btn-save').addEventListener('click', function() {
        if (!lastResult) return;
        document.getElementById('save-title').value = lastResult.title || lastResult.name || '';
        document.getElementById('save-slug').value = (lastResult.title || lastResult.slug || '')
            .toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        document.getElementById('save-modal-title').textContent = currentMode === 'section' ? 'Save Section' : 'Save Page';
        document.getElementById('save-modal').style.display = 'flex';
    });

    document.getElementById('btn-save-confirm').addEventListener('click', function() {
        if (!lastResult) return;
        var title = document.getElementById('save-title').value.trim();
        var slug = document.getElementById('save-slug').value.trim();
        if (!slug) { alert('Please enter a slug.'); return; }

        var url = currentMode === 'section' ? '/cms/ai-builder/save-section' : '/cms/ai-builder/save-page';
        var formData = new FormData();
        formData.append('template', lastResult.template || resultContent.textContent);
        formData.append('title', title);
        formData.append('slug', slug);
        formData.append('css', lastResult.css || '');
        formData.append('_token', document.querySelector('meta[name="csrf-token"]')?.content || '');

        fetch(url, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
        .then(function(r) { return r.json(); })
        .then(function(data) {
            if (data.success) {
                document.getElementById('save-modal').style.display = 'none';
                alert(data.message || 'Saved successfully!');
            } else if (data.exists) {
                if (confirm('File already exists. Overwrite?')) {
                    formData.append('overwrite', '1');
                    fetch(url, { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(function(r) { return r.json(); })
                    .then(function(d) {
                        document.getElementById('save-modal').style.display = 'none';
                        alert(d.message || 'Saved!');
                    });
                }
            } else {
                alert(data.error || 'Failed to save.');
            }
        })
        .catch(function(err) { alert('Save failed: ' + err.message); });
    });

    // Ctrl+Enter to generate
    promptEl.addEventListener('keydown', function(e) {
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            generateBtn.click();
        }
    });
})();
</script>
{% endblock %}
