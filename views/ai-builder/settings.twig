{% extends "@cms/layouts/cms.twig" %}

{% block title %}AI Settings{% endblock %}
{% block styles %}<link rel="stylesheet" href="/cms-assets/css/ai-builder-settings.css">{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="{{ admin_url() }}">Dashboard</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> <a href="{{ admin_url('ai-builder') }}">AI Builder</a> <svg class="breadcrumb-sep" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="m9 18 6-6-6-6"/></svg> Settings
</div>

<div class="page-header">
    <h1>AI Settings</h1>
</div>

{% if flash.success is defined and flash.success %}
<div class="alert alert-success">{{ flash.success }}</div>
{% endif %}
{% if flash.errors is defined and flash.errors %}
<div class="alert alert-danger">
    {% for error in flash.errors %}<p>{{ error }}</p>{% endfor %}
</div>
{% endif %}

<form method="POST" action="{{ admin_url('ai-builder/settings') }}" autocomplete="off">
    {# Default Provider #}
    <div class="card" style="margin-bottom:var(--sp-5);">
        <div class="card-header"><h3>Default Provider</h3></div>
        <div class="card-body">
            <p class="text-secondary text-sm" style="margin-bottom:12px;">
                Select which AI provider to use by default. Only providers with a configured API key (or local host) will work.
            </p>
            <div class="form-group">
                <label for="ai_provider">Default AI Provider</label>
                <select name="AI_PROVIDER" id="ai_provider" class="form-control" style="max-width:300px;">
                    <option value="gemini" {{ envValues.AI_PROVIDER == 'gemini' ? 'selected' : '' }}>Gemini (Free)</option>
                    <option value="groq" {{ envValues.AI_PROVIDER == 'groq' ? 'selected' : '' }}>Groq (Free)</option>
                    <option value="claude" {{ envValues.AI_PROVIDER == 'claude' ? 'selected' : '' }}>Claude</option>
                    <option value="openai" {{ envValues.AI_PROVIDER == 'openai' ? 'selected' : '' }}>OpenAI</option>
                    <option value="mistral" {{ envValues.AI_PROVIDER == 'mistral' ? 'selected' : '' }}>Mistral</option>
                    <option value="openrouter" {{ envValues.AI_PROVIDER == 'openrouter' ? 'selected' : '' }}>OpenRouter</option>
                    <option value="ollama" {{ envValues.AI_PROVIDER == 'ollama' ? 'selected' : '' }}>Ollama (Local)</option>
                </select>
            </div>
        </div>
    </div>

    {# Provider Cards #}
    <div class="card" style="margin-bottom:var(--sp-5);">
        <div class="card-header"><h3>Provider API Keys &amp; Models</h3></div>
        <div class="card-body">
            <p class="text-secondary text-sm" style="margin-bottom:16px;">
                Enter your API keys below. Keys are saved to your <code>.env</code> file. Free providers (Gemini, Groq) require a free API key. Ollama runs locally with no key needed.
            </p>

            <div class="provider-settings-grid">
                {# Gemini #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>Google Gemini</h4>
                        <span class="badge badge-free">Free</span>
                        {% if envValues.GEMINI_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="gemini_key">API Key</label>
                        <input type="password" name="GEMINI_API_KEY" id="gemini_key" class="form-control ai-key-input"
                               value="{{ envValues.GEMINI_API_KEY }}" placeholder="Enter Gemini API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="gemini_model">Model</label>
                        <input type="text" name="GEMINI_MODEL" id="gemini_model" class="form-control"
                               value="{{ envValues.GEMINI_MODEL }}" placeholder="gemini-2.0-flash">
                    </div>
                </div>

                {# Groq #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>Groq</h4>
                        <span class="badge badge-free">Free</span>
                        {% if envValues.GROQ_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="groq_key">API Key</label>
                        <input type="password" name="GROQ_API_KEY" id="groq_key" class="form-control ai-key-input"
                               value="{{ envValues.GROQ_API_KEY }}" placeholder="Enter Groq API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="groq_model">Model</label>
                        <input type="text" name="GROQ_MODEL" id="groq_model" class="form-control"
                               value="{{ envValues.GROQ_MODEL }}" placeholder="llama-3.3-70b-versatile">
                    </div>
                </div>

                {# Claude #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>Anthropic Claude</h4>
                        <span class="badge badge-pro">Pro</span>
                        {% if envValues.ANTHROPIC_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="claude_key">API Key</label>
                        <input type="password" name="ANTHROPIC_API_KEY" id="claude_key" class="form-control ai-key-input"
                               value="{{ envValues.ANTHROPIC_API_KEY }}" placeholder="Enter Anthropic API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="claude_model">Model</label>
                        <input type="text" name="CLAUDE_MODEL" id="claude_model" class="form-control"
                               value="{{ envValues.CLAUDE_MODEL }}" placeholder="claude-sonnet-4-20250514">
                    </div>
                </div>

                {# OpenAI #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>OpenAI</h4>
                        <span class="badge badge-pro">Pro</span>
                        {% if envValues.OPENAI_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="openai_key">API Key</label>
                        <input type="password" name="OPENAI_API_KEY" id="openai_key" class="form-control ai-key-input"
                               value="{{ envValues.OPENAI_API_KEY }}" placeholder="Enter OpenAI API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="openai_model">Model</label>
                        <input type="text" name="OPENAI_MODEL" id="openai_model" class="form-control"
                               value="{{ envValues.OPENAI_MODEL }}" placeholder="gpt-4o">
                    </div>
                </div>

                {# Mistral #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>Mistral</h4>
                        <span class="badge badge-pro">Pro</span>
                        {% if envValues.MISTRAL_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="mistral_key">API Key</label>
                        <input type="password" name="MISTRAL_API_KEY" id="mistral_key" class="form-control ai-key-input"
                               value="{{ envValues.MISTRAL_API_KEY }}" placeholder="Enter Mistral API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="mistral_model">Model</label>
                        <input type="text" name="MISTRAL_MODEL" id="mistral_model" class="form-control"
                               value="{{ envValues.MISTRAL_MODEL }}" placeholder="mistral-large-latest">
                    </div>
                </div>

                {# OpenRouter #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>OpenRouter</h4>
                        <span class="badge badge-pro">Pro</span>
                        {% if envValues.OPENROUTER_API_KEY %}<span class="status-dot status-active"></span>{% endif %}
                    </div>
                    <div class="form-group">
                        <label for="openrouter_key">API Key</label>
                        <input type="password" name="OPENROUTER_API_KEY" id="openrouter_key" class="form-control ai-key-input"
                               value="{{ envValues.OPENROUTER_API_KEY }}" placeholder="Enter OpenRouter API key">
                        <button type="button" class="btn-toggle-key" onclick="toggleKey(this)">Show</button>
                    </div>
                    <div class="form-group">
                        <label for="openrouter_model">Model</label>
                        <input type="text" name="OPENROUTER_MODEL" id="openrouter_model" class="form-control"
                               value="{{ envValues.OPENROUTER_MODEL }}" placeholder="anthropic/claude-sonnet-4">
                    </div>
                </div>

                {# Ollama #}
                <div class="provider-setting-card">
                    <div class="provider-setting-header">
                        <h4>Ollama (Local)</h4>
                        <span class="badge badge-self-hosted">Local</span>
                    </div>
                    <div class="form-group">
                        <label for="ollama_host">Host URL</label>
                        <input type="text" name="OLLAMA_HOST" id="ollama_host" class="form-control"
                               value="{{ envValues.OLLAMA_HOST }}" placeholder="http://localhost:11434">
                    </div>
                    <div class="form-group">
                        <label for="ollama_model">Model</label>
                        <input type="text" name="OLLAMA_MODEL" id="ollama_model" class="form-control"
                               value="{{ envValues.OLLAMA_MODEL }}" placeholder="llama3">
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="form-actions" style="margin-bottom:var(--sp-5);">
        <button type="submit" class="btn btn-primary">Save Settings</button>
        <a href="{{ admin_url('ai-builder') }}" class="btn btn-secondary">Cancel</a>
    </div>
</form>
{% endblock %}

{% block scripts %}
<script nonce="{{ csp_nonce() }}">
function toggleKey(btn) {
    var input = btn.previousElementSibling;
    if (input.type === 'password') {
        input.type = 'text';
        btn.textContent = 'Hide';
    } else {
        input.type = 'password';
        btn.textContent = 'Show';
    }
}
</script>
{% endblock %}

{% block styles %}
{% endblock %}
