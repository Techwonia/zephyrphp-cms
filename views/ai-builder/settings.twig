{% extends "@cms/layouts/cms.twig" %}

{% block title %}AI Settings{% endblock %}

{% block content %}
<div class="breadcrumb">
    <a href="/cms">Dashboard</a> / <a href="/cms/ai-builder">AI Builder</a> / Settings
</div>

<div class="page-header">
    <h1>AI Settings</h1>
</div>

<div class="card" style="margin-bottom:var(--space-500);">
    <div class="card-header"><h3>AI Providers</h3></div>
    <div class="card-body">
        <p class="text-muted" style="margin-bottom:16px;">
            Configure your AI provider API keys. Set them in your <code>.env</code> file for security.
            Free providers (Gemini, Groq) are great for getting started. Self-hosted users can use Ollama for fully private AI.
        </p>

        <div class="provider-grid">
            {% for p in providers %}
            <div class="provider-card {{ p.available ? 'provider-active' : 'provider-inactive' }}">
                <div class="provider-header">
                    <div>
                        <h4 class="provider-name">{{ p.name }}</h4>
                        <span class="badge badge-{{ p.tier }}">
                            {% if p.tier == 'free' %}Free
                            {% elseif p.tier == 'self-hosted' %}Local
                            {% else %}Pro{% endif %}
                        </span>
                        {% if p.is_default %}
                            <span class="badge badge-primary">Default</span>
                        {% endif %}
                    </div>
                    <div class="provider-status">
                        {% if p.available %}
                            <span class="status-dot status-active"></span> Active
                        {% else %}
                            <span class="status-dot status-inactive"></span> Not configured
                        {% endif %}
                    </div>
                </div>
                <p class="provider-desc">{{ p.description }}</p>
                {% if p.model %}
                    <p class="provider-model">Model: <code>{{ p.model }}</code></p>
                {% endif %}
                <div class="provider-env">
                    {% if p.key == 'gemini' %}
                        <code>GEMINI_API_KEY=your-key</code>
                    {% elseif p.key == 'claude' %}
                        <code>ANTHROPIC_API_KEY=your-key</code>
                    {% elseif p.key == 'openai' %}
                        <code>OPENAI_API_KEY=your-key</code>
                    {% elseif p.key == 'groq' %}
                        <code>GROQ_API_KEY=your-key</code>
                    {% elseif p.key == 'mistral' %}
                        <code>MISTRAL_API_KEY=your-key</code>
                    {% elseif p.key == 'openrouter' %}
                        <code>OPENROUTER_API_KEY=your-key</code>
                    {% elseif p.key == 'ollama' %}
                        <code>OLLAMA_HOST=http://localhost:11434</code>
                    {% endif %}
                </div>
            </div>
            {% endfor %}
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header"><h3>Environment Variables</h3></div>
    <div class="card-body">
        <p class="text-muted" style="margin-bottom:12px;">Add these to your <code>.env</code> file:</p>
        <div class="ai-code-block">
            <pre><code># AI Provider (default: gemini)
AI_PROVIDER=gemini

# Google Gemini (Free)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (Free, rate-limited)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Mistral
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-large-latest

# OpenRouter (any model)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# Ollama (Local, free)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3</code></pre>
        </div>
    </div>
</div>
{% endblock %}

{% block styles %}
<style nonce="{{ csp_nonce() }}">
.provider-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-300);
}
.provider-card {
    border: 1px solid var(--border-color, #e5e5e5);
    border-radius: var(--radius-200);
    padding: 16px;
    transition: border-color 0.15s;
}
.provider-active { border-color: var(--color-success, #047B5D); }
.provider-inactive { opacity: 0.7; }
.provider-header {
    display: flex; justify-content: space-between; align-items: flex-start;
    margin-bottom: 8px;
}
.provider-name { margin: 0 0 4px; font-size: 0.95rem; }
.provider-status { font-size: 0.75rem; color: var(--text-disabled, #999); display: flex; align-items: center; gap: 4px; }
.status-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; }
.status-active { background: var(--color-success, #047B5D); }
.status-inactive { background: var(--text-disabled, #ccc); }
.provider-desc { font-size: 0.8125rem; color: var(--text-secondary); margin: 4px 0 8px; }
.provider-model { font-size: 0.75rem; color: var(--text-disabled); margin: 0 0 8px; }
.provider-env {
    padding-top: 8px; border-top: 1px solid var(--border-color, #e5e5e5);
    font-size: 0.75rem;
}
.provider-env code { background: var(--bg-subdued, #f5f5f5); padding: 2px 6px; border-radius: 3px; }
.badge-free { background: rgba(16,185,129,0.1); color: #047B5D; border: 1px solid rgba(16,185,129,0.2); }
.badge-pro { background: rgba(59,130,246,0.1); color: #3B82F6; border: 1px solid rgba(59,130,246,0.2); }
.badge-self-hosted { background: rgba(128,0,255,0.1); color: #7c3aed; border: 1px solid rgba(128,0,255,0.2); }
.badge-primary { background: var(--color-primary, #3B82F6); color: #fff; }
.ai-code-block {
    background: var(--bg-subdued, #f5f5f5); border-radius: var(--radius-200);
    padding: 16px; overflow-x: auto;
}
.ai-code-block pre { margin: 0; }
.ai-code-block code { font-size: 0.8125rem; line-height: 1.6; }
</style>
{% endblock %}
